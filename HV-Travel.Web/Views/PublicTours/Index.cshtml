@inject IPublicContentService ContentService
@using HVTravel.Domain.Entities
@using HVTravel.Domain.Models
@using HVTravel.Web.Services
@model List<Tour>
@{
    var sections = await ContentService.GetPageSectionsAsync("publicTours");
    var hero = sections.GetSection("indexHero");
    var collectionChips = sections.GetSection("collectionChips");
    var filterPanel = sections.GetSection("filterPanel");
    var resultsPanel = sections.GetSection("resultsPanel");
    var emptyState = sections.GetSection("emptyState");

    var currentSearch = ViewData["CurrentSearch"]?.ToString();
    var currentSort = ViewData["CurrentSort"]?.ToString();
    var currentPage = (int)(ViewData["CurrentPage"] ?? 1);
    var totalPages = (int)(ViewData["TotalPages"] ?? 1);
    var totalItems = (int)(ViewData["TotalItems"] ?? 0);
    var currentRegion = ViewData["CurrentRegion"]?.ToString();
    var currentDestination = ViewData["CurrentDestination"]?.ToString();
    var currentCollection = ViewData["CurrentCollection"]?.ToString();
    var currentMinPrice = ViewData["CurrentMinPrice"]?.ToString();
    var currentMaxPrice = ViewData["CurrentMaxPrice"]?.ToString();
    var currentDepartureMonth = ViewData["CurrentDepartureMonth"]?.ToString();
    var currentMaxDays = ViewData["CurrentMaxDays"]?.ToString();
    var currentAvailableOnly = (bool)(ViewData["CurrentAvailableOnly"] ?? false);
    var currentPromotionOnly = (bool)(ViewData["CurrentPromotionOnly"] ?? false);
    var currentTravellers = (int)(ViewData["CurrentTravellers"] ?? 0);
    var currentConfirmationType = ViewData["CurrentConfirmationType"]?.ToString();
    var currentCancellationType = ViewData["CurrentCancellationType"]?.ToString();
    var regionFacets = ViewData["RegionFacets"] as IReadOnlyList<TourFacetOption> ?? Array.Empty<TourFacetOption>();
    var destinationFacets = ViewData["DestinationFacets"] as IReadOnlyList<TourFacetOption> ?? Array.Empty<TourFacetOption>();
    var confirmationFacets = ViewData["ConfirmationTypeFacets"] as IReadOnlyList<TourFacetOption> ?? Array.Empty<TourFacetOption>();
    var cancellationFacets = ViewData["CancellationTypeFacets"] as IReadOnlyList<TourFacetOption> ?? Array.Empty<TourFacetOption>();

    string CmsText(ContentSection? section, string key, string fallback)
        => section?.Fields.GetVisibleFieldValue(key, fallback) ?? fallback;

    var heroBadgeText = CmsText(hero, "badgeText", "Tour tuyển chọn");
    var heroTitleLine1 = CmsText(hero, "titleLine1", "Tour");
    var heroTitleHighlight = CmsText(hero, "titleHighlight", "du lịch");
    var heroDescription = CmsText(hero, "description", "Tìm điểm đến, loại tour, mùa lễ hội, số khách và chính sách xác nhận phù hợp với từng lịch khởi hành.");
    var heroSearchPlaceholder = CmsText(hero, "searchPlaceholder", "Tìm điểm đến, loại tour, mùa lễ hội...");
    var searchButtonText = CmsText(hero, "searchButtonText", "Tìm kiếm");
    var resultsEyebrow = CmsText(resultsPanel, "eyebrowText", "Discovery");
    var resultsTitleFormat = CmsText(resultsPanel, "titleFormat", "{0} tour phù hợp");
    var resultsTitle = string.IsNullOrWhiteSpace(resultsTitleFormat)
        ? string.Empty
        : string.Format(resultsTitleFormat, totalItems);
    var wishlistEyebrow = CmsText(resultsPanel, "wishlistEyebrow", "Wishlist");
    var wishlistTitle = CmsText(resultsPanel, "wishlistTitle", "Tour đã lưu");
    var wishlistEmptyText = CmsText(resultsPanel, "wishlistEmptyText", "Chưa có tour nào trong wishlist.");
    var recentEyebrow = CmsText(resultsPanel, "recentEyebrow", "Recently viewed");
    var recentTitle = CmsText(resultsPanel, "recentTitle", "Tour vừa xem");
    var recentEmptyText = CmsText(resultsPanel, "recentEmptyText", "Chưa có tour nào vừa xem.");
    var emptyStateTitle = CmsText(emptyState, "title", "Không tìm thấy tour nào");
    var emptyStateDescription = CmsText(emptyState, "description", "Hãy thử đổi bộ lọc hoặc quay lại toàn bộ danh sách tour.");
    var emptyStateCtaText = CmsText(emptyState, "ctaText", "Xem tất cả tour");

    var chips = new[]
    {
        new { Key = "domestic", Label = CmsText(collectionChips, "domesticLabel", "Trong nước") },
        new { Key = "premium", Label = CmsText(collectionChips, "premiumLabel", "Premium") },
        new { Key = "family", Label = CmsText(collectionChips, "familyLabel", "Gia đình") },
        new { Key = "couple", Label = CmsText(collectionChips, "coupleLabel", "Cặp đôi") },
        new { Key = "seasonal", Label = CmsText(collectionChips, "seasonalLabel", "Mùa lễ hội") },
        new { Key = "deal", Label = CmsText(collectionChips, "dealLabel", "Săn deal") }
    }.Where(chip => !string.IsNullOrWhiteSpace(chip.Label)).ToArray();
}

@if (hero?.IsEnabled != false)
{
    <section class="public-top-section public-top-section--hero public-page-hero hero-gradient relative overflow-hidden" style="@ContentPresentationViewHelper.GetSectionStyle(hero)">
        <div class="absolute inset-0 opacity-20">
            <div class="absolute left-20 top-20 h-72 w-72 rounded-full bg-primary/30 blur-3xl"></div>
            <div class="absolute bottom-0 right-10 h-80 w-80 rounded-full bg-cyan-400/20 blur-3xl"></div>
        </div>
        <div class="public-top-section-shell public-page-hero-shell mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
            <div class="@($"public-top-section-content public-page-hero-content is-centered {ContentPresentationViewHelper.GetSectionTextClass(hero)}")" data-animate="fade-up">
                @if (!string.IsNullOrWhiteSpace(heroBadgeText))
                {
                    <span class="public-badge public-top-section-badge public-page-hero-badge" style="@ContentPresentationViewHelper.GetFieldTextStyle(hero, "badgeText")">
                        <span class="material-symbols-outlined text-[16px] text-primary">travel_explore</span>
                        @heroBadgeText
                    </span>
                }
                @if (!string.IsNullOrWhiteSpace(heroTitleLine1) || !string.IsNullOrWhiteSpace(heroTitleHighlight))
                {
                    <h1 class="public-top-section-title public-hero-title text-white">
                        @if (!string.IsNullOrWhiteSpace(heroTitleLine1))
                        {
                            <span style="@ContentPresentationViewHelper.GetFieldTextStyle(hero, "titleLine1")">@heroTitleLine1</span>
                        }
                        @if (!string.IsNullOrWhiteSpace(heroTitleHighlight))
                        {
                            <span class="public-top-section-highlight public-page-hero-highlight" style="@ContentPresentationViewHelper.GetFieldTextStyle(hero, "titleHighlight")">@heroTitleHighlight</span>
                        }
                    </h1>
                }
                @if (!string.IsNullOrWhiteSpace(heroDescription))
                {
                    <div class="public-top-section-lead public-body-copy public-page-hero-copy" style="@ContentPresentationViewHelper.GetFieldTextStyle(hero, "description")">
                        @Html.Raw(heroDescription)
                    </div>
                }
                <div class="public-top-section-actions public-page-hero-actions mt-2 w-full max-w-4xl">
                    <form asp-controller="PublicTours" asp-action="Index" method="get" class="w-full">
                        <input type="hidden" name="sort" value="@currentSort" />
                        <input type="hidden" name="region" value="@currentRegion" />
                        <input type="hidden" name="destination" value="@currentDestination" />
                        <input type="hidden" name="collection" value="@currentCollection" />
                        <input type="hidden" name="travellers" value="@currentTravellers" />
                        <input type="hidden" name="confirmationType" value="@currentConfirmationType" />
                        <input type="hidden" name="cancellationType" value="@currentCancellationType" />
                        <div class="public-search-shell flex flex-col overflow-hidden rounded-2xl border border-white/20 bg-white/10 shadow-2xl shadow-slate-950/20 backdrop-blur-md sm:flex-row">
                            <input type="text" name="search" value="@currentSearch" placeholder="@heroSearchPlaceholder" class="min-w-0 w-full flex-1 bg-transparent px-6 py-4 text-sm text-white outline-none placeholder-white/60" />
                            @if (!string.IsNullOrWhiteSpace(searchButtonText))
                            {
                                <button type="submit" class="flex w-full items-center justify-center gap-2 bg-primary px-8 py-4 text-sm font-bold text-white transition-colors hover:bg-primary-dark sm:w-auto">
                                    <span class="material-symbols-outlined text-[20px]">search</span>
                                    <span>@searchButtonText</span>
                                </button>
                            }
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </section>
}

<section class="bg-background-light py-12 dark:bg-background-dark">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        @if (chips.Any())
        {
            <div class="mb-8 flex flex-wrap gap-3" data-animate="fade-in">
                @foreach (var chip in chips)
                {
                    <a asp-action="Index"
                       asp-route-collection="@chip.Key"
                       asp-route-search="@currentSearch"
                       asp-route-sort="@currentSort"
                       asp-route-region="@currentRegion"
                       asp-route-destination="@currentDestination"
                       asp-route-minPrice="@currentMinPrice"
                       asp-route-maxPrice="@currentMaxPrice"
                       asp-route-departureMonth="@currentDepartureMonth"
                       asp-route-maxDays="@currentMaxDays"
                       asp-route-availableOnly="@currentAvailableOnly"
                       asp-route-promotionOnly="@currentPromotionOnly"
                       asp-route-travellers="@currentTravellers"
                       asp-route-confirmationType="@currentConfirmationType"
                       asp-route-cancellationType="@currentCancellationType"
                       class="rounded-full px-4 py-2 text-xs font-bold uppercase tracking-[0.25em] transition @(currentCollection == chip.Key ? "bg-primary text-white" : "bg-surface-light text-slate-600 ring-1 ring-border-light dark:bg-surface-dark dark:text-slate-300 dark:ring-border-dark")">@chip.Label</a>
                }
            </div>
        }

        <div class="grid items-start gap-8 lg:grid-cols-[360px_minmax(0,1fr)]">
            <aside class="self-start rounded-[2rem] border border-border-light bg-surface-light p-6 shadow-sm dark:border-border-dark dark:bg-surface-dark" data-animate="slide-left">
                @await Html.PartialAsync("_PublicToursFilter", Model, new ViewDataDictionary(ViewData)
                {
                    ["FilterPanel"] = filterPanel
                })
            </aside>

            <div>
                <div class="mb-8 flex flex-wrap items-center justify-between gap-4" data-animate="fade-in">
                    <div>
                        @if (!string.IsNullOrWhiteSpace(resultsEyebrow))
                        {
                            <p class="text-xs uppercase tracking-[0.25em] text-slate-400">@resultsEyebrow</p>
                        }
                        @if (!string.IsNullOrWhiteSpace(resultsTitle))
                        {
                            <h2 class="public-section-title mt-2">@resultsTitle</h2>
                        }
                    </div>
                </div>

                @if (Model != null && Model.Any())
                {
                    <div class="public-card-grid public-tour-card-grid grid grid-cols-1 gap-6 sm:grid-cols-2 xl:grid-cols-3" data-animate="fade-in" data-stagger>
                        @foreach (var tour in Model)
                        {
                            @await Html.PartialAsync("_TourCard", tour)
                        }
                    </div>

                    @if (totalPages > 1)
                    {
                        <div class="mt-10 flex flex-wrap items-center justify-center gap-2">
                            @for (var pageNumber = 1; pageNumber <= totalPages; pageNumber++)
                            {
                                <a asp-action="Index"
                                   asp-route-page="@pageNumber"
                                   asp-route-search="@currentSearch"
                                   asp-route-sort="@currentSort"
                                   asp-route-region="@currentRegion"
                                   asp-route-destination="@currentDestination"
                                   asp-route-minPrice="@currentMinPrice"
                                   asp-route-maxPrice="@currentMaxPrice"
                                   asp-route-departureMonth="@currentDepartureMonth"
                                   asp-route-maxDays="@currentMaxDays"
                                   asp-route-collection="@currentCollection"
                                   asp-route-availableOnly="@currentAvailableOnly"
                                   asp-route-promotionOnly="@currentPromotionOnly"
                                   asp-route-travellers="@currentTravellers"
                                   asp-route-confirmationType="@currentConfirmationType"
                                   asp-route-cancellationType="@currentCancellationType"
                                   class="inline-flex h-10 w-10 items-center justify-center rounded-xl text-sm font-bold @(pageNumber == currentPage ? "bg-primary text-white" : "bg-surface-light text-slate-600 ring-1 ring-border-light dark:bg-surface-dark dark:text-slate-300 dark:ring-border-dark")">@pageNumber</a>
                            }
                        </div>
                    }
                }
                else
                {
                    <div class="@($"rounded-[2rem] border border-border-light px-6 py-14 text-center shadow-sm dark:border-border-dark {ContentPresentationViewHelper.GetSectionBackgroundClass(emptyState)} {ContentPresentationViewHelper.GetSectionTextClass(emptyState)}")" style="@ContentPresentationViewHelper.GetSectionStyle(emptyState)">
                        <span class="material-symbols-outlined mb-4 text-6xl text-slate-300 dark:text-slate-600">search_off</span>
                        @if (!string.IsNullOrWhiteSpace(emptyStateTitle))
                        {
                            <h3 class="text-xl font-bold text-slate-700 dark:text-slate-300" style="@ContentPresentationViewHelper.GetFieldTextStyle(emptyState, "title")">@emptyStateTitle</h3>
                        }
                        @if (!string.IsNullOrWhiteSpace(emptyStateDescription))
                        {
                            <div class="mb-6 mt-3 text-sm text-slate-500 dark:text-slate-400" style="@ContentPresentationViewHelper.GetFieldTextStyle(emptyState, "description")">
                                @Html.Raw(emptyStateDescription)
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(emptyStateCtaText))
                        {
                            <a asp-action="Index" class="inline-flex items-center gap-2 rounded-xl bg-primary px-6 py-3 text-sm font-bold text-white transition-all hover:bg-primary-dark">
                                <span class="material-symbols-outlined text-[18px]">refresh</span>
                                @emptyStateCtaText
                            </a>
                        }
                    </div>
                }

                <div class="mt-12 grid gap-6 lg:grid-cols-2">
                    <section class="rounded-[2rem] border border-border-light bg-surface-light p-6 shadow-sm dark:border-border-dark dark:bg-surface-dark">
                        @if (!string.IsNullOrWhiteSpace(wishlistEyebrow))
                        {
                            <p class="text-xs uppercase tracking-[0.3em] text-primary">@wishlistEyebrow</p>
                        }
                        @if (!string.IsNullOrWhiteSpace(wishlistTitle))
                        {
                            <h2 class="public-section-title mt-2">@wishlistTitle</h2>
                        }
                        <div id="wishlist-shell" data-empty-text="@wishlistEmptyText" class="mt-5 grid gap-4"></div>
                    </section>
                    <section class="rounded-[2rem] border border-border-light bg-surface-light p-6 shadow-sm dark:border-border-dark dark:bg-surface-dark">
                        @if (!string.IsNullOrWhiteSpace(recentEyebrow))
                        {
                            <p class="text-xs uppercase tracking-[0.3em] text-primary">@recentEyebrow</p>
                        }
                        @if (!string.IsNullOrWhiteSpace(recentTitle))
                        {
                            <h2 class="public-section-title mt-2">@recentTitle</h2>
                        }
                        <div id="recently-viewed-shell" data-empty-text="@recentEmptyText" class="mt-5 grid gap-4"></div>
                    </section>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
<script src="~/js/public-custom-select.js" asp-append-version="true"></script>
<script src="~/js/public-tour-card.js" asp-append-version="true"></script>
}



