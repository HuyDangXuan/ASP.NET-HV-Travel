@using System.Linq
@using System.Text.Encodings.Web
@using HVTravel.Domain.Entities
@using HVTravel.Domain.Models
@using HVTravel.Web.Services
@model List<Tour>
@{
    var filterPanel = ViewData["FilterPanel"] as ContentSection;
    var currentSearch = ViewData["CurrentSearch"]?.ToString();
    var currentSort = ViewData["CurrentSort"]?.ToString();
    var currentCollection = ViewData["CurrentCollection"]?.ToString();
    var currentRegion = ViewData["CurrentRegion"]?.ToString();
    var currentDestination = ViewData["CurrentDestination"]?.ToString();
    var currentMinPrice = ViewData["CurrentMinPrice"]?.ToString();
    var currentMaxPrice = ViewData["CurrentMaxPrice"]?.ToString();
    var currentDepartureMonth = ViewData["CurrentDepartureMonth"]?.ToString();
    var currentMaxDays = ViewData["CurrentMaxDays"]?.ToString();
    var currentAvailableOnly = (bool)(ViewData["CurrentAvailableOnly"] ?? false);
    var currentPromotionOnly = (bool)(ViewData["CurrentPromotionOnly"] ?? false);
    var currentTravellers = (int)(ViewData["CurrentTravellers"] ?? 0);
    var currentConfirmationType = ViewData["CurrentConfirmationType"]?.ToString();
    var currentCancellationType = ViewData["CurrentCancellationType"]?.ToString();
    var regionFacets = ViewData["RegionFacets"] as IReadOnlyList<TourFacetOption> ?? Array.Empty<TourFacetOption>();
    var destinationFacets = ViewData["DestinationFacets"] as IReadOnlyList<TourFacetOption> ?? Array.Empty<TourFacetOption>();
    var confirmationFacets = ViewData["ConfirmationTypeFacets"] as IReadOnlyList<TourFacetOption> ?? Array.Empty<TourFacetOption>();
    var cancellationFacets = ViewData["CancellationTypeFacets"] as IReadOnlyList<TourFacetOption> ?? Array.Empty<TourFacetOption>();

    string CmsText(string key, string fallback)
        => filterPanel?.Fields.GetVisibleFieldValue(key, fallback) ?? fallback;

    var headingTitle = CmsText("headingTitle", "Bộ lọc tìm kiếm");
    var regionLabelText = CmsText("regionLabel", "Khu vực");
    var destinationLabelText = CmsText("destinationLabel", "Điểm đến");
    var allOptionLabel = CmsText("allOptionLabel", "Tất cả");
    var minPriceLabelText = CmsText("minPriceLabel", "Giá từ");
    var minPricePlaceholder = CmsText("minPricePlaceholder", "2.000.000");
    var maxPriceLabelText = CmsText("maxPriceLabel", "Giá đến");
    var maxPricePlaceholder = CmsText("maxPricePlaceholder", "15.000.000");
    var departureMonthLabelText = CmsText("departureMonthLabel", "Tháng khởi hành");
    var departureMonthPrefix = CmsText("departureMonthPrefix", "Tháng");
    var maxDaysLabelText = CmsText("maxDaysLabel", "Tối đa ngày");
    var maxDaysPlaceholder = CmsText("maxDaysPlaceholder", "7");
    var travellersLabelText = CmsText("travellersLabel", "Số khách");
    var travellersPlaceholder = CmsText("travellersPlaceholder", "2");
    var sortLabelText = CmsText("sortLabel", "Sắp xếp");
    var sortRatingLabel = CmsText("sortRatingLabel", "Đánh giá cao");
    var sortBestValueLabel = CmsText("sortBestValueLabel", "Giá tốt nhất");
    var sortPriceAscLabel = CmsText("sortPriceAscLabel", "Giá thấp đến cao");
    var sortPriceDescLabel = CmsText("sortPriceDescLabel", "Giá cao đến thấp");
    var sortDepartureLabel = CmsText("sortDepartureLabel", "Khởi hành gần nhất");
    var confirmationLabelText = CmsText("confirmationLabel", "Xác nhận");
    var cancellationLabelText = CmsText("cancellationLabel", "Hủy / hoàn");
    var availableOnlyLabelText = CmsText("availableOnlyLabel", "Chỉ hiển thị tour còn chỗ");
    var promotionOnlyLabelText = CmsText("promotionOnlyLabel", "Chỉ hiển thị tour có khuyến mãi");
    var summaryRegionFormat = CmsText("summaryRegionFormat", "Khu vực đang có: {0} lựa chọn");
    var summaryConfirmationFormat = CmsText("summaryConfirmationFormat", "Kiểu xác nhận: {0} lựa chọn");
    var applyButtonText = CmsText("applyButtonText", "Áp dụng");
    var resetButtonText = CmsText("resetButtonText", "Reset");

    string ResolveFacetLabel(IReadOnlyList<TourFacetOption> facets, string? value)
        => string.IsNullOrWhiteSpace(value) ? allOptionLabel : facets.FirstOrDefault(facet => facet.Value == value)?.Value ?? value;

    var regionSelectedLabel = ResolveFacetLabel(regionFacets, currentRegion);
    var destinationSelectedLabel = ResolveFacetLabel(destinationFacets, currentDestination);
    var confirmationSelectedLabel = ResolveFacetLabel(confirmationFacets, currentConfirmationType);
    var cancellationSelectedLabel = ResolveFacetLabel(cancellationFacets, currentCancellationType);
    var departureMonthSelectedLabel = string.IsNullOrWhiteSpace(currentDepartureMonth) ? allOptionLabel : $"{departureMonthPrefix} {currentDepartureMonth}";
    var sortSelectedLabel = currentSort switch
    {
        "best_value" => sortBestValueLabel,
        "price_asc" => sortPriceAscLabel,
        "price_desc" => sortPriceDescLabel,
        "departure" => sortDepartureLabel,
        _ => sortRatingLabel
    };

    var summaryRegionText = string.IsNullOrWhiteSpace(summaryRegionFormat) ? string.Empty : string.Format(summaryRegionFormat, regionFacets.Count);
    var summaryConfirmationText = string.IsNullOrWhiteSpace(summaryConfirmationFormat) ? string.Empty : string.Format(summaryConfirmationFormat, confirmationFacets.Count);
    var allOptionLabelJs = JavaScriptEncoder.Default.Encode(allOptionLabel);
}

<form asp-action="Index" method="get" class="public-filter-form">
    <input type="hidden" name="search" value="@currentSearch" />
    <input type="hidden" name="collection" value="@currentCollection" />

    <div class="public-filter-heading">
        @if (!string.IsNullOrWhiteSpace(headingTitle))
        {
            <p class="public-filter-heading-title">@headingTitle</p>
        }
    </div>

    <div class="public-filter-shell">
        <div class="public-filter-section">
            <div class="public-filter-grid">
                <div class="public-filter-row">
                    <div class="public-filter-field">
                        @if (!string.IsNullOrWhiteSpace(regionLabelText))
                        {
                            <label class="public-filter-label" for="region-select">@regionLabelText</label>
                        }
                        <div class="public-custom-select" data-public-select-id="region">
                            <select id="region-select" name="region" class="public-filter-control public-native-select">
                                <option value="">@allOptionLabel</option>
                                @foreach (var facet in regionFacets)
                                {
                                    <option value="@facet.Value" selected="@(currentRegion == facet.Value)">@facet.Value (@facet.Count)</option>
                                }
                            </select>
                            <div class="public-custom-select-shell">
                                <button type="button" class="public-custom-select-trigger" data-public-select-trigger onclick="togglePublicCustomSelect('region')">
                                    <span class="public-custom-select-meta">
                                        <span class="selected-label">@regionSelectedLabel</span>
                                    </span>
                                    <span class="material-symbols-outlined arrow-icon">expand_more</span>
                                </button>
                                <div class="public-custom-select-menu">
                                    <button type="button" class="public-custom-select-option @(string.IsNullOrWhiteSpace(currentRegion) ? "selected" : string.Empty)" data-value="" onclick="selectPublicCustomOption('region', '', '@allOptionLabelJs')">
                                        <span class="public-custom-select-option-main"><span class="public-custom-select-option-dot"></span><span>@allOptionLabel</span></span>
                                    </button>
                                    @foreach (var facet in regionFacets)
                                    {
                                        var optionLabel = $"{facet.Value} ({facet.Count})";
                                        var optionLabelJs = JavaScriptEncoder.Default.Encode(optionLabel);
                                        <button type="button" class="public-custom-select-option @(currentRegion == facet.Value ? "selected" : string.Empty)" data-value="@facet.Value" onclick="selectPublicCustomOption('region', '@facet.Value', '@optionLabelJs')">
                                            <span class="public-custom-select-option-main"><span class="public-custom-select-option-dot"></span><span>@optionLabel</span></span>
                                        </button>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="public-filter-row">
                    <div class="public-filter-field">
                        @if (!string.IsNullOrWhiteSpace(destinationLabelText))
                        {
                            <label class="public-filter-label" for="destination-select">@destinationLabelText</label>
                        }
                        <div class="public-custom-select" data-public-select-id="destination">
                            <select id="destination-select" name="destination" class="public-filter-control public-native-select">
                                <option value="">@allOptionLabel</option>
                                @foreach (var facet in destinationFacets)
                                {
                                    <option value="@facet.Value" selected="@(currentDestination == facet.Value)">@facet.Value (@facet.Count)</option>
                                }
                            </select>
                            <div class="public-custom-select-shell">
                                <button type="button" class="public-custom-select-trigger" data-public-select-trigger onclick="togglePublicCustomSelect('destination')">
                                    <span class="public-custom-select-meta">
                                        <span class="selected-label">@destinationSelectedLabel</span>
                                    </span>
                                    <span class="material-symbols-outlined arrow-icon">expand_more</span>
                                </button>
                                <div class="public-custom-select-menu">
                                    <button type="button" class="public-custom-select-option @(string.IsNullOrWhiteSpace(currentDestination) ? "selected" : string.Empty)" data-value="" onclick="selectPublicCustomOption('destination', '', '@allOptionLabelJs')">
                                        <span class="public-custom-select-option-main"><span class="public-custom-select-option-dot"></span><span>@allOptionLabel</span></span>
                                    </button>
                                    @foreach (var facet in destinationFacets)
                                    {
                                        var optionLabel = $"{facet.Value} ({facet.Count})";
                                        var optionLabelJs = JavaScriptEncoder.Default.Encode(optionLabel);
                                        <button type="button" class="public-custom-select-option @(currentDestination == facet.Value ? "selected" : string.Empty)" data-value="@facet.Value" onclick="selectPublicCustomOption('destination', '@facet.Value', '@optionLabelJs')">
                                            <span class="public-custom-select-option-main"><span class="public-custom-select-option-dot"></span><span>@optionLabel</span></span>
                                        </button>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="public-filter-section">
            <div class="public-filter-grid">
                <div class="public-filter-row public-filter-row--pair">
                    <div class="public-filter-field">
                        @if (!string.IsNullOrWhiteSpace(minPriceLabelText))
                        {
                            <label class="public-filter-label" for="min-price">@minPriceLabelText</label>
                        }
                        <input id="min-price" name="minPrice" value="@currentMinPrice" placeholder="@minPricePlaceholder" class="public-filter-control" />
                    </div>
                    <div class="public-filter-field">
                        @if (!string.IsNullOrWhiteSpace(maxPriceLabelText))
                        {
                            <label class="public-filter-label" for="max-price">@maxPriceLabelText</label>
                        }
                        <input id="max-price" name="maxPrice" value="@currentMaxPrice" placeholder="@maxPricePlaceholder" class="public-filter-control" />
                    </div>
                </div>

                <div class="public-filter-row public-filter-row--pair">
                    <div class="public-filter-field">
                        @if (!string.IsNullOrWhiteSpace(departureMonthLabelText))
                        {
                            <label class="public-filter-label" for="departure-month-select">@departureMonthLabelText</label>
                        }
                        <div class="public-custom-select" data-public-select-id="departureMonth">
                            <select id="departure-month-select" name="departureMonth" class="public-filter-control public-native-select">
                                <option value="">@allOptionLabel</option>
                                @for (var month = 1; month <= 12; month++)
                                {
                                    <option value="@month" selected="@(currentDepartureMonth == month.ToString())">@departureMonthPrefix @month</option>
                                }
                            </select>
                            <div class="public-custom-select-shell">
                                <button type="button" class="public-custom-select-trigger" data-public-select-trigger onclick="togglePublicCustomSelect('departureMonth')">
                                    <span class="public-custom-select-meta">
                                        <span class="selected-label">@departureMonthSelectedLabel</span>
                                    </span>
                                    <span class="material-symbols-outlined arrow-icon">expand_more</span>
                                </button>
                                <div class="public-custom-select-menu">
                                    <button type="button" class="public-custom-select-option @(string.IsNullOrWhiteSpace(currentDepartureMonth) ? "selected" : string.Empty)" data-value="" onclick="selectPublicCustomOption('departureMonth', '', '@allOptionLabelJs')">
                                        <span class="public-custom-select-option-main"><span class="public-custom-select-option-dot"></span><span>@allOptionLabel</span></span>
                                    </button>
                                    @for (var month = 1; month <= 12; month++)
                                    {
                                        var optionLabel = $"{departureMonthPrefix} {month}";
                                        var optionLabelJs = JavaScriptEncoder.Default.Encode(optionLabel);
                                        <button type="button" class="public-custom-select-option @(currentDepartureMonth == month.ToString() ? "selected" : string.Empty)" data-value="@month" onclick="selectPublicCustomOption('departureMonth', '@month', '@optionLabelJs')">
                                            <span class="public-custom-select-option-main"><span class="public-custom-select-option-dot"></span><span>@optionLabel</span></span>
                                        </button>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="public-filter-field">
                        @if (!string.IsNullOrWhiteSpace(maxDaysLabelText))
                        {
                            <label class="public-filter-label" for="max-days">@maxDaysLabelText</label>
                        }
                        <input id="max-days" name="maxDays" value="@currentMaxDays" placeholder="@maxDaysPlaceholder" class="public-filter-control" />
                    </div>
                </div>

                <div class="public-filter-row public-filter-row--pair">
                    <div class="public-filter-field">
                        @if (!string.IsNullOrWhiteSpace(travellersLabelText))
                        {
                            <label class="public-filter-label" for="travellers">@travellersLabelText</label>
                        }
                        <input id="travellers" type="number" min="0" name="travellers" value="@(currentTravellers == 0 ? string.Empty : currentTravellers)" placeholder="@travellersPlaceholder" class="public-filter-control" />
                    </div>
                    <div class="public-filter-field">
                        @if (!string.IsNullOrWhiteSpace(sortLabelText))
                        {
                            <label class="public-filter-label" for="sort-select">@sortLabelText</label>
                        }
                        <div class="public-custom-select" data-public-select-id="sort">
                            <select id="sort-select" name="sort" class="public-filter-control public-native-select">
                                <option value="rating" selected="@(string.IsNullOrWhiteSpace(currentSort) || currentSort == "rating")">@sortRatingLabel</option>
                                <option value="best_value" selected="@(currentSort == "best_value")">@sortBestValueLabel</option>
                                <option value="price_asc" selected="@(currentSort == "price_asc")">@sortPriceAscLabel</option>
                                <option value="price_desc" selected="@(currentSort == "price_desc")">@sortPriceDescLabel</option>
                                <option value="departure" selected="@(currentSort == "departure")">@sortDepartureLabel</option>
                            </select>
                            <div class="public-custom-select-shell">
                                <button type="button" class="public-custom-select-trigger" data-public-select-trigger onclick="togglePublicCustomSelect('sort')">
                                    <span class="public-custom-select-meta">
                                        <span class="selected-label">@sortSelectedLabel</span>
                                    </span>
                                    <span class="material-symbols-outlined arrow-icon">expand_more</span>
                                </button>
                                <div class="public-custom-select-menu">
                                    <button type="button" class="public-custom-select-option @((string.IsNullOrWhiteSpace(currentSort) || currentSort == "rating") ? "selected" : string.Empty)" data-value="rating" onclick="selectPublicCustomOption('sort', 'rating', '@(JavaScriptEncoder.Default.Encode(sortRatingLabel))')">
                                        <span class="public-custom-select-option-main"><span class="public-custom-select-option-dot"></span><span>@sortRatingLabel</span></span>
                                    </button>
                                    <button type="button" class="public-custom-select-option @(currentSort == "best_value" ? "selected" : string.Empty)" data-value="best_value" onclick="selectPublicCustomOption('sort', 'best_value', '@(JavaScriptEncoder.Default.Encode(sortBestValueLabel))')">
                                        <span class="public-custom-select-option-main"><span class="public-custom-select-option-dot"></span><span>@sortBestValueLabel</span></span>
                                    </button>
                                    <button type="button" class="public-custom-select-option @(currentSort == "price_asc" ? "selected" : string.Empty)" data-value="price_asc" onclick="selectPublicCustomOption('sort', 'price_asc', '@(JavaScriptEncoder.Default.Encode(sortPriceAscLabel))')">
                                        <span class="public-custom-select-option-main"><span class="public-custom-select-option-dot"></span><span>@sortPriceAscLabel</span></span>
                                    </button>
                                    <button type="button" class="public-custom-select-option @(currentSort == "price_desc" ? "selected" : string.Empty)" data-value="price_desc" onclick="selectPublicCustomOption('sort', 'price_desc', '@(JavaScriptEncoder.Default.Encode(sortPriceDescLabel))')">
                                        <span class="public-custom-select-option-main"><span class="public-custom-select-option-dot"></span><span>@sortPriceDescLabel</span></span>
                                    </button>
                                    <button type="button" class="public-custom-select-option @(currentSort == "departure" ? "selected" : string.Empty)" data-value="departure" onclick="selectPublicCustomOption('sort', 'departure', '@(JavaScriptEncoder.Default.Encode(sortDepartureLabel))')">
                                        <span class="public-custom-select-option-main"><span class="public-custom-select-option-dot"></span><span>@sortDepartureLabel</span></span>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="public-filter-section">
            <div class="public-filter-grid">
                <div class="public-filter-row">
                    <div class="public-filter-field">
                        @if (!string.IsNullOrWhiteSpace(confirmationLabelText))
                        {
                            <label class="public-filter-label" for="confirmation-type-select">@confirmationLabelText</label>
                        }
                        <div class="public-custom-select" data-public-select-id="confirmationType">
                            <select id="confirmation-type-select" name="confirmationType" class="public-filter-control public-native-select">
                                <option value="">@allOptionLabel</option>
                                @foreach (var facet in confirmationFacets)
                                {
                                    <option value="@facet.Value" selected="@(currentConfirmationType == facet.Value)">@facet.Value (@facet.Count)</option>
                                }
                            </select>
                            <div class="public-custom-select-shell">
                                <button type="button" class="public-custom-select-trigger" data-public-select-trigger onclick="togglePublicCustomSelect('confirmationType')">
                                    <span class="public-custom-select-meta">
                                        <span class="selected-label">@confirmationSelectedLabel</span>
                                    </span>
                                    <span class="material-symbols-outlined arrow-icon">expand_more</span>
                                </button>
                                <div class="public-custom-select-menu">
                                    <button type="button" class="public-custom-select-option @(string.IsNullOrWhiteSpace(currentConfirmationType) ? "selected" : string.Empty)" data-value="" onclick="selectPublicCustomOption('confirmationType', '', '@allOptionLabelJs')">
                                        <span class="public-custom-select-option-main"><span class="public-custom-select-option-dot"></span><span>@allOptionLabel</span></span>
                                    </button>
                                    @foreach (var facet in confirmationFacets)
                                    {
                                        var optionLabel = $"{facet.Value} ({facet.Count})";
                                        var optionLabelJs = JavaScriptEncoder.Default.Encode(optionLabel);
                                        <button type="button" class="public-custom-select-option @(currentConfirmationType == facet.Value ? "selected" : string.Empty)" data-value="@facet.Value" onclick="selectPublicCustomOption('confirmationType', '@facet.Value', '@optionLabelJs')">
                                            <span class="public-custom-select-option-main"><span class="public-custom-select-option-dot"></span><span>@optionLabel</span></span>
                                        </button>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="public-filter-row">
                    <div class="public-filter-field">
                        @if (!string.IsNullOrWhiteSpace(cancellationLabelText))
                        {
                            <label class="public-filter-label" for="cancellation-type-select">@cancellationLabelText</label>
                        }
                        <div class="public-custom-select" data-public-select-id="cancellationType">
                            <select id="cancellation-type-select" name="cancellationType" class="public-filter-control public-native-select">
                                <option value="">@allOptionLabel</option>
                                @foreach (var facet in cancellationFacets)
                                {
                                    <option value="@facet.Value" selected="@(currentCancellationType == facet.Value)">@facet.Value (@facet.Count)</option>
                                }
                            </select>
                            <div class="public-custom-select-shell">
                                <button type="button" class="public-custom-select-trigger" data-public-select-trigger onclick="togglePublicCustomSelect('cancellationType')">
                                    <span class="public-custom-select-meta">
                                        <span class="selected-label">@cancellationSelectedLabel</span>
                                    </span>
                                    <span class="material-symbols-outlined arrow-icon">expand_more</span>
                                </button>
                                <div class="public-custom-select-menu">
                                    <button type="button" class="public-custom-select-option @(string.IsNullOrWhiteSpace(currentCancellationType) ? "selected" : string.Empty)" data-value="" onclick="selectPublicCustomOption('cancellationType', '', '@allOptionLabelJs')">
                                        <span class="public-custom-select-option-main"><span class="public-custom-select-option-dot"></span><span>@allOptionLabel</span></span>
                                    </button>
                                    @foreach (var facet in cancellationFacets)
                                    {
                                        var optionLabel = $"{facet.Value} ({facet.Count})";
                                        var optionLabelJs = JavaScriptEncoder.Default.Encode(optionLabel);
                                        <button type="button" class="public-custom-select-option @(currentCancellationType == facet.Value ? "selected" : string.Empty)" data-value="@facet.Value" onclick="selectPublicCustomOption('cancellationType', '@facet.Value', '@optionLabelJs')">
                                            <span class="public-custom-select-option-main"><span class="public-custom-select-option-dot"></span><span>@optionLabel</span></span>
                                        </button>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="public-filter-section public-filter-section--compact">
            <div class="public-filter-checkboxes rounded-2xl bg-surface-muted-light p-4 dark:bg-surface-elevated-dark">
                @if (!string.IsNullOrWhiteSpace(availableOnlyLabelText))
                {
                    <label class="flex items-center gap-3 text-sm text-slate-600 dark:text-slate-300">
                        <input type="checkbox" name="availableOnly" value="true" checked="@currentAvailableOnly" class="rounded border-border-light dark:border-border-dark" />
                        @availableOnlyLabelText
                    </label>
                }
                @if (!string.IsNullOrWhiteSpace(promotionOnlyLabelText))
                {
                    <label class="flex items-center gap-3 text-sm text-slate-600 dark:text-slate-300">
                        <input type="checkbox" name="promotionOnly" value="true" checked="@currentPromotionOnly" class="rounded border-border-light dark:border-border-dark" />
                        @promotionOnlyLabelText
                    </label>
                }
            </div>

            <div class="public-filter-summary rounded-2xl border border-dashed border-border-light p-4 text-xs text-slate-500 dark:border-border-dark dark:text-slate-400" data-facet-source="RegionFacets" data-confirmation-source="ConfirmationTypeFacets">
                @if (!string.IsNullOrWhiteSpace(summaryRegionText))
                {
                    <div>@summaryRegionText</div>
                }
                @if (!string.IsNullOrWhiteSpace(summaryConfirmationText))
                {
                    <div>@summaryConfirmationText</div>
                }
            </div>

            @if (!string.IsNullOrWhiteSpace(applyButtonText) || !string.IsNullOrWhiteSpace(resetButtonText))
            {
                <div class="public-filter-actions">
                    @if (!string.IsNullOrWhiteSpace(applyButtonText))
                    {
                        <button type="submit" class="flex-1 rounded-2xl bg-primary px-5 py-3 text-sm font-bold text-white">@applyButtonText</button>
                    }
                    @if (!string.IsNullOrWhiteSpace(resetButtonText))
                    {
                        <a asp-action="Index" class="public-filter-reset rounded-2xl border border-border-light px-5 py-3 text-sm font-bold text-slate-600 dark:border-border-dark dark:text-slate-300">@resetButtonText</a>
                    }
                </div>
            }
        </div>
    </div>
</form>

