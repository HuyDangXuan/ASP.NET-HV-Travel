@using System.Linq
@using HVTravel.Domain.Entities
@using HVTravel.Domain.Models
@using HVTravel.Web.Services
@model List<Tour>
@{
    var filterPanel = ViewData["FilterPanel"] as ContentSection;
    var currentSearch = ViewData["CurrentSearch"]?.ToString();
    var currentSort = ViewData["CurrentSort"]?.ToString();
    var currentCollection = ViewData["CurrentCollection"]?.ToString();
    var currentRegion = ViewData["CurrentRegion"]?.ToString();
    var currentDestination = ViewData["CurrentDestination"]?.ToString();
    var currentMinPrice = ViewData["CurrentMinPrice"]?.ToString();
    var currentMaxPrice = ViewData["CurrentMaxPrice"]?.ToString();
    var currentDepartureMonth = ViewData["CurrentDepartureMonth"]?.ToString();
    var currentMaxDays = ViewData["CurrentMaxDays"]?.ToString();
    var currentAvailableOnly = (bool)(ViewData["CurrentAvailableOnly"] ?? false);
    var currentPromotionOnly = (bool)(ViewData["CurrentPromotionOnly"] ?? false);
    var currentTravellers = (int)(ViewData["CurrentTravellers"] ?? 0);
    var currentConfirmationType = ViewData["CurrentConfirmationType"]?.ToString();
    var currentCancellationType = ViewData["CurrentCancellationType"]?.ToString();
    var regionFacets = ViewData["RegionFacets"] as IReadOnlyList<TourFacetOption> ?? Array.Empty<TourFacetOption>();
    var destinationFacets = ViewData["DestinationFacets"] as IReadOnlyList<TourFacetOption> ?? Array.Empty<TourFacetOption>();
    var confirmationFacets = ViewData["ConfirmationTypeFacets"] as IReadOnlyList<TourFacetOption> ?? Array.Empty<TourFacetOption>();
    var cancellationFacets = ViewData["CancellationTypeFacets"] as IReadOnlyList<TourFacetOption> ?? Array.Empty<TourFacetOption>();

    string CmsText(string key, string fallback)
        => filterPanel?.Fields.GetVisibleFieldValue(key, fallback) ?? fallback;

    var headingTitle = CmsText("headingTitle", "Bộ lọc tìm kiếm");
    var regionLabelText = CmsText("regionLabel", "Khu vực");
    var destinationLabelText = CmsText("destinationLabel", "Điểm đến");
    var allOptionLabel = CmsText("allOptionLabel", "Tất cả");
    var minPriceLabelText = CmsText("minPriceLabel", "Giá từ");
    var minPricePlaceholder = CmsText("minPricePlaceholder", "2.000.000");
    var maxPriceLabelText = CmsText("maxPriceLabel", "Giá đến");
    var maxPricePlaceholder = CmsText("maxPricePlaceholder", "15.000.000");
    var departureMonthLabelText = CmsText("departureMonthLabel", "Tháng khởi hành");
    var departureMonthPrefix = CmsText("departureMonthPrefix", "Tháng");
    var maxDaysLabelText = CmsText("maxDaysLabel", "Tối đa ngày");
    var maxDaysPlaceholder = CmsText("maxDaysPlaceholder", "7");
    var travellersLabelText = CmsText("travellersLabel", "Số khách");
    var travellersPlaceholder = CmsText("travellersPlaceholder", "2");
    var sortLabelText = CmsText("sortLabel", "Sắp xếp");
    var sortRatingLabel = CmsText("sortRatingLabel", "Đánh giá cao");
    var sortBestValueLabel = CmsText("sortBestValueLabel", "Giá tốt nhất");
    var sortPriceAscLabel = CmsText("sortPriceAscLabel", "Giá thấp đến cao");
    var sortPriceDescLabel = CmsText("sortPriceDescLabel", "Giá cao đến thấp");
    var sortDepartureLabel = CmsText("sortDepartureLabel", "Khởi hành gần nhất");
    var confirmationLabelText = CmsText("confirmationLabel", "Xác nhận");
    var cancellationLabelText = CmsText("cancellationLabel", "Hủy / hoàn");
    var availableOnlyLabelText = CmsText("availableOnlyLabel", "Chỉ hiển thị tour còn chỗ");
    var promotionOnlyLabelText = CmsText("promotionOnlyLabel", "Chỉ hiển thị tour có khuyến mãi");
    var summaryRegionFormat = CmsText("summaryRegionFormat", "Khu vực đang có: {0} lựa chọn");
    var summaryConfirmationFormat = CmsText("summaryConfirmationFormat", "Kiểu xác nhận: {0} lựa chọn");
    var applyButtonText = CmsText("applyButtonText", "Áp dụng");
    var resetButtonText = CmsText("resetButtonText", "Reset");

    var summaryRegionText = string.IsNullOrWhiteSpace(summaryRegionFormat) ? string.Empty : string.Format(summaryRegionFormat, regionFacets.Count);
    var summaryConfirmationText = string.IsNullOrWhiteSpace(summaryConfirmationFormat) ? string.Empty : string.Format(summaryConfirmationFormat, confirmationFacets.Count);

    const string SectionClass = "space-y-5 rounded-[1.75rem] border border-slate-200 bg-white/90 p-5 shadow-sm dark:border-slate-800 dark:bg-slate-950/80";
    const string FieldClass = "space-y-2";
    const string LabelClass = "block text-[11px] font-black uppercase tracking-[0.24em] text-slate-500 dark:text-slate-400";
    const string ControlClass = "w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 shadow-sm outline-none transition focus:border-primary focus:ring-4 focus:ring-primary/10 dark:border-slate-700 dark:bg-slate-950 dark:text-white";
}

<form asp-action="Index" method="get" class="space-y-6">
    <input type="hidden" name="search" value="@currentSearch" />
    <input type="hidden" name="collection" value="@currentCollection" />

    @if (!string.IsNullOrWhiteSpace(headingTitle))
    {
        <div>
            <p class="text-sm font-black uppercase tracking-[0.28em] text-slate-400 dark:text-slate-500">@headingTitle</p>
        </div>
    }

    <section class="@SectionClass">
        <div class="grid gap-5">
            <div class="@FieldClass">
                @if (!string.IsNullOrWhiteSpace(regionLabelText))
                {
                    <label class="@LabelClass" for="region-select">@regionLabelText</label>
                }
                <select id="region-select" name="region" class="@ControlClass">
                    <option value="">@allOptionLabel</option>
                    @foreach (var facet in regionFacets)
                    {
                        <option value="@facet.Value" selected="@(currentRegion == facet.Value)">@facet.Value (@facet.Count)</option>
                    }
                </select>
            </div>

            <div class="@FieldClass">
                @if (!string.IsNullOrWhiteSpace(destinationLabelText))
                {
                    <label class="@LabelClass" for="destination-select">@destinationLabelText</label>
                }
                <select id="destination-select" name="destination" class="@ControlClass">
                    <option value="">@allOptionLabel</option>
                    @foreach (var facet in destinationFacets)
                    {
                        <option value="@facet.Value" selected="@(currentDestination == facet.Value)">@facet.Value (@facet.Count)</option>
                    }
                </select>
            </div>
        </div>
    </section>

    <section class="@SectionClass">
        <div class="grid gap-5 sm:grid-cols-2">
            <div class="@FieldClass">
                @if (!string.IsNullOrWhiteSpace(minPriceLabelText))
                {
                    <label class="@LabelClass" for="min-price">@minPriceLabelText</label>
                }
                <input id="min-price" name="minPrice" value="@currentMinPrice" placeholder="@minPricePlaceholder" class="@ControlClass" />
            </div>
            <div class="@FieldClass">
                @if (!string.IsNullOrWhiteSpace(maxPriceLabelText))
                {
                    <label class="@LabelClass" for="max-price">@maxPriceLabelText</label>
                }
                <input id="max-price" name="maxPrice" value="@currentMaxPrice" placeholder="@maxPricePlaceholder" class="@ControlClass" />
            </div>
            <div class="@FieldClass">
                @if (!string.IsNullOrWhiteSpace(departureMonthLabelText))
                {
                    <label class="@LabelClass" for="departure-month-select">@departureMonthLabelText</label>
                }
                <select id="departure-month-select" name="departureMonth" class="@ControlClass">
                    <option value="">@allOptionLabel</option>
                    @for (var month = 1; month <= 12; month++)
                    {
                        <option value="@month" selected="@(currentDepartureMonth == month.ToString())">@departureMonthPrefix @month</option>
                    }
                </select>
            </div>
            <div class="@FieldClass">
                @if (!string.IsNullOrWhiteSpace(maxDaysLabelText))
                {
                    <label class="@LabelClass" for="max-days">@maxDaysLabelText</label>
                }
                <input id="max-days" name="maxDays" value="@currentMaxDays" placeholder="@maxDaysPlaceholder" class="@ControlClass" />
            </div>
            <div class="@FieldClass">
                @if (!string.IsNullOrWhiteSpace(travellersLabelText))
                {
                    <label class="@LabelClass" for="travellers">@travellersLabelText</label>
                }
                <input id="travellers" type="number" min="0" name="travellers" value="@(currentTravellers == 0 ? string.Empty : currentTravellers)" placeholder="@travellersPlaceholder" class="@ControlClass" />
            </div>
            <div class="@FieldClass">
                @if (!string.IsNullOrWhiteSpace(sortLabelText))
                {
                    <label class="@LabelClass" for="sort-select">@sortLabelText</label>
                }
                <select id="sort-select" name="sort" class="@ControlClass">
                    <option value="rating" selected="@(string.IsNullOrWhiteSpace(currentSort) || currentSort == "rating")">@sortRatingLabel</option>
                    <option value="best_value" selected="@(currentSort == "best_value")">@sortBestValueLabel</option>
                    <option value="price_asc" selected="@(currentSort == "price_asc")">@sortPriceAscLabel</option>
                    <option value="price_desc" selected="@(currentSort == "price_desc")">@sortPriceDescLabel</option>
                    <option value="departure" selected="@(currentSort == "departure")">@sortDepartureLabel</option>
                </select>
            </div>
        </div>
    </section>

    <section class="@SectionClass">
        <div class="grid gap-5">
            <div class="@FieldClass">
                @if (!string.IsNullOrWhiteSpace(confirmationLabelText))
                {
                    <label class="@LabelClass" for="confirmation-type-select">@confirmationLabelText</label>
                }
                <select id="confirmation-type-select" name="confirmationType" class="@ControlClass">
                    <option value="">@allOptionLabel</option>
                    @foreach (var facet in confirmationFacets)
                    {
                        <option value="@facet.Value" selected="@(currentConfirmationType == facet.Value)">@facet.Value (@facet.Count)</option>
                    }
                </select>
            </div>

            <div class="@FieldClass">
                @if (!string.IsNullOrWhiteSpace(cancellationLabelText))
                {
                    <label class="@LabelClass" for="cancellation-type-select">@cancellationLabelText</label>
                }
                <select id="cancellation-type-select" name="cancellationType" class="@ControlClass">
                    <option value="">@allOptionLabel</option>
                    @foreach (var facet in cancellationFacets)
                    {
                        <option value="@facet.Value" selected="@(currentCancellationType == facet.Value)">@facet.Value (@facet.Count)</option>
                    }
                </select>
            </div>
        </div>
    </section>

    <section class="@SectionClass">
        <div class="space-y-4 rounded-[1.5rem] border border-slate-200 bg-slate-50/80 p-4 dark:border-slate-800 dark:bg-slate-900/70">
            @if (!string.IsNullOrWhiteSpace(availableOnlyLabelText))
            {
                <label class="flex items-center gap-3 text-sm text-slate-600 dark:text-slate-300">
                    <input type="checkbox" name="availableOnly" value="true" checked="@currentAvailableOnly" class="rounded border-border-light dark:border-border-dark" />
                    @availableOnlyLabelText
                </label>
            }
            @if (!string.IsNullOrWhiteSpace(promotionOnlyLabelText))
            {
                <label class="flex items-center gap-3 text-sm text-slate-600 dark:text-slate-300">
                    <input type="checkbox" name="promotionOnly" value="true" checked="@currentPromotionOnly" class="rounded border-border-light dark:border-border-dark" />
                    @promotionOnlyLabelText
                </label>
            }
        </div>

        <div class="space-y-2 rounded-[1.5rem] border border-dashed border-slate-300 px-4 py-4 text-xs text-slate-500 dark:border-slate-700 dark:text-slate-400" data-facet-source="RegionFacets" data-confirmation-source="ConfirmationTypeFacets">
            @if (!string.IsNullOrWhiteSpace(summaryRegionText))
            {
                <div>@summaryRegionText</div>
            }
            @if (!string.IsNullOrWhiteSpace(summaryConfirmationText))
            {
                <div>@summaryConfirmationText</div>
            }
        </div>

        @if (!string.IsNullOrWhiteSpace(applyButtonText) || !string.IsNullOrWhiteSpace(resetButtonText))
        {
            <div class="flex flex-col gap-3 sm:flex-row">
                @if (!string.IsNullOrWhiteSpace(applyButtonText))
                {
                    <button type="submit" class="inline-flex flex-1 items-center justify-center rounded-2xl bg-primary px-5 py-3 text-sm font-black text-white shadow-lg shadow-primary/20 transition hover:-translate-y-0.5 hover:bg-primary-dark hover:shadow-primary/35">@applyButtonText</button>
                }
                @if (!string.IsNullOrWhiteSpace(resetButtonText))
                {
                    <a asp-action="Index" class="inline-flex items-center justify-center rounded-2xl border border-slate-200 px-5 py-3 text-sm font-black text-slate-600 transition hover:border-primary/30 hover:text-primary dark:border-slate-700 dark:text-slate-300">@resetButtonText</a>
                }
            </div>
        }
    </section>
</form>
