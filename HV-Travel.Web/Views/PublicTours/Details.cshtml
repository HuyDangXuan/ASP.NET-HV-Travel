                    <p class="mt-4 text-sm leading-7 text-slate-500 dark:text-slate-400">@bookingPanel?.Fields.GetVisibleFieldValue("priceHelperText", "Mức giá tốt nhất theo lịch khởi hành hiện có.")</p>
                    @if (departures.Any())
                    {
                        <div class="mt-6 space-y-2"><label class="block text-[11px] font-black uppercase tracking-[0.24em] text-slate-500 dark:text-slate-400">Chọn ngày khởi hành</label><select class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 shadow-sm outline-none transition focus:border-primary focus:ring-4 focus:ring-primary/10 dark:border-slate-700 dark:bg-slate-950 dark:text-white" data-detail-departure-select>@foreach (var departure in departures) { var departureConfirmation = ConfirmationText(departure.ConfirmationType); <option value="@departure.Id" selected="@(selectedDeparture?.Id == departure.Id ? "selected" : null)" data-departure-text="@departure.StartDate.ToString("dd/MM/yyyy")" data-adult-price="@DepartureAdultPrice(departure)" data-child-price="@DepartureChildPrice(departure)" data-infant-price="@DepartureInfantPrice(departure)" data-confirmation="@departureConfirmation" data-seats="@SeatsRemainingText(departure)">@departure.StartDate.ToString("dd/MM/yyyy")</option> }</select><p class="text-sm text-slate-500 dark:text-slate-400" data-detail-seats-text>@seatsLabel</p></div>
                    }
                    <div class="mt-6 space-y-3 rounded-[1.5rem] border border-slate-200 bg-slate-50/80 p-4 dark:border-slate-800 dark:bg-slate-900/70">
                        <div class="flex items-center justify-between text-sm text-slate-600 dark:text-slate-300"><span>Người lớn</span><strong class="font-black text-slate-900 dark:text-white" data-detail-price-adult>@adultPrice.ToString("N0") VND</strong></div>
