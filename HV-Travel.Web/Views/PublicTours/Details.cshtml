                    <article class="@($"{Card} {ContentPresentationViewHelper.GetSectionBackgroundClass(inclusions)}")" style="@ContentPresentationViewHelper.GetSectionStyle(inclusions)"><h2 class="@Heading">@inclusions?.Fields.GetVisibleFieldValue("excludedTitle", "Excluded")</h2>@if (Model.GeneratedExclusions != null && Model.GeneratedExclusions.Any()) { <ul class="mt-6 space-y-3 @Copy">@foreach (var item in Model.GeneratedExclusions) { <li class="flex gap-3"><span class="material-symbols-outlined mt-1 text-rose-500 text-[18px]">remove_circle</span><span>@item</span></li> }</ul> } else { <p class="mt-6 text-sm leading-7 text-slate-500 dark:text-slate-400">@inclusions?.Fields.GetVisibleFieldValue("excludedEmptyText", "Excluded services will be updated soon.")</p> }</article>
