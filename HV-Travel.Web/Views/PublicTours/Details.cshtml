                                        </div>
                                        <div class="flex flex-wrap gap-2">
                                            <span class="inline-flex items-center rounded-full border border-slate-200 bg-white px-3 py-1 text-[11px] font-black uppercase tracking-[0.2em] text-slate-500 dark:border-slate-700 dark:bg-slate-950 dark:text-slate-300">@string.Format(routing?.Fields.GetVisibleFieldValue("stopCountFormat", "{0} điểm dừng") ?? "{0} điểm dừng", routeDay.Stops.Count)</span>
                                            <span class="inline-flex items-center rounded-full border border-slate-200 bg-white px-3 py-1 text-[11px] font-black uppercase tracking-[0.2em] text-slate-500 dark:border-slate-700 dark:bg-slate-950 dark:text-slate-300">@string.Format(routing?.Fields.GetVisibleFieldValue("dayTravelMinutesFormat", "{0} phút di chuyển") ?? "{0} phút di chuyển", routeDay.TravelMinutes)</span>
                                            <span class="inline-flex items-center rounded-full border border-slate-200 bg-white px-3 py-1 text-[11px] font-black uppercase tracking-[0.2em] text-slate-500 dark:border-slate-700 dark:bg-slate-950 dark:text-slate-300">@string.Format(routing?.Fields.GetVisibleFieldValue("dayJourneyMinutesFormat", "{0} phút hành trình") ?? "{0} phút hành trình", routeDay.JourneyMinutes)</span>
                                            @if (!string.IsNullOrWhiteSpace(routeDay.PeakDayPart))
                                            {
                                                <span class="inline-flex items-center rounded-full border border-sky-200 bg-sky-50 px-3 py-1 text-[11px] font-black uppercase tracking-[0.2em] text-sky-700 dark:border-sky-800/60 dark:bg-sky-950/40 dark:text-sky-200">@(routing?.Fields.GetVisibleFieldValue("dayPartLabel", "Khung giờ")): @DayPartText(routeDay.PeakDayPart)</span>
                                            }
                                        </div>
                                    </div>
                                    <div class="mt-5 space-y-3">
                                        @foreach (var stop in routeDay.Stops)
                                        {
                                            <div class="rounded-[1.4rem] border border-slate-200 bg-white p-4 dark:border-slate-800 dark:bg-slate-950/80">
                                                @if (stop.TransferFromPrevious != null)
                                                {
                                                    <div class="mb-4 rounded-[1.1rem] border border-dashed border-slate-200 bg-slate-50/80 px-4 py-3 text-xs font-semibold text-slate-600 dark:border-slate-800 dark:bg-slate-900/70 dark:text-slate-300">
                                                        <div class="flex flex-wrap items-center gap-3">
                                                            <span>@string.Format(routing?.Fields.GetVisibleFieldValue("transferTimeFormat", "Di chuyển khoảng {0} phút") ?? "Di chuyển khoảng {0} phút", stop.TransferFromPrevious.TravelMinutes)</span>
                                                            <span>@(routing?.Fields.GetVisibleFieldValue("dayPartLabel", "Khung giờ")): @DayPartText(stop.TransferFromPrevious.DayPart)</span>
                                                            <span>@(routing?.Fields.GetVisibleFieldValue("congestionLabel", "Mật độ giao thông")): @CongestionText(stop.TransferFromPrevious.CongestionLevel)</span>
                                                        </div>
                                                    </div>
                                                }
                                                <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
                                                    <div class="min-w-0">
                                                        <p class="text-base font-black tracking-tight text-slate-900 dark:text-white">@stop.Name</p>
                                                        @if (!string.IsNullOrWhiteSpace(stop.Type))
                                                        {
                                                            <p class="mt-1 text-[11px] font-bold uppercase tracking-[0.2em] text-slate-400 dark:text-slate-500">@(routing?.Fields.GetVisibleFieldValue("typeLabel", "Loại điểm")): @stop.Type</p>
                                                        }
                                                    </div>
                                                    @if (stop.VisitMinutes > 0)
                                                    {
                                                        <span class="inline-flex shrink-0 items-center rounded-full bg-slate-100 px-3 py-1 text-[11px] font-black uppercase tracking-[0.2em] text-slate-600 dark:bg-slate-900 dark:text-slate-300">@stop.VisitMinutes phút</span>
                                                    }
                                                </div>
                                                @if (!string.IsNullOrWhiteSpace(stop.Note))
                                                {
                                                    <p class="mt-3 text-sm leading-7 text-slate-500 dark:text-slate-400">@stop.Note</p>
