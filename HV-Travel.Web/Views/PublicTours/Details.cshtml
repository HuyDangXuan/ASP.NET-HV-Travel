                    }
                    <div class="mt-6 space-y-3 rounded-[1.5rem] border border-slate-200 bg-slate-50/80 p-4 dark:border-slate-800 dark:bg-slate-900/70">
                        <div class="flex items-center justify-between text-sm text-slate-600 dark:text-slate-300"><span>Người lớn</span><strong class="font-black text-slate-900 dark:text-white" data-detail-price-adult>@adultPrice.ToString("N0") VND</strong></div>
                        <div class="flex items-center justify-between text-sm text-slate-600 dark:text-slate-300"><span>Trẻ em</span><strong class="font-black text-slate-900 dark:text-white" data-detail-price-child>@childPrice.ToString("N0") VND</strong></div>
                        <div class="flex items-center justify-between text-sm text-slate-600 dark:text-slate-300"><span>Em bé</span><strong class="font-black text-slate-900 dark:text-white" data-detail-price-infant>@infantPrice.ToString("N0") VND</strong></div>
                        <div class="flex items-center justify-between border-t border-dashed border-slate-200 pt-3 text-sm text-slate-500 dark:border-slate-700 dark:text-slate-400"><span>@bookingPanel?.Fields.GetVisibleFieldValue("departureLabel", "Ngày khởi hành")</span><strong class="font-black text-slate-900 dark:text-white" data-detail-departure-text>@selectedDepartureText</strong></div>
                    </div>
                    <div class="mt-6 flex items-center justify-between rounded-[1.5rem] bg-slate-950 px-4 py-4 text-white dark:bg-white dark:text-slate-950"><span class="text-sm font-bold uppercase tracking-[0.22em]">Tổng tạm tính</span><strong class="text-lg font-black" data-detail-price-total>@adultPrice.ToString("N0") VND</strong></div>
