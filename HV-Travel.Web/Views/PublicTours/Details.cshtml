@inject IPublicContentService ContentService
@using System.Text.Json
@using HVTravel.Web.Services
@model Tour
@{
    var sections = await ContentService.GetPageSectionsAsync("publicTourDetails");
    var hero = sections.GetSection("hero");
    var highlights = sections.GetSection("highlights");
    var overview = sections.GetSection("overview");
    var inclusions = sections.GetSection("inclusions");
    var schedule = sections.GetSection("schedule");
    var policies = sections.GetSection("policies");
    var departuresSection = sections.GetSection("departures");
    var bookingPanel = sections.GetSection("bookingPanel");
    var relatedToursSection = sections.GetSection("relatedTours");
    var relatedTours = ViewData["RelatedTours"] as List<Tour> ?? new List<Tour>();
    var departures = ((Model.Departures != null && Model.Departures.Any()) ? Model.Departures : Model.EffectiveDepartures).OrderBy(item => item.StartDate).ToList();
    var featuredDeparture = departures.FirstOrDefault();
    var startingPrice = departures.Any() ? departures.Min(item => item.AdultPrice > 0m ? item.AdultPrice : Model.Price?.Adult ?? 0m) : Model.Price?.Adult ?? 0m;
    var headlineDescription = RichTextContentFormatter.ToPlainTextSummary(Model.ShortDescription ?? Model.Description, 180);
    var structuredData = JsonSerializer.Serialize(new Dictionary<string, object?>
    {
        ["@context"] = "https://schema.org",
        ["@type"] = "Product",
        ["name"] = Model.Name,
        ["description"] = headlineDescription,
        ["image"] = Model.Images
    });
    string ConfirmationText(string? value) => string.Equals(value, "Instant", StringComparison.OrdinalIgnoreCase)
        ? hero?.Fields.GetVisibleFieldValue("instantConfirmationLabel", "Xác nhận tức thì") ?? "Xác nhận tức thì"
        : hero?.Fields.GetVisibleFieldValue("requestConfirmationLabel", "Chờ xác nhận") ?? "Chờ xác nhận";
}

<script type="application/ld+json">@Html.Raw(structuredData)</script>

@if (hero?.IsEnabled != false)
{
    <section class="public-top-section public-top-section--compact hero-gradient @ContentPresentationViewHelper.GetSectionBackgroundClass(hero)" style="@ContentPresentationViewHelper.GetSectionStyle(hero)">
        <div class="public-top-section-shell mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8 @ContentPresentationViewHelper.GetSectionTextClass(hero)">
            <div class="flex flex-wrap gap-2 text-xs font-bold uppercase tracking-[0.2em] text-white/80">
                <span class="rounded-full bg-white/10 px-3 py-1.5" style="@ContentPresentationViewHelper.GetFieldTextStyle(hero, "instantConfirmationLabel")">@ConfirmationText(Model.ConfirmationType)</span>
                @if (Model.CancellationPolicy?.IsFreeCancellation == true)
                {
                    <span class="rounded-full bg-emerald-400/20 px-3 py-1.5 text-emerald-100" style="@ContentPresentationViewHelper.GetFieldTextStyle(hero, "freeCancellationLabel")">@hero.Fields.GetVisibleFieldValue("freeCancellationLabel", "Hủy miễn phí")</span>
                }
                @if (featuredDeparture?.RemainingCapacity is > 0 and <= 5)
                {
                    <span class="rounded-full bg-amber-300/20 px-3 py-1.5 text-amber-50" style="@ContentPresentationViewHelper.GetFieldTextStyle(hero, "lowAvailabilityLabel")">@hero.Fields.GetVisibleFieldValue("lowAvailabilityLabel", "Còn ít chỗ")</span>
                }
            </div>
            <h1 class="public-top-section-title mt-4 text-white">@Model.Name</h1>
            <p class="public-top-section-lead">@headlineDescription</p>
            <div class="mt-4 flex flex-wrap gap-4 text-sm text-slate-200">
                <span>@(Model.Destination?.City ?? (hero.Fields.GetVisibleFieldValue("locationFallback", "Việt Nam")))</span>
                <span>@(Model.Duration?.Text ?? (hero.Fields.GetVisibleFieldValue("durationFallback", "Liên hệ tư vấn")))</span>
                <span>@string.Format(hero.Fields.GetVisibleFieldValue("reviewFormat", "{0} đánh giá") ?? "{0} đánh giá", Model.ReviewCount)</span>
            </div>
        </div>
    </section>
}

<section class="bg-background-light py-10 dark:bg-background-dark">
    <div class="mx-auto grid max-w-7xl gap-8 px-4 sm:px-6 lg:grid-cols-[minmax(0,1fr)_320px] lg:px-8">
        <div class="space-y-6">
            <section class="rounded-3xl border border-border-light bg-surface-light p-6 shadow-sm dark:border-border-dark dark:bg-surface-dark">
                @if (Model.Images != null && Model.Images.Any())
                {
                    <img src="@Model.Images.First()" alt="@Model.Name" class="h-80 w-full rounded-3xl object-cover" />
                }
            </section>

            <section class="rounded-3xl border border-border-light bg-surface-light p-6 shadow-sm dark:border-border-dark dark:bg-surface-dark @ContentPresentationViewHelper.GetSectionTextClass(highlights)" style="@ContentPresentationViewHelper.GetSectionStyle(highlights)">
                <p class="text-xs font-bold uppercase tracking-[0.25em] text-primary" style="@ContentPresentationViewHelper.GetFieldTextStyle(highlights, "eyebrowText")">@highlights?.Fields.GetVisibleFieldValue("eyebrowText", "Highlights")</p>
                <div class="mt-2 flex items-center justify-between gap-4">
                    <h2 class="text-2xl font-black" style="@ContentPresentationViewHelper.GetFieldTextStyle(highlights, "title")">@highlights?.Fields.GetVisibleFieldValue("title", "Điểm nổi bật của hành trình")</h2>
                    <span class="rounded-full bg-primary/10 px-3 py-1 text-xs font-bold text-primary" style="@ContentPresentationViewHelper.GetFieldTextStyle(highlights, "badgeText")">@highlights?.Fields.GetVisibleFieldValue("badgeText", "Tour bán tốt")</span>
                </div>
                @if (Model.Highlights != null && Model.Highlights.Any())
                {
                    <div class="mt-4 grid gap-3 sm:grid-cols-2">
                        @foreach (var item in Model.Highlights)
                        {
                            <div class="rounded-2xl bg-surface-muted-light px-4 py-3 text-sm dark:bg-surface-elevated-dark">@item</div>
                        }
                    </div>
                }
                else
                {
                    <p class="mt-4 text-sm text-slate-500 dark:text-slate-400">@highlights?.Fields.GetVisibleFieldValue("emptyStateText", "Tour này chưa có danh sách highlights hiển thị.")</p>
                }
            </section>

            <section class="rounded-3xl border border-border-light bg-surface-light p-6 shadow-sm dark:border-border-dark dark:bg-surface-dark @ContentPresentationViewHelper.GetSectionTextClass(overview)" style="@ContentPresentationViewHelper.GetSectionStyle(overview)">
                <p class="text-xs font-bold uppercase tracking-[0.25em] text-primary" style="@ContentPresentationViewHelper.GetFieldTextStyle(overview, "eyebrowText")">@overview?.Fields.GetVisibleFieldValue("eyebrowText", "Tổng quan")</p>
                <h2 class="mt-2 text-2xl font-black" style="@ContentPresentationViewHelper.GetFieldTextStyle(overview, "title")">@overview?.Fields.GetVisibleFieldValue("title", "Tổng quan hành trình")</h2>
                <div class="public-rich-text mt-4">@Html.Raw(RichTextContentFormatter.ToTrustedHtml(Model.Description))</div>
            </section>

            <section class="grid gap-6 sm:grid-cols-2 @ContentPresentationViewHelper.GetSectionTextClass(inclusions)" style="@ContentPresentationViewHelper.GetSectionStyle(inclusions)">
                <div class="rounded-3xl border border-border-light bg-surface-light p-6 shadow-sm dark:border-border-dark dark:bg-surface-dark">
                    <h2 class="text-xl font-black" style="@ContentPresentationViewHelper.GetFieldTextStyle(inclusions, "includedTitle")">@inclusions?.Fields.GetVisibleFieldValue("includedTitle", "Bao gồm")</h2>
                    @if (Model.GeneratedInclusions != null && Model.GeneratedInclusions.Any())
                    {
                        <ul class="mt-4 space-y-2 text-sm">@foreach (var item in Model.GeneratedInclusions) { <li>@item</li> }</ul>
                    }
                    else
                    {
                        <p class="mt-4 text-sm text-slate-500 dark:text-slate-400">@inclusions?.Fields.GetVisibleFieldValue("includedEmptyText", "Thông tin dịch vụ bao gồm đang được cập nhật.")</p>
                    }
                </div>
                <div class="rounded-3xl border border-border-light bg-surface-light p-6 shadow-sm dark:border-border-dark dark:bg-surface-dark">
                    <h2 class="text-xl font-black" style="@ContentPresentationViewHelper.GetFieldTextStyle(inclusions, "excludedTitle")">@inclusions?.Fields.GetVisibleFieldValue("excludedTitle", "Không bao gồm")</h2>
                    @if (Model.GeneratedExclusions != null && Model.GeneratedExclusions.Any())
                    {
                        <ul class="mt-4 space-y-2 text-sm">@foreach (var item in Model.GeneratedExclusions) { <li>@item</li> }</ul>
                    }
                    else
                    {
                        <p class="mt-4 text-sm text-slate-500 dark:text-slate-400">@inclusions?.Fields.GetVisibleFieldValue("excludedEmptyText", "Thông tin dịch vụ không bao gồm đang được cập nhật.")</p>
                    }
                </div>
            </section>

            <section class="rounded-3xl border border-border-light bg-surface-light p-6 shadow-sm dark:border-border-dark dark:bg-surface-dark @ContentPresentationViewHelper.GetSectionTextClass(schedule)" style="@ContentPresentationViewHelper.GetSectionStyle(schedule)">
                <p class="text-xs font-bold uppercase tracking-[0.25em] text-primary" style="@ContentPresentationViewHelper.GetFieldTextStyle(schedule, "eyebrowText")">@schedule?.Fields.GetVisibleFieldValue("eyebrowText", "Lịch trình")</p>
                <h2 class="mt-2 text-2xl font-black" style="@ContentPresentationViewHelper.GetFieldTextStyle(schedule, "title")">@schedule?.Fields.GetVisibleFieldValue("title", "Lịch trình chi tiết")</h2>
                @if (Model.Schedule != null && Model.Schedule.Any())
                {
                    <div class="mt-4 space-y-4">
                        @foreach (var item in Model.Schedule)
                        {
                            <article class="rounded-2xl border border-border-light p-4 dark:border-border-dark">
                                <strong>Ngày @item.Day - @item.Title</strong>
                                @if (!string.IsNullOrWhiteSpace(item.Description))
                                {
                                    <div class="public-rich-text mt-2">@Html.Raw(RichTextContentFormatter.ToTrustedHtml(item.Description))</div>
                                }
                            </article>
                        }
                    </div>
                }
                else
                {
                    <p class="mt-4 text-sm text-slate-500 dark:text-slate-400">@schedule?.Fields.GetVisibleFieldValue("emptyStateText", "Lịch trình chi tiết sẽ được cập nhật gần ngày khởi hành.")</p>
                }
            </section>

            <section class="grid gap-6 sm:grid-cols-2 @ContentPresentationViewHelper.GetSectionTextClass(policies)" style="@ContentPresentationViewHelper.GetSectionStyle(policies)">
                <div class="rounded-3xl border border-border-light bg-surface-light p-6 shadow-sm dark:border-border-dark dark:bg-surface-dark">
                    <p class="text-xs font-bold uppercase tracking-[0.25em] text-primary">@policies?.Fields.GetVisibleFieldValue("cancellationEyebrowText", "Cancellation")</p>
                    <h2 class="mt-2 text-2xl font-black">@policies?.Fields.GetVisibleFieldValue("cancellationTitle", "Chính sách hủy và hoàn")</h2>
                    <p class="mt-4 text-sm">@(string.IsNullOrWhiteSpace(Model.CancellationPolicy?.Summary) ? (policies?.Fields.GetVisibleFieldValue("cancellationSummaryFallback", "Liên hệ tư vấn để kiểm tra chính sách theo từng departure.")) : Model.CancellationPolicy.Summary)</p>
                </div>
                <div class="rounded-3xl border border-border-light bg-surface-light p-6 shadow-sm dark:border-border-dark dark:bg-surface-dark">
                    <p class="text-xs font-bold uppercase tracking-[0.25em] text-primary">@policies?.Fields.GetVisibleFieldValue("meetingPointEyebrowText", "Meeting point")</p>
                    <h2 class="mt-2 text-2xl font-black">@policies?.Fields.GetVisibleFieldValue("meetingPointTitle", "Điểm đón và hướng dẫn check-in")</h2>
                    <p class="mt-4 text-sm">@(string.IsNullOrWhiteSpace(Model.MeetingPoint) ? (policies?.Fields.GetVisibleFieldValue("meetingPointFallback", "HV Travel sẽ gửi meeting point chi tiết trong voucher xác nhận.")) : Model.MeetingPoint)</p>
                </div>
            </section>

            <section class="rounded-3xl border border-border-light bg-surface-light p-6 shadow-sm dark:border-border-dark dark:bg-surface-dark @ContentPresentationViewHelper.GetSectionTextClass(departuresSection)" style="@ContentPresentationViewHelper.GetSectionStyle(departuresSection)">
                <p class="text-xs font-bold uppercase tracking-[0.25em] text-primary" style="@ContentPresentationViewHelper.GetFieldTextStyle(departuresSection, "eyebrowText")">@departuresSection?.Fields.GetVisibleFieldValue("eyebrowText", "Price calendar")</p>
                <div class="mt-2 flex items-center justify-between gap-4">
                    <h2 class="text-2xl font-black" style="@ContentPresentationViewHelper.GetFieldTextStyle(departuresSection, "title")">@departuresSection?.Fields.GetVisibleFieldValue("title", "Lịch khởi hành và chỗ trống")</h2>
                    <span class="text-sm text-primary">@string.Format(departuresSection?.Fields.GetVisibleFieldValue("countFormat", "{0} đợt khởi hành") ?? "{0} đợt khởi hành", departures.Count)</span>
                </div>
                <div class="mt-4 space-y-3 text-sm">
                    @foreach (var departure in departures)
                    {
                        <div class="rounded-2xl border border-border-light px-4 py-3 dark:border-border-dark">
                            <div class="flex items-center justify-between gap-4">
                                <span>@departure.StartDate.ToString("dd/MM/yyyy")</span>
                                <span>@((departure.AdultPrice > 0m ? departure.AdultPrice : Model.Price?.Adult ?? 0m).ToString("N0"))₫</span>
                                <span>@ConfirmationText(departure.ConfirmationType)</span>
                                <span>@string.Format(departuresSection?.Fields.GetVisibleFieldValue("seatsRemainingFormat", "{0} còn lại") ?? "{0} còn lại", departure.RemainingCapacity)</span>
                            </div>
                        </div>
                    }
                </div>
            </section>
        </div>

        <aside class="space-y-6">
            <section class="rounded-3xl border border-border-light bg-surface-light p-6 shadow-sm dark:border-border-dark dark:bg-surface-dark @ContentPresentationViewHelper.GetSectionTextClass(bookingPanel)" style="@ContentPresentationViewHelper.GetSectionStyle(bookingPanel)">
                <p class="text-xs font-bold uppercase tracking-[0.25em] text-primary" style="@ContentPresentationViewHelper.GetFieldTextStyle(bookingPanel, "eyebrowText")">@bookingPanel?.Fields.GetVisibleFieldValue("eyebrowText", "Sẵn sàng đặt tour")</p>
                <p class="mt-3 text-4xl font-extrabold text-primary">@startingPrice.ToString("N0")₫</p>
                <p class="mt-2 text-sm text-slate-500 dark:text-slate-400" style="@ContentPresentationViewHelper.GetFieldTextStyle(bookingPanel, "priceHelperText")">@bookingPanel?.Fields.GetVisibleFieldValue("priceHelperText", "Mức giá tốt nhất theo departure hiện có.")</p>
                <div class="mt-4 space-y-2 text-sm">
                    <div class="flex justify-between"><span>@bookingPanel?.Fields.GetVisibleFieldValue("confirmationLabel", "Xác nhận")</span><span>@Model.ConfirmationType</span></div>
                    <div class="flex justify-between"><span>@bookingPanel?.Fields.GetVisibleFieldValue("ratingLabel", "Đánh giá")</span><span>@Model.Rating.ToString("0.0") / 5</span></div>
                    <div class="flex justify-between"><span>@bookingPanel?.Fields.GetVisibleFieldValue("departureLabel", "Departure gần nhất")</span><span>@(featuredDeparture?.StartDate.ToString("dd/MM") ?? "TBD")</span></div>
                </div>
                <a asp-controller="Booking" asp-action="Create" asp-route-tourId="@Model.Id" class="mt-6 inline-flex w-full items-center justify-center rounded-2xl bg-primary px-4 py-3 font-bold text-white" style="@ContentPresentationViewHelper.GetFieldTextStyle(bookingPanel, "bookNowText")">@bookingPanel?.Fields.GetVisibleFieldValue("bookNowText", "Đặt tour ngay")</a>
                <a href="tel:+842838229999" class="mt-3 inline-flex w-full items-center justify-center rounded-2xl border border-border-light px-4 py-3 font-bold dark:border-border-dark" style="@ContentPresentationViewHelper.GetFieldTextStyle(bookingPanel, "callAdvisorText")">@bookingPanel?.Fields.GetVisibleFieldValue("callAdvisorText", "Gọi tư vấn")</a>
            </section>

            <section class="rounded-3xl border border-border-light bg-surface-light p-6 shadow-sm dark:border-border-dark dark:bg-surface-dark @ContentPresentationViewHelper.GetSectionTextClass(relatedToursSection)" style="@ContentPresentationViewHelper.GetSectionStyle(relatedToursSection)">
                <h2 class="text-2xl font-black" style="@ContentPresentationViewHelper.GetFieldTextStyle(relatedToursSection, "title")">@relatedToursSection?.Fields.GetVisibleFieldValue("title", "Tour liên quan")</h2>
                @if (relatedTours.Any())
                {
                    <div class="mt-4 space-y-3">
                        @foreach (var tour in relatedTours)
                        {
                            var relatedPrice = tour.EffectiveDepartures.FirstOrDefault()?.AdultPrice ?? tour.Price?.Adult ?? 0m;
                            <a asp-controller="PublicTours" asp-action="Details" asp-route-id="@(string.IsNullOrWhiteSpace(tour.Slug) ? tour.Id : tour.Slug)" class="block rounded-2xl border border-border-light px-4 py-3 dark:border-border-dark">
                                <p class="font-bold">@tour.Name</p>
                                <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">@relatedPrice.ToString("N0")₫</p>
                            </a>
                        }
                    </div>
                }
                else
                {
                    <p class="mt-4 text-sm text-slate-500 dark:text-slate-400">@relatedToursSection?.Fields.GetVisibleFieldValue("emptyStateText", "Chưa có tour liên quan phù hợp để hiển thị.")</p>
                }
            </section>
        </aside>
    </div>
</section>
