                        <div class="flex gap-4 rounded-[1.5rem] border border-slate-200 bg-slate-50/80 p-4 dark:border-slate-800 dark:bg-slate-900/70"><span class="material-symbols-outlined text-primary">inventory_2</span><div><h3 class="text-base font-black text-slate-900 dark:text-white">@voucherTitle</h3><p class="mt-2 @Copy">@voucherDescription</p></div></div>
                    </div>
                </section>
