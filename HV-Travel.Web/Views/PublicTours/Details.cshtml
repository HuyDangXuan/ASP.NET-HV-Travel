                                        class="inline-flex size-11 items-center justify-center rounded-full border border-slate-200 bg-white text-slate-700 shadow-sm transition duration-200 hover:-translate-y-0.5 hover:border-primary/35 hover:text-primary disabled:pointer-events-none disabled:translate-y-0 disabled:opacity-35 dark:border-slate-800 dark:bg-slate-900/70 dark:text-slate-100 dark:hover:border-primary/40"
                                        data-tour-card-carousel-next
                                        aria-label="Nhóm tour liên quan tiếp theo">
                                    <span class="material-symbols-outlined text-[18px]">arrow_forward_ios</span>
                                </button>
                            </div>
                        </div>
                    </div>
                    @if (relatedTours.Any())
                    {
                        <div class="relative mt-7" data-tour-card-carousel data-tour-card-carousel-items-desktop="2" aria-label="Danh sách tour liên quan">
                            <div class="-mx-1 px-1 pb-4 sm:px-2 lg:px-3">
                                <div class="overflow-hidden cursor-grab rounded-[1.9rem] [touch-action:pan-y]" data-tour-card-carousel-viewport>
                                    <div class="flex gap-5 will-change-transform" data-tour-card-carousel-track>
                                        @foreach (var tour in relatedTours)
                                        {
                                            <div class="min-w-0 shrink-0 basis-full md:basis-[calc((100%-1.25rem)/2)] xl:basis-[calc((100%-2.5rem)/2.35)]" data-tour-card-carousel-item>
                                                @await Html.PartialAsync("_CarouselTourCard", tour)
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
