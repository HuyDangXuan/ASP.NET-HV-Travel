@model PublicTourDetailsPageViewModel
@{
    var tour = Model.Tour;
    var dossier = Model.Dossier;
    var relatedTours = Model.RelatedTours ?? Array.Empty<Tour>();
    var posterImage = dossier.GalleryImages.FirstOrDefault() ?? (tour.Images ?? new List<string>()).FirstOrDefault();
    var galleryImages = dossier.GalleryImages.Skip(1).ToList();
    var schedule = tour.Schedule ?? new List<ScheduleItem>();
    var inclusions = tour.GeneratedInclusions ?? new List<string>();
    var exclusions = tour.GeneratedExclusions ?? new List<string>();
    var departureLead = dossier.Departures.FirstOrDefault();
}

<section class="public-tour-dossier-shell">
    <div class="public-tour-dossier-hero">
        <div class="public-tour-dossier-hero-copy">
            <p class="public-tour-dossier-eyebrow">@dossier.Eyebrow</p>
            <h1>@dossier.Headline</h1>
            <p class="public-tour-dossier-lead">@dossier.Description</p>
            <div class="public-tour-dossier-booking-bar">
                <article>
                    <span>Giá từ</span>
                    <strong>@dossier.StartingPriceDisplay</strong>
                </article>
                <article>
                    <span>Khởi hành gần nhất</span>
                    <strong>@dossier.NextDepartureText</strong>
                </article>
                <article>
                    <span>Còn chỗ</span>
                    <strong>@(departureLead?.RemainingCapacityText ?? "Liên hệ tư vấn")</strong>
                </article>
            </div>
            <div class="public-tour-dossier-actions">
                <a asp-controller="Booking" asp-action="Create" asp-route-tourId="@tour.Id" asp-route-departureId="@dossier.PrimaryDepartureId" asp-route-startDate="@dossier.PrimaryDepartureStartDateValue" class="public-tour-dossier-primary">Đặt tour</a>
                <a asp-controller="Booking" asp-action="Consultation" class="public-tour-dossier-secondary">Nhờ tư vấn</a>
            </div>
        </div>
        <div class="public-tour-dossier-poster">
            @if (!string.IsNullOrWhiteSpace(posterImage))
            {
                <img src="@posterImage" alt="@tour.Name" />
            }
            else
            {
                <div class="public-tour-dossier-placeholder">Hình ảnh đang được cập nhật</div>
            }
            @if (galleryImages.Any())
            {
                <div class="public-tour-dossier-gallery">
                    @foreach (var image in galleryImages)
                    {
                        <img src="@image" alt="@tour.Name" />
                    }
                </div>
            }
        </div>
    </div>

    <div class="public-tour-dossier-strip">
        @foreach (var fact in dossier.Facts)
        {
            <article>
                <span>@fact.Label</span>
                <strong>@fact.Value</strong>
            </article>
        }
    </div>

    <div class="public-tour-dossier-grid">
        <main class="public-tour-dossier-main">
            <section class="public-tour-dossier-chapter">
                <p class="public-tour-dossier-chapter-eyebrow">Tổng quan</p>
                <h2>Tổng quan hành trình</h2>
                <div class="public-rich-text public-tour-dossier-content-list">@Html.Raw(RichTextContentFormatter.ToTrustedHtml(tour.Description))</div>
            </section>

            <section class="public-tour-dossier-chapter public-tour-dossier-departures">
                <p class="public-tour-dossier-chapter-eyebrow">Lịch khởi hành</p>
                <h2>Chọn ngày đi phù hợp</h2>
                <div class="public-tour-dossier-departure-grid">
                    @foreach (var departure in dossier.Departures)
                    {
                        var isLowCapacity = departure.LowAvailability;
                        var isConfirmed = departure.ConfirmationText?.Contains("Xác nhận tức thì") ?? false;

                        <article class="public-tour-dossier-departure-card">
                            <div class="public-tour-dossier-departure-card-badges public-journey-badge-group">
                                <span class="public-badge @(isConfirmed ? "is-success" : "is-info")">@departure.ConfirmationText</span>
                                <span class="public-badge @(isLowCapacity ? "is-warning" : "is-cyan")">@departure.RemainingCapacityText</span>
                            </div>

                            <div class="public-tour-dossier-departure-card-header">
                                <strong class="public-tour-dossier-departure-card-date">@departure.StartDateText</strong>
                            </div>

                            <div class="public-tour-dossier-departure-card-footer">
                                <div class="public-tour-dossier-departure-card-price">
                                    <span>Giá tour từ</span>
                                    <strong>@departure.PriceText</strong>
                                </div>
                                <a asp-controller="Booking" asp-action="Create" asp-route-tourId="@tour.Id" asp-route-departureId="@departure.Id" asp-route-startDate="@departure.StartDateValue" class="public-tour-dossier-departure-card-btn">
                                    <span>Bắt đầu đặt</span>
                                    <i class="fa-solid fa-chevron-right"></i>
                                </a>
                            </div>
                        </article>
                    }
                </div>
            </section>

            <section class="public-tour-dossier-chapter">
                <p class="public-tour-dossier-chapter-eyebrow">Lịch trình</p>
                <h2>Lịch trình theo chặng</h2>
                @if (schedule.Any())
                {
                    <div class="public-tour-dossier-itinerary-timeline">
                        @foreach (var item in schedule)
                        {
                            <article class="public-tour-dossier-itinerary-item">
                                <div class="public-tour-itinerary-marker"></div>
                                <div class="public-tour-itinerary-content">
                                    <div class="public-tour-itinerary-header">
                                        <span class="public-badge is-day">Ngày @item.Day</span>
                                        <h3>@item.Title</h3>
                                    </div>
                                    <div class="public-rich-text public-tour-dossier-content-list">@Html.Raw(RichTextContentFormatter.ToTrustedHtml(item.Description))</div>
                                </div>
                            </article>
                        }
                    </div>
                }
                else
                {
                    <p class="public-tour-dossier-note">Lịch trình chi tiết sẽ được cập nhật gần ngày khởi hành.</p>
                }
            </section>

            <section class="public-tour-dossier-chapter public-tour-dossier-columns">
                <article>
                    <p class="public-tour-dossier-chapter-eyebrow">Bao gồm</p>
                    <h2>Dịch vụ bao gồm</h2>
                    @if (inclusions.Any())
                    {
                        <ul class="public-tour-dossier-detail-list">
                            @foreach (var item in inclusions)
                            {
                                <li>@item</li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p class="public-tour-dossier-note">Thông tin bao gồm đang được cập nhật.</p>
                    }
                </article>
                <article>
                    <p class="public-tour-dossier-chapter-eyebrow">Không bao gồm</p>
                    <h2>Chi phí không bao gồm</h2>
                    @if (exclusions.Any())
                    {
                        <ul class="public-tour-dossier-detail-list">
                            @foreach (var item in exclusions)
                            {
                                <li>@item</li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p class="public-tour-dossier-note">Thông tin không bao gồm đang được cập nhật.</p>
                    }
                </article>
            </section>
        </main>

        <aside class="public-tour-dossier-rail">
            <section class="public-tour-dossier-rail-card">
                <p class="public-tour-dossier-chapter-eyebrow">Giữ chỗ</p>
                <h2>@dossier.StartingPriceDisplay</h2>
                <dl class="public-tour-dossier-detail-list public-tour-dossier-detail-list--dense">
                    <div><dt>Điểm đến</dt><dd>@dossier.DestinationText</dd></div>
                    <div><dt>Thời lượng</dt><dd>@dossier.DurationText</dd></div>
                    <div><dt>Khởi hành gần nhất</dt><dd>@dossier.NextDepartureText</dd></div>
                    <div><dt>Điểm hẹn</dt><dd>@dossier.MeetingPointText</dd></div>
                </dl>
                <a asp-controller="Booking" asp-action="Create" asp-route-tourId="@tour.Id" asp-route-departureId="@dossier.PrimaryDepartureId" asp-route-startDate="@dossier.PrimaryDepartureStartDateValue" class="public-tour-dossier-primary">Giữ chỗ ngay</a>
                <a asp-controller="Booking" asp-action="Consultation" class="public-tour-dossier-secondary">Trao đổi với tư vấn viên</a>
            </section>

            @if (relatedTours.Any())
            {
                <section class="public-tour-dossier-rail-card">
                    <p class="public-tour-dossier-chapter-eyebrow">Gợi ý thêm</p>
                    <h2>Gần với hành trình này</h2>
                    <div class="public-tour-dossier-related-list">
                        @foreach (var relatedTour in relatedTours)
                        {
                            <a asp-controller="PublicTours" asp-action="Details" asp-route-id="@(string.IsNullOrWhiteSpace(relatedTour.Slug) ? relatedTour.Id : relatedTour.Slug)">
                                <strong>@relatedTour.Name</strong>
                                <span>@((relatedTour.EffectiveDepartures.FirstOrDefault()?.AdultPrice ?? relatedTour.Price?.Adult ?? 0m).ToString("N0"))₫</span>
                            </a>
                        }
                    </div>
                </section>
            }
        </aside>
    </div>
</section>
