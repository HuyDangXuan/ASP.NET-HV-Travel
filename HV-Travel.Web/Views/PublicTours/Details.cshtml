                                        }
                                    </div>
                                </article>
                            }
                        </div>
                    </section>
                }

                <section class="grid gap-6 lg:grid-cols-2">
                    <article class="@($"{Card} {ContentPresentationViewHelper.GetSectionBackgroundClass(inclusions)}")" style="@ContentPresentationViewHelper.GetSectionStyle(inclusions)"><h2 class="@Heading">@inclusions?.Fields.GetVisibleFieldValue("includedTitle", "Bao gồm")</h2>@if (Model.GeneratedInclusions != null && Model.GeneratedInclusions.Any()) { <ul class="mt-6 space-y-3 @Copy">@foreach (var item in Model.GeneratedInclusions) { <li class="flex gap-3"><span class="material-symbols-outlined mt-1 text-primary text-[18px]">check_circle</span><span>@item</span></li> }</ul> } else { <p class="mt-6 text-sm leading-7 text-slate-500 dark:text-slate-400">@inclusions?.Fields.GetVisibleFieldValue("includedEmptyText", "Dịch vụ bao gồm sẽ được cập nhật sớm.")</p> }</article>
                    <article class="@($"{Card} {ContentPresentationViewHelper.GetSectionBackgroundClass(inclusions)}")" style="@ContentPresentationViewHelper.GetSectionStyle(inclusions)"><h2 class="@Heading">@inclusions?.Fields.GetVisibleFieldValue("excludedTitle", "Không bao gồm")</h2>@if (Model.GeneratedExclusions != null && Model.GeneratedExclusions.Any()) { <ul class="mt-6 space-y-3 @Copy">@foreach (var item in Model.GeneratedExclusions) { <li class="flex gap-3"><span class="material-symbols-outlined mt-1 text-rose-500 text-[18px]">remove_circle</span><span>@item</span></li> }</ul> } else { <p class="mt-6 text-sm leading-7 text-slate-500 dark:text-slate-400">@inclusions?.Fields.GetVisibleFieldValue("excludedEmptyText", "Dịch vụ không bao gồm sẽ được cập nhật sớm.")</p> }</article>
                    <article class="@($"{Card} {ContentPresentationViewHelper.GetSectionBackgroundClass(policies)}")" style="@ContentPresentationViewHelper.GetSectionStyle(policies)"><p class="@Eyebrow">@policies?.Fields.GetVisibleFieldValue("cancellationEyebrowText", "Hủy tour")</p><h2 class="@Heading">@policies?.Fields.GetVisibleFieldValue("cancellationTitle", "Chính sách hủy tour")</h2><p class="mt-6 @Copy">@(string.IsNullOrWhiteSpace(Model.CancellationPolicy?.Summary) ? policies?.Fields.GetVisibleFieldValue("cancellationSummaryFallback", "Liên hệ đội tư vấn để xác nhận chính sách hủy cho từng lịch khởi hành.") : Model.CancellationPolicy.Summary)</p></article>
                    <article class="@($"{Card} {ContentPresentationViewHelper.GetSectionBackgroundClass(policies)}")" style="@ContentPresentationViewHelper.GetSectionStyle(policies)"><p class="@Eyebrow">@policies?.Fields.GetVisibleFieldValue("meetingPointEyebrowText", "Điểm hẹn")</p><h2 class="@Heading">@policies?.Fields.GetVisibleFieldValue("meetingPointTitle", "Điểm hẹn và check-in")</h2><p class="mt-6 @Copy">@(string.IsNullOrWhiteSpace(Model.MeetingPoint) ? policies?.Fields.GetVisibleFieldValue("meetingPointFallback", "HV Travel sẽ gửi điểm hẹn chi tiết trong voucher xác nhận.") : Model.MeetingPoint)</p></article>
