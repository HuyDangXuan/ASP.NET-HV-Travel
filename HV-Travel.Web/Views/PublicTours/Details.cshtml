                                <span class="inline-flex items-center rounded-full bg-slate-100 px-3 py-1 text-[11px] font-black uppercase tracking-[0.2em] text-slate-600 dark:bg-slate-900 dark:text-slate-300">@string.Format(routing?.Fields.GetVisibleFieldValue("stopCountFormat", "{0} điểm dừng") ?? "{0} điểm dừng", routeOverview.StopCount)</span>
                                <span class="inline-flex items-center rounded-full bg-slate-100 px-3 py-1 text-[11px] font-black uppercase tracking-[0.2em] text-slate-600 dark:bg-slate-900 dark:text-slate-300">@string.Format(routing?.Fields.GetVisibleFieldValue("visitMinutesFormat", "{0} phút tham quan") ?? "{0} phút tham quan", routeOverview.TotalVisitMinutes)</span>
                                <span class="inline-flex items-center rounded-full bg-slate-100 px-3 py-1 text-[11px] font-black uppercase tracking-[0.2em] text-slate-600 dark:bg-slate-900 dark:text-slate-300">@string.Format(routing?.Fields.GetVisibleFieldValue("travelMinutesFormat", "{0} phút di chuyển") ?? "{0} phút di chuyển", routeOverview.TotalTravelMinutes)</span>
                                <span class="inline-flex items-center rounded-full bg-slate-100 px-3 py-1 text-[11px] font-black uppercase tracking-[0.2em] text-slate-600 dark:bg-slate-900 dark:text-slate-300">@string.Format(routing?.Fields.GetVisibleFieldValue("journeyMinutesFormat", "{0} phút hành trình") ?? "{0} phút hành trình", routeOverview.TotalJourneyMinutes)</span>
                                <span class="inline-flex items-center rounded-full bg-slate-100 px-3 py-1 text-[11px] font-black uppercase tracking-[0.2em] text-slate-600 dark:bg-slate-900 dark:text-slate-300">@string.Format(routing?.Fields.GetVisibleFieldValue("distanceFormat", "{0} km") ?? "{0} km", routeOverview.TotalDistanceKm.ToString("0.0"))</span>
                            </div>
                        </div>
                        <div class="mt-6 space-y-5">
                            @foreach (var routeDay in routeOverview.Days)
