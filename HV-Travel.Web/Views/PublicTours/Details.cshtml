                </section>
            </div>

            <aside class="space-y-6 lg:sticky lg:top-24">
                <section class="@($"{Card} {ContentPresentationViewHelper.GetSectionTextClass(bookingPanel)} {ContentPresentationViewHelper.GetSectionBackgroundClass(bookingPanel)}")" style="@ContentPresentationViewHelper.GetSectionStyle(bookingPanel)">
                    <div><p class="@Eyebrow">@bookingPanel?.Fields.GetVisibleFieldValue("eyebrowText", "Sẵn sàng đặt tour")</p><div class="mt-3 flex items-end gap-2"><p class="text-4xl font-black tracking-tight text-slate-900 dark:text-white" data-detail-price-starting>@startingPrice.ToString("N0")</p><span class="pb-1 text-sm font-bold uppercase tracking-[0.2em] text-slate-400 dark:text-slate-500">VND</span></div></div>
                    <p class="mt-4 text-sm leading-7 text-slate-500 dark:text-slate-400">@bookingPanel?.Fields.GetVisibleFieldValue("priceHelperText", "Mức giá tốt nhất theo lịch khởi hành hiện có.")</p>
