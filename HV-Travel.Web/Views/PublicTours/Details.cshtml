                <section class="@($"{Card} overflow-hidden {ContentPresentationViewHelper.GetSectionTextClass(relatedToursSection)} {ContentPresentationViewHelper.GetSectionBackgroundClass(relatedToursSection)}")" style="@ContentPresentationViewHelper.GetSectionStyle(relatedToursSection)">
