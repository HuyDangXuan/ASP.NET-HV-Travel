@inject IPublicContentService ContentService
@using System.Text.Json
@using HVTravel.Web.Models
@using HVTravel.Web.Services
@model Tour
@{
    var sections = await ContentService.GetPageSectionsAsync("publicTourDetails");
    var hero = sections.GetSection("hero");
    var highlights = sections.GetSection("highlights");
    var overview = sections.GetSection("overview");
    var inclusions = sections.GetSection("inclusions");
    var schedule = sections.GetSection("schedule");
    var routing = sections.GetSection("routing");
    var policies = sections.GetSection("policies");
    var departuresSection = sections.GetSection("departures");
    var bookingPanel = sections.GetSection("bookingPanel");
    var relatedToursSection = sections.GetSection("relatedTours");
    var relatedTours = ViewData["RelatedTours"] as List<Tour> ?? new List<Tour>();
    var routeOverview = ViewData["RouteOverview"] as PublicTourRouteOverview ?? PublicTourRouteOverview.Empty;
    var routeStyle = ViewData["CurrentRouteStyle"]?.ToString();
    var currentRouteStyle = routeStyle;
    var relatedToursRouteStyleText = ViewData["RelatedToursRouteStyleText"]?.ToString();
    var departures = ((Model.Departures != null && Model.Departures.Any()) ? Model.Departures : (Model.EffectiveDepartures ?? Array.Empty<TourDeparture>())).OrderBy(item => item.StartDate).ToList();
    var featuredDeparture = departures.FirstOrDefault();
    var startingPrice = departures.Any() ? departures.Min(item => item.AdultPrice > 0m ? item.AdultPrice : Model.Price?.Adult ?? 0m) : Model.Price?.Adult ?? 0m;
    var headlineDescription = RichTextContentFormatter.ToPlainTextSummary(Model.ShortDescription ?? Model.Description, 180);
    var structuredData = JsonSerializer.Serialize(new Dictionary<string, object?> { ["@context"] = "https://schema.org", ["@type"] = "Product", ["name"] = Model.Name, ["description"] = headlineDescription, ["image"] = Model.Images });
    var galleryImages = (Model.Images ?? new List<string>()).Where(image => !string.IsNullOrWhiteSpace(image)).ToList();
    var heroImage = galleryImages.FirstOrDefault() ?? ViewData["OpenGraphImage"]?.ToString() ?? string.Empty;
    var gallerySlots = new[] { galleryImages.ElementAtOrDefault(0) ?? heroImage, galleryImages.ElementAtOrDefault(1) ?? heroImage, galleryImages.ElementAtOrDefault(2) ?? heroImage, galleryImages.ElementAtOrDefault(3) ?? heroImage };
    var locationParts = new[] { Model.Destination?.City, Model.Destination?.Country }.Where(value => !string.IsNullOrWhiteSpace(value)).Distinct(StringComparer.OrdinalIgnoreCase).ToList();
    var locationLabel = locationParts.Any() ? string.Join(", ", locationParts) : hero?.Fields.GetVisibleFieldValue("locationFallback", "Vietnam") ?? "Vietnam";
    var plannerDetailId = PublicTourIdentifierHelper.GetDetailIdentifier(Model);
    var plannerDetailUrl = Url.Action("Details", "PublicTours", new { id = plannerDetailId, routeStyle = currentRouteStyle }) ?? "#";
    var scheduleItems = (Model.Schedule ?? new List<ScheduleItem>()).OrderBy(entry => entry.Day).ToList();
    var durationLabel = Model.Duration?.Text ?? hero?.Fields.GetVisibleFieldValue("durationFallback", "Contact for itinerary") ?? "Contact for itinerary";
    var reviewLabel = string.Format(hero?.Fields.GetVisibleFieldValue("reviewFormat", "{0} reviews") ?? "{0} reviews", Model.ReviewCount);
    var selectedDeparture = featuredDeparture;
    var adultPrice = selectedDeparture?.AdultPrice > 0m ? selectedDeparture.AdultPrice : Model.Price?.Adult ?? 0m;
    var childPrice = selectedDeparture?.ChildPrice > 0m ? selectedDeparture.ChildPrice : Model.Price?.Child ?? 0m;
    var infantPrice = selectedDeparture?.InfantPrice > 0m ? selectedDeparture.InfantPrice : Model.Price?.Infant ?? 0m;
    var supportTitle = bookingPanel?.Fields.GetVisibleFieldValue("supportTitle", "Support after booking") ?? "Support after booking";
    var supportDescription = bookingPanel?.Fields.GetVisibleFieldValue("supportDescription", "Customer portal, payment timeline, and booking lookup stay available after checkout.") ?? "Customer portal, payment timeline, and booking lookup stay available after checkout.";
    var voucherTitle = bookingPanel?.Fields.GetVisibleFieldValue("voucherTitle", "Voucher and invoice") ?? "Voucher and invoice";
    var voucherDescription = bookingPanel?.Fields.GetVisibleFieldValue("voucherDescription", "After payment, the booking can extend into voucher, invoice, and fulfillment status updates.") ?? "After payment, the booking can extend into voucher, invoice, and fulfillment status updates.";
    string ConfirmationText(string? value) => string.Equals(value, "Instant", StringComparison.OrdinalIgnoreCase) ? hero?.Fields.GetVisibleFieldValue("instantConfirmationLabel", "Instant confirmation") ?? "Instant confirmation" : hero?.Fields.GetVisibleFieldValue("requestConfirmationLabel", "On-request confirmation") ?? "On-request confirmation";
    decimal DepartureAdultPrice(TourDeparture? departure) => departure?.AdultPrice > 0m ? departure.AdultPrice : Model.Price?.Adult ?? 0m;
    decimal DepartureChildPrice(TourDeparture? departure) => departure?.ChildPrice > 0m ? departure.ChildPrice : Model.Price?.Child ?? 0m;
    decimal DepartureInfantPrice(TourDeparture? departure) => departure?.InfantPrice > 0m ? departure.InfantPrice : Model.Price?.Infant ?? 0m;
    string SeatsRemainingText(TourDeparture? departure) => string.Format(departuresSection?.Fields.GetVisibleFieldValue("seatsRemainingFormat", "{0} seats left") ?? "{0} seats left", departure?.RemainingCapacity ?? 0);
    var confirmationLabel = ConfirmationText(selectedDeparture?.ConfirmationType ?? Model.ConfirmationType);
    var seatsLabel = SeatsRemainingText(selectedDeparture);
    var selectedDepartureText = selectedDeparture?.StartDate.ToString("dd/MM/yyyy") ?? "TBD";
    var richTextClass = ContentPresentationViewHelper.GetRichTextClass();
    const string Card = "rounded-[2rem] border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-slate-950/80 sm:p-7";
    const string Eyebrow = "text-[11px] font-black uppercase tracking-[0.28em] text-primary";
    const string Heading = "text-2xl font-black tracking-tight text-slate-900 dark:text-white";
    const string Copy = "text-sm leading-7 text-slate-600 dark:text-slate-300";
    string DayPartText(string? value) => value switch
    {
        "early_morning" => "Early morning",
        "morning_peak" => "Morning peak",
        "late_morning" => "Late morning",
        "midday" => "Midday",
        "afternoon" => "Afternoon",
        "evening_peak" => "Evening peak",
        _ => "Night"
    };
    string CongestionText(string? value) => value switch
    {
        "high" => "High",
        "moderate" => "Moderate",
        _ => "Low"
    };
}

<script type="application/ld+json">@Html.Raw(structuredData)</script>

@if (hero?.IsEnabled != false)
{
    <section class="relative overflow-hidden bg-[radial-gradient(circle_at_top_left,rgba(59,130,246,0.24),transparent_36%),linear-gradient(135deg,#020617_0%,#0f172a_48%,#1e3a8a_100%)] py-16 sm:py-20" style="@ContentPresentationViewHelper.GetSectionStyle(hero)">
        <div class="absolute inset-0 opacity-20">
            <div class="absolute left-20 top-20 h-72 w-72 rounded-full bg-primary/30 blur-3xl"></div>
            <div class="absolute bottom-0 right-10 h-80 w-80 rounded-full bg-cyan-400/20 blur-3xl"></div>
        </div>
        <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 @ContentPresentationViewHelper.GetSectionTextClass(hero)">
            <div class="max-w-4xl space-y-6" data-animate="fade-up">
                <div class="flex flex-wrap gap-2">
                    <span class="inline-flex items-center rounded-full border border-white/10 bg-white/10 px-3 py-1 text-[11px] font-black uppercase tracking-[0.22em] text-white/90 backdrop-blur">@ConfirmationText(Model.ConfirmationType)</span>
                    @if (Model.CancellationPolicy?.IsFreeCancellation == true) { <span class="inline-flex items-center rounded-full bg-emerald-500 px-3 py-1 text-[11px] font-black uppercase tracking-[0.22em] text-white">@(hero?.Fields.GetVisibleFieldValue("freeCancellationLabel", "Free cancellation"))</span> }
                    @if (featuredDeparture?.RemainingCapacity is > 0 and <= 5) { <span class="inline-flex items-center rounded-full bg-amber-400 px-3 py-1 text-[11px] font-black uppercase tracking-[0.22em] text-slate-950">@(hero?.Fields.GetVisibleFieldValue("lowAvailabilityLabel", "Limited seats"))</span> }
                    @if (!string.IsNullOrWhiteSpace(Model.Status)) { <span class="inline-flex items-center rounded-full bg-slate-900/70 px-3 py-1 text-[11px] font-black uppercase tracking-[0.22em] text-white backdrop-blur">@Model.Status</span> }
                </div>
                @if (!string.IsNullOrWhiteSpace(Model.Code)) { <p class="text-[11px] font-black uppercase tracking-[0.3em] text-white/60">@Model.Code</p> }
                <h1 class="text-4xl font-black tracking-tight text-white sm:text-5xl lg:text-6xl" style="@ContentPresentationViewHelper.GetFieldTextStyle(hero, "title")">@Model.Name</h1>
                <p class="max-w-3xl text-base leading-relaxed text-slate-300 sm:text-lg" style="@ContentPresentationViewHelper.GetFieldTextStyle(hero, "description")">@headlineDescription</p>
                <button type="button"
                        class="inline-flex items-center justify-center gap-2 rounded-2xl border border-cyan-200/30 bg-cyan-400/15 px-5 py-3 text-sm font-black text-cyan-50 shadow-lg shadow-cyan-950/20 backdrop-blur transition hover:-translate-y-0.5 hover:bg-cyan-400/25"
                        data-tour-planner-toggle
                        data-tour-id="@Model.Id"
                        data-tour-name="@Model.Name"
                        data-tour-price="@startingPrice"
                        data-tour-location="@locationLabel"
                        data-tour-url="@plannerDetailUrl"
                        data-tour-image="@heroImage"
                        aria-pressed="false">
                    <span class="material-symbols-outlined text-[18px]" data-tour-planner-icon>playlist_add</span>
                    <span>Add to planner</span>
                </button>
                <div class="flex flex-wrap gap-3 text-sm text-white/80">
                    <span class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/10 px-4 py-2 backdrop-blur"><span class="material-symbols-outlined text-[18px]">location_on</span><span>@locationLabel</span></span>
                    <span class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/10 px-4 py-2 backdrop-blur"><span class="material-symbols-outlined text-[18px]">schedule</span><span>@durationLabel</span></span>
                    <span class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/10 px-4 py-2 backdrop-blur"><span class="material-symbols-outlined text-[18px]">star</span><span>@reviewLabel</span></span>
                </div>
            </div>
        </div>
    </section>
}

<section class="bg-background-light py-4 dark:bg-background-dark">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4" data-animate="fade-up">
            @for (var index = 0; index < gallerySlots.Length; index++)
            {
                var image = gallerySlots[index];
                var figureClass = index == 0 ? "overflow-hidden rounded-[2rem] bg-slate-100 shadow-sm dark:bg-slate-900 sm:col-span-2 lg:col-span-2 lg:row-span-2" : index == 3 ? "relative overflow-hidden rounded-[1.75rem] bg-slate-100 shadow-sm dark:bg-slate-900 sm:col-span-2 lg:col-span-2" : "overflow-hidden rounded-[1.75rem] bg-slate-100 shadow-sm dark:bg-slate-900";
                var imageClass = index == 0 ? "h-full min-h-[320px] w-full object-cover sm:min-h-[420px]" : index == 3 ? "h-full min-h-[220px] w-full object-cover" : "h-full min-h-[190px] w-full object-cover";
                <figure class="@figureClass">
                    @if (!string.IsNullOrWhiteSpace(image))
                    {
                        <img src="@image" alt="@($"{Model.Name} gallery {index + 1}")" class="@imageClass" />
                    }
                    else
                    {
                        <div class="flex h-full min-h-[190px] items-center justify-center bg-gradient-to-br from-slate-200 to-white text-slate-400 dark:from-slate-900 dark:to-slate-950 dark:text-slate-600"><span class="material-symbols-outlined text-5xl">image</span></div>
                    }
                    @if (index == 3 && galleryImages.Count > 4)
                    {
                        <div class="absolute inset-0 flex items-end bg-gradient-to-t from-slate-950/70 via-slate-950/10 to-transparent p-5 text-white"><span class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/10 px-4 py-2 text-sm font-black backdrop-blur"><span class="material-symbols-outlined text-[18px]">grid_view</span><span>View @galleryImages.Count photos</span></span></div>
                    }
                </figure>
            }
        </div>
    </div>
</section>

<section class="bg-background-light pb-16 pt-4 dark:bg-background-dark">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid items-start gap-8 lg:grid-cols-[minmax(0,1fr)_360px]">
            <div class="space-y-8">
                <section class="@($"{Card} {ContentPresentationViewHelper.GetSectionTextClass(overview)} {ContentPresentationViewHelper.GetSectionBackgroundClass(overview)}")" style="@ContentPresentationViewHelper.GetSectionStyle(overview)">
                    <p class="@Eyebrow">@overview?.Fields.GetVisibleFieldValue("eyebrowText", "Overview")</p>
                    <h2 class="@Heading">@overview?.Fields.GetVisibleFieldValue("title", "Tour overview")</h2>
                    <div class="@($"{richTextClass} mt-6 max-w-none")">@Html.Raw(RichTextContentFormatter.ToTrustedHtml(Model.Description))</div>
                </section>

                <section class="@($"{Card} {ContentPresentationViewHelper.GetSectionTextClass(highlights)} {ContentPresentationViewHelper.GetSectionBackgroundClass(highlights)}")" style="@ContentPresentationViewHelper.GetSectionStyle(highlights)">
                    <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
                        <div><p class="@Eyebrow">@highlights?.Fields.GetVisibleFieldValue("eyebrowText", "Highlights")</p><h2 class="@Heading">@highlights?.Fields.GetVisibleFieldValue("title", "Journey highlights")</h2></div>
                        <span class="inline-flex items-center rounded-full bg-slate-100 px-3 py-1 text-[11px] font-black uppercase tracking-[0.2em] text-slate-600 dark:bg-slate-900 dark:text-slate-300">@highlights?.Fields.GetVisibleFieldValue("badgeText", "Editor pick")</span>
                    </div>
                    @if (Model.Highlights != null && Model.Highlights.Any())
                    {
                        <div class="mt-6 grid gap-4 sm:grid-cols-2">
                            @foreach (var item in Model.Highlights) { <article class="flex gap-3 rounded-[1.5rem] border border-slate-200 bg-slate-50/80 p-4 dark:border-slate-800 dark:bg-slate-900/70"><span class="material-symbols-outlined mt-1 text-primary">auto_awesome</span><p class="@Copy">@item</p></article> }
                        </div>
                    }
                    else { <p class="mt-6 text-sm leading-7 text-slate-500 dark:text-slate-400">@highlights?.Fields.GetVisibleFieldValue("emptyStateText", "Highlights will be updated soon.")</p> }
                </section>

                <section class="@($"{Card} {ContentPresentationViewHelper.GetSectionTextClass(schedule)} {ContentPresentationViewHelper.GetSectionBackgroundClass(schedule)}")" style="@ContentPresentationViewHelper.GetSectionStyle(schedule)">
                    <div class="relative overflow-hidden rounded-[1.75rem] border border-sky-100/80 bg-[radial-gradient(circle_at_top_left,rgba(56,189,248,0.18),transparent_28%),linear-gradient(135deg,rgba(248,250,252,0.98)_0%,rgba(239,246,255,0.96)_48%,rgba(224,242,254,0.92)_100%)] px-5 py-6 shadow-[0_32px_90px_-54px_rgba(14,116,144,0.55)] dark:border-sky-900/30 dark:bg-[radial-gradient(circle_at_top_left,rgba(34,211,238,0.14),transparent_28%),linear-gradient(135deg,rgba(2,6,23,0.92)_0%,rgba(15,23,42,0.9)_48%,rgba(12,74,110,0.76)_100%)] sm:px-6 sm:py-7">
                        <div class="pointer-events-none absolute inset-y-0 right-0 w-1/3 bg-[radial-gradient(circle_at_top_right,rgba(14,165,233,0.14),transparent_62%)]"></div>
                        <div class="relative z-10 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
                            <div class="max-w-2xl">
                                <p class="@Eyebrow">@schedule?.Fields.GetVisibleFieldValue("eyebrowText", "Itinerary")</p>
                                <h2 class="@Heading">@schedule?.Fields.GetVisibleFieldValue("title", "Detailed itinerary")</h2>
                                <p class="mt-3 max-w-xl text-sm leading-7 text-slate-600 dark:text-slate-300">@schedule?.Fields.GetVisibleFieldValue("description", "Theo dõi hành trình theo từng ngày với các điểm dừng, trải nghiệm và nhịp di chuyển chính của tour.")</p>
                            </div>
                            @if (scheduleItems.Any())
                            {
                                <div class="inline-flex items-center gap-3 self-start rounded-full border border-sky-200/80 bg-white/80 px-4 py-2 text-xs font-black uppercase tracking-[0.24em] text-sky-700 shadow-sm shadow-sky-100/70 backdrop-blur dark:border-sky-800/40 dark:bg-slate-950/40 dark:text-sky-200">
                                    <span class="material-symbols-outlined text-[18px]">route</span>
                                    <span>@string.Format(schedule?.Fields.GetVisibleFieldValue("countFormat", "{0} days") ?? "{0} days", scheduleItems.Count)</span>
                                </div>
                            }
                        </div>
                    </div>
                    @if (scheduleItems.Any())
                    {
                        <div class="mt-8 space-y-6 sm:space-y-7">
                            @for (var index = 0; index < scheduleItems.Count; index++)
                            {
                                var item = scheduleItems[index];
                                var isLastItem = index == scheduleItems.Count - 1;
                                <article class="group relative grid gap-4 sm:grid-cols-[110px_minmax(0,1fr)] sm:gap-6">
                                    <div class="relative flex items-start gap-4 sm:block">
                                        <div class="relative z-10 inline-flex h-20 w-20 shrink-0 flex-col items-center justify-center rounded-[1.85rem] border border-sky-200/80 bg-gradient-to-br from-sky-500 via-cyan-500 to-blue-600 text-white shadow-[0_20px_55px_-24px_rgba(14,165,233,0.75)] transition-transform duration-300 group-hover:-translate-y-1 dark:border-sky-400/20 dark:from-sky-500 dark:via-cyan-500 dark:to-blue-700 sm:h-24 sm:w-24">
                                            <span class="text-[10px] font-black uppercase tracking-[0.28em] text-white/70">Ngày</span>
                                            <span class="mt-1 text-[1.85rem] font-black leading-none sm:text-[2.1rem]">@item.Day.ToString("00")</span>
                                        </div>
                                        <div class="relative flex-1 pt-2 sm:absolute sm:left-1/2 sm:top-[5.9rem] sm:h-[calc(100%+1.75rem)] sm:-translate-x-1/2 sm:pt-0">
                                            <span class="absolute left-10 top-0 h-4 w-px bg-transparent sm:left-1/2 sm:h-6 sm:-translate-x-1/2"></span>
                                            <span class="absolute left-[2.13rem] top-0 inline-flex h-5 w-5 items-center justify-center rounded-full border border-sky-200 bg-white shadow-md shadow-sky-100 dark:border-sky-800 dark:bg-slate-950 sm:left-1/2 sm:-translate-x-1/2">
                                                <span class="h-2.5 w-2.5 rounded-full bg-gradient-to-br from-sky-500 to-blue-600"></span>
                                            </span>
                                            @if (!isLastItem)
                                            {
                                                <span class="absolute left-[2.35rem] top-5 bottom-[-1.75rem] w-px bg-gradient-to-b from-sky-300 via-cyan-200 to-transparent dark:from-sky-700 dark:via-cyan-900/70 sm:left-1/2 sm:-translate-x-1/2"></span>
                                            }
                                        </div>
                                    </div>
                                    <div class="relative overflow-hidden rounded-[1.75rem] border border-slate-200/90 bg-white/92 p-5 shadow-[0_22px_60px_-40px_rgba(15,23,42,0.45)] transition-all duration-300 group-hover:-translate-y-0.5 group-hover:border-sky-200 group-hover:shadow-[0_28px_70px_-38px_rgba(14,165,233,0.35)] dark:border-slate-800 dark:bg-slate-950/78 dark:group-hover:border-sky-800/60 sm:p-6">
                                        <div class="pointer-events-none absolute inset-y-0 right-0 w-28 bg-[radial-gradient(circle_at_top_right,rgba(56,189,248,0.12),transparent_68%)]"></div>
                                        <div class="relative z-10">
                                            <div class="flex flex-col gap-3 border-b border-slate-200/80 pb-4 dark:border-slate-800 sm:flex-row sm:items-center sm:justify-between">
                                                <div>
                                                    <p class="text-[11px] font-black uppercase tracking-[0.24em] text-sky-600 dark:text-sky-300">Chặng @item.Day.ToString("00")</p>
                                                    <h3 class="mt-2 text-xl font-black tracking-tight text-slate-900 dark:text-white">@item.Title</h3>
                                                </div>
                                                <span class="inline-flex items-center gap-2 self-start rounded-full border border-sky-100 bg-sky-50/90 px-3 py-1.5 text-[11px] font-black uppercase tracking-[0.18em] text-sky-700 dark:border-sky-900/40 dark:bg-sky-950/30 dark:text-sky-200">
                                                    <span class="material-symbols-outlined text-[16px]">travel_explore</span>
                                                    <span>Hành trình ngày @item.Day.ToString("00")</span>
                                                </span>
                                            </div>
                                            @if (!string.IsNullOrWhiteSpace(item.Description))
                                            {
                                                <div class="@($"{ContentPresentationViewHelper.GetRichTextClass(true)} mt-5 max-w-none text-slate-600 dark:text-slate-300")">@Html.Raw(RichTextContentFormatter.ToTrustedHtml(item.Description))</div>
                                            }
                                        </div>
                                    </div>
                                </article>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="mt-8 overflow-hidden rounded-[1.75rem] border border-dashed border-sky-200 bg-sky-50/70 px-6 py-7 text-center shadow-inner shadow-sky-100/70 dark:border-sky-900/40 dark:bg-sky-950/20 dark:shadow-none sm:px-8">
                            <div class="mx-auto inline-flex h-16 w-16 items-center justify-center rounded-full bg-white text-sky-600 shadow-lg shadow-sky-100 dark:bg-slate-950 dark:text-sky-300 dark:shadow-none">
                                <span class="material-symbols-outlined text-[28px]">map</span>
                            </div>
                            <p class="mt-5 text-base font-bold text-slate-900 dark:text-white">@schedule?.Fields.GetVisibleFieldValue("emptyStateTitle", "Lịch trình chi tiết đang được cập nhật")</p>
                            <p class="mt-3 text-sm leading-7 text-slate-500 dark:text-slate-400">@schedule?.Fields.GetVisibleFieldValue("emptyStateText", "Detailed itinerary will be shared closer to departure.")</p>
                        </div>
                    }
                </section>

                @if (routeOverview.HasRouting)
                {
                    <section class="@($"{Card} {ContentPresentationViewHelper.GetSectionTextClass(routing)} {ContentPresentationViewHelper.GetSectionBackgroundClass(routing)}")" style="@ContentPresentationViewHelper.GetSectionStyle(routing)">
                        <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
                            <div>
                                <p class="@Eyebrow">@routing?.Fields.GetVisibleFieldValue("eyebrowText", "Route overview")</p>
                                <h2 class="@Heading">@routing?.Fields.GetVisibleFieldValue("title", "Route overview")</h2>
                                <p class="mt-3 max-w-3xl text-sm leading-7 text-slate-500 dark:text-slate-400">@routing?.Fields.GetVisibleFieldValue("description", "Các điểm dừng chính được cấu trúc lại theo từng ngày để bạn hình dung nhịp di chuyển của hành trình.")</p>
                            </div>
                            <div class="flex flex-wrap gap-2">
                                <span class="inline-flex items-center rounded-full bg-slate-100 px-3 py-1 text-[11px] font-black uppercase tracking-[0.2em] text-slate-600 dark:bg-slate-900 dark:text-slate-300">@string.Format(routing?.Fields.GetVisibleFieldValue("dayCountFormat", "{0} days") ?? "{0} days", routeOverview.DayCount)</span>
                                <span class="inline-flex items-center rounded-full bg-slate-100 px-3 py-1 text-[11px] font-black uppercase tracking-[0.2em] text-slate-600 dark:bg-slate-900 dark:text-slate-300">@string.Format(routing?.Fields.GetVisibleFieldValue("stopCountFormat", "{0} stops") ?? "{0} stops", routeOverview.StopCount)</span>
                                <span class="inline-flex items-center rounded-full bg-slate-100 px-3 py-1 text-[11px] font-black uppercase tracking-[0.2em] text-slate-600 dark:bg-slate-900 dark:text-slate-300">@string.Format(routing?.Fields.GetVisibleFieldValue("visitMinutesFormat", "{0} visit minutes") ?? "{0} visit minutes", routeOverview.TotalVisitMinutes)</span>
                                <span class="inline-flex items-center rounded-full bg-slate-100 px-3 py-1 text-[11px] font-black uppercase tracking-[0.2em] text-slate-600 dark:bg-slate-900 dark:text-slate-300">@string.Format(routing?.Fields.GetVisibleFieldValue("travelMinutesFormat", "{0} travel minutes") ?? "{0} travel minutes", routeOverview.TotalTravelMinutes)</span>
                                <span class="inline-flex items-center rounded-full bg-slate-100 px-3 py-1 text-[11px] font-black uppercase tracking-[0.2em] text-slate-600 dark:bg-slate-900 dark:text-slate-300">@string.Format(routing?.Fields.GetVisibleFieldValue("journeyMinutesFormat", "{0} journey minutes") ?? "{0} journey minutes", routeOverview.TotalJourneyMinutes)</span>
                                <span class="inline-flex items-center rounded-full bg-slate-100 px-3 py-1 text-[11px] font-black uppercase tracking-[0.2em] text-slate-600 dark:bg-slate-900 dark:text-slate-300">@string.Format(routing?.Fields.GetVisibleFieldValue("distanceFormat", "{0} km") ?? "{0} km", routeOverview.TotalDistanceKm.ToString("0.0"))</span>
                            </div>
                        </div>
                        <div class="mt-6 space-y-5">
                            @foreach (var routeDay in routeOverview.Days)
                            {
                                <article class="rounded-[1.75rem] border border-slate-200 bg-slate-50/80 p-5 dark:border-slate-800 dark:bg-slate-900/70">
                                    <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
                                        <div>
                                            <p class="text-[11px] font-black uppercase tracking-[0.24em] text-primary">Day @routeDay.Day</p>
                                            <h3 class="mt-2 text-xl font-black tracking-tight text-slate-900 dark:text-white">@routeDay.DayTitle</h3>
                                        </div>
                                        <div class="flex flex-wrap gap-2">
                                            <span class="inline-flex items-center rounded-full border border-slate-200 bg-white px-3 py-1 text-[11px] font-black uppercase tracking-[0.2em] text-slate-500 dark:border-slate-700 dark:bg-slate-950 dark:text-slate-300">@string.Format(routing?.Fields.GetVisibleFieldValue("stopCountFormat", "{0} stops") ?? "{0} stops", routeDay.Stops.Count)</span>
                                            <span class="inline-flex items-center rounded-full border border-slate-200 bg-white px-3 py-1 text-[11px] font-black uppercase tracking-[0.2em] text-slate-500 dark:border-slate-700 dark:bg-slate-950 dark:text-slate-300">@string.Format(routing?.Fields.GetVisibleFieldValue("dayTravelMinutesFormat", "{0} travel minutes") ?? "{0} travel minutes", routeDay.TravelMinutes)</span>
                                            <span class="inline-flex items-center rounded-full border border-slate-200 bg-white px-3 py-1 text-[11px] font-black uppercase tracking-[0.2em] text-slate-500 dark:border-slate-700 dark:bg-slate-950 dark:text-slate-300">@string.Format(routing?.Fields.GetVisibleFieldValue("dayJourneyMinutesFormat", "{0} journey minutes") ?? "{0} journey minutes", routeDay.JourneyMinutes)</span>
                                            @if (!string.IsNullOrWhiteSpace(routeDay.PeakDayPart))
                                            {
                                                <span class="inline-flex items-center rounded-full border border-sky-200 bg-sky-50 px-3 py-1 text-[11px] font-black uppercase tracking-[0.2em] text-sky-700 dark:border-sky-800/60 dark:bg-sky-950/40 dark:text-sky-200">@(routing?.Fields.GetVisibleFieldValue("dayPartLabel", "Day part")): @DayPartText(routeDay.PeakDayPart)</span>
                                            }
                                        </div>
                                    </div>
                                    <div class="mt-5 space-y-3">
                                        @foreach (var stop in routeDay.Stops)
                                        {
                                            <div class="rounded-[1.4rem] border border-slate-200 bg-white p-4 dark:border-slate-800 dark:bg-slate-950/80">
                                                @if (stop.TransferFromPrevious != null)
                                                {
                                                    <div class="mb-4 rounded-[1.1rem] border border-dashed border-slate-200 bg-slate-50/80 px-4 py-3 text-xs font-semibold text-slate-600 dark:border-slate-800 dark:bg-slate-900/70 dark:text-slate-300">
                                                        <div class="flex flex-wrap items-center gap-3">
                                                            <span>@string.Format(routing?.Fields.GetVisibleFieldValue("transferTimeFormat", "Travel about {0} minutes") ?? "Travel about {0} minutes", stop.TransferFromPrevious.TravelMinutes)</span>
                                                            <span>@(routing?.Fields.GetVisibleFieldValue("dayPartLabel", "Day part")): @DayPartText(stop.TransferFromPrevious.DayPart)</span>
                                                            <span>@(routing?.Fields.GetVisibleFieldValue("congestionLabel", "Congestion")): @CongestionText(stop.TransferFromPrevious.CongestionLevel)</span>
                                                        </div>
                                                    </div>
                                                }
                                                <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
                                                    <div class="min-w-0">
                                                        <p class="text-base font-black tracking-tight text-slate-900 dark:text-white">@stop.Name</p>
                                                        @if (!string.IsNullOrWhiteSpace(stop.Type))
                                                        {
                                                            <p class="mt-1 text-[11px] font-bold uppercase tracking-[0.2em] text-slate-400 dark:text-slate-500">@(routing?.Fields.GetVisibleFieldValue("typeLabel", "Type")): @stop.Type</p>
                                                        }
                                                    </div>
                                                    @if (stop.VisitMinutes > 0)
                                                    {
                                                        <span class="inline-flex shrink-0 items-center rounded-full bg-slate-100 px-3 py-1 text-[11px] font-black uppercase tracking-[0.2em] text-slate-600 dark:bg-slate-900 dark:text-slate-300">@stop.VisitMinutes phút</span>
                                                    }
                                                </div>
                                                @if (!string.IsNullOrWhiteSpace(stop.Note))
                                                {
                                                    <p class="mt-3 text-sm leading-7 text-slate-500 dark:text-slate-400">@stop.Note</p>
                                                }
                                            </div>
                                        }
                                    </div>
                                </article>
                            }
                        </div>
                    </section>
                }

                <section class="grid gap-6 lg:grid-cols-2">
