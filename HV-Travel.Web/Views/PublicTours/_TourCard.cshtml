@using System
@using System.Linq
@using HVTravel.Domain.Entities
@using HVTravel.Web.Services
@model Tour
@{
    var tour = Model;
    var departures = tour.EffectiveDepartures.Where(item => item.StartDate >= DateTime.UtcNow.Date).OrderBy(item => item.StartDate).ToList();
    if (!departures.Any())
    {
        departures = tour.EffectiveDepartures.OrderBy(item => item.StartDate).ToList();
    }

    var featuredDeparture = departures.FirstOrDefault() ?? tour.ResolveDeparture(null);
    var startingPrice = featuredDeparture?.AdultPrice > 0m ? featuredDeparture.AdultPrice : tour.Price?.Adult ?? 0m;
    var remainingCapacity = featuredDeparture?.RemainingCapacity ?? tour.RemainingSpots;
    var discountPercent = featuredDeparture?.DiscountPercentage ?? (decimal)(tour.Price?.Discount ?? 0d);
    var hasDiscount = discountPercent > 0m && discountPercent < 100m && startingPrice > 0m;
    var originalPrice = hasDiscount
        ? Math.Round(startingPrice / (1m - (discountPercent / 100m)), 0, MidpointRounding.AwayFromZero)
        : 0m;

    if (originalPrice <= startingPrice)
    {
        hasDiscount = false;
        originalPrice = 0m;
    }

    var detailId = PublicTourIdentifierHelper.GetDetailIdentifier(tour);
    var currentRouteStyle = ViewData["CurrentRouteStyle"]?.ToString();
    var detailUrl = Url.Action("Details", "PublicTours", new { id = detailId, routeStyle = currentRouteStyle }) ?? "#";
    var bookingUrl = Url.Action("Create", "Booking", new { tourId = tour.Id }) ?? detailUrl;
    var coverImage = tour.Images.FirstOrDefault();
    var locationText = string.Join(", ", new[] { tour.Destination?.City, tour.Destination?.Region }.Where(part => !string.IsNullOrWhiteSpace(part)));
    if (string.IsNullOrWhiteSpace(locationText))
    {
        locationText = "Việt Nam";
    }

    var durationLabel = tour.Duration?.Days > 0 && tour.Duration?.Nights >= 0
        ? $"{tour.Duration.Days}N{tour.Duration.Nights}Đ"
        : null;

    var isInstantConfirmation = string.Equals(featuredDeparture?.ConfirmationType ?? tour.ConfirmationType, "Instant", StringComparison.OrdinalIgnoreCase);
    var lowAvailability = remainingCapacity is > 0 and <= 5;
}

<article class="group flex h-full flex-col overflow-hidden rounded-[1.75rem] border border-slate-200 bg-white shadow-[0_20px_60px_-40px_rgba(15,23,42,0.45)] transition duration-300 hover:-translate-y-1 hover:border-primary/30 hover:shadow-[0_24px_70px_-36px_rgba(15,23,42,0.55)] dark:border-slate-800 dark:bg-slate-950"
         data-tour-card
         data-tour-id="@tour.Id"
         data-tour-name="@tour.Name"
         data-tour-price="@startingPrice"
         data-tour-location="@locationText"
         data-tour-url="@detailUrl"
         data-tour-image="@(coverImage ?? string.Empty)">
    <div class="relative aspect-[4/3] overflow-hidden bg-slate-100 dark:bg-slate-900">
        <a asp-controller="PublicTours" asp-action="Details" asp-route-id="@detailId" asp-route-routeStyle="@currentRouteStyle" class="record-view block h-full w-full" aria-label="Xem chi tiết tour @tour.Name">
            @if (!string.IsNullOrWhiteSpace(coverImage))
            {
                <img src="@coverImage"
                     alt="@tour.Name"
                     class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
                     data-tour-image-fallback
                     onerror="this.classList.add('hidden'); this.nextElementSibling?.classList.remove('hidden'); this.nextElementSibling?.classList.add('flex');" />
                <div class="hidden h-full w-full items-center justify-center bg-gradient-to-br from-slate-200 via-white to-slate-100 text-slate-400 dark:from-slate-900 dark:via-slate-950 dark:to-slate-800 dark:text-slate-600" aria-hidden="true">
                    <span class="material-symbols-outlined text-[68px]">landscape</span>
                </div>
            }
            else
            {
                <div class="flex h-full w-full items-center justify-center bg-gradient-to-br from-slate-200 via-white to-slate-100 text-slate-400 dark:from-slate-900 dark:via-slate-950 dark:to-slate-800 dark:text-slate-600" aria-hidden="true">
                    <span class="material-symbols-outlined text-[68px]">landscape</span>
                </div>
            }
        </a>

        <div class="pointer-events-none absolute inset-x-0 top-0 flex items-start justify-between gap-3 p-4">
            <div class="flex flex-wrap gap-2">
                @if (hasDiscount)
                {
                    <span class="inline-flex items-center rounded-full bg-rose-500 px-3 py-1 text-[11px] font-black uppercase tracking-[0.2em] text-white shadow-lg shadow-rose-500/30">Giảm @discountPercent.ToString("0")%</span>
                }
                else if (lowAvailability)
                {
                    <span class="inline-flex items-center rounded-full bg-amber-400 px-3 py-1 text-[11px] font-black uppercase tracking-[0.2em] text-slate-950 shadow-lg shadow-amber-500/30">Còn ít chỗ</span>
                }
                else if (tour.CancellationPolicy?.IsFreeCancellation == true)
                {
                    <span class="inline-flex items-center rounded-full bg-emerald-500 px-3 py-1 text-[11px] font-black uppercase tracking-[0.2em] text-white shadow-lg shadow-emerald-500/30">Hủy miễn phí</span>
                }
                else if (isInstantConfirmation)
                {
                    <span class="inline-flex items-center rounded-full bg-slate-900/80 px-3 py-1 text-[11px] font-black uppercase tracking-[0.2em] text-white shadow-lg shadow-slate-900/30 dark:bg-white/15">Xác nhận nhanh</span>
                }
            </div>

            <button type="button"
                    class="pointer-events-auto inline-flex size-11 items-center justify-center rounded-full border border-white/50 bg-white/90 text-cyan-700 shadow-lg shadow-slate-900/15 backdrop-blur transition hover:-translate-y-0.5 hover:border-cyan-400 hover:text-cyan-600 dark:border-white/10 dark:bg-slate-950/80 dark:text-cyan-200"
                    data-tour-planner-toggle
                    aria-pressed="false"
                    aria-label="Them tour @tour.Name vao planner">
                <span class="material-symbols-outlined text-[20px]" data-tour-planner-icon>playlist_add</span>
            </button>

            <button type="button"
                    class="pointer-events-auto inline-flex size-11 items-center justify-center rounded-full border border-white/50 bg-white/90 text-slate-600 shadow-lg shadow-slate-900/15 backdrop-blur transition hover:-translate-y-0.5 hover:border-primary/40 hover:text-primary dark:border-white/10 dark:bg-slate-950/80 dark:text-slate-200"
                    data-tour-wishlist-toggle
                    aria-pressed="false"
                    aria-label="Lưu tour @tour.Name">
                <span class="material-symbols-outlined text-[20px]" data-tour-heart-icon>favorite_border</span>
            </button>
        </div>
    </div>

    <div class="flex flex-1 flex-col gap-5 p-5">
        <div class="space-y-4">
            <div class="space-y-3">
                <div class="flex flex-wrap items-center gap-2 text-[11px] font-bold uppercase tracking-[0.2em] text-slate-400 dark:text-slate-500">
                    <span class="inline-flex items-center gap-1.5 rounded-full bg-slate-100 px-3 py-1 text-slate-600 dark:bg-slate-900 dark:text-slate-300">
                        <span class="material-symbols-outlined text-[15px]">location_on</span>
                        <span>@locationText</span>
                    </span>
                    @if (!string.IsNullOrWhiteSpace(durationLabel))
                    {
                        <span class="inline-flex items-center gap-1.5 rounded-full bg-slate-100 px-3 py-1 text-slate-600 dark:bg-slate-900 dark:text-slate-300">
                            <span class="material-symbols-outlined text-[15px]">schedule</span>
                            <span>@durationLabel</span>
                        </span>
                    }
                </div>

                <a asp-controller="PublicTours" asp-action="Details" asp-route-id="@detailId" asp-route-routeStyle="@currentRouteStyle" class="record-view block" aria-label="Xem chi tiết tour @tour.Name">
                    <h3 class="line-clamp-2 text-lg font-black tracking-tight text-slate-900 transition group-hover:text-primary dark:text-white">@tour.Name</h3>
                </a>
            </div>

            <div class="space-y-2 text-sm text-slate-500 dark:text-slate-400">
                @if (!string.IsNullOrWhiteSpace(tour.Code))
                {
                    <div class="flex items-start gap-2">
                        <span class="material-symbols-outlined mt-0.5 text-[18px] text-slate-400 dark:text-slate-500">confirmation_number</span>
                        <span>@tour.Code</span>
                    </div>
                }

                @if (featuredDeparture != null)
                {
                    <div class="flex items-start gap-2">
                        <span class="material-symbols-outlined mt-0.5 text-[18px] text-slate-400 dark:text-slate-500">calendar_month</span>
                        <span>Khởi hành: @featuredDeparture.StartDate.ToString("dd/MM/yyyy")</span>
                    </div>
                }

                @if (remainingCapacity >= 0)
                {
                    <div class="flex items-start gap-2">
                        <span class="material-symbols-outlined mt-0.5 text-[18px] text-slate-400 dark:text-slate-500">group</span>
                        <span>Còn <strong class="font-black text-slate-700 dark:text-slate-200">@remainingCapacity</strong> chỗ</span>
                    </div>
                }
            </div>
        </div>

        <div class="mt-auto flex items-end justify-between gap-4 rounded-[1.5rem] bg-slate-50 px-4 py-4 dark:bg-slate-900/70">
            <div>
                <p class="text-[11px] font-bold uppercase tracking-[0.22em] text-slate-400 dark:text-slate-500">Giá từ</p>
                @if (hasDiscount)
                {
                    <p class="mt-1 text-sm text-slate-400 line-through dark:text-slate-500">@originalPrice.ToString("N0") ₫</p>
                }
                <p class="mt-1 text-xl font-black tracking-tight text-slate-900 dark:text-white">@startingPrice.ToString("N0") ₫</p>
            </div>

            <a href="@bookingUrl" class="inline-flex items-center justify-center rounded-2xl bg-primary px-5 py-3 text-sm font-black text-white shadow-lg shadow-primary/20 transition hover:-translate-y-0.5 hover:bg-primary-dark hover:shadow-primary/35">
                Đặt ngay
            </a>
        </div>
    </div>
</article>
