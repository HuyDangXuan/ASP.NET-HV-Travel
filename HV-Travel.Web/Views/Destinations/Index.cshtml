@inject IPublicContentService ContentService
@model HVTravel.Web.Models.DestinationHubViewModel
@{
    var sections = await ContentService.GetPageSectionsAsync("destinations");
    var hero = sections.GetSection("hero");
    var collectionsIntro = sections.GetSection("collectionsIntro");
    var regionsIntro = sections.GetSection("regionsIntro");

    ViewData["Description"] = hero?.Fields.GetFieldValue("description", "Trang này hỗ trợ marketing mở landing theo vùng, theo nhu cầu và theo mức giá thay vì chỉ có danh sách tour phẳng.")
        ?? "Trang này hỗ trợ marketing mở landing theo vùng, theo nhu cầu và theo mức giá thay vì chỉ có danh sách tour phẳng.";
}

@if (hero?.IsEnabled != false)
{
    <section class="public-top-section public-top-section--hero public-page-hero hero-gradient relative overflow-hidden">
        <div class="absolute inset-0 opacity-20">
            <div class="absolute left-0 top-20 h-72 w-72 rounded-full bg-emerald-400/20 blur-3xl"></div>
            <div class="absolute right-10 bottom-0 h-96 w-96 rounded-full bg-sky-500/20 blur-3xl"></div>
        </div>
        <div class="public-top-section-shell public-page-hero-shell max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="public-top-section-content public-page-hero-content is-centered max-w-4xl" data-animate="fade-up">
                <span class="public-badge public-top-section-badge public-page-hero-badge">
                    <span class="material-symbols-outlined text-[16px] text-primary">globe_asia</span>
                    @hero.Fields.GetFieldValue("eyebrowText", "Điểm đến nổi bật")
                </span>
                <h1 class="public-top-section-title public-hero-title text-white">@hero.Fields.GetFieldValue("title", "Từ điểm đến đến bộ sưu tập tour, tất cả được gom về một hub khám phá.")</h1>
                <div class="public-top-section-lead public-body-copy public-page-hero-copy">
                    @Html.Raw(hero.Fields.GetFieldValue("description", "Trang này hỗ trợ marketing mở landing theo vùng, theo nhu cầu và theo mức giá thay vì chỉ có danh sách tour phẳng."))
                </div>
            </div>
        </div>
    </section>
}

<section class="py-12 bg-background-light dark:bg-background-dark">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 space-y-12">
        @if (collectionsIntro?.IsEnabled != false)
        {
            <div>
                <p class="text-xs uppercase tracking-[0.3em] text-primary">@collectionsIntro.Fields.GetFieldValue("eyebrowText", "Collections")</p>
                <h2 class="public-section-title mt-2">@collectionsIntro.Fields.GetFieldValue("title", "Bộ sưu tập nổi bật")</h2>
                <div class="mt-3 max-w-3xl text-sm leading-7 text-slate-500 dark:text-slate-400">
                    @Html.Raw(collectionsIntro.Fields.GetFieldValue("description", "Nhóm các collection giúp marketing đẩy nhanh trang đích theo nhu cầu và mức ngân sách."))
                </div>
                <div class="mt-6 grid gap-6 lg:grid-cols-2">
                    @foreach (var collection in Model.Collections)
                    {
                        <article class="rounded-[2rem] border border-border-light bg-surface-light p-6 shadow-sm dark:border-border-dark dark:bg-surface-dark">
                            <p class="text-xs uppercase tracking-[0.3em] text-slate-400">@collection.Key</p>
                            <h3 class="mt-2 text-2xl font-black text-slate-900 dark:text-white">@collection.Title</h3>
                            <p class="mt-3 text-sm leading-7 text-slate-500 dark:text-slate-400">@collection.Description</p>
                            <div class="mt-5 space-y-3">
                                @foreach (var tour in collection.Tours)
                                {
                                    <a asp-controller="PublicTours" asp-action="Details" asp-route-id="@tour.Id" class="flex items-center justify-between gap-4 rounded-2xl border border-border-light px-4 py-4 transition hover:border-primary dark:border-border-dark">
                                        <div>
                                            <p class="text-sm font-black text-slate-900 dark:text-white">@tour.Name</p>
                                            <p class="mt-1 text-xs text-slate-500 dark:text-slate-400">@(tour.Destination?.City ?? "Việt Nam") • @(tour.Duration?.Text)</p>
                                        </div>
                                        <span class="text-base font-black text-primary">@(tour.Price?.Adult.ToString("N0"))₫</span>
                                    </a>
                                }
                            </div>
                        </article>
                    }
                </div>
            </div>
        }

        @if (regionsIntro?.IsEnabled != false)
        {
            <div>
                <p class="text-xs uppercase tracking-[0.3em] text-primary">@regionsIntro.Fields.GetFieldValue("eyebrowText", "Regions")</p>
                <h2 class="public-section-title mt-2">@regionsIntro.Fields.GetFieldValue("title", "Khám phá theo vùng")</h2>
                <div class="mt-3 max-w-3xl text-sm leading-7 text-slate-500 dark:text-slate-400">
                    @Html.Raw(regionsIntro.Fields.GetFieldValue("description", "Trình bày điểm đến theo vùng để mở rộng landing page bán theo khu vực và nhóm thành phố nổi bật."))
                </div>
                <div class="mt-6 space-y-8">
                    @foreach (var region in Model.Regions)
                    {
                        <section class="rounded-[2rem] border border-border-light bg-surface-light p-6 shadow-sm dark:border-border-dark dark:bg-surface-dark">
                            <div>
                                <p class="text-xs uppercase tracking-[0.3em] text-slate-400">Region</p>
                                <h3 class="mt-2 text-2xl font-black text-slate-900 dark:text-white">@region.Region</h3>
                            </div>
                            <div class="mt-6 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
                                @foreach (var destination in region.Destinations)
                                {
                                    <article class="overflow-hidden rounded-[1.5rem] border border-border-light bg-white dark:border-border-dark dark:bg-slate-900/40">
                                        @if (!string.IsNullOrWhiteSpace(destination.RepresentativeImage))
                                        {
                                            <img src="@destination.RepresentativeImage" alt="@destination.City" class="h-44 w-full object-cover" />
                                        }
                                        <div class="p-5">
                                            <p class="text-xs uppercase tracking-[0.3em] text-slate-400">@destination.Country</p>
                                            <h4 class="mt-2 text-xl font-black text-slate-900 dark:text-white">@destination.City</h4>
                                            <div class="mt-4 flex items-center justify-between text-sm text-slate-500 dark:text-slate-400">
                                                <span>@destination.TourCount tour</span>
                                                <span>Rating @destination.BestRating.ToString("0.0")</span>
                                            </div>
                                            <p class="mt-3 text-lg font-black text-primary">Từ @destination.StartingPrice.ToString("N0")₫</p>
                                        </div>
                                    </article>
                                }
                            </div>
                        </section>
                    }
                </div>
            </div>
        }
    </div>
</section>



