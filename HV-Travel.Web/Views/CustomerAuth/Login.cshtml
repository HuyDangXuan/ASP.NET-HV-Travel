@model HVTravel.Web.Models.CustomerLoginViewModel
@{
    ViewData["ActivePage"] = "Login";
}

<section class="relative overflow-hidden bg-slate-950">
    <div class="absolute inset-0">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,_rgba(43,205,238,0.22),_transparent_32%),radial-gradient(circle_at_bottom_right,_rgba(14,165,233,0.28),_transparent_30%),linear-gradient(135deg,_#020617_0%,_#0f172a_50%,_#082f49_100%)]"></div>
        <div class="absolute -left-24 top-28 h-72 w-72 rounded-full bg-cyan-400/10 blur-3xl"></div>
        <div class="absolute -right-10 bottom-10 h-96 w-96 rounded-full bg-sky-500/10 blur-3xl"></div>
    </div>

    <div class="relative mx-auto flex min-h-[calc(100vh-9rem)] max-w-7xl items-center px-4 py-14 sm:px-6 lg:px-8">
        <div class="grid w-full gap-10 lg:grid-cols-[1.1fr_0.9fr] lg:gap-14">
            <div class="flex flex-col justify-center text-white" data-animate="slide-left">
                <span class="inline-flex w-fit items-center gap-2 rounded-full border border-white/10 bg-white/10 px-4 py-2 text-xs font-bold uppercase tracking-[0.3em] text-cyan-100">
                    HV Travel Account
                </span>
                <h1 class="mt-6 max-w-2xl text-4xl font-extrabold leading-tight sm:text-5xl lg:text-6xl">
                    Đăng nhập để tiếp tục hành trình của bạn.
                </h1>
                <p class="mt-5 max-w-xl text-base leading-8 text-slate-300 sm:text-lg">
                    Sử dụng email khách hàng để xem thông tin tài khoản, theo dõi trạng thái đặt tour và giữ mọi trải nghiệm du lịch ở cùng một nơi.
                </p>

                <div class="mt-10 grid gap-4 sm:grid-cols-3">
                    <div class="rounded-3xl border border-white/10 bg-white/10 p-5 backdrop-blur-sm">
                        <p class="text-2xl font-extrabold text-white">24/7</p>
                        <p class="mt-2 text-sm text-slate-300">Hỗ trợ cập nhật booking mọi lúc</p>
                    </div>
                    <div class="rounded-3xl border border-white/10 bg-white/10 p-5 backdrop-blur-sm">
                        <p class="text-2xl font-extrabold text-white">1 tài khoản</p>
                        <p class="mt-2 text-sm text-slate-300">Quản lý email, hồ sơ và điểm thưởng</p>
                    </div>
                    <div class="rounded-3xl border border-white/10 bg-white/10 p-5 backdrop-blur-sm">
                        <p class="text-2xl font-extrabold text-white">Bảo mật</p>
                        <p class="mt-2 text-sm text-slate-300">Mật khẩu đang được mã hóa theo chuẩn hash</p>
                    </div>
                </div>
            </div>

            <div class="flex items-center justify-center" data-animate="zoom-in">
                <div class="w-full max-w-lg rounded-[2rem] border border-white/60 bg-white/90 p-6 shadow-2xl shadow-sky-950/20 backdrop-blur-xl dark:border-slate-700 dark:bg-slate-900/90 sm:p-8">
                    <div class="mb-8">
                        <p class="text-sm font-bold uppercase tracking-[0.25em] text-primary">Welcome back</p>
                        <h2 class="mt-3 text-3xl font-extrabold text-slate-900 dark:text-white">Đăng nhập khách hàng</h2>
                        <p class="mt-3 text-sm leading-7 text-slate-500 dark:text-slate-400">
                            Ví dụ tài khoản hợp lệ theo dữ liệu hiện có: <span class="font-semibold text-slate-700 dark:text-slate-200">hhunu114@gmail.com</span>
                        </p>
                    </div>

                    @if (TempData["AuthSuccessMessage"] != null)
                    {
                        <div class="mb-5 rounded-2xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-700 dark:border-emerald-500/30 dark:bg-emerald-500/10 dark:text-emerald-200">
                            @TempData["AuthSuccessMessage"]
                        </div>
                    }

                    <form asp-action="Login" method="post" class="space-y-5">
                        @Html.AntiForgeryToken()
                        <input asp-for="ReturnUrl" type="hidden" />

                        <div asp-validation-summary="ModelOnly" class="rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-600 empty:hidden dark:border-red-500/30 dark:bg-red-500/10 dark:text-red-200"></div>

                        <div>
                            <label asp-for="Email" class="mb-2 block text-sm font-bold text-slate-700 dark:text-slate-200">Email</label>
                            <input asp-for="Email" class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 shadow-sm outline-none transition focus:border-primary focus:ring-4 focus:ring-primary/10 dark:border-slate-700 dark:bg-slate-950 dark:text-white" placeholder="you@example.com" />
                            <span asp-validation-for="Email" class="mt-2 block text-sm text-red-500"></span>
                        </div>

                        <div>
                            <div class="mb-2 flex items-center justify-between gap-4">
                                <label asp-for="Password" class="block text-sm font-bold text-slate-700 dark:text-slate-200">Mật khẩu</label>
                                <a asp-area="Admin" asp-controller="Auth" asp-action="ForgotPassword" class="text-xs font-semibold text-primary hover:text-primary-dark">Quên mật khẩu?</a>
                            </div>
                            <input asp-for="Password" class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 shadow-sm outline-none transition focus:border-primary focus:ring-4 focus:ring-primary/10 dark:border-slate-700 dark:bg-slate-950 dark:text-white" placeholder="Nhập mật khẩu của bạn" />
                            <span asp-validation-for="Password" class="mt-2 block text-sm text-red-500"></span>
                        </div>

                        <div class="flex items-center justify-between gap-4 rounded-2xl bg-slate-50 px-4 py-3 dark:bg-slate-800/80">
                            <label class="flex items-center gap-3 text-sm font-medium text-slate-600 dark:text-slate-300">
                                <input asp-for="RememberMe" class="rounded border-slate-300 text-primary focus:ring-primary" />
                                Ghi nhớ đăng nhập
                            </label>
                            <span class="text-xs text-slate-400">Cookie tối đa 14 ngày</span>
                        </div>

                        <button type="submit" class="inline-flex w-full items-center justify-center gap-2 rounded-2xl bg-primary px-5 py-3.5 text-sm font-extrabold text-white shadow-lg shadow-primary/30 transition hover:-translate-y-0.5 hover:bg-primary-dark hover:shadow-primary/40">
                            <span class="material-symbols-outlined text-[18px]">login</span>
                            Đăng nhập
                        </button>
                    </form>

                    <div class="mt-6 flex flex-col gap-3 rounded-2xl border border-slate-200 bg-slate-50 p-4 text-sm text-slate-500 dark:border-slate-700 dark:bg-slate-800/70 dark:text-slate-300 sm:flex-row sm:items-center sm:justify-between">
                        <span>Chưa có tài khoản? Tạo mới để lưu lịch sử đặt tour và hồ sơ liên hệ.</span>
                        <a asp-controller="CustomerAuth" asp-action="Register" class="font-bold text-primary hover:text-primary-dark">Đăng ký ngay</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
