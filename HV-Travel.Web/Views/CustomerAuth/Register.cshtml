@model HVTravel.Web.Models.CustomerRegisterViewModel
@{
    ViewData["ActivePage"] = "Register";
}

<section class="relative overflow-hidden bg-slate-950">
    <div class="absolute inset-0">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,_rgba(43,205,238,0.2),_transparent_32%),radial-gradient(circle_at_bottom_right,_rgba(14,165,233,0.28),_transparent_30%),linear-gradient(145deg,_#020617_0%,_#0f172a_45%,_#082f49_100%)]"></div>
        <div class="absolute left-10 top-20 h-72 w-72 rounded-full bg-cyan-400/10 blur-3xl"></div>
        <div class="absolute right-0 bottom-0 h-96 w-96 rounded-full bg-sky-500/10 blur-3xl"></div>
    </div>

    <div class="relative mx-auto flex min-h-[calc(100vh-9rem)] max-w-7xl items-center px-4 py-14 sm:px-6 lg:px-8">
        <div class="grid w-full gap-10 lg:grid-cols-[1fr_1fr] lg:gap-14">
            <div class="flex flex-col justify-center text-white" data-animate="slide-left">
                <span class="public-badge inline-flex w-fit items-center gap-2 rounded-full border border-white/10 bg-white/10 px-4 py-2 text-xs font-bold uppercase tracking-[0.3em] text-cyan-100">
                    Tham gia HV Travel
                </span>
                <h1 class="public-auth-title mt-6 max-w-2xl text-4xl font-extrabold leading-tight sm:text-5xl lg:text-6xl">
                    Tạo tài khoản để bắt đầu những chuyến đi mới.
                </h1>
                <p class="public-body-copy mt-5 max-w-xl text-base leading-8 text-slate-300 sm:text-lg">
                    Đăng ký một lần để lưu hồ sơ liên hệ, nhận ưu đãi riêng và quản lý toàn bộ lịch sử đặt tour trên cùng một giao diện.
                </p>

                <div class="mt-10 space-y-4">
                    <div class="rounded-3xl border border-white/10 bg-white/10 p-5 backdrop-blur-sm">
                        <p class="text-sm font-bold uppercase tracking-[0.2em] text-cyan-100">Quyền lợi</p>
                        <p class="mt-2 text-lg font-bold">Theo dõi booking và thông tin khách hàng tập trung</p>
                    </div>
                    <div class="public-card-grid grid gap-4 sm:grid-cols-2">
                        <div class="rounded-3xl border border-white/10 bg-white/10 p-5 backdrop-blur-sm">
                            <p class="text-2xl font-extrabold text-white">Nhanh</p>
                            <p class="mt-2 text-sm text-slate-300">Đăng ký trong vài phút với thông tin cơ bản</p>
                        </div>
                        <div class="rounded-3xl border border-white/10 bg-white/10 p-5 backdrop-blur-sm">
                            <p class="text-2xl font-extrabold text-white">Minh bạch</p>
                            <p class="mt-2 text-sm text-slate-300">Tài khoản mới được tạo ở trạng thái hoạt động ngay</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="flex items-center justify-center" data-animate="zoom-in">
                <div class="public-form-card w-full max-w-2xl rounded-[2rem] border border-white/60 bg-white/90 p-6 shadow-2xl shadow-sky-950/20 backdrop-blur-xl dark:border-slate-700 dark:bg-slate-900/90 sm:p-8">
                    <div class="mb-8">
                        <p class="text-sm font-bold uppercase tracking-[0.25em] text-primary">Tạo tài khoản</p>
                        <h2 class="mt-3 text-3xl font-extrabold text-slate-900 dark:text-white">Đăng ký khách hàng</h2>
                        <p class="mt-3 text-sm leading-7 text-slate-500 dark:text-slate-400">
                            Giao diện này được thiết kế đồng bộ với trang đăng nhập để người dùng có trải nghiệm liền mạch.
                        </p>
                    </div>

                    <form asp-action="Register" method="post" class="space-y-5">
                        @Html.AntiForgeryToken()

                        <div asp-validation-summary="ModelOnly" class="rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-600 empty:hidden dark:border-red-500/30 dark:bg-red-500/10 dark:text-red-200"></div>

                        <div class="grid gap-5 sm:grid-cols-2">
                            <div class="sm:col-span-2">
                                <label asp-for="FullName" class="mb-2 block text-sm font-bold text-slate-700 dark:text-slate-200">Họ và tên</label>
                                <input asp-for="FullName" class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 shadow-sm outline-none transition focus:border-primary focus:ring-4 focus:ring-primary/10 dark:border-slate-700 dark:bg-slate-950 dark:text-white" placeholder="Nguyễn Văn A" />
                                <span asp-validation-for="FullName" class="mt-2 block text-sm text-red-500"></span>
                            </div>

                            <div>
                                <label asp-for="Email" class="mb-2 block text-sm font-bold text-slate-700 dark:text-slate-200">Email</label>
                                <input asp-for="Email" class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 shadow-sm outline-none transition focus:border-primary focus:ring-4 focus:ring-primary/10 dark:border-slate-700 dark:bg-slate-950 dark:text-white" placeholder="email@vidu.com" />
                                <span asp-validation-for="Email" class="mt-2 block text-sm text-red-500"></span>
                            </div>

                            <div>
                                <label asp-for="PhoneNumber" class="mb-2 block text-sm font-bold text-slate-700 dark:text-slate-200">Số điện thoại</label>
                                <input asp-for="PhoneNumber" class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 shadow-sm outline-none transition focus:border-primary focus:ring-4 focus:ring-primary/10 dark:border-slate-700 dark:bg-slate-950 dark:text-white" placeholder="09xxxxxxxx" />
                                <span asp-validation-for="PhoneNumber" class="mt-2 block text-sm text-red-500"></span>
                            </div>

                            <div>
                                <label asp-for="Password" class="mb-2 block text-sm font-bold text-slate-700 dark:text-slate-200">Mật khẩu</label>
                                <input asp-for="Password" class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 shadow-sm outline-none transition focus:border-primary focus:ring-4 focus:ring-primary/10 dark:border-slate-700 dark:bg-slate-950 dark:text-white" placeholder="Tối thiểu 6 ký tự" />
                                <span asp-validation-for="Password" class="mt-2 block text-sm text-red-500"></span>
                            </div>

                            <div>
                                <label asp-for="ConfirmPassword" class="mb-2 block text-sm font-bold text-slate-700 dark:text-slate-200">Xác nhận mật khẩu</label>
                                <input asp-for="ConfirmPassword" class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 shadow-sm outline-none transition focus:border-primary focus:ring-4 focus:ring-ring-primary/10 dark:border-slate-700 dark:bg-slate-950 dark:text-white" placeholder="Nhập lại mật khẩu" />
                                <span asp-validation-for="ConfirmPassword" class="mt-2 block text-sm text-red-500"></span>
                            </div>

                            <div class="sm:col-span-2">
                                <label asp-for="Street" class="mb-2 block text-sm font-bold text-slate-700 dark:text-slate-200">Địa chỉ</label>
                                <input asp-for="Street" class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 shadow-sm outline-none transition focus:border-primary focus:ring-4 focus:ring-primary/10 dark:border-slate-700 dark:bg-slate-950 dark:text-white" placeholder="Số nhà, đường, phường/xã" />
                                <span asp-validation-for="Street" class="mt-2 block text-sm text-red-500"></span>
                            </div>

                            <div>
                                <label asp-for="City" class="mb-2 block text-sm font-bold text-slate-700 dark:text-slate-200">Thành phố</label>
                                <input asp-for="City" class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 shadow-sm outline-none transition focus:border-primary focus:ring-4 focus:ring-primary/10 dark:border-slate-700 dark:bg-slate-950 dark:text-white" placeholder="Hà Nội" />
                                <span asp-validation-for="City" class="mt-2 block text-sm text-red-500"></span>
                            </div>

                            <div>
                                <label asp-for="Country" class="mb-2 block text-sm font-bold text-slate-700 dark:text-slate-200">Quốc gia</label>
                                <input asp-for="Country" class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 shadow-sm outline-none transition focus:border-primary focus:ring-4 focus:ring-primary/10 dark:border-slate-700 dark:bg-slate-950 dark:text-white" placeholder="Việt Nam" />
                                <span asp-validation-for="Country" class="mt-2 block text-sm text-red-500"></span>
                            </div>
                        </div>

                        <div class="rounded-2xl bg-slate-50 px-4 py-4 dark:bg-surface-elevated-dark/85">
                            <label class="flex items-start gap-3 text-sm font-medium text-slate-600 dark:text-slate-300">
                                <input asp-for="AcceptTerms" class="mt-1 rounded border-slate-300 text-primary focus:ring-primary" />
                                <span>Tôi đồng ý với điều khoản sử dụng và cho phép HV Travel lưu thông tin để phục vụ quá trình tư vấn, đặt tour.</span>
                            </label>
                            <span asp-validation-for="AcceptTerms" class="mt-2 block text-sm text-red-500"></span>
                        </div>

                        <button type="submit" class="inline-flex w-full items-center justify-center gap-2 rounded-2xl bg-primary px-5 py-3.5 text-sm font-extrabold text-white shadow-lg shadow-primary/30 transition hover:-translate-y-0.5 hover:bg-primary-dark hover:shadow-primary/40">
                            <span class="material-symbols-outlined text-[18px]">person_add</span>
                            Tạo tài khoản
                        </button>
                    </form>

                    <div class="mt-6 flex flex-col gap-3 rounded-2xl border border-slate-200 bg-slate-50 p-4 text-sm text-slate-500 dark:border-slate-700 dark:bg-slate-800/70 dark:text-slate-300 sm:flex-row sm:items-center sm:justify-between">
                        <span>Đã có tài khoản? Đăng nhập để tiếp tục đặt tour và quản lý hành trình.</span>
                        <a asp-controller="CustomerAuth" asp-action="Login" class="font-bold text-primary hover:text-primary-dark">Đi đến đăng nhập</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

