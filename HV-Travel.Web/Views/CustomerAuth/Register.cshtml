@inject IPublicContentService ContentService
@using HVTravel.Web.Services
@model HVTravel.Web.Models.CustomerRegisterViewModel
@{
    ViewData["ActivePage"] = "Register";
    var sections = await ContentService.GetPageSectionsAsync("customerRegister");
    var hero = sections.GetSection("hero");
    var benefits = sections.GetSection("benefits");
    var formIntro = sections.GetSection("formIntro");
    var loginPrompt = sections.GetSection("loginPrompt");
}

<section class="public-top-section public-top-section--compact relative overflow-hidden bg-slate-950 @ContentPresentationViewHelper.GetSectionBackgroundClass(hero)" style="@ContentPresentationViewHelper.GetSectionStyle(hero)">
    <div class="public-top-section-shell relative mx-auto flex min-h-[calc(100vh-9rem)] max-w-7xl items-center px-4 py-14 sm:px-6 lg:px-8">
        <div class="grid w-full gap-10 lg:grid-cols-[1fr_1fr] lg:gap-14">
            <div class="public-top-section-content is-left flex flex-col justify-center text-white @ContentPresentationViewHelper.GetSectionTextClass(hero)" data-animate="slide-left">
                <span class="public-badge public-top-section-badge inline-flex w-fit rounded-full border border-white/10 bg-white/10 px-4 py-2 text-xs font-bold uppercase tracking-[0.3em]" style="@ContentPresentationViewHelper.GetFieldTextStyle(hero, "badgeText")">@hero?.Fields.GetVisibleFieldValue("badgeText", "Tham gia HV Travel")</span>
                <h1 class="public-top-section-title mt-6 max-w-2xl text-4xl font-extrabold leading-tight sm:text-5xl lg:text-6xl">@hero?.Fields.GetVisibleFieldValue("title", "Tạo tài khoản để bắt đầu những chuyến đi mới.")</h1>
                <p class="public-top-section-lead mt-5 max-w-xl text-base leading-8 text-slate-300" style="@ContentPresentationViewHelper.GetFieldTextStyle(hero, "description")">@hero?.Fields.GetVisibleFieldValue("description", "Đăng ký một lần để lưu hồ sơ liên hệ, nhận ưu đãi riêng và quản lý toàn bộ lịch sử đặt tour trên cùng một giao diện.")</p>
                <div class="mt-10 space-y-4 @ContentPresentationViewHelper.GetSectionTextClass(benefits)" style="@ContentPresentationViewHelper.GetSectionStyle(benefits)">
                    <div class="rounded-3xl border border-white/10 bg-white/10 p-5"><p class="text-sm font-bold uppercase tracking-[0.2em] text-cyan-100">@benefits?.Fields.GetVisibleFieldValue("sectionTitle", "Quyền lợi")</p><p class="mt-2 text-lg font-bold">@benefits?.Fields.GetVisibleFieldValue("sectionDescription", "Theo dõi booking và thông tin khách hàng tập trung")</p></div>
                    <div class="grid gap-4 sm:grid-cols-2">
                        <div class="rounded-3xl border border-white/10 bg-white/10 p-5"><p class="text-2xl font-extrabold">@benefits?.Fields.GetVisibleFieldValue("card1Title", "Nhanh")</p><p class="mt-2 text-sm text-slate-300">@benefits?.Fields.GetVisibleFieldValue("card1Description", "Đăng ký trong vài phút với thông tin cơ bản")</p></div>
                        <div class="rounded-3xl border border-white/10 bg-white/10 p-5"><p class="text-2xl font-extrabold">@benefits?.Fields.GetVisibleFieldValue("card2Title", "Minh bạch")</p><p class="mt-2 text-sm text-slate-300">@benefits?.Fields.GetVisibleFieldValue("card2Description", "Tài khoản mới được tạo ở trạng thái hoạt động ngay")</p></div>
                    </div>
                </div>
            </div>

            <div class="flex items-center justify-center" data-animate="zoom-in">
                <div class="w-full max-w-2xl rounded-[2rem] border border-white/60 bg-white/90 p-6 shadow-2xl shadow-sky-950/20 backdrop-blur-xl dark:border-slate-700 dark:bg-slate-900/90 sm:p-8 @ContentPresentationViewHelper.GetSectionTextClass(formIntro)" style="@ContentPresentationViewHelper.GetSectionStyle(formIntro)">
                    <div class="mb-8">
                        <p class="text-sm font-bold uppercase tracking-[0.25em] text-primary" style="@ContentPresentationViewHelper.GetFieldTextStyle(formIntro, "eyebrowText")">@formIntro?.Fields.GetVisibleFieldValue("eyebrowText", "Tạo tài khoản")</p>
                        <h2 class="mt-3 text-3xl font-extrabold text-slate-900 dark:text-white" style="@ContentPresentationViewHelper.GetFieldTextStyle(formIntro, "title")">@formIntro?.Fields.GetVisibleFieldValue("title", "Đăng ký khách hàng")</h2>
                        <p class="mt-3 text-sm leading-7 text-slate-500 dark:text-slate-400" style="@ContentPresentationViewHelper.GetFieldTextStyle(formIntro, "description")">@formIntro?.Fields.GetVisibleFieldValue("description", "Giao diện này được thiết kế đồng bộ với trang đăng nhập để người dùng có trải nghiệm liền mạch.")</p>
                    </div>

                    <form asp-action="Register" method="post" class="space-y-5">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-600 empty:hidden"></div>
                        <div class="grid gap-5 sm:grid-cols-2">
                            <div class="sm:col-span-2"><label asp-for="FullName" class="mb-2 block text-sm font-bold">@formIntro?.Fields.GetVisibleFieldValue("fullNameLabel", "Họ và tên")</label><input asp-for="FullName" class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm shadow-sm dark:border-slate-700 dark:bg-slate-950" placeholder="@(formIntro?.Fields.GetVisibleFieldValue("fullNamePlaceholder", "Nguyễn Văn A"))" /></div>
                            <div><label asp-for="Email" class="mb-2 block text-sm font-bold">@formIntro?.Fields.GetVisibleFieldValue("emailLabel", "Email")</label><input asp-for="Email" class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm shadow-sm dark:border-slate-700 dark:bg-slate-950" placeholder="@(formIntro?.Fields.GetVisibleFieldValue("emailPlaceholder", "email@vidu.com"))" /></div>
                            <div><label asp-for="PhoneNumber" class="mb-2 block text-sm font-bold">@formIntro?.Fields.GetVisibleFieldValue("phoneLabel", "Số điện thoại")</label><input asp-for="PhoneNumber" class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm shadow-sm dark:border-slate-700 dark:bg-slate-950" placeholder="@(formIntro?.Fields.GetVisibleFieldValue("phonePlaceholder", "09xxxxxxxx"))" /></div>
                            <div><label asp-for="Password" class="mb-2 block text-sm font-bold">@formIntro?.Fields.GetVisibleFieldValue("passwordLabel", "Mật khẩu")</label><input asp-for="Password" class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm shadow-sm dark:border-slate-700 dark:bg-slate-950" placeholder="@(formIntro?.Fields.GetVisibleFieldValue("passwordPlaceholder", "Tối thiểu 6 ký tự"))" /></div>
                            <div><label asp-for="ConfirmPassword" class="mb-2 block text-sm font-bold">@formIntro?.Fields.GetVisibleFieldValue("confirmPasswordLabel", "Xác nhận mật khẩu")</label><input asp-for="ConfirmPassword" class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm shadow-sm dark:border-slate-700 dark:bg-slate-950" placeholder="@(formIntro?.Fields.GetVisibleFieldValue("confirmPasswordPlaceholder", "Nhập lại mật khẩu"))" /></div>
                            <div class="sm:col-span-2"><label asp-for="Street" class="mb-2 block text-sm font-bold">@formIntro?.Fields.GetVisibleFieldValue("streetLabel", "Địa chỉ")</label><input asp-for="Street" class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm shadow-sm dark:border-slate-700 dark:bg-slate-950" placeholder="@(formIntro?.Fields.GetVisibleFieldValue("streetPlaceholder", "Số nhà, đường, phường/xã"))" /></div>
                            <div><label asp-for="City" class="mb-2 block text-sm font-bold">@formIntro?.Fields.GetVisibleFieldValue("cityLabel", "Thành phố")</label><input asp-for="City" class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm shadow-sm dark:border-slate-700 dark:bg-slate-950" placeholder="@(formIntro?.Fields.GetVisibleFieldValue("cityPlaceholder", "Hà Nội"))" /></div>
                            <div><label asp-for="Country" class="mb-2 block text-sm font-bold">@formIntro?.Fields.GetVisibleFieldValue("countryLabel", "Quốc gia")</label><input asp-for="Country" class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm shadow-sm dark:border-slate-700 dark:bg-slate-950" placeholder="@(formIntro?.Fields.GetVisibleFieldValue("countryPlaceholder", "Việt Nam"))" /></div>
                        </div>
                        <div class="rounded-2xl bg-slate-50 px-4 py-4 dark:bg-surface-elevated-dark/85">
                            <label class="flex items-start gap-3 text-sm font-medium"><input asp-for="AcceptTerms" class="mt-1 rounded border-slate-300 text-primary" /><span>@formIntro?.Fields.GetVisibleFieldValue("acceptTermsText", "Tôi đồng ý với điều khoản sử dụng và cho phép HV Travel lưu thông tin để phục vụ quá trình tư vấn, đặt tour.")</span></label>
                            <span asp-validation-for="AcceptTerms" class="mt-2 block text-sm text-red-500"></span>
                        </div>
                        <button type="submit" class="inline-flex w-full items-center justify-center gap-2 rounded-2xl bg-primary px-5 py-3.5 text-sm font-extrabold text-white" style="@ContentPresentationViewHelper.GetFieldTextStyle(formIntro, "submitText")">@formIntro?.Fields.GetVisibleFieldValue("submitText", "Tạo tài khoản")</button>
                    </form>

                    <div class="mt-6 flex flex-col gap-3 rounded-2xl border border-slate-200 bg-slate-50 p-4 text-sm text-slate-500 dark:border-slate-700 dark:bg-slate-800/70 dark:text-slate-300 @ContentPresentationViewHelper.GetSectionTextClass(loginPrompt)" style="@ContentPresentationViewHelper.GetSectionStyle(loginPrompt)">
                        <span style="@ContentPresentationViewHelper.GetFieldTextStyle(loginPrompt, "title")">@loginPrompt?.Fields.GetVisibleFieldValue("title", "Đã có tài khoản? Đăng nhập để tiếp tục đặt tour và quản lý hành trình.")</span>
                        <a asp-controller="CustomerAuth" asp-action="Login" class="font-bold text-primary" style="@ContentPresentationViewHelper.GetFieldTextStyle(loginPrompt, "actionText")">@loginPrompt?.Fields.GetVisibleFieldValue("actionText", "Đi đến đăng nhập")</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
