@inject IPublicContentService ContentService
@using HVTravel.Web.Services
@model HVTravel.Web.Models.ServicesHubViewModel
@{
    var request = Model.Request ?? new HVTravel.Web.Models.AncillaryLeadRequestViewModel();
    var sections = await ContentService.GetPageSectionsAsync("services");
    var hero = sections.GetSection("hero");
    var serviceCards = sections.GetSection("serviceCards");
    var quoteFormIntro = sections.GetSection("quoteFormIntro");
    var showServiceCards = serviceCards?.IsEnabled != false;
    var showQuoteForm = quoteFormIntro?.IsEnabled != false;
    var servicesGridClass = showServiceCards && showQuoteForm
        ? "grid gap-8 lg:grid-cols-[1.1fr_0.9fr]"
        : "grid gap-8";

    string ResolveServiceFieldKey(string serviceType, string fieldSuffix)
    {
        var prefix = serviceType switch
        {
            "Flight" => "flight",
            "Hotel" => "hotel",
            "Combo" => "combo",
            "Visa" => "visa",
            _ => string.Empty
        };

        return string.IsNullOrWhiteSpace(prefix)
            ? string.Empty
            : $"{prefix}{fieldSuffix}";
    }

    string ResolveServiceText(string serviceType, string fieldSuffix, string fallback)
    {
        var key = ResolveServiceFieldKey(serviceType, fieldSuffix);
        return string.IsNullOrWhiteSpace(key)
            ? fallback
            : serviceCards?.Fields.GetFieldValue(key, fallback) ?? fallback;
    }

    ViewData["Description"] = hero?.Fields.GetFieldValue("description", "Mô hình mới theo hướng ecosystem: khách để brief nhanh, sales nhận lead ngay, portal vẫn giữ lịch sử yêu cầu và trạng thái xử lý.")
        ?? "Mô hình mới theo hướng ecosystem: khách để brief nhanh, sales nhận lead ngay, portal vẫn giữ lịch sử yêu cầu và trạng thái xử lý.";
}

@if (hero?.IsEnabled != false)
{
    <section class="@($"relative overflow-hidden bg-[radial-gradient(circle_at_top_left,rgba(59,130,246,0.24),transparent_36%),linear-gradient(135deg,#020617_0%,#0f172a_45%,#1e3a8a_100%)] {ContentPresentationViewHelper.GetSectionBackgroundClass(hero)}")" style="@ContentPresentationViewHelper.GetSectionStyle(hero)">
        <div class="absolute inset-0 opacity-20">
            <div class="absolute left-10 top-20 h-72 w-72 rounded-full bg-primary/30 blur-3xl animate-pulse"></div>
            <div class="absolute bottom-10 right-20 h-96 w-96 rounded-full bg-blue-500/20 blur-3xl animate-pulse" style="animation-delay: 1s;"></div>
        </div>
        <div class="relative z-10 mx-auto max-w-7xl px-4 py-24 sm:px-6 sm:py-32 lg:px-8 lg:py-40">
            <div class="mx-auto flex max-w-4xl flex-col items-center text-center @ContentPresentationViewHelper.GetSectionTextClass(hero)" data-animate="fade-up">
                <span class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/10 px-4 py-2 text-xs font-bold uppercase tracking-[0.25em] text-white/90 backdrop-blur-md" style="@ContentPresentationViewHelper.GetFieldTextStyle(hero, "eyebrowText")">
                    <span class="material-symbols-outlined text-[16px] text-primary">package_2</span>
                    @hero.Fields.GetFieldValue("eyebrowText", "Hệ sinh thái dịch vụ")
                </span>
                <h1 class="mt-6 text-4xl font-extrabold leading-tight tracking-tight text-white sm:text-5xl lg:text-6xl" style="@ContentPresentationViewHelper.GetFieldTextStyle(hero, "title")">@hero.Fields.GetFieldValue("title", "Báo giá vé, khách sạn, combo, visa trong một màn hình.")</h1>
                <div class="mt-6 max-w-2xl text-lg leading-relaxed text-slate-300 sm:text-xl" style="@ContentPresentationViewHelper.GetFieldTextStyle(hero, "description")">
                    @Html.Raw(hero.Fields.GetFieldValue("description", "Mô hình mới theo hướng ecosystem: khách để brief nhanh, sales nhận lead ngay, portal vẫn giữ lịch sử yêu cầu và trạng thái xử lý."))
                </div>
            </div>
        </div>
    </section>
}

<section class="py-12 bg-background-light dark:bg-background-dark">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        @if (TempData["ServiceLeadSuccess"] != null)
        {
            <div class="mb-8 rounded-2xl border border-emerald-200 bg-emerald-50 px-5 py-4 text-sm font-semibold text-emerald-700 dark:border-emerald-800 dark:bg-emerald-950/30 dark:text-emerald-300">Yêu cầu đã được ghi nhận. Đội tư vấn sẽ phản hồi trong SLA hiển thị ở admin.</div>
        }

        <div class="@servicesGridClass">
            @if (showServiceCards)
            {
                <div class="space-y-6 @ContentPresentationViewHelper.GetSectionTextClass(serviceCards) @ContentPresentationViewHelper.GetSectionBackgroundClass(serviceCards)" style="@ContentPresentationViewHelper.GetSectionStyle(serviceCards)" data-animate="fade-in" data-stagger>
                    @foreach (var card in Model.ServiceCards)
                    {
                        var titleKey = ResolveServiceFieldKey(card.ServiceType, "Title");
                        var descriptionKey = ResolveServiceFieldKey(card.ServiceType, "Description");
                        <article class="overflow-hidden rounded-[2rem] border border-border-light bg-surface-light shadow-sm dark:border-border-dark dark:bg-surface-dark">
                            <div class="bg-gradient-to-r @card.AccentClass px-6 py-6 text-white">
                                <div class="flex items-center justify-between gap-4">
                                    <div>
                                        <p class="text-xs font-bold uppercase tracking-[0.3em] text-white/70">@card.ServiceType</p>
                                        <h2 class="mt-2 text-2xl font-black" style="@ContentPresentationViewHelper.GetFieldTextStyle(serviceCards, titleKey)">@ResolveServiceText(card.ServiceType, "Title", card.Title)</h2>
                                    </div>
                                    <span class="material-symbols-outlined text-4xl text-white/80">@card.Icon</span>
                                </div>
                            </div>
                            <div class="px-6 py-5">
                                <div class="@($"{ContentPresentationViewHelper.GetRichTextClass(true)} max-w-none text-sm leading-7 text-slate-600 dark:text-slate-300")" style="@ContentPresentationViewHelper.GetFieldTextStyle(serviceCards, descriptionKey)">@Html.Raw(RichTextContentFormatter.ToTrustedHtml(ResolveServiceText(card.ServiceType, "Description", card.Description)))</div>
                            </div>
                        </article>
                    }
                </div>
            }

            @if (showQuoteForm)
            {
                <div class="rounded-[2rem] border border-border-light bg-surface-light p-6 shadow-sm dark:border-border-dark dark:bg-surface-dark @ContentPresentationViewHelper.GetSectionTextClass(quoteFormIntro) @ContentPresentationViewHelper.GetSectionBackgroundClass(quoteFormIntro)" style="@ContentPresentationViewHelper.GetSectionStyle(quoteFormIntro)" data-animate="slide-right">
                    <div class="mb-6">
                        <p class="text-sm font-bold uppercase tracking-[0.3em] text-primary" style="@ContentPresentationViewHelper.GetFieldTextStyle(quoteFormIntro, "eyebrowText")">@quoteFormIntro.Fields.GetFieldValue("eyebrowText", "Quick Brief")</p>
                        <h2 class="text-3xl font-extrabold tracking-tight text-slate-900 dark:text-white mt-3" style="@ContentPresentationViewHelper.GetFieldTextStyle(quoteFormIntro, "title")">@quoteFormIntro.Fields.GetFieldValue("title", "Yêu cầu báo giá")</h2>
                        <div class="mt-3 text-sm leading-7 text-slate-500 dark:text-slate-400" style="@ContentPresentationViewHelper.GetFieldTextStyle(quoteFormIntro, "description")">
                            @Html.Raw(quoteFormIntro.Fields.GetFieldValue("description", "Lead được gắn SLA, phân tuyến admin và giữ lịch sử cho các đợt chăm sóc sau."))
                        </div>
                    </div>

                    <form asp-action="RequestQuote" method="post" enctype="multipart/form-data" class="space-y-4">
                        @Html.AntiForgeryToken()
                        <div>
                            <label asp-for="Request.ServiceType" class="mb-2 block text-sm font-semibold text-slate-700 dark:text-slate-200">Dịch vụ</label>
                            <select asp-for="Request.ServiceType" class="public-select w-full rounded-2xl border border-sky-200/80 bg-white/80 px-4 py-3 text-sm font-bold text-slate-900 shadow-sm shadow-sky-100/50 outline-none transition focus:border-primary focus:ring-4 focus:ring-primary/15 dark:border-border-dark dark:bg-slate-950/70 dark:text-white dark:shadow-black/20">
                                <option value="">Chọn dịch vụ</option>
                                <option value="Flight">Vé máy bay</option>
                                <option value="Hotel">Khách sạn</option>
                                <option value="Combo">Combo</option>
                                <option value="Visa">Visa</option>
                            </select>
                        </div>
                        <div class="grid gap-4 sm:grid-cols-2">
                            <div>
                                <label asp-for="Request.FullName" class="mb-2 block text-sm font-semibold text-slate-700 dark:text-slate-200">Họ tên</label>
                                <input asp-for="Request.FullName" class="w-full rounded-2xl border border-sky-200/80 bg-white/80 px-4 py-3 text-sm font-bold text-slate-900 shadow-sm shadow-sky-100/50 outline-none transition placeholder:text-slate-500 placeholder:font-semibold focus:border-primary focus:ring-4 focus:ring-primary/15 dark:border-border-dark dark:bg-slate-950/70 dark:text-white dark:placeholder:text-slate-400 dark:shadow-black/20" />
                            </div>
                            <div>
                                <label asp-for="Request.Phone" class="mb-2 block text-sm font-semibold text-slate-700 dark:text-slate-200">Số điện thoại</label>
                                <input asp-for="Request.Phone" class="w-full rounded-2xl border border-sky-200/80 bg-white/80 px-4 py-3 text-sm font-bold text-slate-900 shadow-sm shadow-sky-100/50 outline-none transition placeholder:text-slate-500 placeholder:font-semibold focus:border-primary focus:ring-4 focus:ring-primary/15 dark:border-border-dark dark:bg-slate-950/70 dark:text-white dark:placeholder:text-slate-400 dark:shadow-black/20" />
                            </div>
                        </div>
                        <div>
                            <label asp-for="Request.Email" class="mb-2 block text-sm font-semibold text-slate-700 dark:text-slate-200">Email</label>
                            <input asp-for="Request.Email" class="w-full rounded-2xl border border-sky-200/80 bg-white/80 px-4 py-3 text-sm font-bold text-slate-900 shadow-sm shadow-sky-100/50 outline-none transition placeholder:text-slate-500 placeholder:font-semibold focus:border-primary focus:ring-4 focus:ring-primary/15 dark:border-border-dark dark:bg-slate-950/70 dark:text-white dark:placeholder:text-slate-400 dark:shadow-black/20" />
                        </div>
                        <div>
                            <label asp-for="Request.Destination" class="mb-2 block text-sm font-semibold text-slate-700 dark:text-slate-200">Điểm đến / quốc gia</label>
                            <input asp-for="Request.Destination" class="w-full rounded-2xl border border-sky-200/80 bg-white/80 px-4 py-3 text-sm font-bold text-slate-900 shadow-sm shadow-sky-100/50 outline-none transition placeholder:text-slate-500 placeholder:font-semibold focus:border-primary focus:ring-4 focus:ring-primary/15 dark:border-border-dark dark:bg-slate-950/70 dark:text-white dark:placeholder:text-slate-400 dark:shadow-black/20" />
                        </div>
                        <div class="grid gap-4 sm:grid-cols-2">
                            <div>
                                <label asp-for="Request.DepartureDate" class="mb-2 block text-sm font-semibold text-slate-700 dark:text-slate-200">Ngày đi</label>
                                <input asp-for="Request.DepartureDate" type="date" class="w-full rounded-2xl border border-sky-200/80 bg-white/80 px-4 py-3 text-sm font-bold text-slate-900 shadow-sm shadow-sky-100/50 outline-none transition focus:border-primary focus:ring-4 focus:ring-primary/15 dark:border-border-dark dark:bg-slate-950/70 dark:text-white dark:shadow-black/20" />
                            </div>
                            <div>
                                <label asp-for="Request.ReturnDate" class="mb-2 block text-sm font-semibold text-slate-700 dark:text-slate-200">Ngày về</label>
                                <input asp-for="Request.ReturnDate" type="date" class="w-full rounded-2xl border border-sky-200/80 bg-white/80 px-4 py-3 text-sm font-bold text-slate-900 shadow-sm shadow-sky-100/50 outline-none transition focus:border-primary focus:ring-4 focus:ring-primary/15 dark:border-border-dark dark:bg-slate-950/70 dark:text-white dark:shadow-black/20" />
                            </div>
                        </div>
                        <div class="grid gap-4 sm:grid-cols-2">
                            <div>
                                <label asp-for="Request.TravellersCount" class="mb-2 block text-sm font-semibold text-slate-700 dark:text-slate-200">Số khách</label>
                                <input asp-for="Request.TravellersCount" type="number" min="1" class="w-full rounded-2xl border border-sky-200/80 bg-white/80 px-4 py-3 text-sm font-bold text-slate-900 shadow-sm shadow-sky-100/50 outline-none transition placeholder:text-slate-500 placeholder:font-semibold focus:border-primary focus:ring-4 focus:ring-primary/15 dark:border-border-dark dark:bg-slate-950/70 dark:text-white dark:placeholder:text-slate-400 dark:shadow-black/20" />
                            </div>
                            <div>
                                <label asp-for="Request.BudgetText" class="mb-2 block text-sm font-semibold text-slate-700 dark:text-slate-200">Ngân sách</label>
                                <input asp-for="Request.BudgetText" class="w-full rounded-2xl border border-sky-200/80 bg-white/80 px-4 py-3 text-sm font-bold text-slate-900 shadow-sm shadow-sky-100/50 outline-none transition placeholder:text-slate-500 placeholder:font-semibold focus:border-primary focus:ring-4 focus:ring-primary/15 dark:border-border-dark dark:bg-slate-950/70 dark:text-white dark:placeholder:text-slate-400 dark:shadow-black/20" />
                            </div>
                        </div>
                        <div>
                            <label asp-for="Request.RequestNote" class="mb-2 block text-sm font-semibold text-slate-700 dark:text-slate-200">Brief</label>
                            <textarea asp-for="Request.RequestNote" rows="4" class="w-full rounded-2xl border border-sky-200/80 bg-white/80 px-4 py-3 text-sm font-bold text-slate-900 shadow-sm shadow-sky-100/50 outline-none transition placeholder:text-slate-500 placeholder:font-semibold focus:border-primary focus:ring-4 focus:ring-primary/15 dark:border-border-dark dark:bg-slate-950/70 dark:text-white dark:placeholder:text-slate-400 dark:shadow-black/20"></textarea>
                        </div>
                        <button type="submit" class="inline-flex w-full items-center justify-center gap-2 rounded-2xl bg-primary px-5 py-4 text-sm font-bold text-white shadow-lg shadow-primary/20 transition hover:-translate-y-0.5 hover:bg-primary-dark">
                            <span class="material-symbols-outlined text-[18px]">send</span>
                            @quoteFormIntro.Fields.GetFieldValue("submitText", "Gửi yêu cầu báo giá")
                        </button>
                    </form>
                </div>
            }
        </div>
    </div>
</section>

