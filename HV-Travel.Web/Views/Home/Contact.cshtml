@inject IPublicContentService ContentService
@using HVTravel.Web.Services
@model HVTravel.Web.Models.ContactViewModel
@{
    var sections = await ContentService.GetPageSectionsAsync("contact");
    var siteSettings = await ContentService.GetSiteSettingsAsync();
    var hero = sections.GetSection("hero");
    var cards = sections.GetSection("cards");
    var formIntro = sections.GetSection("formIntro");
    var contactGroup = siteSettings.GetGroup("contactInfo");
    var success = TempData["ContactSuccess"] != null;

    var contactAddress = contactGroup?.Fields.GetFieldValue("address", "123 Đường Nguyễn Huệ, Quận 1, TP.HCM") ?? "123 Đường Nguyễn Huệ, Quận 1, TP.HCM";
    var contactPhone = contactGroup?.Fields.GetFieldValue("phoneNumber", "+84 (28) 3822 9999") ?? "+84 (28) 3822 9999";
    var contactEmail = contactGroup?.Fields.GetFieldValue("email", "info@hvtravel.vn") ?? "info@hvtravel.vn";
    var businessHours = contactGroup?.Fields.GetFieldValue("businessHours", "Thứ 2 - Thứ 7: 8:00 - 18:00") ?? "Thứ 2 - Thứ 7: 8:00 - 18:00";
    var mapEmbedUrl = contactGroup?.Fields.GetFieldValue("mapEmbedUrl", "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3919.5177!2d106.7!3d10.7769!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMTDCsDQ2JzM2LjkiTiAxMDbCsDQyJzAwLjAiRQ!5e0!3m2!1svi!2svn!4v1") ?? "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3919.5177!2d106.7!3d10.7769!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMTDCsDQ2JzM2LjkiTiAxMDbCsDQyJzAwLjAiRQ!5e0!3m2!1svi!2svn!4v1";

    ViewData["Title"] = "Liên Hệ";
    ViewData["Description"] = hero?.Fields.GetFieldValue("description", "Liên hệ với HV Travel để được tư vấn và hỗ trợ");
}

@if (hero?.IsEnabled != false)
{
    <section class="@($"relative overflow-hidden bg-[radial-gradient(circle_at_bottom_left,rgba(59,130,246,0.24),transparent_36%),linear-gradient(135deg,#020617_0%,#0f172a_45%,#1e3a8a_100%)] py-20 sm:py-24 {ContentPresentationViewHelper.GetSectionBackgroundClass(hero)}")" style="@ContentPresentationViewHelper.GetSectionStyle(hero)">
        <div class="absolute inset-0 opacity-20">
            <div class="absolute bottom-10 left-20 h-72 w-72 rounded-full bg-primary/30 blur-3xl"></div>
            <div class="absolute top-0 right-12 h-80 w-80 rounded-full bg-cyan-400/15 blur-3xl"></div>
        </div>
        <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
            <div class="@($"mx-auto flex max-w-4xl flex-col items-center text-center {ContentPresentationViewHelper.GetSectionTextClass(hero)}")" data-animate="fade-up">
                <span class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/10 px-4 py-2 text-xs font-bold uppercase tracking-[0.25em] text-white/90 backdrop-blur-md" style="@ContentPresentationViewHelper.GetFieldTextStyle(hero, "badgeText")">
                    <span class="material-symbols-outlined text-[16px] text-primary">call</span>
                    @hero.Fields.GetFieldValue("badgeText", "Liên hệ HV Travel")
                </span>
                <h1 class="mt-6 text-4xl font-extrabold tracking-tight text-white sm:text-5xl lg:text-6xl" style="@ContentPresentationViewHelper.GetFieldTextStyle(hero, "title")">
                    @hero.Fields.GetFieldValue("title", "Chúng tôi luôn sẵn sàng lắng nghe")
                </h1>
                <div class="mt-6 max-w-2xl text-lg leading-relaxed text-slate-300" style="@ContentPresentationViewHelper.GetFieldTextStyle(hero, "description")">
                    @Html.Raw(hero.Fields.GetFieldValue("description", "Liên hệ với HV Travel để được tư vấn hành trình phù hợp và nhận hỗ trợ nhanh chóng."))
                </div>
            </div>
        </div>
    </section>
}

<section class="py-20 bg-background-light dark:bg-background-dark">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid gap-12 lg:grid-cols-5">
            @if (cards?.IsEnabled != false)
            {
                <div class="@($"lg:col-span-2 space-y-6 {ContentPresentationViewHelper.GetSectionTextClass(cards)} {ContentPresentationViewHelper.GetSectionBackgroundClass(cards)}")" style="@ContentPresentationViewHelper.GetSectionStyle(cards)" data-animate="slide-left" data-stagger>
                    <div class="p-6 rounded-2xl bg-surface-light dark:bg-surface-dark shadow-sm border border-border-light dark:border-border-dark hover:border-primary/30 hover:shadow-lg transition-all group">
                        <div class="flex items-start gap-4">
                            <div class="size-12 shrink-0 rounded-xl bg-primary/10 text-primary flex items-center justify-center group-hover:bg-primary group-hover:text-white transition-all">
                                <span class="material-symbols-outlined text-[24px]">location_on</span>
                            </div>
                            <div>
                                <h3 class="text-sm font-bold text-slate-900 dark:text-white mb-1" style="@ContentPresentationViewHelper.GetFieldTextStyle(cards, "addressTitle")">@cards.Fields.GetFieldValue("addressTitle", "Địa Chỉ")</h3>
                                <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed">@contactAddress</p>
                            </div>
                        </div>
                    </div>
                    <div class="p-6 rounded-2xl bg-surface-light dark:bg-surface-dark shadow-sm border border-border-light dark:border-border-dark hover:border-primary/30 hover:shadow-lg transition-all group">
                        <div class="flex items-start gap-4">
                            <div class="size-12 shrink-0 rounded-xl bg-primary/10 text-primary flex items-center justify-center group-hover:bg-primary group-hover:text-white transition-all">
                                <span class="material-symbols-outlined text-[24px]">call</span>
                            </div>
                            <div>
                                <h3 class="text-sm font-bold text-slate-900 dark:text-white mb-1" style="@ContentPresentationViewHelper.GetFieldTextStyle(cards, "phoneTitle")">@cards.Fields.GetFieldValue("phoneTitle", "Điện Thoại")</h3>
                                <a class="text-sm text-slate-500 dark:text-slate-400 hover:text-primary transition-colors" href="tel:@contactPhone">@contactPhone</a>
                            </div>
                        </div>
                    </div>
                    <div class="p-6 rounded-2xl bg-surface-light dark:bg-surface-dark shadow-sm border border-border-light dark:border-border-dark hover:border-primary/30 hover:shadow-lg transition-all group">
                        <div class="flex items-start gap-4">
                            <div class="size-12 shrink-0 rounded-xl bg-primary/10 text-primary flex items-center justify-center group-hover:bg-primary group-hover:text-white transition-all">
                                <span class="material-symbols-outlined text-[24px]">mail</span>
                            </div>
                            <div>
                                <h3 class="text-sm font-bold text-slate-900 dark:text-white mb-1" style="@ContentPresentationViewHelper.GetFieldTextStyle(cards, "emailTitle")">@cards.Fields.GetFieldValue("emailTitle", "Email")</h3>
                                <a class="text-sm text-slate-500 dark:text-slate-400 hover:text-primary transition-colors" href="mailto:@contactEmail">@contactEmail</a>
                            </div>
                        </div>
                    </div>
                    <div class="p-6 rounded-2xl bg-surface-light dark:bg-surface-dark shadow-sm border border-border-light dark:border-border-dark hover:border-primary/30 hover:shadow-lg transition-all group">
                        <div class="flex items-start gap-4">
                            <div class="size-12 shrink-0 rounded-xl bg-primary/10 text-primary flex items-center justify-center group-hover:bg-primary group-hover:text-white transition-all">
                                <span class="material-symbols-outlined text-[24px]">schedule</span>
                            </div>
                            <div>
                                <h3 class="text-sm font-bold text-slate-900 dark:text-white mb-1" style="@ContentPresentationViewHelper.GetFieldTextStyle(cards, "hoursTitle")">@cards.Fields.GetFieldValue("hoursTitle", "Giờ Làm Việc")</h3>
                                <p class="text-sm text-slate-500 dark:text-slate-400">@businessHours</p>
                            </div>
                        </div>
                    </div>
                </div>
            }

            @if (formIntro?.IsEnabled != false)
            {
                <div class="lg:col-span-3" data-animate="slide-right">
                    <div class="@($"rounded-2xl border border-border-light bg-surface-light p-8 shadow-sm dark:border-border-dark dark:bg-surface-dark {ContentPresentationViewHelper.GetSectionTextClass(formIntro)} {ContentPresentationViewHelper.GetSectionBackgroundClass(formIntro)}")" style="@ContentPresentationViewHelper.GetSectionStyle(formIntro)">
                        <h2 class="text-2xl font-extrabold text-slate-900 dark:text-white mb-2" style="@ContentPresentationViewHelper.GetFieldTextStyle(formIntro, "title")">@formIntro.Fields.GetFieldValue("title", "Gửi Tin Nhắn Cho Chúng Tôi")</h2>
                        <div class="text-sm text-slate-500 dark:text-slate-400 mb-8" style="@ContentPresentationViewHelper.GetFieldTextStyle(formIntro, "description")">
                            @Html.Raw(formIntro.Fields.GetFieldValue("description", "Điền thông tin của bạn và đội ngũ HV Travel sẽ phản hồi trong thời gian sớm nhất."))
                        </div>

                        @if (success)
                        {
                            <div class="mb-6 rounded-2xl border border-emerald-200 bg-emerald-50 px-4 py-4 text-sm text-emerald-700 dark:border-emerald-900/40 dark:bg-emerald-900/20 dark:text-emerald-200">
                                Chúng tôi đã nhận được thông tin của bạn và đã gửi thông báo nội bộ thành công. HV Travel sẽ liên hệ lại sớm nhất.
                            </div>
                        }

                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div asp-validation-summary="ModelOnly" class="mb-6 rounded-2xl border border-amber-200 bg-amber-50 px-4 py-4 text-sm text-amber-700 dark:border-amber-900/40 dark:bg-amber-900/20 dark:text-amber-200"></div>
                        }

                        <form id="contact-form" asp-action="Contact" method="post" class="space-y-6">
                            @Html.AntiForgeryToken()
                            <div class="grid sm:grid-cols-2 gap-6">
                                <div>
                                    <label asp-for="FullName" class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-2">Họ và Tên <span class="text-red-500">*</span></label>
                                    <input asp-for="FullName" placeholder="Nhập họ và tên" class="w-full px-4 py-3 rounded-xl border border-border-light dark:border-border-dark bg-surface-muted-light dark:bg-surface-elevated-dark text-slate-900 dark:text-white text-sm focus:ring-2 focus:ring-primary/30 focus:border-primary outline-none transition-all" />
                                    <span asp-validation-for="FullName" class="mt-2 block text-sm text-red-500"></span>
                                </div>
                                <div>
                                    <label asp-for="PhoneNumber" class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-2">Số Điện Thoại <span class="text-red-500">*</span></label>
                                    <input asp-for="PhoneNumber" type="tel" placeholder="Nhập số điện thoại" class="w-full px-4 py-3 rounded-xl border border-border-light dark:border-border-dark bg-surface-muted-light dark:bg-surface-elevated-dark text-slate-900 dark:text-white text-sm focus:ring-2 focus:ring-primary/30 focus:border-primary outline-none transition-all" />
                                    <span asp-validation-for="PhoneNumber" class="mt-2 block text-sm text-red-500"></span>
                                </div>
                            </div>
                            <div>
                                <label asp-for="Email" class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-2">Email <span class="text-red-500">*</span></label>
                                <input asp-for="Email" type="email" placeholder="Nhập địa chỉ email" class="w-full px-4 py-3 rounded-xl border border-border-light dark:border-border-dark bg-surface-muted-light dark:bg-surface-elevated-dark text-slate-900 dark:text-white text-sm focus:ring-2 focus:ring-primary/30 focus:border-primary outline-none transition-all" />
                                <span asp-validation-for="Email" class="mt-2 block text-sm text-red-500"></span>
                            </div>
                            <div>
                                <label asp-for="Subject" class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-2">Chủ Đề</label>
                                <select asp-for="Subject" class="w-full px-4 py-3 rounded-xl border border-border-light dark:border-border-dark bg-surface-muted-light dark:bg-surface-elevated-dark text-slate-900 dark:text-white text-sm focus:ring-2 focus:ring-primary/30 focus:border-primary outline-none transition-all">
                                    <option value="Tư vấn tour du lịch">Tư vấn tour du lịch</option>
                                    <option value="Đặt tour">Đặt tour</option>
                                    <option value="Khiếu nại / Góp ý">Khiếu nại / Góp ý</option>
                                    <option value="Hợp tác kinh doanh">Hợp tác kinh doanh</option>
                                    <option value="Khác">Khác</option>
                                </select>
                            </div>
                            <div>
                                <label asp-for="Message" class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-2">Nội Dung <span class="text-red-500">*</span></label>
                                <textarea asp-for="Message" rows="5" placeholder="Nhập nội dung tin nhắn..." class="w-full px-4 py-3 rounded-xl border border-border-light dark:border-border-dark bg-surface-muted-light dark:bg-surface-elevated-dark text-slate-900 dark:text-white text-sm focus:ring-2 focus:ring-primary/30 focus:border-primary outline-none transition-all resize-none"></textarea>
                                <span asp-validation-for="Message" class="mt-2 block text-sm text-red-500"></span>
                            </div>
                            <button type="submit" class="w-full sm:w-auto inline-flex items-center justify-center gap-2 bg-primary hover:bg-primary-dark text-white px-8 py-3.5 rounded-xl text-sm font-bold shadow-lg shadow-primary/25 hover:shadow-primary/40 transition-all active:scale-95">
                                <span class="material-symbols-outlined text-[18px]">send</span>
                                @formIntro.Fields.GetFieldValue("submitText", "Gửi Tin Nhắn")
                            </button>
                        </form>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<section class="bg-surface-light dark:bg-surface-dark">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-20">
        <div class="rounded-2xl overflow-hidden shadow-sm border border-border-light dark:border-border-dark" data-animate="scale-in">
            <iframe
                src="@mapEmbedUrl"
                width="100%" height="400" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"
                class="w-full"></iframe>
        </div>
    </div>
</section>
