@inject IPublicContentService ContentService
@{
    var sections = await ContentService.GetPageSectionsAsync("about");
    var hero = sections.GetSection("hero");
    var story = sections.GetSection("story");
    var missionVision = sections.GetSection("missionVision");
    var team = sections.GetSection("team");

    ViewData["Title"] = "Gioi Thieu";
    ViewData["Description"] = hero?.Fields.GetFieldValue("description", "Tim hieu ve HV Travel - Don vi du lich hang dau Viet Nam");
}

@if (hero?.IsEnabled != false)
{
    <section class="hero-gradient relative overflow-hidden">
        <div class="absolute inset-0 opacity-15">
            <div class="absolute top-20 right-20 w-72 h-72 bg-primary/30 rounded-full blur-3xl"></div>
        </div>
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-28 relative z-10 text-center" data-animate="fade-up">
            <span class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-md text-white/90 text-xs font-semibold px-4 py-2 rounded-full mb-6 border border-white/10">
                <span class="material-symbols-outlined text-primary text-[16px]">info</span>
                @hero.Fields.GetFieldValue("badgeText", "Ve Chung Toi")
            </span>
            <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white leading-tight mb-6">
                @hero.Fields.GetFieldValue("titleLine1", "Cau Chuyen")
                <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-cyan-300">@hero.Fields.GetFieldValue("titleHighlight", "HV Travel")</span>
            </h1>
            <p class="text-lg text-slate-300 max-w-2xl mx-auto">@hero.Fields.GetFieldValue("description", "Dong hanh cung ban tren moi hanh trinh kham pha ve dep Viet Nam")</p>
        </div>
    </section>
}

@if (story?.IsEnabled != false)
{
    <section class="py-20 bg-background-light dark:bg-background-dark">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid lg:grid-cols-2 gap-16 items-center">
                <div data-animate="slide-left">
                    <span class="inline-flex items-center gap-2 bg-primary/10 text-primary text-xs font-bold px-4 py-2 rounded-full mb-6 uppercase tracking-wider">
                        <span class="material-symbols-outlined text-[16px]">history</span> Câu chuyện của chúng tôi
                    </span>
                    <h2 class="text-3xl sm:text-4xl font-extrabold text-slate-900 dark:text-white mb-6 leading-tight">@story.Fields.GetFieldValue("title", "Hon 10 Nam Kinh Nghiem Trong Nganh Du Lich")</h2>
                    <p class="text-slate-600 dark:text-slate-400 mb-6 leading-relaxed">
                        @story.Fields.GetFieldValue("description1", "HV Travel duoc thanh lap voi niem dam me mang den nhung trai nghiem du lich tuyet voi nhat cho du khach.")
                    </p>
                    <p class="text-slate-600 dark:text-slate-400 mb-8 leading-relaxed">
                        @story.Fields.GetFieldValue("description2", "Chung toi tin rang moi chuyen di khong chi la mot hanh trinh den noi moi, ma con la co hoi de kham pha ban than, ket noi voi van hoa va con nguoi.")
                    </p>
                    <div class="grid grid-cols-2 gap-6" data-animate="fade-up" data-stagger data-delay="200">
                        <div class="p-4 rounded-2xl bg-white dark:bg-slate-800 shadow-sm border border-slate-100 dark:border-slate-700">
                            <p class="text-3xl font-extrabold text-primary mb-1">10+</p>
                            <p class="text-sm font-medium text-slate-500 dark:text-slate-400">Năm hoạt động</p>
                        </div>
                        <div class="p-4 rounded-2xl bg-white dark:bg-slate-800 shadow-sm border border-slate-100 dark:border-slate-700">
                            <p class="text-3xl font-extrabold text-primary mb-1">50+</p>
                            <p class="text-sm font-medium text-slate-500 dark:text-slate-400">Nhân viên</p>
                        </div>
                        <div class="p-4 rounded-2xl bg-white dark:bg-slate-800 shadow-sm border border-slate-100 dark:border-slate-700">
                            <p class="text-3xl font-extrabold text-primary mb-1">10K+</p>
                            <p class="text-sm font-medium text-slate-500 dark:text-slate-400">Khách hàng</p>
                        </div>
                        <div class="p-4 rounded-2xl bg-white dark:bg-slate-800 shadow-sm border border-slate-100 dark:border-slate-700">
                            <p class="text-3xl font-extrabold text-primary mb-1">4.9*</p>
                            <p class="text-sm font-medium text-slate-500 dark:text-slate-400">Đánh giá</p>
                        </div>
                    </div>
                </div>
                <div class="relative" data-animate="slide-right">
                    <div class="aspect-[4/5] rounded-3xl bg-gradient-to-br from-primary/20 to-blue-500/20 flex items-center justify-center overflow-hidden">
                        <span class="material-symbols-outlined text-[120px] text-primary/30">landscape</span>
                    </div>
                    <div class="absolute -bottom-6 -left-6 bg-white dark:bg-slate-800 rounded-2xl shadow-2xl p-6 border border-slate-100 dark:border-slate-700">
                        <div class="flex items-center gap-3">
                            <div class="size-12 rounded-xl bg-primary/10 text-primary flex items-center justify-center">
                                <span class="material-symbols-outlined">workspace_premium</span>
                            </div>
                            <div>
                                <p class="text-2xl font-extrabold text-slate-900 dark:text-white">Top 10</p>
                                <p class="text-xs font-medium text-slate-500">Công ty du lịch uy tín</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
}

@if (missionVision?.IsEnabled != false)
{
    <section class="py-20 bg-white dark:bg-slate-900">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center mb-14" data-animate="fade-up">
                <h2 class="text-3xl sm:text-4xl font-extrabold text-slate-900 dark:text-white mb-4">@missionVision.Fields.GetFieldValue("title", "Su Menh & Tam Nhin")</h2>
            </div>
            <div class="grid md:grid-cols-3 gap-8" data-animate="fade-in" data-stagger>
                <div class="p-8 rounded-2xl bg-slate-50 dark:bg-slate-800/50 border border-slate-100 dark:border-slate-700 hover:border-primary/30 transition-all group text-center">
                    <div class="size-16 mx-auto mb-6 rounded-2xl bg-primary/10 text-primary flex items-center justify-center group-hover:bg-primary group-hover:text-white transition-all">
                        <span class="material-symbols-outlined text-[28px]">flag</span>
                    </div>
                    <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-3">@missionVision.Fields.GetFieldValue("missionTitle", "Su Menh")</h3>
                    <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">@missionVision.Fields.GetFieldValue("missionText", "Mang den nhung hanh trinh duoc ca nhan hoa, an toan va giau cam xuc cho moi du khach.")</p>
                </div>
                <div class="p-8 rounded-2xl bg-slate-50 dark:bg-slate-800/50 border border-slate-100 dark:border-slate-700 hover:border-primary/30 transition-all group text-center">
                    <div class="size-16 mx-auto mb-6 rounded-2xl bg-primary/10 text-primary flex items-center justify-center group-hover:bg-primary group-hover:text-white transition-all">
                        <span class="material-symbols-outlined text-[28px]">visibility</span>
                    </div>
                    <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-3">@missionVision.Fields.GetFieldValue("visionTitle", "Tam Nhin")</h3>
                    <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">@missionVision.Fields.GetFieldValue("visionText", "Tro thanh thuong hieu du lich duoc tin yeu hang dau cho nhung chuyen di kham pha Viet Nam.")</p>
                </div>
                <div class="p-8 rounded-2xl bg-slate-50 dark:bg-slate-800/50 border border-slate-100 dark:border-slate-700 hover:border-primary/30 transition-all group text-center">
                    <div class="size-16 mx-auto mb-6 rounded-2xl bg-primary/10 text-primary flex items-center justify-center group-hover:bg-primary group-hover:text-white transition-all">
                        <span class="material-symbols-outlined text-[28px]">favorite</span>
                    </div>
                    <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-3">@missionVision.Fields.GetFieldValue("valuesTitle", "Gia Tri Cot Loi")</h3>
                    <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">@missionVision.Fields.GetFieldValue("valuesText", "Tan tam, minh bach, sang tao va luon lay trai nghiem khach hang lam trung tam.")</p>
                </div>
            </div>
        </div>
    </section>
}

@if (team?.IsEnabled != false)
{
    <section class="py-20 bg-background-light dark:bg-background-dark">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center mb-14" data-animate="fade-up">
                <span class="inline-flex items-center gap-2 bg-primary/10 text-primary text-xs font-bold px-4 py-2 rounded-full mb-4 uppercase tracking-wider">
                    <span class="material-symbols-outlined text-[16px]">groups</span> Đội ngũ
                </span>
                <h2 class="text-3xl sm:text-4xl font-extrabold text-slate-900 dark:text-white mb-4">@team.Fields.GetFieldValue("title", "Nhung Con Nguoi Dang Sau HV Travel")</h2>
                <p class="text-slate-500 dark:text-slate-400 max-w-2xl mx-auto">@team.Fields.GetFieldValue("description", "Đội ngũ tạo nên các hành trình chín chu và giàu cảm hứng cho từng chuyến đi.")</p>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8" data-animate="fade-in" data-stagger>
                @{
                    var teamMembers = new[]
                    {
                        new { Name = team.Fields.GetFieldValue("member1Name", "Nguyen Hoang Vu"), Role = team.Fields.GetFieldValue("member1Role", "Nha Sang Lap"), Icon = "person" },
                        new { Name = team.Fields.GetFieldValue("member2Name", "Le Minh Duc"), Role = team.Fields.GetFieldValue("member2Role", "Truong Phong Tour"), Icon = "manage_accounts" },
                        new { Name = team.Fields.GetFieldValue("member3Name", "Tran Khanh Linh"), Role = team.Fields.GetFieldValue("member3Role", "Cham Soc Khach Hang"), Icon = "support_agent" },
                        new { Name = team.Fields.GetFieldValue("member4Name", "Pham Gia Hung"), Role = team.Fields.GetFieldValue("member4Role", "Dieu Hanh Tour"), Icon = "map" }
                    };
                }
                @foreach (var member in teamMembers)
                {
                    <div class="text-center group">
                        <div class="size-32 mx-auto mb-5 rounded-3xl bg-gradient-to-br from-primary/20 to-blue-500/20 flex items-center justify-center group-hover:from-primary group-hover:to-blue-500 transition-all duration-500">
                            <span class="material-symbols-outlined text-[48px] text-primary/60 group-hover:text-white transition-all">@member.Icon</span>
                        </div>
                        <h4 class="text-base font-bold text-slate-900 dark:text-white mb-1">@member.Name</h4>
                        <p class="text-sm text-primary font-medium">@member.Role</p>
                    </div>
                }
            </div>
        </div>
    </section>
}
