@inject IPublicContentService ContentService
@using HVTravel.Web.Services
@{
    var sections = await ContentService.GetPageSectionsAsync("about");
    var hero = sections.GetSection("hero");
    var heroFields = hero?.Fields;
    var story = sections.GetSection("story");
    var storyFields = story?.Fields;
    var values = sections.GetSection("values");
    var valuesFields = values?.Fields;
    var stats = sections.GetSection("stats");
    var statsFields = stats?.Fields;
    var team = sections.GetSection("team");
    var teamFields = team?.Fields;
    var cta = sections.GetSection("cta");
    var ctaFields = cta?.Fields;

    ViewData["Title"] = "Giới Thiệu";
    ViewData["Description"] = heroFields?.GetFieldValue("description", "HV Travel là đối tác tin cậy trong hành trình khám phá thế giới của bạn, với 15+ năm kinh nghiệm.")
        ?? "Tìm hiểu về HV Travel - Đơn vị du lịch hàng đầu Việt Nam";
}

@if (hero?.IsEnabled != false)
{
    <section class="@($"public-top-section public-top-section--hero public-page-hero hero-gradient relative overflow-hidden {ContentPresentationViewHelper.GetSectionBackgroundClass(hero)}")" style="@ContentPresentationViewHelper.GetSectionStyle(hero)">
        <div class="absolute inset-0 opacity-20">
            <div class="absolute top-20 right-20 h-72 w-72 rounded-full bg-primary/30 blur-3xl"></div>
            <div class="absolute bottom-0 left-10 h-80 w-80 rounded-full bg-cyan-400/15 blur-3xl"></div>
        </div>
        <div class="public-top-section-shell public-page-hero-shell max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="@($"public-top-section-content public-page-hero-content is-centered {ContentPresentationViewHelper.GetSectionTextClass(hero)}")" data-animate="fade-up">
                <span class="public-badge public-top-section-badge public-page-hero-badge" style="@ContentPresentationViewHelper.GetFieldTextStyle(hero, "badgeText")">
                    <span class="material-symbols-outlined text-[16px] text-primary">info</span>
                    @heroFields?.GetFieldValue("badgeText", "Về chúng tôi")
                </span>
                <h1 class="public-top-section-title public-hero-title text-white" style="@ContentPresentationViewHelper.GetFieldTextStyle(hero, "title")">@heroFields?.GetFieldValue("title", "Chúng tôi giúp bạn đi xa hơn, an tâm hơn.")</h1>
                <div class="public-top-section-lead public-body-copy public-page-hero-copy" style="@ContentPresentationViewHelper.GetFieldTextStyle(hero, "description")">
                    @Html.Raw(heroFields?.GetFieldValue("description", "Hơn 15 năm qua, HV Travel giúp 50,000+ du khách khám phá 5 châu lục an toàn và trọn vẹn."))
                </div>
            </div>
        </div>
    </section>
}

@if (story?.IsEnabled != false)
{
    <section class="@($"py-20 bg-background-light dark:bg-background-dark {ContentPresentationViewHelper.GetSectionBackgroundClass(story)}")" style="@ContentPresentationViewHelper.GetSectionStyle(story)">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid lg:grid-cols-2 gap-16 items-center">
                <div class="@ContentPresentationViewHelper.GetSectionTextClass(story)" data-animate="slide-left">
                    <span class="public-badge inline-flex items-center gap-2 bg-primary/10 text-primary text-xs font-bold px-4 py-2 rounded-full mb-6 uppercase tracking-wider" style="@ContentPresentationViewHelper.GetRoleTextStyle(story, "eyebrow")">
                        <span class="material-symbols-outlined text-[16px]">history</span> Câu chuyện của chúng tôi
                    </span>
                    <h2 class="public-section-title text-3xl sm:text-4xl font-extrabold text-slate-900 dark:text-white mb-6 leading-tight" style="@ContentPresentationViewHelper.GetFieldTextStyle(story, "title")">@storyFields?.GetFieldValue("title", "Hơn 10 năm kinh nghiệm trong ngành du lịch")</h2>
                    <div class="text-slate-600 dark:text-slate-400 mb-6 leading-relaxed" style="@ContentPresentationViewHelper.GetFieldTextStyle(story, "description1")">
                        @Html.Raw(storyFields?.GetFieldValue("description1", "HV Travel được thành lập với niềm đam mê mang đến những trải nghiệm du lịch tuyệt vời nhất cho du khách."))
                    </div>
                    <div class="text-slate-600 dark:text-slate-400 mb-8 leading-relaxed" style="@ContentPresentationViewHelper.GetFieldTextStyle(story, "description2")">
                        @Html.Raw(storyFields?.GetFieldValue("description2", "Chúng tôi tin rằng mỗi chuyến đi không chỉ là một hành trình đến nơi mới, mà còn là cơ hội để khám phá bản thân, kết nối với văn hóa và con người."))
                    </div>
                </div>
                <div class="relative" data-animate="slide-right">
                    <div class="aspect-[4/5] rounded-3xl bg-gradient-to-br from-primary/20 to-blue-500/20 flex items-center justify-center overflow-hidden">
                        <span class="material-symbols-outlined text-[120px] text-primary/30">landscape</span>
                    </div>
                    <div class="absolute -bottom-6 -left-6 bg-surface-light dark:bg-surface-dark rounded-2xl shadow-2xl p-6 border border-border-light dark:border-border-dark">
                        <div class="flex items-center gap-3">
                            <div class="size-12 rounded-xl bg-primary/10 text-primary flex items-center justify-center">
                                <span class="material-symbols-outlined">workspace_premium</span>
                            </div>
                            <div>
                                <p class="text-2xl font-extrabold text-slate-900 dark:text-white">Top 10</p>
                                <p class="text-xs font-medium text-slate-500">Công ty du lịch uy tín</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
}

@if (stats?.IsEnabled != false)
{
    <section class="@($"py-20 bg-surface-light dark:bg-surface-dark {ContentPresentationViewHelper.GetSectionBackgroundClass(stats)}")" style="@ContentPresentationViewHelper.GetSectionStyle(stats)">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 @ContentPresentationViewHelper.GetSectionTextClass(stats)">
            <div class="public-card-grid grid md:grid-cols-4 gap-8" data-animate="fade-in" data-stagger>
                <div class="p-8 rounded-2xl bg-surface-muted-light dark:bg-surface-elevated-dark/70 border border-border-light dark:border-border-dark hover:border-primary/30 transition-all group text-center">
                    <p class="text-[3rem] font-black text-teal-900 dark:text-white" style="@ContentPresentationViewHelper.GetFieldTextStyle(stats, "s1_val")">@statsFields?.GetFieldValue("s1_val", "15+")</p>
                    <p class="mt-2 text-sm font-semibold tracking-wide text-teal-800 dark:text-teal-200" style="@ContentPresentationViewHelper.GetFieldTextStyle(stats, "s1_label")">@statsFields?.GetFieldValue("s1_label", "Năm kinh nghiệm")</p>
                </div>
                <div class="p-8 rounded-2xl bg-surface-muted-light dark:bg-surface-elevated-dark/70 border border-border-light dark:border-border-dark hover:border-primary/30 transition-all group text-center">
                    <p class="text-[3rem] font-black text-teal-900 dark:text-white" style="@ContentPresentationViewHelper.GetFieldTextStyle(stats, "s2_val")">@statsFields?.GetFieldValue("s2_val", "50K+")</p>
                    <p class="mt-2 text-sm font-semibold tracking-wide text-teal-800 dark:text-teal-200" style="@ContentPresentationViewHelper.GetFieldTextStyle(stats, "s2_label")">@statsFields?.GetFieldValue("s2_label", "Khách hàng")</p>
                </div>
                <div class="p-8 rounded-2xl bg-surface-muted-light dark:bg-surface-elevated-dark/70 border border-border-light dark:border-border-dark hover:border-primary/30 transition-all group text-center">
                    <p class="text-[3rem] font-black text-teal-900 dark:text-white" style="@ContentPresentationViewHelper.GetFieldTextStyle(stats, "s3_val")">@statsFields?.GetFieldValue("s3_val", "100+")</p>
                    <p class="mt-2 text-sm font-semibold tracking-wide text-teal-800 dark:text-teal-200" style="@ContentPresentationViewHelper.GetFieldTextStyle(stats, "s3_label")">@statsFields?.GetFieldValue("s3_label", "Điểm đến")</p>
                </div>
                <div class="p-8 rounded-2xl bg-surface-muted-light dark:bg-surface-elevated-dark/70 border border-border-light dark:border-border-dark hover:border-primary/30 transition-all group text-center">
                    <p class="text-[3rem] font-black text-teal-900 dark:text-white" style="@ContentPresentationViewHelper.GetFieldTextStyle(stats, "s4_val")">@statsFields?.GetFieldValue("s4_val", "98%")</p>
                    <p class="mt-2 text-sm font-semibold tracking-wide text-teal-800 dark:text-teal-200" style="@ContentPresentationViewHelper.GetFieldTextStyle(stats, "s4_label")">@statsFields?.GetFieldValue("s4_label", "Hài lòng dịch vụ")</p>
                </div>
            </div>
        </div>
    </section>
}

@if (values?.IsEnabled != false)
{
    <section class="@($"py-20 bg-background-light dark:bg-background-dark {ContentPresentationViewHelper.GetSectionBackgroundClass(values)}")" style="@ContentPresentationViewHelper.GetSectionStyle(values)">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 @ContentPresentationViewHelper.GetSectionTextClass(values)">
            <div class="text-center mb-14" data-animate="fade-up">
                <h2 class="public-section-title text-center" style="@ContentPresentationViewHelper.GetFieldTextStyle(values, "title")">@valuesFields?.GetFieldValue("title", "Giá trị cốt lõi")</h2>
                <p class="mx-auto mt-4 max-w-2xl text-center text-sm leading-8 text-slate-500 dark:text-slate-400" style="@ContentPresentationViewHelper.GetFieldTextStyle(values, "description")">
                    @Html.Raw(valuesFields?.GetFieldValue("description", "Kim chỉ nam trong mọi quyết định và hành động của đội ngũ HV Travel."))
                </p>
            </div>
            <div class="public-card-grid grid md:grid-cols-3 gap-8" data-animate="fade-in" data-stagger>
                <div class="p-8 rounded-2xl bg-surface-muted-light dark:bg-surface-elevated-dark/70 border border-border-light dark:border-border-dark hover:border-primary/30 transition-all group text-center">
                    <h3 class="mt-4 text-base font-black text-slate-900 dark:text-white" style="@ContentPresentationViewHelper.GetFieldTextStyle(values, "v1_title")">@valuesFields?.GetFieldValue("v1_title", "Trải nghiệm cá nhân hóa")</h3>
                    <p class="mt-2 text-sm leading-7 text-slate-500 dark:text-slate-400" style="@ContentPresentationViewHelper.GetFieldTextStyle(values, "v1_desc")">@valuesFields?.GetFieldValue("v1_desc", "Mỗi chuyến đi được thiết kế riêng phù hợp với gu du lịch của từng khách hàng.")</p>
                </div>
                <div class="p-8 rounded-2xl bg-surface-muted-light dark:bg-surface-elevated-dark/70 border border-border-light dark:border-border-dark hover:border-primary/30 transition-all group text-center">
                    <h3 class="mt-4 text-base font-black text-slate-900 dark:text-white" style="@ContentPresentationViewHelper.GetFieldTextStyle(values, "v2_title")">@valuesFields?.GetFieldValue("v2_title", "An toàn tuyệt đối")</h3>
                    <p class="mt-2 text-sm leading-7 text-slate-500 dark:text-slate-400" style="@ContentPresentationViewHelper.GetFieldTextStyle(values, "v2_desc")">@valuesFields?.GetFieldValue("v2_desc", "Chúng tôi ưu tiên sự an toàn của khách hàng lên hàng đầu trong mọi hành trình.")</p>
                </div>
                <div class="p-8 rounded-2xl bg-surface-muted-light dark:bg-surface-elevated-dark/70 border border-border-light dark:border-border-dark hover:border-primary/30 transition-all group text-center">
                    <h3 class="mt-4 text-base font-black text-slate-900 dark:text-white" style="@ContentPresentationViewHelper.GetFieldTextStyle(values, "v3_title")">@valuesFields?.GetFieldValue("v3_title", "Tận tâm phục vụ")</h3>
                    <p class="mt-2 text-sm leading-7 text-slate-500 dark:text-slate-400" style="@ContentPresentationViewHelper.GetFieldTextStyle(values, "v3_desc")">@valuesFields?.GetFieldValue("v3_desc", "Đội ngũ hỗ trợ 24/7 luôn sẵn sàng đồng hành cùng bạn mọi lúc mọi nơi.")</p>
                </div>
            </div>
        </div>
    </section>
}

@if (team?.IsEnabled != false)
{
    <section class="@($"py-20 bg-background-light dark:bg-background-dark {ContentPresentationViewHelper.GetSectionBackgroundClass(team)}")" style="@ContentPresentationViewHelper.GetSectionStyle(team)">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 @ContentPresentationViewHelper.GetSectionTextClass(team)">
            <div class="text-center mb-14" data-animate="fade-up">
                <span class="inline-flex items-center gap-2 bg-primary/10 text-primary text-xs font-bold px-4 py-2 rounded-full mb-4 uppercase tracking-wider" style="@ContentPresentationViewHelper.GetRoleTextStyle(team, "eyebrow")">
                    <span class="material-symbols-outlined text-[16px]">groups</span> Đội ngũ
                </span>
                <h2 class="public-section-title text-3xl sm:text-4xl font-extrabold text-slate-900 dark:text-white mb-4" style="@ContentPresentationViewHelper.GetFieldTextStyle(team, "title")">@teamFields?.GetFieldValue("title", "Những con người đằng sau HV Travel")</h2>
                <div class="text-slate-500 dark:text-slate-400 max-w-2xl mx-auto" style="@ContentPresentationViewHelper.GetFieldTextStyle(team, "description")">
                    @Html.Raw(teamFields?.GetFieldValue("description", "Đội ngũ tạo nên các hành trình chỉn chu và giàu cảm hứng cho từng chuyến đi."))
                </div>
            </div>
            <div class="public-card-grid grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8" data-animate="fade-in" data-stagger>
                @{
                    var teamMembers = new[]
                    {
                        new { Name = teamFields?.GetFieldValue("member1Name", "Nguyen Hoang Vu"), Role = teamFields?.GetFieldValue("member1Role", "Nhà sáng lập"), Icon = "person", NameKey = "member1Name", RoleKey = "member1Role" },
                        new { Name = teamFields?.GetFieldValue("member2Name", "Le Minh Duc"), Role = teamFields?.GetFieldValue("member2Role", "Trưởng phòng tour"), Icon = "manage_accounts", NameKey = "member2Name", RoleKey = "member2Role" },
                        new { Name = teamFields?.GetFieldValue("member3Name", "Tran Khanh Linh"), Role = teamFields?.GetFieldValue("member3Role", "Chăm sóc khách hàng"), Icon = "support_agent", NameKey = "member3Name", RoleKey = "member3Role" },
                        new { Name = teamFields?.GetFieldValue("member4Name", "Pham Gia Hung"), Role = teamFields?.GetFieldValue("member4Role", "Điều hành tour"), Icon = "map", NameKey = "member4Name", RoleKey = "member4Role" }
                    };
                }
                @foreach (var member in teamMembers)
                {
                    <div class="text-center group">
                        <div class="size-32 mx-auto mb-5 rounded-3xl bg-gradient-to-br from-primary/20 to-blue-500/20 flex items-center justify-center group-hover:from-primary group-hover:to-blue-500 transition-all duration-500">
                            <span class="material-symbols-outlined text-[48px] text-primary/60 group-hover:text-white transition-all">@member.Icon</span>
                        </div>
                        <h4 class="text-base font-bold text-slate-900 dark:text-white mb-1" style="@ContentPresentationViewHelper.GetFieldTextStyle(team, member.NameKey)">@member.Name</h4>
                        <p class="text-sm text-primary font-medium" style="@ContentPresentationViewHelper.GetFieldTextStyle(team, member.RoleKey)">@member.Role</p>
                    </div>
                }
            </div>
        </div>
    </section>
}
