@inject IPublicContentService ContentService
@{
    var sections = await ContentService.GetPageSectionsAsync("about");
    var hero = sections.GetSection("hero");
    var story = sections.GetSection("story");
    var missionVision = sections.GetSection("missionVision");
    var team = sections.GetSection("team");

    ViewData["Title"] = "Giới Thiệu";
    ViewData["Description"] = hero?.Fields.GetFieldValue("description", "Tìm hiểu về HV Travel - Đơn vị du lịch hàng đầu Việt Nam");
}

@if (hero?.IsEnabled != false)
{
    <section class="hero-gradient relative overflow-hidden">
        <div class="absolute inset-0 opacity-15">
            <div class="absolute top-20 right-20 w-72 h-72 bg-primary/30 rounded-full blur-3xl"></div>
        </div>
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-28 relative z-10 text-center" data-animate="fade-up">
            <span class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-md text-white/90 text-xs font-semibold px-4 py-2 rounded-full mb-6 border border-white/10">
                <span class="material-symbols-outlined text-primary text-[16px]">info</span>
                @hero.Fields.GetFieldValue("badgeText", "Về Chúng Tôi")
            </span>
            <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white leading-tight mb-6">
                @hero.Fields.GetFieldValue("titleLine1", "Câu Chuyện")
                <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-accent-soft">@hero.Fields.GetFieldValue("titleHighlight", "HV Travel")</span>
            </h1>
            <p class="text-lg text-slate-300 max-w-2xl mx-auto">@hero.Fields.GetFieldValue("description", "Đồng hành cùng bạn trên mọi hành trình khám phá vẻ đẹp Việt Nam")</p>
        </div>
    </section>
}

@if (story?.IsEnabled != false)
{
    <section class="py-20 bg-background-light dark:bg-background-dark">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid lg:grid-cols-2 gap-16 items-center">
                <div data-animate="slide-left">
                    <span class="inline-flex items-center gap-2 bg-primary/10 text-primary text-xs font-bold px-4 py-2 rounded-full mb-6 uppercase tracking-wider">
                        <span class="material-symbols-outlined text-[16px]">history</span> Câu chuyện của chúng tôi
                    </span>
                    <h2 class="text-3xl sm:text-4xl font-extrabold text-slate-900 dark:text-white mb-6 leading-tight">@story.Fields.GetFieldValue("title", "Hơn 10 Năm Kinh Nghiệm Trong Ngành Du Lịch")</h2>
                    <p class="text-slate-600 dark:text-slate-400 mb-6 leading-relaxed">
                        @story.Fields.GetFieldValue("description1", "HV Travel được thành lập với niềm đam mê mang đến những trải nghiệm du lịch tuyệt vời nhất cho du khách.")
                    </p>
                    <p class="text-slate-600 dark:text-slate-400 mb-8 leading-relaxed">
                        @story.Fields.GetFieldValue("description2", "Chúng tôi tin rằng mỗi chuyến đi không chỉ là một hành trình đến nơi mới, mà còn là cơ hội để khám phá bản thân, kết nối với văn hóa và con người.")
                    </p>
                    <div class="grid grid-cols-2 gap-6" data-animate="fade-up" data-stagger data-delay="200">
                        <div class="p-4 rounded-2xl bg-surface-light dark:bg-surface-dark shadow-sm border border-border-light dark:border-border-dark">
                            <p class="text-3xl font-extrabold text-primary mb-1">10+</p>
                            <p class="text-sm font-medium text-slate-500 dark:text-slate-400">Năm hoạt động</p>
                        </div>
                        <div class="p-4 rounded-2xl bg-surface-light dark:bg-surface-dark shadow-sm border border-border-light dark:border-border-dark">
                            <p class="text-3xl font-extrabold text-primary mb-1">50+</p>
                            <p class="text-sm font-medium text-slate-500 dark:text-slate-400">Nhân viên</p>
                        </div>
                        <div class="p-4 rounded-2xl bg-surface-light dark:bg-surface-dark shadow-sm border border-border-light dark:border-border-dark">
                            <p class="text-3xl font-extrabold text-primary mb-1">10K+</p>
                            <p class="text-sm font-medium text-slate-500 dark:text-slate-400">Khách hàng</p>
                        </div>
                        <div class="p-4 rounded-2xl bg-surface-light dark:bg-surface-dark shadow-sm border border-border-light dark:border-border-dark">
                            <p class="text-3xl font-extrabold text-primary mb-1">4.9*</p>
                            <p class="text-sm font-medium text-slate-500 dark:text-slate-400">Đánh giá</p>
                        </div>
                    </div>
                </div>
                <div class="relative" data-animate="slide-right">
                    <div class="aspect-[4/5] rounded-3xl bg-gradient-to-br from-primary/20 to-blue-500/20 flex items-center justify-center overflow-hidden">
                        <span class="material-symbols-outlined text-[120px] text-primary/30">landscape</span>
                    </div>
                    <div class="absolute -bottom-6 -left-6 bg-surface-light dark:bg-surface-dark rounded-2xl shadow-2xl p-6 border border-border-light dark:border-border-dark">
                        <div class="flex items-center gap-3">
                            <div class="size-12 rounded-xl bg-primary/10 text-primary flex items-center justify-center">
                                <span class="material-symbols-outlined">workspace_premium</span>
                            </div>
                            <div>
                                <p class="text-2xl font-extrabold text-slate-900 dark:text-white">Top 10</p>
                                <p class="text-xs font-medium text-slate-500">Công ty du lịch uy tín</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
}

@if (missionVision?.IsEnabled != false)
{
    <section class="py-20 bg-surface-light dark:bg-surface-dark">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center mb-14" data-animate="fade-up">
                <h2 class="text-3xl sm:text-4xl font-extrabold text-slate-900 dark:text-white mb-4">@missionVision.Fields.GetFieldValue("title", "Sứ Mệnh & Tầm Nhìn")</h2>
            </div>
            <div class="grid md:grid-cols-3 gap-8" data-animate="fade-in" data-stagger>
                <div class="p-8 rounded-2xl bg-surface-muted-light dark:bg-surface-elevated-dark/70 border border-border-light dark:border-border-dark hover:border-primary/30 transition-all group text-center">
                    <div class="size-16 mx-auto mb-6 rounded-2xl bg-primary/10 text-primary flex items-center justify-center group-hover:bg-primary group-hover:text-white transition-all">
                        <span class="material-symbols-outlined text-[28px]">flag</span>
                    </div>
                    <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-3">@missionVision.Fields.GetFieldValue("missionTitle", "Sứ Mệnh")</h3>
                    <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">@missionVision.Fields.GetFieldValue("missionText", "Mang đến những hành trình được cá nhân hóa, an toàn và giàu cảm xúc cho mỗi du khách.")</p>
                </div>
                <div class="p-8 rounded-2xl bg-surface-muted-light dark:bg-surface-elevated-dark/70 border border-border-light dark:border-border-dark hover:border-primary/30 transition-all group text-center">
                    <div class="size-16 mx-auto mb-6 rounded-2xl bg-primary/10 text-primary flex items-center justify-center group-hover:bg-primary group-hover:text-white transition-all">
                        <span class="material-symbols-outlined text-[28px]">visibility</span>
                    </div>
                    <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-3">@missionVision.Fields.GetFieldValue("visionTitle", "Tầm Nhìn")</h3>
                    <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">@missionVision.Fields.GetFieldValue("visionText", "Trở thành thương hiệu du lịch được tin yêu hàng đầu cho những chuyến đi khám phá Việt Nam.")</p>
                </div>
                <div class="p-8 rounded-2xl bg-surface-muted-light dark:bg-surface-elevated-dark/70 border border-border-light dark:border-border-dark hover:border-primary/30 transition-all group text-center">
                    <div class="size-16 mx-auto mb-6 rounded-2xl bg-primary/10 text-primary flex items-center justify-center group-hover:bg-primary group-hover:text-white transition-all">
                        <span class="material-symbols-outlined text-[28px]">favorite</span>
                    </div>
                    <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-3">@missionVision.Fields.GetFieldValue("valuesTitle", "Giá Trị Cốt Lõi")</h3>
                    <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">@missionVision.Fields.GetFieldValue("valuesText", "Tận tâm, minh bạch, sáng tạo và luôn lấy trải nghiệm khách hàng làm trung tâm.")</p>
                </div>
            </div>
        </div>
    </section>
}

@if (team?.IsEnabled != false)
{
    <section class="py-20 bg-background-light dark:bg-background-dark">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center mb-14" data-animate="fade-up">
                <span class="inline-flex items-center gap-2 bg-primary/10 text-primary text-xs font-bold px-4 py-2 rounded-full mb-4 uppercase tracking-wider">
                    <span class="material-symbols-outlined text-[16px]">groups</span> Đội ngũ
                </span>
                <h2 class="text-3xl sm:text-4xl font-extrabold text-slate-900 dark:text-white mb-4">@team.Fields.GetFieldValue("title", "Những Con Người Đằng Sau HV Travel")</h2>
                <p class="text-slate-500 dark:text-slate-400 max-w-2xl mx-auto">@team.Fields.GetFieldValue("description", "Đội ngũ tạo nên các hành trình chỉn chu và giàu cảm hứng cho từng chuyến đi.")</p>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8" data-animate="fade-in" data-stagger>
                @{
                    var teamMembers = new[]
                    {
                        new { Name = team.Fields.GetFieldValue("member1Name", "Nguyen Hoang Vu"), Role = team.Fields.GetFieldValue("member1Role", "Nhà Sáng Lập"), Icon = "person" },
                        new { Name = team.Fields.GetFieldValue("member2Name", "Le Minh Duc"), Role = team.Fields.GetFieldValue("member2Role", "Trưởng Phòng Tour"), Icon = "manage_accounts" },
                        new { Name = team.Fields.GetFieldValue("member3Name", "Tran Khanh Linh"), Role = team.Fields.GetFieldValue("member3Role", "Chăm Sóc Khách Hàng"), Icon = "support_agent" },
                        new { Name = team.Fields.GetFieldValue("member4Name", "Pham Gia Hung"), Role = team.Fields.GetFieldValue("member4Role", "Điều Hành Tour"), Icon = "map" }
                    };
                }
                @foreach (var member in teamMembers)
                {
                    <div class="text-center group">
                        <div class="size-32 mx-auto mb-5 rounded-3xl bg-gradient-to-br from-primary/20 to-blue-500/20 flex items-center justify-center group-hover:from-primary group-hover:to-blue-500 transition-all duration-500">
                            <span class="material-symbols-outlined text-[48px] text-primary/60 group-hover:text-white transition-all">@member.Icon</span>
                        </div>
                        <h4 class="text-base font-bold text-slate-900 dark:text-white mb-1">@member.Name</h4>
                        <p class="text-sm text-primary font-medium">@member.Role</p>
                    </div>
                }
            </div>
        </div>
    </section>
}

