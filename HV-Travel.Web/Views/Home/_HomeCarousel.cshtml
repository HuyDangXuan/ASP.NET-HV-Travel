@using System.Linq
@using HVTravel.Domain.Entities
@using HVTravel.Web.Services
@model ContentSection
@{
    var carousel = Model;
    var slides = Enumerable.Range(1, 5)
        .Select(index => new
        {
            Index = index,
            ImageUrl = carousel.Fields.GetFieldValue($"slide{index}ImageUrl"),
            LinkUrl = carousel.Fields.GetFieldValue($"slide{index}LinkUrl"),
            SourceType = carousel.Fields.GetFieldValue($"slide{index}SourceType", "external")
        })
        .Where(slide => !string.IsNullOrWhiteSpace(slide.ImageUrl))
        .ToList();
}

@if (slides.Any())
{
    <section class="home-carousel-section" data-animate="fade-up">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
            <div class="home-carousel-shell @ContentPresentationViewHelper.GetSectionBackgroundClass(carousel)" style="@ContentPresentationViewHelper.GetSectionStyle(carousel)">
                <div class="home-carousel" data-home-carousel data-autoplay-interval="5000">
                    <div class="home-carousel-viewport">
                        <div class="home-carousel-track" data-home-carousel-track>
                            @foreach (var slide in slides)
                            {
                                var alt = $"Carousel trang chủ {slide.Index}";
                                var linkUrl = ContentAccessExtensions.NormalizeCarouselLink(slide.LinkUrl);
                                var hasLink = !string.IsNullOrWhiteSpace(linkUrl);
                                if (hasLink)
                                {
                                    <a href="@linkUrl" class="home-carousel-slide" data-home-carousel-slide aria-label="@alt">
                                        <img src="@slide.ImageUrl" alt="@alt" class="home-carousel-image" loading="lazy" />
                                    </a>
                                }
                                else
                                {
                                    <div class="home-carousel-slide" data-home-carousel-slide>
                                        <img src="@slide.ImageUrl" alt="@alt" class="home-carousel-image" loading="lazy" />
                                    </div>
                                }
                            }
                        </div>
                    </div>

                    @if (slides.Count > 1)
                    {
                        <button type="button" class="home-carousel-nav home-carousel-nav--prev" data-home-carousel-prev aria-label="Slide trước">
                            <span class="material-symbols-outlined">arrow_back_ios_new</span>
                        </button>
                        <button type="button" class="home-carousel-nav home-carousel-nav--next" data-home-carousel-next aria-label="Slide tiếp theo">
                            <span class="material-symbols-outlined">arrow_forward_ios</span>
                        </button>

                        <div class="home-carousel-dots" data-home-carousel-dots>
                            @for (var index = 0; index < slides.Count; index++)
                            {
                                <button type="button" class="home-carousel-dot" data-home-carousel-dot data-slide-index="@index" aria-label="Đi đến slide @(index + 1)"></button>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </section>
}

