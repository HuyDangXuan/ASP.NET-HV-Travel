@inject IPublicContentService ContentService
@using HVTravel.Web.Services
@model HVTravel.Web.Models.PromotionsIndexViewModel
@{
    var sections = await ContentService.GetPageSectionsAsync("promotions");
    var hero = sections.GetSection("hero");
    var flashSalesIntro = sections.GetSection("flashSalesIntro");
    var voucherIntro = sections.GetSection("voucherIntro");
    var seasonalDealsIntro = sections.GetSection("seasonalDealsIntro");

    ViewData["Description"] = hero?.Fields.GetFieldValue("description", "Trang mới gom toàn bộ khuyến mãi, hiển thị mức ưu đãi, thời hạn và điều kiện theo segment.")
        ?? "Trang mới gom toàn bộ khuyến mãi, hiển thị mức ưu đãi, thời hạn và điều kiện theo segment.";
}

@if (hero?.IsEnabled != false)
{
    <section class="@($"relative overflow-hidden bg-[radial-gradient(circle_at_top_left,rgba(59,130,246,0.24),transparent_36%),linear-gradient(135deg,#020617_0%,#0f172a_45%,#1e3a8a_100%)] {ContentPresentationViewHelper.GetSectionBackgroundClass(hero)}")" style="@ContentPresentationViewHelper.GetSectionStyle(hero)">
        <div class="absolute inset-0 opacity-20">
            <div class="absolute left-10 top-20 h-72 w-72 rounded-full bg-primary/30 blur-3xl animate-pulse"></div>
            <div class="absolute bottom-10 right-20 h-96 w-96 rounded-full bg-blue-500/20 blur-3xl animate-pulse" style="animation-delay: 1s;"></div>
        </div>
        <div class="relative z-10 mx-auto max-w-7xl px-4 py-24 sm:px-6 sm:py-32 lg:px-8 lg:py-40">
            <div class="mx-auto flex max-w-4xl flex-col items-center text-center @ContentPresentationViewHelper.GetSectionTextClass(hero)" data-animate="fade-up">
                <span class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/10 px-4 py-2 text-xs font-bold uppercase tracking-[0.25em] text-white/90 backdrop-blur-md" style="@ContentPresentationViewHelper.GetFieldTextStyle(hero, "eyebrowText")">
                    <span class="material-symbols-outlined text-[16px] text-primary">local_activity</span>
                    @hero.Fields.GetFieldValue("eyebrowText", "Ưu đãi theo chiến dịch")
                </span>
                <h1 class="mt-6 text-4xl font-extrabold leading-tight tracking-tight text-white sm:text-5xl lg:text-6xl" style="@ContentPresentationViewHelper.GetFieldTextStyle(hero, "title")">@hero.Fields.GetFieldValue("title", "Flash sale, voucher campaign và deal landing page cho HV Travel.")</h1>
                <div class="mt-6 max-w-2xl text-lg leading-relaxed text-slate-300 sm:text-xl" style="@ContentPresentationViewHelper.GetFieldTextStyle(hero, "description")">
                    @Html.Raw(hero.Fields.GetFieldValue("description", "Trang mới gom toàn bộ khuyến mãi, hiển thị mức ưu đãi, thời hạn và điều kiện theo segment."))
                    @if (!string.IsNullOrWhiteSpace(Model.CustomerSegment))
                    {
                        <span> Segment của bạn hiện là <strong>@Model.CustomerSegment</strong>.</span>
                    }
                </div>
            </div>
        </div>
    </section>
}

<section class="py-12 bg-background-light dark:bg-background-dark">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 space-y-10">
        @if (flashSalesIntro?.IsEnabled != false)
        {
            <div class="@($"{ContentPresentationViewHelper.GetSectionBackgroundClass(flashSalesIntro)} {ContentPresentationViewHelper.GetSectionTextClass(flashSalesIntro)}")" style="@ContentPresentationViewHelper.GetSectionStyle(flashSalesIntro)">
                <div class="flex items-end justify-between gap-4">
                    <div>
                        <p class="text-xs uppercase tracking-[0.3em] text-primary" style="@ContentPresentationViewHelper.GetFieldTextStyle(flashSalesIntro, "eyebrowText")">@flashSalesIntro.Fields.GetFieldValue("eyebrowText", "Flash sale")</p>
                        <h2 class="text-3xl font-extrabold tracking-tight text-slate-900 dark:text-white mt-2" style="@ContentPresentationViewHelper.GetFieldTextStyle(flashSalesIntro, "title")">@flashSalesIntro.Fields.GetFieldValue("title", "Khuyến mãi tạo urgency")</h2>
                        <div class="mt-3 max-w-3xl text-sm leading-7 text-slate-500 dark:text-slate-400" style="@ContentPresentationViewHelper.GetFieldTextStyle(flashSalesIntro, "description")">
                            @Html.Raw(flashSalesIntro.Fields.GetFieldValue("description", "Khối ưu đãi có thời hạn ngắn để kéo chuyển đổi ngay trên mặt tiền B2C."))
                        </div>
                    </div>
                </div>
                <div class="mt-6 grid gap-6 lg:grid-cols-2">
                    @foreach (var promo in Model.FlashSales)
                    {
                        <article class="overflow-hidden rounded-[2rem] border border-border-light bg-surface-light shadow-sm dark:border-border-dark dark:bg-surface-dark">
                            <div class="bg-gradient-to-r from-rose-500 to-orange-500 px-6 py-6 text-white">
                                <div class="flex items-start justify-between gap-4">
                                    <div>
                                        <p class="text-xs uppercase tracking-[0.3em] text-white/70">@promo.Code</p>
                                        <h3 class="mt-2 text-2xl font-black">@(string.IsNullOrWhiteSpace(promo.Title) ? promo.Code : promo.Title)</h3>
                                    </div>
                                    <p class="text-4xl font-black">-@promo.DiscountPercentage.ToString("0")%</p>
                                </div>
                            </div>
                            <div class="px-6 py-5">
                                <p class="text-sm leading-7 text-slate-600 dark:text-slate-300">@promo.Description</p>
                                <div class="mt-4 flex flex-wrap gap-3 text-xs font-semibold text-slate-500 dark:text-slate-400">
                                    <span>Hiệu lực đến @promo.ValidTo.ToString("dd/MM/yyyy")</span>
                                    @if (promo.MinimumSpend > 0)
                                    {
                                        <span>Đơn tối thiểu @promo.MinimumSpend.ToString("N0")₫</span>
                                    }
                                </div>
                            </div>
                        </article>
                    }
                </div>
            </div>
        }

        <div class="grid gap-8 lg:grid-cols-2">
            @if (voucherIntro?.IsEnabled != false)
            {
                <section class="rounded-[2rem] border border-border-light bg-surface-light p-6 shadow-sm dark:border-border-dark dark:bg-surface-dark @ContentPresentationViewHelper.GetSectionTextClass(voucherIntro) @ContentPresentationViewHelper.GetSectionBackgroundClass(voucherIntro)" style="@ContentPresentationViewHelper.GetSectionStyle(voucherIntro)">
                    <p class="text-xs uppercase tracking-[0.3em] text-primary" style="@ContentPresentationViewHelper.GetFieldTextStyle(voucherIntro, "eyebrowText")">@voucherIntro.Fields.GetFieldValue("eyebrowText", "Voucher campaigns")</p>
                    <h2 class="text-3xl font-extrabold tracking-tight text-slate-900 dark:text-white mt-2" style="@ContentPresentationViewHelper.GetFieldTextStyle(voucherIntro, "title")">@voucherIntro.Fields.GetFieldValue("title", "Ví voucher")</h2>
                    <div class="mt-3 text-sm leading-7 text-slate-500 dark:text-slate-400" style="@ContentPresentationViewHelper.GetFieldTextStyle(voucherIntro, "description")">
                        @Html.Raw(voucherIntro.Fields.GetFieldValue("description", "Tập hợp voucher và campaign có thể tái sử dụng cho nhiều phân khúc khách hàng."))
                    </div>
                    <div class="mt-5 space-y-4">
                        @foreach (var promo in Model.VoucherCampaigns)
                        {
                            <div class="rounded-2xl border border-border-light px-4 py-4 dark:border-border-dark">
                                <div class="flex items-center justify-between gap-4">
                                    <div>
                                        <p class="text-xs uppercase tracking-[0.3em] text-slate-400">@promo.Code</p>
                                        <h3 class="mt-2 text-lg font-black text-slate-900 dark:text-white">@(string.IsNullOrWhiteSpace(promo.Title) ? promo.Code : promo.Title)</h3>
                                    </div>
                                    <p class="text-2xl font-black text-primary">@promo.DiscountPercentage.ToString("0")%</p>
                                </div>
                                <p class="mt-3 text-sm leading-7 text-slate-500 dark:text-slate-400">@promo.Description</p>
                            </div>
                        }
                    </div>
                </section>
            }
            @if (seasonalDealsIntro?.IsEnabled != false)
            {
                <section class="rounded-[2rem] border border-border-light bg-surface-light p-6 shadow-sm dark:border-border-dark dark:bg-surface-dark @ContentPresentationViewHelper.GetSectionTextClass(seasonalDealsIntro) @ContentPresentationViewHelper.GetSectionBackgroundClass(seasonalDealsIntro)" style="@ContentPresentationViewHelper.GetSectionStyle(seasonalDealsIntro)">
                    <p class="text-xs uppercase tracking-[0.3em] text-primary" style="@ContentPresentationViewHelper.GetFieldTextStyle(seasonalDealsIntro, "eyebrowText")">@seasonalDealsIntro.Fields.GetFieldValue("eyebrowText", "Seasonal deals")</p>
                    <h2 class="text-3xl font-extrabold tracking-tight text-slate-900 dark:text-white mt-2" style="@ContentPresentationViewHelper.GetFieldTextStyle(seasonalDealsIntro, "title")">@seasonalDealsIntro.Fields.GetFieldValue("title", "Deal theo mùa")</h2>
                    <div class="mt-3 text-sm leading-7 text-slate-500 dark:text-slate-400" style="@ContentPresentationViewHelper.GetFieldTextStyle(seasonalDealsIntro, "description")">
                        @Html.Raw(seasonalDealsIntro.Fields.GetFieldValue("description", "Nội dung dành cho các chiến dịch theo mùa, lễ hội và khung thời gian bán hàng cao điểm."))
                    </div>
                    <div class="mt-5 space-y-4">
                        @foreach (var promo in Model.SeasonalDeals)
                        {
                            <div class="rounded-2xl border border-border-light px-4 py-4 dark:border-border-dark">
                                <p class="text-xs uppercase tracking-[0.3em] text-slate-400">@promo.CampaignType</p>
                                <h3 class="mt-2 text-lg font-black text-slate-900 dark:text-white">@(string.IsNullOrWhiteSpace(promo.Title) ? promo.Code : promo.Title)</h3>
                                <p class="mt-2 text-sm leading-7 text-slate-500 dark:text-slate-400">@promo.Description</p>
                            </div>
                        }
                    </div>
                </section>
            }
        </div>
    </div>
</section>

