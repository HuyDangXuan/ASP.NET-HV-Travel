@inject IPublicContentService ContentService
@using HVTravel.Web.Services
@model HVTravel.Web.Models.CustomerPortalDashboardViewModel
@{
    var sections = await ContentService.GetPageSectionsAsync("customerPortal");
    var hero = sections.GetSection("hero");
    var stats = sections.GetSection("stats");
    var bookingPanel = sections.GetSection("bookingPanel");
    var reviewPanel = sections.GetSection("reviewPanel");
    var voucherPanel = sections.GetSection("voucherPanel");
    var travellerPanel = sections.GetSection("travellerPanel");
    var notificationsPanel = sections.GetSection("notificationsPanel");
    var focusBookingCode = ViewData["FocusBookingCode"]?.ToString();
}

<section class="public-top-section public-top-section--compact hero-gradient @ContentPresentationViewHelper.GetSectionBackgroundClass(hero)" style="@ContentPresentationViewHelper.GetSectionStyle(hero)">
    <div class="public-top-section-shell relative z-10 mx-auto max-w-7xl px-4 py-14 sm:px-6 lg:px-8 @ContentPresentationViewHelper.GetSectionTextClass(hero)">
        <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
            <div>
                <p class="text-sm font-bold uppercase tracking-[0.35em] text-cyan-200" style="@ContentPresentationViewHelper.GetFieldTextStyle(hero, "eyebrowText")">@hero?.Fields.GetVisibleFieldValue("eyebrowText", "Customer Portal")</p>
                <h1 class="public-top-section-title mt-4 text-white">@string.Format(hero?.Fields.GetVisibleFieldValue("greetingFormat", "Xin chào {0}.") ?? "Xin chào {0}.", Model.Customer.FullName)</h1>
                <p class="public-top-section-lead mt-5 max-w-2xl text-sm leading-7 text-slate-200" style="@ContentPresentationViewHelper.GetFieldTextStyle(hero, "description")">@hero?.Fields.GetVisibleFieldValue("description", "Portal mới gom booking, thanh toán, loyalty, voucher, traveller profile và yêu cầu hậu mãi về cùng một nơi.")</p>
            </div>
            <div class="rounded-[2rem] border border-white/20 bg-white/10 px-6 py-5 backdrop-blur-xl">
                <p class="text-xs uppercase tracking-[0.3em] text-cyan-100" style="@ContentPresentationViewHelper.GetFieldTextStyle(hero, "tierLabel")">@hero?.Fields.GetVisibleFieldValue("tierLabel", "Tier hiện tại")</p>
                <p class="mt-2 text-2xl font-black text-white">@Model.Tier.Name</p>
                <p class="text-xs text-slate-200">@string.Format(hero?.Fields.GetVisibleFieldValue("pointsFormat", "{0} điểm • chi tiêu {1}₫") ?? "{0} điểm • chi tiêu {1}₫", Model.Tier.Points, Model.Tier.LifetimeSpend.ToString("N0"))</p>
            </div>
        </div>
    </div>
</section>

<section class="bg-background-light py-10 dark:bg-background-dark">
    <div class="mx-auto max-w-7xl space-y-8 px-4 sm:px-6 lg:px-8">
        <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4 @ContentPresentationViewHelper.GetSectionTextClass(stats)" style="@ContentPresentationViewHelper.GetSectionStyle(stats)">
            <div class="rounded-[2rem] border border-border-light bg-surface-light p-6 dark:border-border-dark dark:bg-surface-dark"><p class="text-xs uppercase tracking-[0.3em] text-slate-400">@stats?.Fields.GetVisibleFieldValue("loyaltyLabel", "Điểm thưởng")</p><p class="mt-3 text-3xl font-black">@Model.Customer.Stats.LoyaltyPoints</p></div>
            <div class="rounded-[2rem] border border-border-light bg-surface-light p-6 dark:border-border-dark dark:bg-surface-dark"><p class="text-xs uppercase tracking-[0.3em] text-slate-400">@stats?.Fields.GetVisibleFieldValue("voucherLabel", "Voucher khả dụng")</p><p class="mt-3 text-3xl font-black">@Model.ActiveVouchers.Count</p></div>
            <div class="rounded-[2rem] border border-border-light bg-surface-light p-6 dark:border-border-dark dark:bg-surface-dark"><p class="text-xs uppercase tracking-[0.3em] text-slate-400">@stats?.Fields.GetVisibleFieldValue("travellerLabel", "Hồ sơ hành khách")</p><p class="mt-3 text-3xl font-black">@Model.SavedTravellers.Count</p></div>
            <div class="rounded-[2rem] border border-border-light bg-surface-light p-6 dark:border-border-dark dark:bg-surface-dark"><p class="text-xs uppercase tracking-[0.3em] text-slate-400">@stats?.Fields.GetVisibleFieldValue("notificationLabel", "Thông báo chưa đọc")</p><p class="mt-3 text-3xl font-black">@Model.UnreadNotificationCount</p></div>
        </div>

        <div class="grid gap-8 lg:grid-cols-[1.15fr_0.85fr]">
            <div class="space-y-8">
                <section class="rounded-[2rem] border border-border-light bg-surface-light p-6 shadow-sm dark:border-border-dark dark:bg-surface-dark @ContentPresentationViewHelper.GetSectionTextClass(bookingPanel)" style="@ContentPresentationViewHelper.GetSectionStyle(bookingPanel)">
                    <div class="flex items-center justify-between gap-4">
                        <div>
                            <p class="text-xs uppercase tracking-[0.3em] text-primary" style="@ContentPresentationViewHelper.GetFieldTextStyle(bookingPanel, "eyebrowText")">@bookingPanel?.Fields.GetVisibleFieldValue("eyebrowText", "Booking timeline")</p>
                            <h2 class="public-section-title mt-2" style="@ContentPresentationViewHelper.GetFieldTextStyle(bookingPanel, "title")">@bookingPanel?.Fields.GetVisibleFieldValue("title", "Lịch sử booking")</h2>
                        </div>
                        @if (Model.UpcomingBooking != null)
                        {
                            <div class="rounded-2xl bg-primary/10 px-4 py-2 text-sm font-semibold text-primary">@string.Format(bookingPanel?.Fields.GetVisibleFieldValue("upcomingFormat", "Sắp khởi hành: {0}") ?? "Sắp khởi hành: {0}", Model.UpcomingBooking.BookingCode)</div>
                        }
                    </div>
                    @if (Model.RecentBookings.Any())
                    {
                        <div class="mt-6 space-y-4">
                            @foreach (var booking in Model.RecentBookings)
                            {
                                var focused = !string.IsNullOrWhiteSpace(focusBookingCode) && string.Equals(focusBookingCode, booking.BookingCode, StringComparison.OrdinalIgnoreCase);
                                <article class="rounded-[1.5rem] border @(focused ? "border-primary bg-primary/5" : "border-border-light bg-white dark:border-border-dark dark:bg-slate-900/40") p-5">
                                    <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
                                        <div>
                                            <p class="text-xs uppercase tracking-[0.3em] text-slate-400">@booking.BookingCode</p>
                                            <h3 class="mt-2 text-lg font-black">@(booking.TourSnapshot?.Name ?? (bookingPanel?.Fields.GetVisibleFieldValue("tourFallbackTitle", "Hành trình HV Travel") ?? "Hành trình HV Travel"))</h3>
                                            <p class="mt-2 text-sm text-slate-500 dark:text-slate-400">@(bookingPanel?.Fields.GetVisibleFieldValue("departurePrefix", "Khởi hành")): @(booking.TourSnapshot?.StartDate?.ToString("dd/MM/yyyy") ?? (bookingPanel?.Fields.GetVisibleFieldValue("departureFallback", "Đang cập nhật"))) • @(bookingPanel?.Fields.GetVisibleFieldValue("paymentPrefix", "Thanh toán")): @booking.PaymentStatus • @(bookingPanel?.Fields.GetVisibleFieldValue("statusPrefix", "Trạng thái")): @booking.Status</p>
                                        </div>
                                        <div class="text-right"><p class="text-xs uppercase tracking-[0.3em] text-slate-400">@bookingPanel?.Fields.GetVisibleFieldValue("totalLabel", "Tổng tiền")</p><p class="mt-2 text-2xl font-black text-primary">@booking.TotalAmount.ToString("N0")₫</p></div>
                                    </div>
                                    <form asp-action="RequestCancellation" method="post" class="mt-4">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="bookingId" value="@booking.Id" />
                                        <input type="hidden" name="reason" value="@(bookingPanel?.Fields.GetVisibleFieldValue("cancelReason", "Khách yêu cầu tự phục vụ từ portal"))" />
                                        <button type="submit" class="inline-flex items-center gap-2 rounded-xl border border-border-light px-4 py-2 text-xs font-bold dark:border-border-dark">@bookingPanel?.Fields.GetVisibleFieldValue("cancelActionText", "Yêu cầu hủy")</button>
                                    </form>
                                </article>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="mt-6 text-sm text-slate-500 dark:text-slate-400">@bookingPanel?.Fields.GetVisibleFieldValue("emptyStateText", "Khách hàng này chưa có booking hiển thị trên portal.")</p>
                    }
                </section>

                <section class="rounded-[2rem] border border-border-light bg-surface-light p-6 shadow-sm dark:border-border-dark dark:bg-surface-dark @ContentPresentationViewHelper.GetSectionTextClass(reviewPanel)" style="@ContentPresentationViewHelper.GetSectionStyle(reviewPanel)">
                    <p class="text-xs uppercase tracking-[0.3em] text-primary" style="@ContentPresentationViewHelper.GetFieldTextStyle(reviewPanel, "eyebrowText")">@reviewPanel?.Fields.GetVisibleFieldValue("eyebrowText", "Verified review")</p>
                    <h2 class="public-section-title mt-2" style="@ContentPresentationViewHelper.GetFieldTextStyle(reviewPanel, "title")">@reviewPanel?.Fields.GetVisibleFieldValue("title", "Đánh giá chờ gửi")</h2>
                    @if (Model.ReviewRequests.Any())
                    {
                        <div class="mt-6 space-y-4">
                            @foreach (var review in Model.ReviewRequests)
                            {
                                <form asp-action="SubmitReview" method="post" class="rounded-[1.5rem] border border-border-light bg-white p-5 dark:border-border-dark dark:bg-slate-900/40">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="BookingId" value="@review.BookingId" />
                                    <input type="hidden" name="TourId" value="@review.TourId" />
                                    <h3 class="text-lg font-black">@review.TourName</h3>
                                    <textarea name="Comment" rows="3" class="mt-4 w-full rounded-2xl border border-border-light bg-transparent px-4 py-3 text-sm dark:border-border-dark" placeholder="@(reviewPanel?.Fields.GetVisibleFieldValue("commentPlaceholder", "Chia sẻ cảm nhận của bạn"))"></textarea>
                                    <button type="submit" class="mt-4 inline-flex items-center gap-2 rounded-2xl bg-primary px-5 py-3 text-xs font-bold text-white">@reviewPanel?.Fields.GetVisibleFieldValue("submitText", "Gửi đánh giá")</button>
                                </form>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="mt-6 text-sm text-slate-500 dark:text-slate-400">@reviewPanel?.Fields.GetVisibleFieldValue("emptyStateText", "Hiện chưa có chuyến đi đủ điều kiện gửi review mới.")</p>
                    }
                </section>
            </div>

            <div class="space-y-8">
                <section class="rounded-[2rem] border border-border-light bg-surface-light p-6 shadow-sm dark:border-border-dark dark:bg-surface-dark @ContentPresentationViewHelper.GetSectionTextClass(voucherPanel)" style="@ContentPresentationViewHelper.GetSectionStyle(voucherPanel)">
                    <p class="text-xs uppercase tracking-[0.3em] text-primary" style="@ContentPresentationViewHelper.GetFieldTextStyle(voucherPanel, "eyebrowText")">@voucherPanel?.Fields.GetVisibleFieldValue("eyebrowText", "Voucher wallet")</p>
                    <h2 class="public-section-title mt-2" style="@ContentPresentationViewHelper.GetFieldTextStyle(voucherPanel, "title")">@voucherPanel?.Fields.GetVisibleFieldValue("title", "Ưu đãi cá nhân hóa")</h2>
                    @if (Model.ActiveVouchers.Any())
                    {
                        <div class="mt-5 space-y-3">@foreach (var voucher in Model.ActiveVouchers) { <article class="rounded-[1.5rem] bg-gradient-to-r from-slate-900 to-slate-700 px-5 py-5 text-white"><p class="text-xs uppercase tracking-[0.3em] text-white/60">@voucher.Code</p><h3 class="mt-2 text-lg font-black">@voucher.Title</h3></article> }</div>
                    }
                    else
                    {
                        <p class="mt-5 text-sm text-slate-500 dark:text-slate-400">@voucherPanel?.Fields.GetVisibleFieldValue("emptyStateText", "Ví voucher chưa có item khả dụng.")</p>
                    }
                </section>

                <section class="rounded-[2rem] border border-border-light bg-surface-light p-6 shadow-sm dark:border-border-dark dark:bg-surface-dark @ContentPresentationViewHelper.GetSectionTextClass(travellerPanel)" style="@ContentPresentationViewHelper.GetSectionStyle(travellerPanel)">
                    <p class="text-xs uppercase tracking-[0.3em] text-primary" style="@ContentPresentationViewHelper.GetFieldTextStyle(travellerPanel, "eyebrowText")">@travellerPanel?.Fields.GetVisibleFieldValue("eyebrowText", "Traveller profiles")</p>
                    <h2 class="public-section-title mt-2" style="@ContentPresentationViewHelper.GetFieldTextStyle(travellerPanel, "title")">@travellerPanel?.Fields.GetVisibleFieldValue("title", "Lưu hồ sơ hành khách")</h2>
                    <div class="mt-5 space-y-3">@foreach (var traveller in Model.SavedTravellers) { <div class="rounded-2xl border border-border-light px-4 py-4 dark:border-border-dark"><p class="text-sm font-black">@traveller.FullName</p><p class="mt-1 text-xs uppercase tracking-[0.3em] text-slate-400">@traveller.PassportNumber • @traveller.Nationality</p></div> }</div>
                    <form asp-action="SaveTraveller" method="post" class="mt-6 space-y-3">
                        @Html.AntiForgeryToken()
                        <input name="FullName" placeholder="@(travellerPanel?.Fields.GetVisibleFieldValue("fullNamePlaceholder", "Họ tên"))" class="w-full rounded-2xl border border-border-light bg-transparent px-4 py-3 text-sm dark:border-border-dark" />
                        <div class="grid gap-3 sm:grid-cols-2">
                            <input name="PassportNumber" placeholder="@(travellerPanel?.Fields.GetVisibleFieldValue("passportPlaceholder", "Số hộ chiếu"))" class="w-full rounded-2xl border border-border-light bg-transparent px-4 py-3 text-sm dark:border-border-dark" />
                            <input name="Nationality" placeholder="@(travellerPanel?.Fields.GetVisibleFieldValue("nationalityPlaceholder", "Quốc tịch"))" class="w-full rounded-2xl border border-border-light bg-transparent px-4 py-3 text-sm dark:border-border-dark" />
                        </div>
                        <label class="inline-flex items-center gap-2 text-sm"><input type="checkbox" name="IsDefault" value="true" class="rounded border-border-light dark:border-border-dark" />@travellerPanel?.Fields.GetVisibleFieldValue("defaultCheckboxLabel", "Đặt làm hồ sơ mặc định")</label>
                        <button type="submit" class="inline-flex items-center gap-2 rounded-2xl bg-primary px-5 py-3 text-xs font-bold text-white">@travellerPanel?.Fields.GetVisibleFieldValue("submitText", "Lưu hồ sơ")</button>
                    </form>
                </section>

                <section class="rounded-[2rem] border border-border-light bg-surface-light p-6 shadow-sm dark:border-border-dark dark:bg-surface-dark @ContentPresentationViewHelper.GetSectionTextClass(notificationsPanel)" style="@ContentPresentationViewHelper.GetSectionStyle(notificationsPanel)">
                    <p class="text-xs uppercase tracking-[0.3em] text-primary" style="@ContentPresentationViewHelper.GetFieldTextStyle(notificationsPanel, "eyebrowText")">@notificationsPanel?.Fields.GetVisibleFieldValue("eyebrowText", "Notifications")</p>
                    <h2 class="public-section-title mt-2" style="@ContentPresentationViewHelper.GetFieldTextStyle(notificationsPanel, "title")">@notificationsPanel?.Fields.GetVisibleFieldValue("title", "Thông báo gần đây")</h2>
                    @if (Model.RecentNotifications.Any())
                    {
                        <div class="mt-5 space-y-3">@foreach (var notification in Model.RecentNotifications) { <div class="rounded-2xl border border-border-light px-4 py-4 dark:border-border-dark"><p class="text-sm font-black">@notification.Title</p><p class="mt-2 text-sm leading-7 text-slate-500 dark:text-slate-400">@notification.Message</p></div> }</div>
                    }
                    else
                    {
                        <p class="mt-5 text-sm text-slate-500 dark:text-slate-400">@notificationsPanel?.Fields.GetVisibleFieldValue("emptyStateText", "Hiện chưa có thông báo mới.")</p>
                    }
                </section>
            </div>
        </div>
    </div>
</section>
