@model HVTravel.Web.Models.CustomerPortalDashboardViewModel
@{
    var focusBookingCode = ViewData["FocusBookingCode"]?.ToString();
}

<section class="public-top-section public-top-section--compact hero-gradient relative overflow-hidden">
    <div class="absolute inset-0 opacity-20">
        <div class="absolute left-0 top-10 h-80 w-80 rounded-full bg-cyan-400/20 blur-3xl"></div>
        <div class="absolute right-10 bottom-0 h-96 w-96 rounded-full bg-blue-500/20 blur-3xl"></div>
    </div>
    <div class="public-top-section-shell relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14 sm:py-18">
        <div class="public-top-section-content is-left flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between" data-animate="fade-up">
            <div>
                <p class="text-sm font-bold uppercase tracking-[0.35em] text-cyan-200">Customer Portal</p>
                <h1 class="public-top-section-title public-hero-title mt-4 text-white">Xin chào @Model.Customer.FullName.</h1>
                <p class="public-top-section-lead mt-5 max-w-2xl text-sm leading-7 text-slate-200">Portal mới gom booking, thanh toán, loyalty, voucher, traveller profile và yêu cầu hậu mãi về cùng một nơi.</p>
            </div>
            <div class="rounded-[2rem] border border-white/20 bg-white/10 px-6 py-5 backdrop-blur-xl">
                <p class="text-xs uppercase tracking-[0.3em] text-cyan-100">Tier hiện tại</p>
                <div class="mt-2 flex items-center gap-3">
                    <span class="material-symbols-outlined text-3xl text-amber-300">workspace_premium</span>
                    <div>
                        <p class="text-2xl font-black text-white">@Model.Tier.Name</p>
                        <p class="text-xs text-slate-200">@Model.Tier.Points điểm • chi tiêu @(Model.Tier.LifetimeSpend.ToString("N0"))₫</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-10 bg-background-light dark:bg-background-dark">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 space-y-8">
        @if (TempData["PortalSuccess"] != null)
        {
            <div class="rounded-2xl border border-emerald-200 bg-emerald-50 px-5 py-4 text-sm font-semibold text-emerald-700 dark:border-emerald-800 dark:bg-emerald-950/30 dark:text-emerald-300">@TempData["PortalSuccess"]</div>
        }
        @if (TempData["PortalError"] != null)
        {
            <div class="rounded-2xl border border-rose-200 bg-rose-50 px-5 py-4 text-sm font-semibold text-rose-700 dark:border-rose-800 dark:bg-rose-950/30 dark:text-rose-300">@TempData["PortalError"]</div>
        }

        <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4" data-animate="fade-in" data-stagger>
            <div class="rounded-[2rem] border border-border-light bg-surface-light p-6 dark:border-border-dark dark:bg-surface-dark">
                <p class="text-xs uppercase tracking-[0.3em] text-slate-400">Điểm thưởng</p>
                <p class="mt-3 text-3xl font-black text-slate-900 dark:text-white">@Model.Customer.Stats.LoyaltyPoints</p>
            </div>
            <div class="rounded-[2rem] border border-border-light bg-surface-light p-6 dark:border-border-dark dark:bg-surface-dark">
                <p class="text-xs uppercase tracking-[0.3em] text-slate-400">Voucher khả dụng</p>
                <p class="mt-3 text-3xl font-black text-slate-900 dark:text-white">@Model.ActiveVouchers.Count</p>
            </div>
            <div class="rounded-[2rem] border border-border-light bg-surface-light p-6 dark:border-border-dark dark:bg-surface-dark">
                <p class="text-xs uppercase tracking-[0.3em] text-slate-400">Hồ sơ hành khách</p>
                <p class="mt-3 text-3xl font-black text-slate-900 dark:text-white">@Model.SavedTravellers.Count</p>
            </div>
            <div class="rounded-[2rem] border border-border-light bg-surface-light p-6 dark:border-border-dark dark:bg-surface-dark">
                <p class="text-xs uppercase tracking-[0.3em] text-slate-400">Thông báo chưa đọc</p>
                <p class="mt-3 text-3xl font-black text-slate-900 dark:text-white">@Model.UnreadNotificationCount</p>
            </div>
        </div>

        <div class="grid gap-8 lg:grid-cols-[1.15fr_0.85fr]">
            <div class="space-y-8">
                <section class="rounded-[2rem] border border-border-light bg-surface-light p-6 shadow-sm dark:border-border-dark dark:bg-surface-dark">
                    <div class="flex items-center justify-between gap-4">
                        <div>
                            <p class="text-xs uppercase tracking-[0.3em] text-primary">Booking timeline</p>
                            <h2 class="public-section-title mt-2">Lịch sử booking</h2>
                        </div>
                        @if (Model.UpcomingBooking != null)
                        {
                            <div class="rounded-2xl bg-primary/10 px-4 py-2 text-sm font-semibold text-primary">Sắp khởi hành: @Model.UpcomingBooking.BookingCode</div>
                        }
                    </div>
                    <div class="mt-6 space-y-4">
                        @foreach (var booking in Model.RecentBookings)
                        {
                            var focused = !string.IsNullOrWhiteSpace(focusBookingCode) && string.Equals(focusBookingCode, booking.BookingCode, StringComparison.OrdinalIgnoreCase);
                            <article class="rounded-[1.5rem] border @(focused ? "border-primary bg-primary/5" : "border-border-light bg-white dark:border-border-dark dark:bg-slate-900/40") p-5">
                                <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
                                    <div>
                                        <p class="text-xs uppercase tracking-[0.3em] text-slate-400">@booking.BookingCode</p>
                                        <h3 class="mt-2 text-lg font-black text-slate-900 dark:text-white">@(booking.TourSnapshot?.Name ?? "Hành trình HV Travel")</h3>
                                        <p class="mt-2 text-sm text-slate-500 dark:text-slate-400">Khởi hành: @(booking.TourSnapshot?.StartDate?.ToString("dd/MM/yyyy") ?? "Đang cập nhật") • Thanh toán: @booking.PaymentStatus • Trạng thái: @booking.Status</p>
                                    </div>
                                    <div class="text-right">
                                        <p class="text-xs uppercase tracking-[0.3em] text-slate-400">Tổng tiền</p>
                                        <p class="mt-2 text-2xl font-black text-primary">@booking.TotalAmount.ToString("N0")₫</p>
                                    </div>
                                </div>
                                <div class="mt-4 flex flex-wrap gap-2">
                                    <form asp-action="RequestCancellation" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="bookingId" value="@booking.Id" />
                                        <input type="hidden" name="reason" value="Khách yêu cầu tự phục vụ từ portal" />
                                        <button type="submit" class="inline-flex items-center gap-2 rounded-xl border border-border-light px-4 py-2 text-xs font-bold text-slate-600 transition hover:border-rose-300 hover:text-rose-600 dark:border-border-dark dark:text-slate-300">Yêu cầu hủy</button>
                                    </form>
                                </div>
                            </article>
                        }
                    </div>
                </section>

                <section class="rounded-[2rem] border border-border-light bg-surface-light p-6 shadow-sm dark:border-border-dark dark:bg-surface-dark">
                    <div class="flex items-center justify-between gap-4">
                        <div>
                            <p class="text-xs uppercase tracking-[0.3em] text-primary">Verified review</p>
                            <h2 class="public-section-title mt-2">Đánh giá chờ gửi</h2>
                        </div>
                    </div>
                    <div class="mt-6 space-y-4">
                        @if (Model.ReviewRequests.Any())
                        {
                            @foreach (var review in Model.ReviewRequests)
                            {
                                <form asp-action="SubmitReview" method="post" class="rounded-[1.5rem] border border-border-light bg-white p-5 dark:border-border-dark dark:bg-slate-900/40">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="BookingId" value="@review.BookingId" />
                                    <input type="hidden" name="TourId" value="@review.TourId" />
                                    <div class="flex items-center justify-between gap-4">
                                        <div>
                                            <p class="text-xs uppercase tracking-[0.3em] text-slate-400">@review.BookingCode</p>
                                            <h3 class="mt-2 text-lg font-black text-slate-900 dark:text-white">@review.TourName</h3>
                                        </div>
                                        <select name="Rating" class="rounded-xl border border-border-light bg-transparent px-3 py-2 text-sm dark:border-border-dark">
                                            <option value="5">5 sao</option>
                                            <option value="4">4 sao</option>
                                            <option value="3">3 sao</option>
                                        </select>
                                    </div>
                                    <textarea name="Comment" rows="3" class="mt-4 w-full rounded-2xl border border-border-light bg-transparent px-4 py-3 text-sm dark:border-border-dark" placeholder="Chia sẻ cảm nhận của bạn"></textarea>
                                    <button type="submit" class="mt-4 inline-flex items-center gap-2 rounded-2xl bg-primary px-5 py-3 text-xs font-bold text-white">Gửi đánh giá</button>
                                </form>
                            }
                        }
                        else
                        {
                            <p class="text-sm leading-7 text-slate-500 dark:text-slate-400">Hiện chưa có chuyến đi đủ điều kiện gửi review mới.</p>
                        }
                    </div>
                </section>
            </div>

            <div class="space-y-8">
                <section class="rounded-[2rem] border border-border-light bg-surface-light p-6 shadow-sm dark:border-border-dark dark:bg-surface-dark">
                    <p class="text-xs uppercase tracking-[0.3em] text-primary">Voucher wallet</p>
                    <h2 class="public-section-title mt-2">Ưu đãi cá nhân hóa</h2>
                    <div class="mt-5 space-y-3">
                        @foreach (var voucher in Model.ActiveVouchers)
                        {
                            <article class="rounded-[1.5rem] bg-gradient-to-r from-slate-900 to-slate-700 px-5 py-5 text-white">
                                <div class="flex items-center justify-between gap-4">
                                    <div>
                                        <p class="text-xs uppercase tracking-[0.3em] text-white/60">@voucher.Code</p>
                                        <h3 class="mt-2 text-lg font-black">@voucher.Title</h3>
                                    </div>
                                    <p class="text-3xl font-black">-@voucher.DiscountPercentage.ToString("0")%</p>
                                </div>
                            </article>
                        }
                        @if (!Model.ActiveVouchers.Any())
                        {
                            <p class="text-sm text-slate-500 dark:text-slate-400">Ví voucher chưa có item khả dụng.</p>
                        }
                    </div>
                    <div class="mt-6 space-y-3">
                        @foreach (var offer in Model.PersonalizedOffers.Take(3))
                        {
                            <div class="rounded-2xl border border-border-light px-4 py-4 dark:border-border-dark">
                                <p class="text-xs uppercase tracking-[0.3em] text-slate-400">@offer.Code</p>
                                <h3 class="mt-2 text-base font-black text-slate-900 dark:text-white">@(string.IsNullOrWhiteSpace(offer.Title) ? offer.Code : offer.Title)</h3>
                                <p class="mt-2 text-sm text-slate-500 dark:text-slate-400">@offer.Description</p>
                            </div>
                        }
                    </div>
                </section>

                <section class="rounded-[2rem] border border-border-light bg-surface-light p-6 shadow-sm dark:border-border-dark dark:bg-surface-dark">
                    <p class="text-xs uppercase tracking-[0.3em] text-primary">Traveller profiles</p>
                    <h2 class="public-section-title mt-2">Lưu hồ sơ hành khách</h2>
                    <div class="mt-5 space-y-3">
                        @foreach (var traveller in Model.SavedTravellers)
                        {
                            <div class="rounded-2xl border border-border-light px-4 py-4 dark:border-border-dark">
                                <p class="text-sm font-black text-slate-900 dark:text-white">@traveller.FullName</p>
                                <p class="mt-1 text-xs uppercase tracking-[0.3em] text-slate-400">@traveller.PassportNumber • @traveller.Nationality</p>
                            </div>
                        }
                    </div>
                    <form asp-action="SaveTraveller" method="post" class="mt-6 space-y-3">
                        @Html.AntiForgeryToken()
                        <input name="FullName" placeholder="Họ tên" class="w-full rounded-2xl border border-border-light bg-transparent px-4 py-3 text-sm dark:border-border-dark" />
                        <div class="grid gap-3 sm:grid-cols-2">
                            <input name="PassportNumber" placeholder="Số hộ chiếu" class="w-full rounded-2xl border border-border-light bg-transparent px-4 py-3 text-sm dark:border-border-dark" />
                            <input name="Nationality" placeholder="Quốc tịch" class="w-full rounded-2xl border border-border-light bg-transparent px-4 py-3 text-sm dark:border-border-dark" />
                        </div>
                        <label class="inline-flex items-center gap-2 text-sm text-slate-600 dark:text-slate-300">
                            <input type="checkbox" name="IsDefault" value="true" class="rounded border-border-light dark:border-border-dark" />
                            Đặt làm hồ sơ mặc định
                        </label>
                        <button type="submit" class="inline-flex items-center gap-2 rounded-2xl bg-primary px-5 py-3 text-xs font-bold text-white">Lưu hồ sơ</button>
                    </form>
                </section>

                <section class="rounded-[2rem] border border-border-light bg-surface-light p-6 shadow-sm dark:border-border-dark dark:bg-surface-dark">
                    <p class="text-xs uppercase tracking-[0.3em] text-primary">Notifications</p>
                    <h2 class="public-section-title mt-2">Thông báo gần đây</h2>
                    <div class="mt-5 space-y-3">
                        @foreach (var notification in Model.RecentNotifications)
                        {
                            <div class="rounded-2xl border border-border-light px-4 py-4 dark:border-border-dark">
                                <p class="text-sm font-black text-slate-900 dark:text-white">@notification.Title</p>
                                <p class="mt-2 text-sm leading-7 text-slate-500 dark:text-slate-400">@notification.Message</p>
                            </div>
                        }
                    </div>
                </section>
            </div>
        </div>
    </div>
</section>

