@model HVTravel.Domain.Entities.TravelArticle
@{
    var categoryLabel = string.IsNullOrWhiteSpace(Model.Category) ? "Khác" : Model.Category;
    var destinationLabel = string.IsNullOrWhiteSpace(Model.Destination) ? "Cẩm nang HV Travel" : Model.Destination;
    var summaryText = string.IsNullOrWhiteSpace(Model.Summary)
        ? "Bài viết đang được cập nhật phần tóm tắt để bạn xem nhanh nội dung chính."
        : Model.Summary;
    var publishedLabel = Model.PublishedAt == default ? "Mới cập nhật" : Model.PublishedAt.ToString("dd/MM/yyyy");
}

<article class="group flex h-full min-w-0 flex-col overflow-hidden rounded-[1.9rem] border border-slate-200 bg-white shadow-[0_24px_70px_-52px_rgba(15,23,42,0.6)] transition duration-300 hover:-translate-y-1 hover:border-primary/35 hover:shadow-[0_30px_90px_-45px_rgba(14,165,233,0.45)] dark:border-slate-800 dark:bg-slate-950">
    <div class="relative aspect-[4/3] overflow-hidden bg-slate-100 dark:bg-slate-900">
        <a asp-controller="Inspiration" asp-action="Details" asp-route-slug="@Model.Slug" class="block h-full w-full" aria-label="Đọc bài viết @Model.Title">
            @if (!string.IsNullOrWhiteSpace(Model.HeroImageUrl))
            {
                <img src="@Model.HeroImageUrl"
                     alt="@Model.Title"
                     class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
                     onerror="this.classList.add('hidden'); this.nextElementSibling?.classList.remove('hidden'); this.nextElementSibling?.classList.add('flex');" />
                <div class="hidden h-full w-full items-center justify-center bg-gradient-to-br from-slate-200 via-white to-slate-100 text-slate-400 dark:from-slate-900 dark:via-slate-950 dark:to-slate-800 dark:text-slate-600" aria-hidden="true">
                    <span class="material-symbols-outlined text-[64px]">article</span>
                </div>
            }
            else
            {
                <div class="flex h-full w-full items-center justify-center bg-gradient-to-br from-slate-200 via-white to-slate-100 text-slate-400 dark:from-slate-900 dark:via-slate-950 dark:to-slate-800 dark:text-slate-600" aria-hidden="true">
                    <span class="material-symbols-outlined text-[64px]">article</span>
                </div>
            }
        </a>

        <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-slate-950/75 via-slate-950/10 to-transparent"></div>
        <div class="pointer-events-none absolute inset-x-0 top-0 flex flex-wrap items-start gap-2 p-4">
            <span class="inline-flex items-center rounded-full bg-white/90 px-3 py-1 text-[10px] font-black uppercase tracking-[0.22em] text-slate-900 shadow-lg shadow-slate-950/10 dark:bg-slate-950/85 dark:text-white">@categoryLabel</span>
        </div>
        <div class="pointer-events-none absolute inset-x-0 bottom-0 p-4">
            <div class="flex flex-wrap items-center gap-2 text-[11px] font-bold uppercase tracking-[0.2em] text-white/90">
                <span class="inline-flex items-center gap-1.5 rounded-full bg-white/15 px-3 py-1 backdrop-blur">
                    <span class="material-symbols-outlined text-[14px]">location_on</span>
                    <span>@destinationLabel</span>
                </span>
                <span class="inline-flex items-center gap-1.5 rounded-full bg-white/15 px-3 py-1 backdrop-blur">
                    <span class="material-symbols-outlined text-[14px]">calendar_month</span>
                    <span>@publishedLabel</span>
                </span>
            </div>
        </div>
    </div>

    <div class="flex flex-1 flex-col gap-4 p-5">
        <div class="space-y-3">
            <a asp-controller="Inspiration" asp-action="Details" asp-route-slug="@Model.Slug" class="block" aria-label="Đọc bài viết @Model.Title">
                <h3 class="line-clamp-2 text-xl font-black tracking-tight text-slate-900 transition group-hover:text-primary dark:text-white">@Model.Title</h3>
            </a>
            <p class="line-clamp-3 text-sm leading-7 text-slate-500 dark:text-slate-400">@summaryText</p>
        </div>

        <div class="mt-auto flex items-end justify-between gap-4 rounded-[1.5rem] bg-slate-50 px-4 py-4 dark:bg-slate-900/85">
            <div>
                <p class="text-[10px] font-bold uppercase tracking-[0.22em] text-slate-400 dark:text-slate-500">Chuyên mục</p>
                <p class="mt-1 text-base font-black tracking-tight text-slate-900 dark:text-white">@categoryLabel</p>
            </div>

            <a asp-controller="Inspiration" asp-action="Details" asp-route-slug="@Model.Slug" class="inline-flex items-center justify-center rounded-2xl bg-primary px-4 py-3 text-sm font-black text-white shadow-lg shadow-primary/25 transition hover:-translate-y-0.5 hover:bg-primary-dark hover:shadow-primary/35">
                Đọc bài viết
            </a>
        </div>
    </div>
</article>
