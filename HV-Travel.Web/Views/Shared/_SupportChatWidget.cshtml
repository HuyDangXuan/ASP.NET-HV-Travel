@{
    var isCustomer = User.Identity?.IsAuthenticated == true && User.IsInRole("Customer");
    var customerName = User.FindFirst("FullName")?.Value ?? User.Identity?.Name ?? "Khách hàng";
    var customerEmail = User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value
        ?? User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value
        ?? string.Empty;
    var customerPhone = User.FindFirst("PhoneNumber")?.Value ?? string.Empty;
}

<style>
    #support-chat-widget {
        inset-inline-end: 1.25rem;
        inset-block-end: 1.25rem;
    }

    #support-chat-panel {
        width: min(100vw - 1.75rem, 30rem);
        max-height: min(48rem, calc(100dvh - 1.75rem));
    }

    #support-chat-messages {
        min-height: 0;
    }

    @@media (max-width: 640px), (max-height: 760px) {
        #support-chat-widget {
            inset-inline: 0.75rem;
            inset-block-end: 0.75rem;
        }

        #support-chat-panel {
            width: 100%;
            max-width: none;
            max-height: calc(100dvh - 1.5rem);
            border-radius: 1.75rem;
        }
    }
</style>

<div id="support-chat-widget" class="fixed z-[70]">
    <form id="public-chat-antiforgery-form" class="hidden">
        @Html.AntiForgeryToken()
    </form>

    <div id="support-chat-panel" class="hidden flex-col overflow-hidden border border-border-light/80 bg-surface-light shadow-2xl shadow-slate-900/20 dark:border-border-dark dark:bg-surface-dark sm:rounded-[2rem]">
        <div class="hero-gradient shrink-0 px-5 py-5 text-white sm:px-6">
            <div class="flex items-start justify-between gap-4">
                <div class="max-w-[82%]">
                    <p class="text-[11px] font-bold uppercase tracking-[0.34em] text-primary-light/90">Tư vấn trực tuyến</p>
                    <h3 class="mt-3 text-2xl font-bold leading-tight">Hỗ trợ trực tuyến dành riêng cho chuyến đi của bạn</h3>
                </div>
                <button id="support-chat-close" type="button" class="inline-flex size-11 items-center justify-center rounded-2xl bg-white/10 text-white transition-all hover:bg-white/20">
                    <span class="material-symbols-outlined text-[20px]">close</span>
                </button>
            </div>
        </div>

        <div id="support-chat-intro-step" class="flex flex-1 flex-col overflow-y-auto bg-gradient-to-b from-white via-slate-50/70 to-slate-100/80 px-5 py-5 dark:from-slate-950 dark:via-slate-950 dark:to-slate-900 sm:px-6">
            <div class="rounded-[1.75rem] border border-white/70 bg-white/90 p-5 shadow-xl shadow-slate-900/5 backdrop-blur dark:border-slate-800 dark:bg-slate-950/80">
                <div class="flex items-start gap-4">
                    <div class="flex size-14 shrink-0 items-center justify-center rounded-3xl bg-gradient-to-br from-primary/20 via-primary/10 to-accent/25 text-primary shadow-lg shadow-primary/10 dark:text-primary-light">
                        <span class="material-symbols-outlined text-[28px]">support_agent</span>
                    </div>
                    <div class="min-w-0">
                        <p class="text-xs font-bold uppercase tracking-[0.28em] text-primary/80 dark:text-primary-light/90">Bước 1 / 2</p>
                        <h4 class="mt-2 text-lg font-bold text-slate-900 dark:text-white">Xác nhận thông tin để bắt đầu trò chuyện</h4>
                    </div>
                </div>

                <form id="support-chat-profile-form" class="mt-6 space-y-4">
                    <div>
                        <label for="support-chat-display-name" class="mb-2 block text-xs font-bold uppercase tracking-[0.2em] text-slate-400">Tên hiển thị</label>
                        <input id="support-chat-display-name" value="@(isCustomer ? customerName : "")" class="w-full rounded-2xl border border-border-light bg-surface-light px-4 py-3 text-sm text-slate-900 shadow-sm outline-none transition focus:border-primary focus:ring-4 focus:ring-primary/10 dark:border-border-dark dark:bg-surface-elevated-dark dark:text-white" placeholder="Nguyễn Văn A" />
                        <p id="support-chat-display-name-error" class="mt-2 hidden text-xs font-medium text-red-500"></p>
                    </div>

                    <div class="grid gap-4 sm:grid-cols-2">
                        <div>
                            <label for="support-chat-email" class="mb-2 block text-xs font-bold uppercase tracking-[0.2em] text-slate-400">Email</label>
                            <input id="support-chat-email" type="email" value="@(isCustomer ? customerEmail : "")" class="w-full rounded-2xl border border-border-light bg-surface-light px-4 py-3 text-sm text-slate-900 shadow-sm outline-none transition focus:border-primary focus:ring-4 focus:ring-primary/10 dark:border-border-dark dark:bg-surface-elevated-dark dark:text-white" placeholder="email@example.com" />
                            <p id="support-chat-email-error" class="mt-2 hidden text-xs font-medium text-red-500"></p>
                        </div>
                        <div>
                            <label for="support-chat-phone" class="mb-2 block text-xs font-bold uppercase tracking-[0.2em] text-slate-400">Số điện thoại</label>
                            <input id="support-chat-phone" value="@(isCustomer ? customerPhone : "")" class="w-full rounded-2xl border border-border-light bg-surface-light px-4 py-3 text-sm text-slate-900 shadow-sm outline-none transition focus:border-primary focus:ring-4 focus:ring-primary/10 dark:border-border-dark dark:bg-surface-elevated-dark dark:text-white" placeholder="09xx xxx xxx" />
                            <p id="support-chat-phone-error" class="mt-2 hidden text-xs font-medium text-red-500"></p>
                        </div>
                    </div>

                    <div class="rounded-[1.5rem] border border-primary/10 bg-primary/5 px-4 py-3 text-sm text-slate-600 dark:border-primary/20 dark:bg-primary/10 dark:text-slate-300">
                        @if (isCustomer)
                        {
                            <p>Thông tin đã được điền sẵn từ tài khoản của bạn. Bạn có thể kiểm tra lại trước khi bắt đầu chat.</p>
                        }
                        else
                        {
                            <p>Vui lòng điền đủ thông tin để đội ngũ tư vấn theo sát đúng hành trình và dễ liên hệ lại khi cần.</p>
                        }
                    </div>

                    <div id="support-chat-intro-status" class="hidden rounded-2xl border px-4 py-3 text-sm"></div>

                    <div class="flex flex-col items-center gap-3 pt-1 sm:flex-row sm:items-center sm:justify-center">
                        <button id="support-chat-start" type="submit" class="inline-flex items-center justify-center gap-2 rounded-2xl bg-gradient-to-r from-primary to-accent px-5 py-3 text-sm font-bold text-white shadow-lg shadow-primary/25 transition-all hover:-translate-y-0.5 hover:brightness-105">
                            <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
                            Bắt đầu trò chuyện
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <div id="support-chat-chat-step" class="hidden min-h-0 flex-1 flex-col">
            <div class="shrink-0 border-b border-border-light bg-surface-light/95 px-5 py-4 backdrop-blur dark:border-border-dark dark:bg-surface-dark/95 sm:px-6">
                <div class="flex items-start justify-between gap-4">
                    <div>
                        <p class="text-xs font-bold uppercase tracking-[0.24em] text-primary/80 dark:text-primary-light/90">Bước 2 / 2</p>
                        <h4 class="mt-2 text-lg font-bold text-slate-900 dark:text-white">Phòng chat hỗ trợ của bạn</h4>
                        <p id="support-chat-chat-status" class="mt-2 text-sm text-slate-500 dark:text-slate-400">Hệ thống chat đang sẵn sàng.</p>
                    </div>
                    <div class="flex items-center gap-2 rounded-2xl border border-border-light bg-surface-muted-light px-3 py-2 text-right whitespace-nowrap dark:border-border-dark dark:bg-surface-elevated-dark">
                        <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-slate-400">Liên hệ</p>
                        <p id="support-chat-summary-name" class="text-sm font-semibold text-slate-900 dark:text-white"></p>
                    </div>
                </div>
            </div>

            <div id="support-chat-messages" class="min-h-[240px] flex-1 space-y-3 overflow-y-auto bg-slate-50/70 px-5 py-5 dark:bg-slate-950/70 sm:px-6">
                <div class="rounded-3xl border border-dashed border-border-light bg-white/70 px-4 py-8 text-center text-sm text-slate-400 dark:border-border-dark dark:bg-surface-elevated-dark/45 dark:text-slate-500">
                    Khung chat sẽ hiển thị lịch sử hội thoại sau khi bạn xác nhận thông tin.
                </div>
            </div>

            <form id="support-chat-form" class="shrink-0 border-t border-border-light bg-surface-light px-5 py-4 dark:border-border-dark dark:bg-surface-dark sm:px-6">
                <div class="rounded-[1.75rem] border border-border-light bg-white p-3 shadow-sm dark:border-border-dark dark:bg-surface-elevated-dark">
                    <textarea id="support-chat-input" rows="3" class="w-full h-[40px] resize-none border-0 bg-transparent p-1 text-sm text-slate-900 outline-none placeholder:text-slate-400 focus:ring-0 dark:text-white dark:placeholder:text-slate-500" placeholder="Nhập nội dung cần hỗ trợ..."></textarea>
                    <div class="mt-3 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                        <p class="text-[11px] leading-relaxed text-primary/80 dark:text-primary-light/80">Nhấn Enter để gửi, Shift+Enter để xuống dòng.</p>
                        <button id="support-chat-send" type="submit" class="inline-flex items-center justify-center gap-2 rounded-2xl bg-gradient-to-r from-primary to-accent px-4 py-2.5 text-sm font-bold text-white shadow-lg shadow-primary/30 transition-all hover:-translate-y-0.5 hover:brightness-105">
                            <span class="material-symbols-outlined text-[18px]">send</span>
                            Gửi
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <button id="support-chat-toggle" type="button" class="ml-auto inline-flex items-center gap-3 rounded-full bg-gradient-to-r from-surface-dark to-surface-elevated-dark px-5 py-4 text-sm font-bold text-white shadow-2xl shadow-slate-900/30 transition-all hover:-translate-y-0.5 dark:from-primary dark:to-accent dark:text-white">
        <span class="flex size-11 items-center justify-center rounded-full bg-primary text-white shadow-lg shadow-primary/30">
            <span class="material-symbols-outlined text-[20px]">chat</span>
        </span>
        <span class="hidden sm:inline">Tin nhắn</span>
    </button>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
<script>
    (() => {
        const root = document.getElementById('support-chat-widget');
        if (!root || typeof signalR === 'undefined') {
            return;
        }

        const panelEl = document.getElementById('support-chat-panel');
        const toggleEl = document.getElementById('support-chat-toggle');
        const closeEl = document.getElementById('support-chat-close');
        const introStepEl = document.getElementById('support-chat-intro-step');
        const chatStepEl = document.getElementById('support-chat-chat-step');
        const introStatusEl = document.getElementById('support-chat-intro-status');
        const chatStatusEl = document.getElementById('support-chat-chat-status');
        const summaryNameEl = document.getElementById('support-chat-summary-name');
        const messagesEl = document.getElementById('support-chat-messages');
        const inputEl = document.getElementById('support-chat-input');
        const formEl = document.getElementById('support-chat-form');
        const profileFormEl = document.getElementById('support-chat-profile-form');
        const startButtonEl = document.getElementById('support-chat-start');
        const sendButtonEl = document.getElementById('support-chat-send');
        const displayNameEl = document.getElementById('support-chat-display-name');
        const emailEl = document.getElementById('support-chat-email');
        const phoneEl = document.getElementById('support-chat-phone');
        const displayNameErrorEl = document.getElementById('support-chat-display-name-error');
        const emailErrorEl = document.getElementById('support-chat-email-error');
        const phoneErrorEl = document.getElementById('support-chat-phone-error');

        const createSessionId = () => {
            if (window.crypto && typeof window.crypto.randomUUID === 'function') {
                return window.crypto.randomUUID();
            }

            return `visitor-${Date.now()}-${Math.floor(Math.random() * 1000000)}`;
        };

        const state = {
            bootstrapped: false,
            conversation: null,
            messages: [],
            connection: null,
            joinedConversationId: '',
            visitorSessionId: localStorage.getItem('hvtravel.supportChat.visitorSessionId') || createSessionId(),
            isCustomer: @isCustomer.ToString().ToLowerInvariant()
        };

        localStorage.setItem('hvtravel.supportChat.visitorSessionId', state.visitorSessionId);

        const escapeHtml = (value) => (value || '')
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#39;');

        const formatTime = (value) => {
            if (!value) {
                return '';
            }

            return new Intl.DateTimeFormat('vi-VN', {
                hour: '2-digit',
                minute: '2-digit',
                day: '2-digit',
                month: '2-digit'
            }).format(new Date(value));
        };

        const emailPattern = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/;

        const getProfile = () => ({
            displayName: displayNameEl.value.trim(),
            email: emailEl.value.trim(),
            phoneNumber: phoneEl.value.trim()
        });

        const setIntroStatus = (message, tone = 'neutral') => {
            if (!message) {
                introStatusEl.className = 'hidden rounded-2xl border px-4 py-3 text-sm';
                introStatusEl.textContent = '';
                return;
            }

            const styles = {
                neutral: 'border-slate-200 bg-slate-50 text-slate-600 dark:border-slate-800 dark:bg-slate-900/80 dark:text-slate-300',
                success: 'border-emerald-200 bg-emerald-50 text-emerald-700 dark:border-emerald-900/70 dark:bg-emerald-900/20 dark:text-emerald-300',
                error: 'border-red-200 bg-red-50 text-red-700 dark:border-red-900/70 dark:bg-red-900/20 dark:text-red-300'
            };

            introStatusEl.className = `rounded-2xl border px-4 py-3 text-sm ${styles[tone] || styles.neutral}`;
            introStatusEl.textContent = message;
        };

        const setChatStatus = (message) => {
            chatStatusEl.textContent = message;
        };

        const setFieldError = (element, message) => {
            if (!message) {
                element.textContent = '';
                element.classList.add('hidden');
                return;
            }

            element.textContent = message;
            element.classList.remove('hidden');
        };

        const clearValidationErrors = () => {
            setFieldError(displayNameErrorEl, '');
            setFieldError(emailErrorEl, '');
            setFieldError(phoneErrorEl, '');
        };

        const validateProfile = () => {
            clearValidationErrors();
            const profile = getProfile();
            let isValid = true;

            if (!profile.displayName) {
                setFieldError(displayNameErrorEl, 'Vui lòng nhập tên hiển thị.');
                isValid = false;
            }

            if (!profile.email) {
                setFieldError(emailErrorEl, 'Vui lòng nhập email.');
                isValid = false;
            } else if (!emailPattern.test(profile.email)) {
                setFieldError(emailErrorEl, 'Email chưa đúng định dạng.');
                isValid = false;
            }

            if (!profile.phoneNumber) {
                setFieldError(phoneErrorEl, 'Vui lòng nhập số điện thoại.');
                isValid = false;
            }

            return isValid ? profile : null;
        };

        const updateSummary = () => {
            const profile = getProfile();
            summaryNameEl.textContent = profile.displayName || 'Khách hàng HV Travel';
        };

        const showIntroStep = () => {
            introStepEl.classList.remove('hidden');
            introStepEl.classList.add('flex');
            chatStepEl.classList.add('hidden');
            chatStepEl.classList.remove('flex');
            clearValidationErrors();
            if (!state.bootstrapped) {
                setIntroStatus('', 'neutral');
            }
        };

        const showChatStep = () => {
            introStepEl.classList.add('hidden');
            introStepEl.classList.remove('flex');
            chatStepEl.classList.remove('hidden');
            chatStepEl.classList.add('flex');
            updateSummary();
            setIntroStatus('', 'neutral');
        };

        const renderMessages = () => {
            if (!state.messages.length) {
                messagesEl.innerHTML = `
                    <div class="rounded-3xl border border-dashed border-border-light bg-white/70 px-4 py-8 text-center text-sm text-slate-400 dark:border-border-dark dark:bg-surface-elevated-dark/45 dark:text-slate-500">
                        Hội thoại của bạn đã sẵn sàng. Hãy gửi tin nhắn đầu tiên để đội ngũ HV Travel hỗ trợ ngay.
                    </div>`;
                return;
            }

            messagesEl.innerHTML = state.messages.map((message) => {
                const isStaff = message.senderType === 'staff';
                const alignment = isStaff ? 'items-start' : 'items-end';
                const bubble = isStaff
                    ? 'bg-white text-slate-900 dark:bg-surface-elevated-dark dark:text-slate-100'
                    : message.senderType === 'system'
                        ? 'bg-amber-50 text-amber-900 dark:bg-amber-900/20 dark:text-amber-300'
                        : 'bg-gradient-to-r from-primary to-accent text-white';

                return `
                    <div class="flex flex-col ${alignment}">
                        <div class="max-w-[88%] rounded-3xl px-4 py-3 text-sm shadow-sm ${bubble}">
                            <p class="text-[11px] font-bold uppercase tracking-[0.16em] ${message.senderType === 'guest' || message.senderType === 'customer' ? 'text-white/70' : 'text-slate-400 dark:text-slate-500'}">${escapeHtml(message.senderDisplayName || 'HV Travel')}</p>
                            <p class="mt-2 whitespace-pre-wrap leading-relaxed">${escapeHtml(message.content || '')}</p>
                        </div>
                        <p class="mt-1 px-1 text-[11px] text-slate-400">${escapeHtml(formatTime(message.sentAt))}</p>
                    </div>`;
            }).join('');

            messagesEl.scrollTop = messagesEl.scrollHeight;
        };

        const setBusyState = (isBusy) => {
            startButtonEl.disabled = isBusy;
            sendButtonEl.disabled = isBusy;
            startButtonEl.classList.toggle('opacity-70', isBusy);
            sendButtonEl.classList.toggle('opacity-70', isBusy);
        };

        const ensureConnection = async () => {
            if (state.connection) {
                return;
            }

            state.connection = new signalR.HubConnectionBuilder()
                .withUrl('/supportChatHub')
                .withAutomaticReconnect()
                .build();

            state.connection.on('ReceiveMessage', (message) => {
                if (!state.conversation || message.conversationId !== state.conversation.id) {
                    return;
                }

                state.messages.push(message);
                renderMessages();
                if (message.senderType === 'staff') {
                    markRead().catch(() => { });
                }
            });

            await state.connection.start();
        };

        const joinConversation = async () => {
            if (!state.connection || !state.conversation || state.joinedConversationId === state.conversation.id) {
                return;
            }

            await state.connection.invoke('JoinConversation', state.conversation.id, state.visitorSessionId);
            state.joinedConversationId = state.conversation.id;
        };

        const bootstrap = async (profile) => {
            const response = await fetch('/SupportChat/bootstrap', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    visitorSessionId: state.visitorSessionId,
                    displayName: profile.displayName,
                    email: profile.email,
                    phoneNumber: profile.phoneNumber,
                    sourcePage: `${window.location.pathname}${window.location.search}`
                })
            });

            if (!response.ok) {
                let errorMessage = 'Không thể khởi tạo hội thoại.';

                try {
                    const payload = await response.json();
                    errorMessage = payload.message || errorMessage;
                } catch {
                    // Ignore JSON parse failures and fall back to the default message.
                }

                throw new Error(errorMessage);
            }

            const payload = await response.json();
            state.conversation = payload.conversation;
            state.messages = payload.messages || [];
            state.bootstrapped = true;
            updateSummary();
            renderMessages();
            await ensureConnection();
            await joinConversation();
            await markRead();
        };

        const markRead = async () => {
            if (!state.conversation) {
                return;
            }

            await fetch('/SupportChat/mark-read', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    conversationId: state.conversation.id,
                    visitorSessionId: state.visitorSessionId
                })
            });
        };

        const openPanel = () => {
            panelEl.classList.remove('hidden');
            panelEl.classList.add('flex');
            toggleEl.classList.add('hidden');

            if (state.bootstrapped) {
                showChatStep();
                renderMessages();
                requestAnimationFrame(() => inputEl.focus());
                return;
            }

            if (state.isCustomer) {
                showChatStep();
                setChatStatus('Đang kết nối cuộc trò chuyện của bạn...');
                bootstrapAndOpenChat(true).catch((error) => {
                    setChatStatus(error.message || 'Không thể khởi tạo chat.');
                });
                return;
            }

            showIntroStep();
            setIntroStatus('Vui lòng xác nhận thông tin trước khi bắt đầu chat.', 'neutral');
            requestAnimationFrame(() => {
                if (!displayNameEl.value.trim()) {
                    displayNameEl.focus();
                } else if (!emailEl.value.trim()) {
                    emailEl.focus();
                } else {
                    phoneEl.focus();
                }
            });
        };

        const closePanel = () => {
            panelEl.classList.add('hidden');
            panelEl.classList.remove('flex');
            toggleEl.classList.remove('hidden');
        };

        const bootstrapAndOpenChat = async (skipValidation = false) => {
            const profile = skipValidation ? getProfile() : validateProfile();
            if (!profile) {
                setIntroStatus('Vui lòng điền đủ và đúng thông tin liên hệ để tiếp tục.', 'error');
                return;
            }

            setBusyState(true);
            if (!skipValidation) {
                setIntroStatus('Đang xác nhận thông tin và chuẩn bị phòng chat...', 'neutral');
            }

            try {
                if (!state.bootstrapped) {
                    await bootstrap(profile);
                }

                showChatStep();
                setChatStatus('Hội thoại đã sẵn sàng. Bạn có thể gửi tin nhắn ngay bây giờ.');
                if (!skipValidation) {
                    setIntroStatus('Thông tin đã được xác nhận thành công.', 'success');
                }
                requestAnimationFrame(() => inputEl.focus());
            } catch (error) {
                if (skipValidation) {
                    setChatStatus(error.message || 'Không thể khởi tạo chat.');
                } else {
                    setIntroStatus(error.message || 'Không thể khởi tạo chat.', 'error');
                }
            } finally {
                setBusyState(false);
            }
        };

        toggleEl.addEventListener('click', openPanel);
        closeEl.addEventListener('click', closePanel);

        profileFormEl.addEventListener('submit', async (event) => {
            event.preventDefault();
            await bootstrapAndOpenChat();
        });

        formEl.addEventListener('submit', async (event) => {
            event.preventDefault();

            const content = inputEl.value.trim();
            if (!content || !state.conversation) {
                return;
            }

            setBusyState(true);

            try {
                await ensureConnection();
                await joinConversation();
                await state.connection.invoke('SendPublicMessage', state.conversation.id, state.visitorSessionId, content);
                inputEl.value = '';
                setChatStatus('Tin nhắn đã được gửi tới nhân viên tư vấn.');
            } catch (error) {
                setChatStatus(error.message || 'Không gửi được tin nhắn.');
            } finally {
                setBusyState(false);
            }
        });

        inputEl.addEventListener('keydown', (event) => {
            if (event.key === 'Enter' && !event.shiftKey && !event.isComposing) {
                event.preventDefault();
                formEl.requestSubmit();
            }
        });

        [displayNameEl, emailEl, phoneEl].forEach((field) => {
            field.addEventListener('input', () => {
                updateSummary();
                clearValidationErrors();
                if (!state.bootstrapped) {
                    setIntroStatus('Thông tin của bạn sẽ được dùng để tạo hội thoại hỗ trợ.', 'neutral');
                }
            });
        });

        updateSummary();
        setChatStatus('Hệ thống chat đang sẵn sàng.');
    })();
</script>
