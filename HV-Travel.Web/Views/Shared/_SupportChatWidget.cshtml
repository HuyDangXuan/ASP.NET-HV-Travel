@{
    var isCustomer = User.Identity?.IsAuthenticated == true && User.IsInRole("Customer");
    var customerName = User.FindFirst("FullName")?.Value ?? User.Identity?.Name ?? "Khách hàng";
    var customerEmail = User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value
        ?? User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value
        ?? string.Empty;
    var customerPhone = User.FindFirst("PhoneNumber")?.Value ?? string.Empty;
}

<style>
    #support-chat-widget {
        inset-inline-end: 1rem;
        inset-block-end: 1rem;
        max-width: calc(100vw - 1rem);
    }

    #support-chat-panel {
        width: min(100vw - 1.5rem, 34rem);
        height: min(52rem, calc(100dvh - 1.5rem));
        max-height: min(52rem, calc(100dvh - 1.5rem));
    }

    #support-chat-panel.support-chat-onboarding-mode #support-chat-onboarding-step {
        display: flex;
    }

    #support-chat-panel.support-chat-onboarding-mode #support-chat-conversation-step {
        display: none;
    }

    #support-chat-panel.support-chat-conversation-mode #support-chat-onboarding-step {
        display: none;
    }

    #support-chat-panel.support-chat-conversation-mode #support-chat-conversation-step {
        display: flex;
    }

    #support-chat-conversation-step,
    #support-chat-messages,
    #support-chat-thread {
        min-height: 0;
    }

    #support-chat-input {
        min-height: 3rem;
        max-height: 9rem;
    }

    @@media (min-width: 1024px) {
        #support-chat-panel {
            width: min(100vw - 2rem, 36rem);
            height: min(54rem, calc(100dvh - 2rem));
            max-height: min(54rem, calc(100dvh - 2rem));
        }
    }

    @@media (max-width: 640px), (max-height: 760px) {
        #support-chat-widget {
            inset-inline: 0.5rem;
            inset-block-end: 0.5rem;
            max-width: none;
        }

        #support-chat-panel {
            width: 100%;
            height: calc(100dvh - 1rem);
            max-width: none;
            max-height: calc(100dvh - 1rem);
            border-radius: 1.75rem;
        }
    }
</style>

<div id="support-chat-widget" class="fixed z-[70]">
    <form id="public-chat-antiforgery-form" class="hidden">
        @Html.AntiForgeryToken()
    </form>

    <div id="support-chat-panel" class="public-chat-panel support-chat-onboarding-mode hidden flex-col overflow-hidden border border-border-light/80 bg-surface-light shadow-2xl shadow-slate-900/20 dark:border-border-dark dark:bg-surface-dark sm:rounded-[2rem]">
        <div class="shrink-0 border-b border-white/10 bg-slate-950 px-5 py-4 text-white dark:border-slate-800 sm:px-6">
            <div class="flex items-start justify-between gap-4">
                <div class="min-w-0">
                    <p class="text-[11px] font-bold uppercase tracking-[0.32em] text-primary-light/80">Hỗ trợ HV Travel</p>
                    <h3 class="public-chat-title mt-2 text-[1.55rem] font-bold leading-[1.08] text-white sm:text-[1.7rem]">Nhắn trực tiếp với đội ngũ hỗ trợ chuyến đi của bạn</h3>
                </div>
                <button id="support-chat-close" type="button" class="inline-flex size-11 shrink-0 items-center justify-center rounded-2xl bg-white/10 text-white transition-all hover:bg-white/20">
                    <span class="material-symbols-outlined text-[20px]">close</span>
                </button>
            </div>
        </div>

        <section id="support-chat-onboarding-step" class="public-chat-onboarding hidden min-h-0 flex-1 flex-col overflow-y-auto px-5 py-5 sm:px-6 sm:py-6">
            <div class="flex flex-1 flex-col justify-center gap-6">
                <div class="space-y-4">
                    <div class="inline-flex items-center gap-2 rounded-full border border-primary/15 bg-primary/5 px-3 py-1.5 text-[11px] font-bold uppercase tracking-[0.24em] text-primary dark:border-primary/20 dark:bg-primary/10 dark:text-primary-light">
                        <span class="material-symbols-outlined text-[15px]">support_agent</span>
                        Kênh chat riêng cho khách hàng
                    </div>
                    <div class="space-y-3">
                        <h4 class="text-2xl font-bold leading-tight text-slate-900 dark:text-white">Để lại thông tin ngắn gọn để bắt đầu cuộc trò chuyện.</h4>
                        <p class="text-sm leading-7 text-slate-500 dark:text-slate-400">Sau bước này, toàn bộ khung sẽ chuyển sang chế độ hội thoại để bạn xem lịch sử và nhắn tin thuận tiện hơn.</p>
                    </div>
                </div>

                <form id="support-chat-profile-form" class="space-y-4 rounded-[1.75rem] border border-border-light bg-white/95 p-5 shadow-xl shadow-slate-900/5 dark:border-border-dark dark:bg-slate-950/85 sm:p-6">
                    <div>
                        <label for="support-chat-display-name" class="mb-2 block text-[11px] font-bold uppercase tracking-[0.2em] text-slate-400">Tên hiển thị</label>
                        <input id="support-chat-display-name" value="@(isCustomer ? customerName : "")" class="w-full rounded-2xl border border-border-light bg-surface-light px-4 py-3 text-[15px] text-slate-900 shadow-sm outline-none transition focus:border-primary focus:ring-4 focus:ring-primary/10 dark:border-border-dark dark:bg-surface-elevated-dark dark:text-white" placeholder="Nguyễn Văn A" />
                        <p id="support-chat-display-name-error" class="mt-2 hidden text-xs font-medium text-red-500"></p>
                    </div>

                    <div class="grid gap-4 sm:grid-cols-2">
                        <div>
                            <label for="support-chat-email" class="mb-2 block text-[11px] font-bold uppercase tracking-[0.2em] text-slate-400">Email</label>
                            <input id="support-chat-email" type="email" value="@(isCustomer ? customerEmail : "")" class="w-full rounded-2xl border border-border-light bg-surface-light px-4 py-3 text-[15px] text-slate-900 shadow-sm outline-none transition focus:border-primary focus:ring-4 focus:ring-primary/10 dark:border-border-dark dark:bg-surface-elevated-dark dark:text-white" placeholder="email@example.com" />
                            <p id="support-chat-email-error" class="mt-2 hidden text-xs font-medium text-red-500"></p>
                        </div>
                        <div>
                            <label for="support-chat-phone" class="mb-2 block text-[11px] font-bold uppercase tracking-[0.2em] text-slate-400">Số điện thoại</label>
                            <input id="support-chat-phone" value="@(isCustomer ? customerPhone : "")" class="w-full rounded-2xl border border-border-light bg-surface-light px-4 py-3 text-[15px] text-slate-900 shadow-sm outline-none transition focus:border-primary focus:ring-4 focus:ring-primary/10 dark:border-border-dark dark:bg-surface-elevated-dark dark:text-white" placeholder="09xx xxx xxx" />
                            <p id="support-chat-phone-error" class="mt-2 hidden text-xs font-medium text-red-500"></p>
                        </div>
                    </div>

                    <div id="support-chat-intro-status" class="hidden rounded-2xl border px-4 py-3 text-sm"></div>

                    <button id="support-chat-start" type="submit" class="inline-flex w-full items-center justify-center gap-2 rounded-2xl bg-gradient-to-r from-primary to-accent px-5 py-3.5 text-sm font-bold text-white shadow-lg shadow-primary/25 transition-all hover:-translate-y-0.5 hover:brightness-105">
                        <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
                        Bắt đầu trò chuyện
                    </button>
                </form>
            </div>
        </section>

        <section id="support-chat-conversation-step" class="hidden min-h-0 flex-1 flex-col">
            <div class="hidden">
                <span id="support-chat-summary-name"></span>
                <p id="support-chat-chat-status" class="public-chat-status"></p>
            </div>

            <div id="support-chat-messages" class="min-h-0 flex flex-1 flex-col overflow-y-auto bg-slate-50/80 px-4 py-4 dark:bg-slate-950/70 sm:px-5 sm:py-5">
                <div id="support-chat-thread" class="public-chat-thread flex flex-1 flex-col gap-4"></div>
            </div>

            <form id="support-chat-form" class="public-chat-composer shrink-0 border-t border-border-light bg-surface-light px-4 py-3 dark:border-border-dark dark:bg-surface-dark sm:px-5 sm:py-4">
                <div class="rounded-[1.5rem] border border-border-light bg-white px-3 py-3 shadow-sm dark:border-border-dark dark:bg-surface-elevated-dark sm:px-4">
                    <div class="flex items-end gap-3">
                        <textarea id="support-chat-input" rows="1" class="h-12 w-full resize-none border-0 bg-transparent px-1 py-2 text-[15px] text-slate-900 outline-none placeholder:text-slate-400 focus:ring-0 disabled:cursor-not-allowed disabled:opacity-60 dark:text-white dark:placeholder:text-slate-500" placeholder="Nhập nội dung cần hỗ trợ..."></textarea>
                        <button id="support-chat-send" type="submit" class="inline-flex h-12 shrink-0 items-center justify-center gap-2 rounded-2xl bg-gradient-to-r from-primary to-accent px-4 text-sm font-bold text-white shadow-lg shadow-primary/30 transition-all hover:-translate-y-0.5 hover:brightness-105 disabled:cursor-not-allowed disabled:opacity-60 sm:px-5">
                            <span class="material-symbols-outlined text-[18px]">send</span>
                            <span>Gửi</span>
                        </button>
                    </div>
                    <p id="support-chat-input-hint" class="mt-2 px-1 text-[11px] leading-relaxed text-slate-400 dark:text-slate-500">Enter để gửi, Shift+Enter để xuống dòng.</p>
                </div>
            </form>
        </section>
    </div>

    <button id="support-chat-toggle" type="button" class="ml-auto inline-flex items-center gap-3 rounded-full bg-gradient-to-r from-surface-dark to-surface-elevated-dark px-5 py-4 text-sm font-bold text-white shadow-2xl shadow-slate-900/30 transition-all hover:-translate-y-0.5 dark:from-primary dark:to-accent dark:text-white">
        <span class="flex size-11 items-center justify-center rounded-full bg-primary text-white shadow-lg shadow-primary/30">
            <span class="material-symbols-outlined text-[20px]">chat</span>
        </span>
        <span class="hidden sm:inline">Tin nhắn</span>
    </button>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
<script>
    (() => {
        const root = document.getElementById('support-chat-widget');
        if (!root || typeof signalR === 'undefined') {
            return;
        }

        const panelEl = document.getElementById('support-chat-panel');
        const toggleEl = document.getElementById('support-chat-toggle');
        const closeEl = document.getElementById('support-chat-close');
        const onboardingStepEl = document.getElementById('support-chat-onboarding-step');
        const conversationStepEl = document.getElementById('support-chat-conversation-step');
        const introStatusEl = document.getElementById('support-chat-intro-status');
        const chatStatusEl = document.getElementById('support-chat-chat-status');
        const summaryNameEl = document.getElementById('support-chat-summary-name');
        const messagesEl = document.getElementById('support-chat-messages');
        const threadEl = document.getElementById('support-chat-thread');
        const inputEl = document.getElementById('support-chat-input');
        const inputHintEl = document.getElementById('support-chat-input-hint');
        const formEl = document.getElementById('support-chat-form');
        const profileFormEl = document.getElementById('support-chat-profile-form');
        const startButtonEl = document.getElementById('support-chat-start');
        const sendButtonEl = document.getElementById('support-chat-send');
        const displayNameEl = document.getElementById('support-chat-display-name');
        const emailEl = document.getElementById('support-chat-email');
        const phoneEl = document.getElementById('support-chat-phone');
        const displayNameErrorEl = document.getElementById('support-chat-display-name-error');
        const emailErrorEl = document.getElementById('support-chat-email-error');
        const phoneErrorEl = document.getElementById('support-chat-phone-error');

        const createSessionId = () => {
            if (window.crypto && typeof window.crypto.randomUUID === 'function') {
                return window.crypto.randomUUID();
            }

            return `visitor-${Date.now()}-${Math.floor(Math.random() * 1000000)}`;
        };

        const state = {
            bootstrapped: false,
            conversation: null,
            messages: [],
            connection: null,
            joinedConversationId: '',
            visitorSessionId: localStorage.getItem('hvtravel.supportChat.visitorSessionId') || createSessionId(),
            isCustomer: @isCustomer.ToString().ToLowerInvariant()
        };

        localStorage.setItem('hvtravel.supportChat.visitorSessionId', state.visitorSessionId);

        const escapeHtml = (value) => (value || '')
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#39;');

        const formatTime = (value) => {
            if (!value) {
                return '';
            }

            return new Intl.DateTimeFormat('vi-VN', {
                hour: '2-digit',
                minute: '2-digit',
                day: '2-digit',
                month: '2-digit'
            }).format(new Date(value));
        };

        const emailPattern = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/;

        const adjustComposerHeight = () => {
            inputEl.style.height = 'auto';
            const nextHeight = Math.max(48, Math.min(inputEl.scrollHeight, 144));
            inputEl.style.height = `${nextHeight}px`;
        };

        const getProfile = () => ({
            displayName: displayNameEl.value.trim(),
            email: emailEl.value.trim(),
            phoneNumber: phoneEl.value.trim()
        });

        const setPanelMode = (mode) => {
            const isConversation = mode === 'conversation';
            panelEl.classList.toggle('support-chat-conversation-mode', isConversation);
            panelEl.classList.toggle('support-chat-onboarding-mode', !isConversation);
            onboardingStepEl.classList.toggle('hidden', isConversation);
            onboardingStepEl.classList.toggle('flex', !isConversation);
            conversationStepEl.classList.toggle('hidden', !isConversation);
            conversationStepEl.classList.toggle('flex', isConversation);
        };

        const focusFirstProfileField = () => {
            requestAnimationFrame(() => {
                if (!displayNameEl.value.trim()) {
                    displayNameEl.focus();
                } else if (!emailEl.value.trim()) {
                    emailEl.focus();
                } else {
                    phoneEl.focus();
                }
            });
        };

        const setIntroStatus = (message, tone = 'neutral') => {
            if (!message) {
                introStatusEl.className = 'hidden rounded-2xl border px-4 py-3 text-sm';
                introStatusEl.textContent = '';
                return;
            }

            const styles = {
                neutral: 'border-slate-200 bg-slate-50 text-slate-600 dark:border-slate-800 dark:bg-slate-900/80 dark:text-slate-300',
                success: 'border-emerald-200 bg-emerald-50 text-emerald-700 dark:border-emerald-900/70 dark:bg-emerald-900/20 dark:text-emerald-300',
                error: 'border-red-200 bg-red-50 text-red-700 dark:border-red-900/70 dark:bg-red-900/20 dark:text-red-300'
            };

            introStatusEl.className = `rounded-2xl border px-4 py-3 text-sm ${styles[tone] || styles.neutral}`;
            introStatusEl.textContent = message;
        };

        const setChatStatus = (message) => {
            chatStatusEl.textContent = message;
        };

        const setFieldError = (element, message) => {
            if (!message) {
                element.textContent = '';
                element.classList.add('hidden');
                return;
            }

            element.textContent = message;
            element.classList.remove('hidden');
        };

        const clearValidationErrors = () => {
            setFieldError(displayNameErrorEl, '');
            setFieldError(emailErrorEl, '');
            setFieldError(phoneErrorEl, '');
        };

        const validateProfile = () => {
            clearValidationErrors();
            const profile = getProfile();
            let isValid = true;

            if (!profile.displayName) {
                setFieldError(displayNameErrorEl, 'Vui lòng nhập tên hiển thị.');
                isValid = false;
            }

            if (!profile.email) {
                setFieldError(emailErrorEl, 'Vui lòng nhập email.');
                isValid = false;
            } else if (!emailPattern.test(profile.email)) {
                setFieldError(emailErrorEl, 'Email chưa đúng định dạng.');
                isValid = false;
            }

            if (!profile.phoneNumber) {
                setFieldError(phoneErrorEl, 'Vui lòng nhập số điện thoại.');
                isValid = false;
            }

            return isValid ? profile : null;
        };

        const updateSummary = () => {
            const profile = getProfile();
            summaryNameEl.textContent = profile.displayName || 'Khách hàng HV Travel';
        };

        const updateComposerState = () => {
            const locked = !state.bootstrapped && !state.isCustomer;
            inputEl.disabled = locked;
            sendButtonEl.disabled = locked;
            inputEl.placeholder = locked
                ? 'Xác nhận thông tin trước để mở cuộc trò chuyện...'
                : 'Nhập nội dung cần hỗ trợ...';
            inputHintEl.textContent = locked
                ? 'Hoàn tất bước bắt đầu chat để mở khung hội thoại.'
                : 'Enter để gửi, Shift+Enter để xuống dòng.';
        };

        const syncPanelState = () => {
            updateSummary();
            updateComposerState();
            if (state.bootstrapped || state.isCustomer) {
                setPanelMode('conversation');
                setIntroStatus('');
                requestAnimationFrame(() => {
                    messagesEl.scrollTop = messagesEl.scrollHeight;
                });
                return;
            }

            setPanelMode('onboarding');
        };

        const renderMessages = () => {
            if (!state.messages.length) {
                threadEl.innerHTML = `
                    <div class="flex flex-1 items-start">
                        <div class="public-chat-bubble max-w-[90%] rounded-[1.6rem] border border-dashed border-border-light bg-white/88 px-4 py-3.5 text-[15px] leading-7 text-slate-500 shadow-sm dark:border-border-dark dark:bg-surface-elevated-dark/70 dark:text-slate-300 sm:max-w-[82%] sm:px-5">
                            ${state.bootstrapped
                                ? 'Cuộc trò chuyện đã sẵn sàng. Hãy gửi tin nhắn đầu tiên để đội ngũ HV Travel hỗ trợ bạn nhanh nhất.'
                                : 'Hoàn tất bước xác nhận thông tin để bắt đầu cuộc trò chuyện với đội ngũ HV Travel.'}
                        </div>
                    </div>`;
                return;
            }

            threadEl.innerHTML = state.messages.map((message) => {
                const isStaff = message.senderType === 'staff';
                const isSystem = message.senderType === 'system';
                const isCustomerSide = !isStaff && !isSystem;
                const alignment = isSystem
                    ? 'items-start'
                    : isStaff
                        ? 'items-start'
                        : 'items-end';
                const bubble = isStaff
                    ? 'border border-border-light bg-white text-slate-900 dark:border-border-dark dark:bg-surface-elevated-dark dark:text-slate-100'
                    : isSystem
                        ? 'border border-amber-200/70 bg-amber-50 text-amber-900 dark:border-amber-900/50 dark:bg-amber-900/20 dark:text-amber-300'
                        : 'bg-gradient-to-r from-primary to-accent text-white';
                const metaTone = isCustomerSide
                    ? 'text-white/70'
                    : isSystem
                        ? 'text-amber-500 dark:text-amber-300/80'
                        : 'text-slate-400 dark:text-slate-500';

                return `
                    <div class="flex flex-col ${alignment}">
                        <div class="public-chat-bubble max-w-[92%] rounded-[1.6rem] px-4 py-3.5 text-[15px] leading-7 shadow-sm sm:max-w-[85%] sm:px-5 ${bubble}">
                            <p class="public-chat-metadata text-[10px] font-bold uppercase tracking-[0.18em] ${metaTone}">${escapeHtml(message.senderDisplayName || 'HV Travel')}</p>
                            <p class="mt-2 whitespace-pre-wrap break-words">${escapeHtml(message.content || '')}</p>
                        </div>
                        <p class="public-chat-metadata mt-1 px-1 text-[11px] text-slate-400 dark:text-slate-500">${escapeHtml(formatTime(message.sentAt))}</p>
                    </div>`;
            }).join('');

            messagesEl.scrollTop = messagesEl.scrollHeight;
        };

        const setBusyState = (isBusy) => {
            startButtonEl.disabled = isBusy;
            sendButtonEl.disabled = isBusy || (!state.bootstrapped && !state.isCustomer);
            startButtonEl.classList.toggle('opacity-70', isBusy);
            sendButtonEl.classList.toggle('opacity-70', isBusy || (!state.bootstrapped && !state.isCustomer));
        };

        const ensureConnection = async () => {
            if (state.connection) {
                return;
            }

            state.connection = new signalR.HubConnectionBuilder()
                .withUrl('/supportChatHub')
                .withAutomaticReconnect()
                .build();

            state.connection.on('ReceiveMessage', (message) => {
                if (!state.conversation || message.conversationId !== state.conversation.id) {
                    return;
                }

                state.messages.push(message);
                renderMessages();
                if (message.senderType === 'staff') {
                    markRead().catch(() => { });
                }
            });

            await state.connection.start();
        };

        const joinConversation = async () => {
            if (!state.connection || !state.conversation || state.joinedConversationId === state.conversation.id) {
                return;
            }

            await state.connection.invoke('JoinConversation', state.conversation.id, state.visitorSessionId);
            state.joinedConversationId = state.conversation.id;
        };

        const bootstrap = async (profile) => {
            const response = await fetch('/SupportChat/bootstrap', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    visitorSessionId: state.visitorSessionId,
                    displayName: profile.displayName,
                    email: profile.email,
                    phoneNumber: profile.phoneNumber,
                    sourcePage: `${window.location.pathname}${window.location.search}`
                })
            });

            if (!response.ok) {
                let errorMessage = 'Không thể khởi tạo hội thoại.';

                try {
                    const payload = await response.json();
                    errorMessage = payload.message || errorMessage;
                } catch {
                    // Ignore JSON parse failures and fall back to the default message.
                }

                throw new Error(errorMessage);
            }

            const payload = await response.json();
            state.conversation = payload.conversation;
            state.messages = payload.messages || [];
            state.bootstrapped = true;
            updateSummary();
            syncPanelState();
            renderMessages();
            await ensureConnection();
            await joinConversation();
            await markRead();
        };

        const markRead = async () => {
            if (!state.conversation) {
                return;
            }

            await fetch('/SupportChat/mark-read', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    conversationId: state.conversation.id,
                    visitorSessionId: state.visitorSessionId
                })
            });
        };

        const openPanel = () => {
            panelEl.classList.remove('hidden');
            panelEl.classList.add('flex');
            toggleEl.classList.add('hidden');
            syncPanelState();

            if (state.bootstrapped) {
                renderMessages();
                requestAnimationFrame(() => inputEl.focus());
                return;
            }

            if (state.isCustomer) {
                setPanelMode('conversation');
                setChatStatus('Đang kết nối cuộc trò chuyện của bạn...');
                bootstrapAndOpenChat(true).catch((error) => {
                    setChatStatus(error.message || 'Không thể khởi tạo chat.');
                });
                return;
            }

            setChatStatus('Điền thông tin để bắt đầu cuộc trò chuyện với đội ngũ tư vấn.');
            setIntroStatus('Để lại thông tin liên hệ để đội ngũ hỗ trợ có thể theo sát bạn xuyên suốt cuộc trò chuyện.', 'neutral');
            renderMessages();
            focusFirstProfileField();
        };

        const closePanel = () => {
            panelEl.classList.add('hidden');
            panelEl.classList.remove('flex');
            toggleEl.classList.remove('hidden');
        };

        const bootstrapAndOpenChat = async (skipValidation = false) => {
            const profile = skipValidation ? getProfile() : validateProfile();
            if (!profile) {
                setIntroStatus('Vui lòng điền đủ và đúng thông tin liên hệ để tiếp tục.', 'error');
                return;
            }

            setBusyState(true);
            if (!skipValidation) {
                setIntroStatus('Äang xÃ¡c nháº­n thÃ´ng tin vÃ  chuáº©n bá»‹ phÃ²ng chat...', 'neutral');
            }

            try {
                if (!state.bootstrapped) {
                    await bootstrap(profile);
                }

                renderMessages();
                setPanelMode('conversation');
                setChatStatus('Hội thoại đã sẵn sàng. Bạn có thể gửi tin nhắn ngay bây giờ.');
                if (!skipValidation) {
                    setIntroStatus('Thông tin đã được xác nhận thành công.', 'success');
                }
                requestAnimationFrame(() => inputEl.focus());
            } catch (error) {
                if (skipValidation) {
                    setChatStatus(error.message || 'Không thể khởi tạo chat.');
                } else {
                    setIntroStatus(error.message || 'Không thể khởi tạo chat.', 'error');
                }
            } finally {
                setBusyState(false);
                updateComposerState();
                adjustComposerHeight();
            }
        };

        toggleEl.addEventListener('click', openPanel);
        closeEl.addEventListener('click', closePanel);

        profileFormEl.addEventListener('submit', async (event) => {
            event.preventDefault();
            await bootstrapAndOpenChat();
        });

        formEl.addEventListener('submit', async (event) => {
            event.preventDefault();

            const content = inputEl.value.trim();
            if (!content || !state.conversation) {
                return;
            }

            setBusyState(true);

            try {
                await ensureConnection();
                await joinConversation();
                await state.connection.invoke('SendPublicMessage', state.conversation.id, state.visitorSessionId, content);
                inputEl.value = '';
                adjustComposerHeight();
                setChatStatus('Tin nhắn đã được gửi tới nhân viên tư vấn.');
            } catch (error) {
                setChatStatus(error.message || 'Không gửi được tin nhắn.');
            } finally {
                setBusyState(false);
                updateComposerState();
            }
        });

        inputEl.addEventListener('input', adjustComposerHeight);
        inputEl.addEventListener('keydown', (event) => {
            if (event.key === 'Enter' && !event.shiftKey && !event.isComposing) {
                event.preventDefault();
                formEl.requestSubmit();
            }
        });

        [displayNameEl, emailEl, phoneEl].forEach((field) => {
            field.addEventListener('input', () => {
                updateSummary();
                clearValidationErrors();
                if (!state.bootstrapped && !state.isCustomer) {
                    setIntroStatus('Thông tin của bạn sẽ được dùng để tạo hội thoại hỗ trợ.', 'neutral');
                }
            });
        });

        syncPanelState();
        renderMessages();
        updateSummary();
        adjustComposerHeight();
        setChatStatus(state.isCustomer ? 'Hệ thống chat đang sẵn sàng.' : 'Điền thông tin để bắt đầu cuộc trò chuyện với đội ngũ tư vấn.');
    })();
</script>

