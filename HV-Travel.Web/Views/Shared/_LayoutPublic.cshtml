@inject IPublicContentService ContentService
@{
    var siteSettings = await ContentService.GetSiteSettingsAsync();
    var headerGroup = siteSettings.GetGroup("header");
    var footerBrandGroup = siteSettings.GetGroup("footerBrand");
    var footerExploreGroup = siteSettings.GetGroup("footerExplore");
    var footerCompanyGroup = siteSettings.GetGroup("footerCompany");
    var contactGroup = siteSettings.GetGroup("contactInfo");
    var socialGroup = siteSettings.GetGroup("socialLinks");
    var seoGroup = siteSettings.GetGroup("seo");

    var brandName = headerGroup?.Fields.GetFieldValue("brandName", "HV Travel") ?? "HV Travel";
    var brandTagline = headerGroup?.Fields.GetFieldValue("brandTagline", "Kh\u00e1m ph\u00e1 Vi\u1ec7t Nam") ?? "Kh\u00e1m ph\u00e1 Vi\u1ec7t Nam";
    var navHomeLabel = headerGroup?.Fields.GetFieldValue("navHomeLabel", "Trang ch\u1ee7") ?? "Trang ch\u1ee7";
    var navToursLabel = headerGroup?.Fields.GetFieldValue("navToursLabel", "Tour du l\u1ecbch") ?? "Tour du l\u1ecbch";
    var navAboutLabel = headerGroup?.Fields.GetFieldValue("navAboutLabel", "Gi\u1edbi thi\u1ec7u") ?? "Gi\u1edbi thi\u1ec7u";
    var navContactLabel = headerGroup?.Fields.GetFieldValue("navContactLabel", "Li\u00ean h\u1ec7") ?? "Li\u00ean h\u1ec7";
    var registerLabel = headerGroup?.Fields.GetFieldValue("registerLabel", "\u0110\u0103ng k\u00fd") ?? "\u0110\u0103ng k\u00fd";
    var loginLabel = headerGroup?.Fields.GetFieldValue("loginLabel", "\u0110\u0103ng nh\u1eadp") ?? "\u0110\u0103ng nh\u1eadp";
    var defaultDescription = seoGroup?.Fields.GetFieldValue("defaultMetaDescription", "HV Travel - Kh\u00e1m ph\u00e1 Vi\u1ec7t Nam c\u00f9ng nh\u1eefng tour du l\u1ecbch tuy\u1ec7t v\u1eddi nh\u1ea5t")
        ?? "HV Travel - Kh\u00e1m ph\u00e1 Vi\u1ec7t Nam c\u00f9ng nh\u1eefng tour du l\u1ecbch tuy\u1ec7t v\u1eddi nh\u1ea5t";

    var footerBrandTitle = footerBrandGroup?.Fields.GetFieldValue("title", "HV Travel") ?? "HV Travel";
    var footerBrandTagline = footerBrandGroup?.Fields.GetFieldValue("tagline", "Kh\u00e1m ph\u00e1 Vi\u1ec7t Nam") ?? "Kh\u00e1m ph\u00e1 Vi\u1ec7t Nam";
    var footerBrandDescription = footerBrandGroup?.Fields.GetFieldValue("description", "Kh\u00e1m ph\u00e1 v\u1ebb \u0111\u1eb9p Vi\u1ec7t Nam v\u1edbi nh\u1eefng tour du l\u1ecbch \u0111\u01b0\u1ee3c thi\u1ebft k\u1ebf ri\u00eang. Tr\u1ea3i nghi\u1ec7m v\u0103n h\u00f3a, \u1ea9m th\u1ef1c v\u00e0 thi\u00ean nhi\u00ean tuy\u1ec7t v\u1eddi.")
        ?? "Kh\u00e1m ph\u00e1 v\u1ebb \u0111\u1eb9p Vi\u1ec7t Nam v\u1edbi nh\u1eefng tour du l\u1ecbch \u0111\u01b0\u1ee3c thi\u1ebft k\u1ebf ri\u00eang. Tr\u1ea3i nghi\u1ec7m v\u0103n h\u00f3a, \u1ea9m th\u1ef1c v\u00e0 thi\u00ean nhi\u00ean tuy\u1ec7t v\u1eddi.";

    var footerExploreTitle = footerExploreGroup?.Fields.GetFieldValue("title", "Kh\u00e1m ph\u00e1") ?? "Kh\u00e1m ph\u00e1";
    var allToursLabel = footerExploreGroup?.Fields.GetFieldValue("allToursLabel", "T\u1ea5t c\u1ea3 tour") ?? "T\u1ea5t c\u1ea3 tour";
    var popularToursLabel = footerExploreGroup?.Fields.GetFieldValue("popularToursLabel", "Tour ph\u1ed5 bi\u1ebfn") ?? "Tour ph\u1ed5 bi\u1ebfn";
    var hotDestinationsLabel = footerExploreGroup?.Fields.GetFieldValue("hotDestinationsLabel", "\u0110i\u1ec3m \u0111\u1ebfn hot") ?? "\u0110i\u1ec3m \u0111\u1ebfn hot";
    var specialOffersLabel = footerExploreGroup?.Fields.GetFieldValue("specialOffersLabel", "\u01afu \u0111\u00e3i \u0111\u1eb7c bi\u1ec7t") ?? "\u01afu \u0111\u00e3i \u0111\u1eb7c bi\u1ec7t";

    var footerCompanyTitle = footerCompanyGroup?.Fields.GetFieldValue("title", "C\u00f4ng ty") ?? "C\u00f4ng ty";
    var footerAboutLabel = footerCompanyGroup?.Fields.GetFieldValue("aboutLabel", "Gi\u1edbi thi\u1ec7u") ?? "Gi\u1edbi thi\u1ec7u";
    var footerContactLabel = footerCompanyGroup?.Fields.GetFieldValue("contactLabel", "Li\u00ean h\u1ec7") ?? "Li\u00ean h\u1ec7";
    var privacyLabel = footerCompanyGroup?.Fields.GetFieldValue("privacyLabel", "Ch\u00ednh s\u00e1ch b\u1ea3o m\u1eadt") ?? "Ch\u00ednh s\u00e1ch b\u1ea3o m\u1eadt";
    var termsLabel = footerCompanyGroup?.Fields.GetFieldValue("termsLabel", "\u0110i\u1ec1u kho\u1ea3n s\u1eed d\u1ee5ng") ?? "\u0110i\u1ec1u kho\u1ea3n s\u1eed d\u1ee5ng";

    var contactTitle = contactGroup?.Fields.GetFieldValue("title", "Li\u00ean h\u1ec7") ?? "Li\u00ean h\u1ec7";
    var contactAddress = contactGroup?.Fields.GetFieldValue("address", "123 \u0110\u01b0\u1eddng Nguy\u1ec5n Hu\u1ec7, Qu\u1eadn 1, TP.HCM") ?? "123 \u0110\u01b0\u1eddng Nguy\u1ec5n Hu\u1ec7, Qu\u1eadn 1, TP.HCM";
    var contactPhone = contactGroup?.Fields.GetFieldValue("phoneNumber", "+84 (28) 3822 9999") ?? "+84 (28) 3822 9999";
    var contactEmail = contactGroup?.Fields.GetFieldValue("email", "info@hvtravel.vn") ?? "info@hvtravel.vn";
    var businessHours = contactGroup?.Fields.GetFieldValue("businessHours", "T2 - T7: 8:00 - 18:00") ?? "T2 - T7: 8:00 - 18:00";

    var facebookUrl = socialGroup?.Fields.GetFieldValue("facebookUrl", "#") ?? "#";
    var instagramUrl = socialGroup?.Fields.GetFieldValue("instagramUrl", "#") ?? "#";
    var youtubeUrl = socialGroup?.Fields.GetFieldValue("youtubeUrl", "#") ?? "#";
    var activePage = ViewData["ActivePage"]?.ToString() ?? string.Empty;
    var destinationsLabel = "\u0110i\u1ec3m \u0111\u1ebfn";
    var promotionsLabel = "\u01afu \u0111\u00e3i";
    var inspirationLabel = "C\u1ea9m nang";
    var servicesLabel = "D\u1ecbch v\u1ee5";
    var bookingLookupLabel = "Tra c\u1ee9u booking";
    var moreLabel = "Kh\u00e1m ph\u00e1 th\u00eam";
    var openPortalLabel = "M\u1edf portal";
    var customerFallbackLabel = "Kh\u00e1ch h\u00e0ng";
    var customerCodeFallbackLabel = "Kh\u00e1ch h\u00e0ng HV Travel";
    var logoutLabel = "\u0110\u0103ng xu\u1ea5t";
    var allRightsReservedLabel = "B\u1ea3o l\u01b0u m\u1ecdi quy\u1ec1n.";
    var sitemapLabel = "S\u01a1 \u0111\u1ed3 trang";

    bool IsActive(string pageKey) => string.Equals(activePage, pageKey, System.StringComparison.OrdinalIgnoreCase);

    var primaryNavItems = new[]
    {
        new { Controller = "Home", Action = "Index", Label = navHomeLabel, ActivePage = "Home", Icon = "home" },
        new { Controller = "PublicTours", Action = "Index", Label = navToursLabel, ActivePage = "Tours", Icon = "map" },
        new { Controller = "Destinations", Action = "Index", Label = destinationsLabel, ActivePage = "Destinations", Icon = "globe_asia" },
        new { Controller = "Home", Action = "Contact", Label = navContactLabel, ActivePage = "Contact", Icon = "call" }
    };

    var secondaryNavItems = new[]
    {
        new { Controller = "Promotions", Action = "Index", Label = promotionsLabel, ActivePage = "Promotions", Icon = "local_activity" },
        new { Controller = "Inspiration", Action = "Index", Label = inspirationLabel, ActivePage = "Inspiration", Icon = "article" },
        new { Controller = "Services", Action = "Index", Label = servicesLabel, ActivePage = "Services", Icon = "package_2" },
        new { Controller = "Home", Action = "About", Label = navAboutLabel, ActivePage = "About", Icon = "info" }
    };

    var mobileNavItems = new[]
    {
        new { Controller = "Home", Action = "Index", Label = navHomeLabel, ActivePage = "Home", Icon = "home" },
        new { Controller = "PublicTours", Action = "Index", Label = navToursLabel, ActivePage = "Tours", Icon = "map" },
        new { Controller = "Destinations", Action = "Index", Label = destinationsLabel, ActivePage = "Destinations", Icon = "globe_asia" },
        new { Controller = "Promotions", Action = "Index", Label = promotionsLabel, ActivePage = "Promotions", Icon = "local_activity" },
        new { Controller = "Inspiration", Action = "Index", Label = inspirationLabel, ActivePage = "Inspiration", Icon = "article" },
        new { Controller = "Services", Action = "Index", Label = servicesLabel, ActivePage = "Services", Icon = "package_2" },
        new { Controller = "Home", Action = "About", Label = navAboutLabel, ActivePage = "About", Icon = "info" },
        new { Controller = "Home", Action = "Contact", Label = navContactLabel, ActivePage = "Contact", Icon = "call" }
    };

    var hasSecondaryActive = false;
    foreach (var secondaryItem in secondaryNavItems)
    {
        if (IsActive(secondaryItem.ActivePage))
        {
            hasSecondaryActive = true;
            break;
        }
    }

        string DesktopNavLinkClass(string pageKey)
    {
        var stateClass = IsActive(pageKey)
            ? "active border-primary/25 bg-gradient-to-r from-primary/15 via-cyan-400/10 to-transparent text-primary dark:border-primary/20 dark:bg-primary/12 dark:text-white"
            : "text-slate-700 dark:text-slate-100 hover:border-primary/20 hover:bg-primary/8 hover:text-primary dark:hover:border-primary/20 dark:hover:bg-primary/10 dark:hover:text-primary";

        return $"public-nav-link inline-flex items-center rounded-full border border-transparent px-3.5 py-2 text-[0.87rem] font-bold tracking-[0.01em] transition-all {stateClass}";
    }

        string MoreToggleClass()
    {
        var stateClass = hasSecondaryActive
            ? "border-primary/25 bg-gradient-to-r from-primary/15 via-cyan-400/10 to-transparent text-primary dark:border-primary/20 dark:bg-primary/12 dark:text-white"
            : "text-slate-700 dark:text-slate-100 hover:border-primary/20 hover:bg-primary/8 hover:text-primary dark:hover:border-primary/20 dark:hover:bg-primary/10 dark:hover:text-primary";

        return $"public-nav-more-toggle inline-flex items-center gap-2 rounded-full border border-transparent px-3.5 py-2 text-[0.87rem] font-bold tracking-[0.01em] transition-all {stateClass}";
    }

        string MobileNavLinkClass(string pageKey)
    {
        var stateClass = IsActive(pageKey)
            ? "bg-primary/10 text-primary dark:bg-primary/10 dark:text-primary"
            : "text-slate-700 dark:text-slate-100 hover:bg-primary/10 hover:text-primary dark:hover:text-primary";

        return $"flex items-center gap-3 rounded-2xl px-4 py-3 text-[0.9rem] font-semibold transition-all {stateClass}";
    }
}
<!DOCTYPE html>
<html class="light" lang="vi">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>@ViewData["Title"] - @brandName</title>
    <meta name="description" content="@(RichTextContentFormatter.ToPlainTextSummary(ViewData["Description"]?.ToString() ?? defaultDescription, 160))" />

    <link href="https://fonts.googleapis.com" rel="preconnect" />
    <link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect" />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Be+Vietnam+Pro:wght@300;400;500;600;700;800&family=Manrope:wght@300;400;500;600;700;800&family=Playfair+Display:wght@400;500;600;700;800&family=Merriweather:wght@300;400;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script src="~/js/tailwind.theme.js" asp-append-version="true"></script>
    <link rel="stylesheet" href="~/css/theme-ocean.css" asp-append-version="true" />
    <style>
        .tour-card:hover .tour-card-img {
            transform: scale(1.08);
        }
        .nav-link {
            position: relative;
        }
        .nav-link::after {
            content: '';
            position: absolute;
            bottom: -2px;
            left: 50%;
            width: 0;
            height: 2px;
            background: linear-gradient(90deg, #14B8D4, #1D4ED8);
            transition: all 0.3s ease;
            transform: translateX(-50%);
        }
        .nav-link:hover::after, .nav-link.active::after {
            width: 100%;
        }

        [data-animate] {
            opacity: 0;
            transition: opacity 1.1s cubic-bezier(.22,1,.36,1), transform 1.1s cubic-bezier(.22,1,.36,1);
            will-change: opacity, transform;
        }
        [data-animate="fade-up"] { transform: translateY(40px); }
        [data-animate="fade-down"] { transform: translateY(-40px); }
        [data-animate="fade-in"] { transform: none; }
        [data-animate="slide-left"] { transform: translateX(-60px); }
        [data-animate="slide-right"] { transform: translateX(60px); }
        [data-animate="scale-in"] { transform: scale(0.9); }
        [data-animate="zoom-in"] { transform: scale(0.85); }
        [data-animate].is-visible {
            opacity: 1;
            transform: none;
        }
        [data-stagger] > * { opacity: 0; transform: translateY(24px); transition: opacity 0.5s ease, transform 0.5s ease; }
        [data-stagger].is-visible > *:nth-child(1) { transition-delay: 0.05s; }
        [data-stagger].is-visible > *:nth-child(2) { transition-delay: 0.12s; }
        [data-stagger].is-visible > *:nth-child(3) { transition-delay: 0.19s; }
        [data-stagger].is-visible > *:nth-child(4) { transition-delay: 0.26s; }
        [data-stagger].is-visible > *:nth-child(5) { transition-delay: 0.33s; }
        [data-stagger].is-visible > *:nth-child(6) { transition-delay: 0.40s; }
        [data-stagger].is-visible > *:nth-child(n+7) { transition-delay: 0.47s; }
        .nav-link:hover::after, .nav-link.active::after {
            width: 100%;
        }

        [data-animate] {
            opacity: 0;
            transition: opacity 1.1s cubic-bezier(.22,1,.36,1), transform 1.1s cubic-bezier(.22,1,.36,1);
            will-change: opacity, transform;
        }
        [data-animate="fade-up"] { transform: translateY(40px); }
        [data-animate="fade-down"] { transform: translateY(-40px); }
        [data-animate="fade-in"] { transform: none; }
        [data-animate="slide-left"] { transform: translateX(-60px); }
        [data-animate="slide-right"] { transform: translateX(60px); }
        [data-animate="scale-in"] { transform: scale(0.9); }
        [data-animate="zoom-in"] { transform: scale(0.85); }
        [data-animate].is-visible {
            opacity: 1;
            transform: none;
        }
        [data-stagger] > * { opacity: 0; transform: translateY(24px); transition: opacity 0.5s ease, transform 0.5s ease; }
        [data-stagger].is-visible > *:nth-child(1) { transition-delay: 0.05s; }
        [data-stagger].is-visible > *:nth-child(2) { transition-delay: 0.12s; }
        [data-stagger].is-visible > *:nth-child(3) { transition-delay: 0.19s; }
        [data-stagger].is-visible > *:nth-child(4) { transition-delay: 0.26s; }
        [data-stagger].is-visible > *:nth-child(5) { transition-delay: 0.33s; }
        [data-stagger].is-visible > *:nth-child(6) { transition-delay: 0.40s; }
        [data-stagger].is-visible > *:nth-child(n+7) { transition-delay: 0.47s; }
        [data-stagger].is-visible > * { opacity: 1; transform: none; }
    </style>
    <script>
        if (localStorage.theme === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark');
        } else {
            document.documentElement.classList.remove('dark');
        }
    </script>
</head>
<body class="public-page-shell bg-background-light dark:bg-background-dark text-text-strong-light dark:text-text-strong-dark font-display min-h-screen flex flex-col selection:bg-primary selection:text-white">
    <header class="public-site-header sticky top-0 z-50 bg-surface-light/82 dark:bg-surface-dark/82 backdrop-blur-xl border-b border-border-light/60 dark:border-border-dark/60 transition-all duration-300" id="site-header">
        <div class="mx-auto max-w-7xl">
            <div class="public-header-shell public-header-compact flex h-[3.9rem] items-center gap-3 sm:h-[4.4rem] xl:gap-5">
                <a asp-controller="Home" asp-action="Index" class="public-brand-lockup flex min-w-0 shrink-0 items-center gap-2.5 group">
                    <div class="flex size-9 items-center justify-center rounded-xl bg-gradient-to-br from-primary to-accent text-white shadow-lg shadow-primary/30 transition-all group-hover:scale-105 group-hover:shadow-primary/50">
                        <span class="material-symbols-outlined">flight_takeoff</span>
                    </div>
                    <div class="min-w-0">
                        <h1 class="public-brand-title truncate text-base font-extrabold leading-none tracking-tight text-slate-900 dark:text-white">@brandName</h1>
                        <p class="public-brand-tagline truncate text-[10px] font-semibold uppercase tracking-[0.28em] text-primary">@brandTagline</p>
                    </div>
                </a>

                <nav class="public-primary-nav hidden xl:flex" aria-label="&#272;i&#7873;u h&#432;&#7899;ng ch&#237;nh">
                    @foreach (var item in primaryNavItems)
                    {
                        <a asp-controller="@item.Controller" asp-action="@item.Action" class="@DesktopNavLinkClass(item.ActivePage)">@item.Label</a>
                    }
                    <div class="public-secondary-nav relative">
                        <button id="public-nav-more-toggle" type="button" class="@MoreToggleClass()" aria-expanded="false" aria-controls="public-nav-more-panel">
                            <span>@moreLabel</span>
                            <span class="material-symbols-outlined text-[18px]">expand_more</span>
                        </button>
                        <div id="public-nav-more-panel" class="public-secondary-nav-panel hidden absolute left-1/2 top-full z-50 mt-3 w-72 -translate-x-1/2 rounded-3xl border border-border-light bg-white/95 p-3 shadow-2xl shadow-slate-200/40 backdrop-blur dark:border-border-dark dark:bg-surface-dark/95">
                            <div class="space-y-1">
                                @foreach (var item in secondaryNavItems)
                                {
                                    <a asp-controller="@item.Controller" asp-action="@item.Action" class="@MobileNavLinkClass(item.ActivePage)">
                                        <span class="material-symbols-outlined text-[20px]">@item.Icon</span>
                                        <span>@item.Label</span>
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                </nav>

                <div class="public-nav-actions ml-auto flex min-w-0 shrink-0 items-center justify-end gap-2 sm:gap-3">
                    <button id="theme-toggle-public" class="group inline-flex size-9 items-center justify-center rounded-full font-medium text-slate-500 transition-all hover:bg-surface-muted-light hover:text-primary dark:text-text-muted-dark dark:hover:bg-surface-elevated-dark" aria-label="Chuy&#7875;n ch&#7871; &#273;&#7897; t&#7889;i">
                        <span class="material-symbols-outlined dark:hidden text-[20px] leading-none transition-transform duration-200 group-hover:rotate-12">dark_mode</span>
                        <span class="material-symbols-outlined hidden dark:block text-[20px] leading-none transition-transform duration-200 group-hover:-rotate-12">light_mode</span>
                    </button>
                    <div class="hidden xl:flex items-center gap-2 2xl:gap-3">
                        <a asp-controller="BookingLookup" asp-action="Index" class="public-nav-utility-link inline-flex items-center gap-2 rounded-xl border border-border-light bg-white/70 px-3.5 py-2 text-[0.86rem] font-bold text-slate-700 transition-all hover:border-primary hover:text-primary dark:border-border-dark dark:bg-surface-elevated-dark/80 dark:text-slate-100">
                            <span class="material-symbols-outlined text-[18px]">search</span>
                            <span>@bookingLookupLabel</span>
                        </a>
                        @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Customer"))
                        {
                            var customerName = User.FindFirst("FullName")?.Value ?? User.Identity?.Name ?? customerFallbackLabel;
                            customerName = string.IsNullOrWhiteSpace(customerName) ? customerFallbackLabel : customerName.Trim();
                            var customerCode = User.FindFirst("CustomerCode")?.Value ?? customerCodeFallbackLabel;
                            var customerInitial = customerName.Substring(0, 1).ToUpperInvariant();
                            <div class="public-account-menu relative">
                                <button id="public-account-toggle" type="button" class="public-account-toggle inline-flex items-center gap-2.5 rounded-2xl border border-border-light/80 bg-surface-light/80 px-3 py-1.5 text-left shadow-sm transition-all hover:border-primary/40 dark:border-border-dark dark:bg-surface-elevated-dark/85" aria-expanded="false" aria-controls="public-account-panel">
                                    <span class="flex size-9 items-center justify-center rounded-full bg-gradient-to-br from-primary to-accent text-xs font-extrabold text-white">@customerInitial</span>
                                    <span class="min-w-0 hidden 2xl:block">
                                        <span class="block truncate text-[0.83rem] font-bold text-slate-900 dark:text-white">@customerName</span>
                                        <span class="block truncate text-xs text-slate-500 dark:text-slate-400">@customerCode</span>
                                    </span>
                                    <span class="material-symbols-outlined text-[18px] text-slate-500 dark:text-slate-300">expand_more</span>
                                </button>
                                <div id="public-account-panel" class="public-account-panel hidden absolute right-0 top-full z-50 mt-3 w-80 rounded-3xl border border-border-light bg-white/95 p-4 shadow-2xl shadow-slate-200/40 backdrop-blur dark:border-border-dark dark:bg-surface-dark/95">
                                    <div class="flex items-center gap-3 rounded-2xl bg-surface-muted-light px-4 py-4 dark:bg-surface-elevated-dark">
                                        <span class="flex size-12 items-center justify-center rounded-full bg-gradient-to-br from-primary to-accent text-base font-extrabold text-white">@customerInitial</span>
                                        <div class="min-w-0">
                                            <p class="truncate text-sm font-bold text-slate-900 dark:text-white">@customerName</p>
                                            <p class="truncate text-xs text-slate-500 dark:text-slate-400">@customerCode</p>
                                        </div>
                                    </div>
                                    <div class="mt-4 space-y-2">
                                        <a asp-controller="CustomerPortal" asp-action="Index" class="flex items-center gap-3 rounded-2xl px-4 py-3 text-sm font-semibold text-primary transition-colors hover:bg-primary/10 dark:hover:bg-primary/10">
                                            <span class="material-symbols-outlined text-[20px]">account_circle</span>
                                            <span>@openPortalLabel</span>
                                        </a>
                                        <form asp-controller="CustomerAuth" asp-action="Logout" method="post">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="flex w-full items-center gap-3 rounded-2xl px-4 py-3 text-sm font-semibold text-slate-600 transition-colors hover:bg-slate-100 hover:text-slate-900 dark:text-slate-200 dark:hover:bg-slate-700/70 dark:hover:text-white">
                                                <span class="material-symbols-outlined text-[20px]">logout</span>
                                                <span>@logoutLabel</span>
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        }
                        else
                        {
                            <a asp-controller="CustomerAuth" asp-action="Login" class="public-nav-action-cta inline-flex items-center gap-2 rounded-xl bg-primary px-4 py-2 text-[0.86rem] font-bold text-white shadow-lg shadow-primary/25 transition-all hover:-translate-y-0.5 hover:bg-primary-dark hover:shadow-primary/40 active:scale-95">
                                <span class="material-symbols-outlined text-[18px]">login</span>
                                @loginLabel
