                                <a asp-controller="CustomerAuth" asp-action="Login" class="public-nav-action-cta flex items-center justify-center gap-2 rounded-2xl bg-primary px-4 py-3 text-sm font-bold text-white shadow-lg shadow-primary/20 transition-all">@loginLabel</a>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </header>

