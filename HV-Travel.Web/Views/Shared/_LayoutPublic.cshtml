                        {
                            var mobileCustomerName = User.FindFirst("FullName")?.Value ?? User.Identity?.Name ?? customerFallbackLabel;
                            mobileCustomerName = string.IsNullOrWhiteSpace(mobileCustomerName) ? customerFallbackLabel : mobileCustomerName.Trim();
                            <div class="mt-3 rounded-3xl bg-surface-muted-light px-4 py-4 dark:bg-surface-elevated-dark">
                                <p class="text-sm font-bold text-slate-900 dark:text-white">@mobileCustomerName</p>
