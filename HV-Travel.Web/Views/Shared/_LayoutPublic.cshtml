@inject IPublicContentService ContentService
@{
    var siteSettings = await ContentService.GetSiteSettingsAsync();
    var headerGroup = siteSettings.GetGroup("header");
    var footerBrandGroup = siteSettings.GetGroup("footerBrand");
    var footerExploreGroup = siteSettings.GetGroup("footerExplore");
    var footerCompanyGroup = siteSettings.GetGroup("footerCompany");
    var contactGroup = siteSettings.GetGroup("contactInfo");
    var socialGroup = siteSettings.GetGroup("socialLinks");
    var seoGroup = siteSettings.GetGroup("seo");

    var brandName = headerGroup?.Fields.GetFieldValue("brandName", "HV Travel") ?? "HV Travel";
    var brandTagline = headerGroup?.Fields.GetFieldValue("brandTagline", "Kh\u00e1m ph\u00e1 Vi\u1ec7t Nam") ?? "Kh\u00e1m ph\u00e1 Vi\u1ec7t Nam";
    var navHomeLabel = headerGroup?.Fields.GetFieldValue("navHomeLabel", "Trang ch\u1ee7") ?? "Trang ch\u1ee7";
    var navToursLabel = headerGroup?.Fields.GetFieldValue("navToursLabel", "Tour du l\u1ecbch") ?? "Tour du l\u1ecbch";
    var navAboutLabel = headerGroup?.Fields.GetFieldValue("navAboutLabel", "Gi\u1edbi thi\u1ec7u") ?? "Gi\u1edbi thi\u1ec7u";
    var navContactLabel = headerGroup?.Fields.GetFieldValue("navContactLabel", "Li\u00ean h\u1ec7") ?? "Li\u00ean h\u1ec7";
    var registerLabel = headerGroup?.Fields.GetFieldValue("registerLabel", "\u0110\u0103ng k\u00fd") ?? "\u0110\u0103ng k\u00fd";
    var loginLabel = headerGroup?.Fields.GetFieldValue("loginLabel", "\u0110\u0103ng nh\u1eadp") ?? "\u0110\u0103ng nh\u1eadp";
    var defaultDescription = seoGroup?.Fields.GetFieldValue("defaultMetaDescription", "HV Travel - Kh\u00e1m ph\u00e1 Vi\u1ec7t Nam c\u00f9ng nh\u1eefng tour du l\u1ecbch tuy\u1ec7t v\u1eddi nh\u1ea5t")
        ?? "HV Travel - Kh\u00e1m ph\u00e1 Vi\u1ec7t Nam c\u00f9ng nh\u1eefng tour du l\u1ecbch tuy\u1ec7t v\u1eddi nh\u1ea5t";
    var pageTitle = ViewData["Title"]?.ToString();
    var resolvedTitle = string.IsNullOrWhiteSpace(pageTitle) ? brandName : $"{pageTitle} - {brandName}";
    var pageDescription = RichTextContentFormatter.ToPlainTextSummary(ViewData["Description"]?.ToString() ?? defaultDescription, 160);
    var canonicalUrl = ViewData["CanonicalUrl"]?.ToString();
    var openGraphTitle = ViewData["OpenGraphTitle"]?.ToString() ?? resolvedTitle;
    var openGraphDescription = ViewData["OpenGraphDescription"]?.ToString() ?? pageDescription;
    var openGraphImage = ViewData["OpenGraphImage"]?.ToString() ?? string.Empty;

    var footerBrandTitle = footerBrandGroup?.Fields.GetFieldValue("title", "HV Travel") ?? "HV Travel";
    var footerBrandTagline = footerBrandGroup?.Fields.GetFieldValue("tagline", "Kh\u00e1m ph\u00e1 Vi\u1ec7t Nam") ?? "Kh\u00e1m ph\u00e1 Vi\u1ec7t Nam";
    var footerBrandDescription = footerBrandGroup?.Fields.GetFieldValue("description", "Khám phá vẻ đẹp Việt Nam với những tour du lịch được thiết kế riêng. Trải nghiệm văn hóa, ẩm thực và thiên nhiên tuyệt vời.")
        ?? "Khám phá vẻ đẹp Việt Nam với những tour du lịch được thiết kế riêng. Trải nghiệm văn hóa, ẩm thực và thiên nhiên tuyệt vời.";
    var allRightsReservedLabel = footerBrandGroup?.Fields.GetFieldValue("allRightsReservedLabel", "Bảo lưu mọi quyền.") ?? "Bảo lưu mọi quyền.";

    var footerExploreTitle = footerExploreGroup?.Fields.GetFieldValue("title", "Kh\u00e1m ph\u00e1") ?? "Kh\u00e1m ph\u00e1";
    var allToursLabel = footerExploreGroup?.Fields.GetFieldValue("allToursLabel", "T\u1ea5t c\u1ea3 tour") ?? "T\u1ea5t c\u1ea3 tour";
    var popularToursLabel = footerExploreGroup?.Fields.GetFieldValue("popularToursLabel", "Tour ph\u1ed5 bi\u1ebfn") ?? "Tour ph\u1ed5 bi\u1ebfn";
    var hotDestinationsLabel = footerExploreGroup?.Fields.GetFieldValue("hotDestinationsLabel", "\u0110i\u1ec3m \u0111\u1ebfn hot") ?? "\u0110i\u1ec3m \u0111\u1ebfn hot";
    var specialOffersLabel = footerExploreGroup?.Fields.GetFieldValue("specialOffersLabel", "\u01afu \u0111\u00e3i \u0111\u1eb7c bi\u1ec7t") ?? "\u01afu \u0111\u00e3i \u0111\u1eb7c bi\u1ec7t";

    var footerCompanyTitle = footerCompanyGroup?.Fields.GetFieldValue("title", "C\u00f4ng ty") ?? "C\u00f4ng ty";
    var footerAboutLabel = footerCompanyGroup?.Fields.GetFieldValue("aboutLabel", "Gi\u1edbi thi\u1ec7u") ?? "Gi\u1edbi thi\u1ec7u";
    var footerContactLabel = footerCompanyGroup?.Fields.GetFieldValue("contactLabel", "Li\u00ean h\u1ec7") ?? "Li\u00ean h\u1ec7";
    var privacyLabel = footerCompanyGroup?.Fields.GetFieldValue("privacyLabel", "Ch\u00ednh s\u00e1ch b\u1ea3o m\u1eadt") ?? "Ch\u00ednh s\u00e1ch b\u1ea3o m\u1eadt";
    var termsLabel = footerCompanyGroup?.Fields.GetFieldValue("termsLabel", "Điều khoản sử dụng") ?? "Điều khoản sử dụng";
    var sitemapLabel = footerCompanyGroup?.Fields.GetFieldValue("sitemapLabel", "Sơ đồ trang") ?? "Sơ đồ trang";

    var contactTitle = contactGroup?.Fields.GetFieldValue("title", "Li\u00ean h\u1ec7") ?? "Li\u00ean h\u1ec7";
    var contactAddress = contactGroup?.Fields.GetFieldValue("address", "123 \u0110\u01b0\u1eddng Nguy\u1ec5n Hu\u1ec7, Qu\u1eadn 1, TP.HCM") ?? "123 \u0110\u01b0\u1eddng Nguy\u1ec5n Hu\u1ec7, Qu\u1eadn 1, TP.HCM";
    var contactPhone = contactGroup?.Fields.GetFieldValue("phoneNumber", "+84 (28) 3822 9999") ?? "+84 (28) 3822 9999";
    var contactEmail = contactGroup?.Fields.GetFieldValue("email", "info@hvtravel.vn") ?? "info@hvtravel.vn";
    var businessHours = contactGroup?.Fields.GetFieldValue("businessHours", "T2 - T7: 8:00 - 18:00") ?? "T2 - T7: 8:00 - 18:00";

    var facebookUrl = socialGroup?.Fields.GetFieldValue("facebookUrl", "#") ?? "#";
    var instagramUrl = socialGroup?.Fields.GetFieldValue("instagramUrl", "#") ?? "#";
    var youtubeUrl = socialGroup?.Fields.GetFieldValue("youtubeUrl", "#") ?? "#";
    var activePage = ViewData["ActivePage"]?.ToString() ?? string.Empty;
    var destinationsLabel = headerGroup?.Fields.GetFieldValue("navDestinationsLabel", "Điểm đến") ?? "Điểm đến";
    var promotionsLabel = headerGroup?.Fields.GetFieldValue("navPromotionsLabel", "Ưu đãi") ?? "Ưu đãi";
    var inspirationLabel = headerGroup?.Fields.GetFieldValue("navInspirationLabel", "Cẩm nang") ?? "Cẩm nang";
    var servicesLabel = headerGroup?.Fields.GetFieldValue("navServicesLabel", "Dịch vụ") ?? "Dịch vụ";
    var bookingLookupLabel = headerGroup?.Fields.GetFieldValue("bookingLookupLabel", "Tra cứu booking") ?? "Tra cứu booking";
    var moreLabel = headerGroup?.Fields.GetFieldValue("moreLabel", "Khám phá thêm") ?? "Khám phá thêm";
    var openPortalLabel = headerGroup?.Fields.GetFieldValue("openPortalLabel", "Mở portal") ?? "Mở portal";
    var customerFallbackLabel = headerGroup?.Fields.GetFieldValue("customerFallbackLabel", "Khách hàng") ?? "Khách hàng";
    var customerCodeFallbackLabel = headerGroup?.Fields.GetFieldValue("customerCodeFallbackLabel", "Khách hàng HV Travel") ?? "Khách hàng HV Travel";
    var logoutLabel = headerGroup?.Fields.GetFieldValue("logoutLabel", "Đăng xuất") ?? "Đăng xuất";

    bool IsActive(string pageKey) => string.Equals(activePage, pageKey, System.StringComparison.OrdinalIgnoreCase);

    var primaryNavItems = new[]
    {
        new { Controller = "Home", Action = "Index", Label = navHomeLabel, ActivePage = "Home", Icon = "home" },
        new { Controller = "PublicTours", Action = "Index", Label = navToursLabel, ActivePage = "Tours", Icon = "map" },
        new { Controller = "Destinations", Action = "Index", Label = destinationsLabel, ActivePage = "Destinations", Icon = "globe_asia" },
        new { Controller = "Home", Action = "Contact", Label = navContactLabel, ActivePage = "Contact", Icon = "call" }
    };
    primaryNavItems = primaryNavItems.Where(item => !string.IsNullOrWhiteSpace(item.Label)).ToArray();

    var secondaryNavItems = new[]
    {
        new { Controller = "Promotions", Action = "Index", Label = promotionsLabel, ActivePage = "Promotions", Icon = "local_activity" },
        new { Controller = "Inspiration", Action = "Index", Label = inspirationLabel, ActivePage = "Inspiration", Icon = "article" },
        new { Controller = "Services", Action = "Index", Label = servicesLabel, ActivePage = "Services", Icon = "package_2" },
        new { Controller = "Home", Action = "About", Label = navAboutLabel, ActivePage = "About", Icon = "info" }
    };
    secondaryNavItems = secondaryNavItems.Where(item => !string.IsNullOrWhiteSpace(item.Label)).ToArray();

    var mobileNavItems = new[]
    {
        new { Controller = "Home", Action = "Index", Label = navHomeLabel, ActivePage = "Home", Icon = "home" },
        new { Controller = "PublicTours", Action = "Index", Label = navToursLabel, ActivePage = "Tours", Icon = "map" },
        new { Controller = "Destinations", Action = "Index", Label = destinationsLabel, ActivePage = "Destinations", Icon = "globe_asia" },
        new { Controller = "Promotions", Action = "Index", Label = promotionsLabel, ActivePage = "Promotions", Icon = "local_activity" },
        new { Controller = "Inspiration", Action = "Index", Label = inspirationLabel, ActivePage = "Inspiration", Icon = "article" },
        new { Controller = "Services", Action = "Index", Label = servicesLabel, ActivePage = "Services", Icon = "package_2" },
        new { Controller = "Home", Action = "About", Label = navAboutLabel, ActivePage = "About", Icon = "info" },
        new { Controller = "Home", Action = "Contact", Label = navContactLabel, ActivePage = "Contact", Icon = "call" }
    };
    mobileNavItems = mobileNavItems.Where(item => !string.IsNullOrWhiteSpace(item.Label)).ToArray();

    var hasSecondaryActive = false;
    foreach (var secondaryItem in secondaryNavItems)
    {
        if (IsActive(secondaryItem.ActivePage))
        {
            hasSecondaryActive = true;
            break;
        }
    }

    string HeaderControlClass(bool active = false)
    {
        var baseClass = "inline-flex items-center justify-center rounded-full border px-3.5 py-2 text-[0.87rem] font-bold tracking-[0.01em] whitespace-nowrap transition duration-200";
        var idleClass = "border-slate-200/80 bg-white/90 text-slate-700 shadow-sm shadow-slate-200/40 hover:-translate-y-0.5 hover:border-primary/30 hover:bg-white hover:text-primary hover:shadow-lg hover:shadow-sky-200/30 dark:border-slate-800 dark:bg-slate-900/90 dark:text-slate-200 dark:shadow-black/20 dark:hover:border-primary/40 dark:hover:bg-slate-900 dark:hover:text-primary";
        var activeClass = "border-primary/30 bg-primary/10 text-primary shadow-lg shadow-sky-200/30 dark:border-primary/40 dark:bg-sky-500/10";
        return $"{baseClass} {(active ? activeClass : idleClass)}";
    }

    string DesktopNavLinkClass(string pageKey) => HeaderControlClass(IsActive(pageKey));

    string MoreToggleClass() => $"{HeaderControlClass(hasSecondaryActive)} gap-2";

    string MobileNavLinkClass(string pageKey)
    {
        var baseClass = "flex items-center gap-3 rounded-[1.4rem] px-4 py-3 text-sm font-semibold transition duration-200";
        var idleClass = "text-slate-700 hover:bg-primary/10 hover:text-primary dark:text-slate-200 dark:hover:bg-sky-500/10";
        var activeClass = "bg-primary/10 text-primary dark:bg-sky-500/10";
        return $"{baseClass} {(IsActive(pageKey) ? activeClass : idleClass)}";
    }
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>@resolvedTitle</title>
        <meta name="description" content="@pageDescription" />
    @if (!string.IsNullOrWhiteSpace(canonicalUrl))
    {
        <link rel="canonical" href="@canonicalUrl" />
    }
    <meta property="og:title" content="@openGraphTitle" />
    <meta property="og:description" content="@openGraphDescription" />
    <meta property="og:type" content="website" />
    @if (!string.IsNullOrWhiteSpace(canonicalUrl))
    {
        <meta property="og:url" content="@canonicalUrl" />
    }
    <meta property="og:image" content="@openGraphImage" />

    <link href="https://fonts.googleapis.com" rel="preconnect" />
    <link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect" />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Be+Vietnam+Pro:wght@300;400;500;600;700;800&family=Manrope:wght@300;400;500;600;700;800&family=Playfair+Display:wght@400;500;600;700;800&family=Merriweather:wght@300;400;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

    <script src="https://cdn.tailwindcss.com?plugins=forms,typography,container-queries"></script>
    <script src="~/js/tailwind.theme.js" asp-append-version="true"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
    <script>
        if (localStorage.theme === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark');
            document.documentElement.classList.remove('light');
        } else {
            document.documentElement.classList.remove('dark');
            document.documentElement.classList.add('light');
        }
    </script>
</head>
<body class="min-h-screen overflow-x-clip bg-background-light text-text-strong-light font-display selection:bg-primary selection:text-white dark:bg-background-dark dark:text-text-strong-dark">
    <div class="flex min-h-screen flex-col">
    <header class="sticky top-0 z-50 border-b border-slate-200/70 bg-white/80 backdrop-blur-xl transition-shadow duration-300 dark:border-slate-800/80 dark:bg-slate-950/85 relative" id="site-header">
        <div aria-hidden="true" class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(20,184,212,0.12),transparent_35%),radial-gradient(circle_at_top_right,rgba(29,78,216,0.12),transparent_35%)]"></div>
        <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
            <div class="relative flex h-[4.25rem] items-center gap-3 sm:h-[4.75rem] xl:gap-5">
                <a asp-controller="Home" asp-action="Index" class="group flex min-w-0 shrink-0 items-center gap-2.5">
                    <div class="flex size-9 items-center justify-center rounded-xl bg-gradient-to-br from-primary to-accent text-white shadow-lg shadow-primary/30 transition-all group-hover:scale-105 group-hover:shadow-primary/50">
                        <span class="material-symbols-outlined">flight_takeoff</span>
                    </div>
                    <div class="min-w-0">
                        <h1 class="truncate text-base font-extrabold leading-none tracking-tight text-slate-950 dark:text-white">@brandName</h1>
                        <p class="truncate text-[10px] font-semibold uppercase tracking-[0.28em] text-primary">@brandTagline</p>
                    </div>
                </a>

                <nav class="hidden min-w-0 flex-1 items-center justify-center gap-2 xl:flex" aria-label="Điều hướng chính">
                    @foreach (var item in primaryNavItems)
                    {
                        <a asp-controller="@item.Controller" asp-action="@item.Action" class="@DesktopNavLinkClass(item.ActivePage)">@item.Label</a>
                    }
                    @if (!string.IsNullOrWhiteSpace(moreLabel) && secondaryNavItems.Any())
                    {
                        <div class="relative">
                            <button id="nav-more-toggle" type="button" class="@MoreToggleClass()" aria-expanded="false" aria-controls="nav-more-panel">
                                <span>@moreLabel</span>
                                <span class="material-symbols-outlined text-[18px] transition-transform" data-chevron>expand_more</span>
                            </button>
                            <div id="nav-more-panel" class="absolute left-1/2 top-full z-[60] mt-3 hidden w-72 -translate-x-1/2 rounded-[1.75rem] border border-slate-200/80 bg-white/95 p-3 shadow-2xl shadow-slate-200/60 backdrop-blur dark:border-slate-800 dark:bg-slate-950/95 dark:shadow-black/40">
                                <div class="space-y-1">
                                    @foreach (var item in secondaryNavItems)
                                    {
                                        <a asp-controller="@item.Controller" asp-action="@item.Action" class="@MobileNavLinkClass(item.ActivePage)">
                                            <span class="material-symbols-outlined text-[20px]">@item.Icon</span>
                                            <span>@item.Label</span>
                                        </a>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </nav>

                <div class="ml-auto flex min-w-0 shrink-0 items-center justify-end gap-2 sm:gap-3">
                    <button id="theme-toggle-public" class="inline-flex size-10 items-center justify-center rounded-full border border-slate-200/80 bg-white/90 text-slate-700 shadow-sm shadow-slate-200/40 transition duration-200 hover:-translate-y-0.5 hover:border-primary/30 hover:text-primary hover:shadow-lg hover:shadow-sky-200/30 dark:border-slate-800 dark:bg-slate-900/90 dark:text-slate-200 dark:shadow-black/20 dark:hover:border-primary/40 dark:hover:text-primary" aria-label="Chuyển chế độ tối">
                        <span class="material-symbols-outlined dark:hidden text-[20px] leading-none transition-transform duration-200">dark_mode</span>
                        <span class="material-symbols-outlined hidden dark:block text-[20px] leading-none transition-transform duration-200">light_mode</span>
                    </button>
                    <div class="hidden items-center gap-2 2xl:gap-3 xl:flex">
@if (!string.IsNullOrWhiteSpace(bookingLookupLabel))
                        {
                            <a asp-controller="BookingLookup" asp-action="Index" class="inline-flex items-center gap-2 rounded-full border border-slate-200/80 bg-white/90 px-3.5 py-2 text-[0.86rem] font-bold text-slate-700 shadow-sm shadow-slate-200/40 transition duration-200 hover:-translate-y-0.5 hover:border-primary/30 hover:text-primary hover:shadow-lg hover:shadow-sky-200/30 dark:border-slate-800 dark:bg-slate-900/90 dark:text-slate-200 dark:shadow-black/20 dark:hover:border-primary/40 dark:hover:text-primary">
                                <span class="material-symbols-outlined text-[18px]">search</span>
                                <span>@bookingLookupLabel</span>
                            </a>
                        }
                        @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Customer"))
                        {
                            var customerName = User.FindFirst("FullName")?.Value ?? User.Identity?.Name ?? customerFallbackLabel;
                            customerName = string.IsNullOrWhiteSpace(customerName) ? customerFallbackLabel : customerName.Trim();
                            var customerCode = User.FindFirst("CustomerCode")?.Value ?? customerCodeFallbackLabel;
                            var customerInitial = customerName.Substring(0, 1).ToUpperInvariant();
                            <div class="relative">
                                <button id="account-toggle" type="button" class="inline-flex items-center gap-2.5 rounded-[1.3rem] border border-slate-200/80 bg-white/90 px-3 py-1.5 text-left text-slate-700 shadow-sm shadow-slate-200/40 transition duration-200 hover:-translate-y-0.5 hover:border-primary/30 hover:text-primary hover:shadow-lg hover:shadow-sky-200/30 dark:border-slate-800 dark:bg-slate-900/90 dark:text-slate-200 dark:shadow-black/20 dark:hover:border-primary/40 dark:hover:text-primary" aria-expanded="false" aria-controls="account-panel">
                                    <span class="flex size-9 items-center justify-center rounded-full bg-gradient-to-br from-primary to-accent text-xs font-extrabold text-white">@customerInitial</span>
                                    <span class="hidden min-w-0 2xl:block">
                                        <span class="block truncate text-[0.83rem] font-bold text-slate-950 dark:text-white">@customerName</span>
                                        <span class="block truncate text-xs text-slate-500 dark:text-slate-400">@customerCode</span>
                                    </span>
                                    <span class="material-symbols-outlined text-[18px] text-slate-500 transition-transform dark:text-slate-300" data-chevron>expand_more</span>
                                </button>
                                <div id="account-panel" class="absolute right-0 top-full z-[60] mt-3 hidden w-80 rounded-[1.75rem] border border-slate-200/80 bg-white/95 p-4 shadow-2xl shadow-slate-200/60 backdrop-blur dark:border-slate-800 dark:bg-slate-950/95 dark:shadow-black/40">
                                    <div class="flex items-center gap-3 rounded-[1.35rem] bg-slate-100/85 px-4 py-4 dark:bg-slate-900/90">
                                        <span class="flex size-12 items-center justify-center rounded-full bg-gradient-to-br from-primary to-accent text-base font-extrabold text-white">@customerInitial</span>
                                        <div class="min-w-0">
                                            <p class="truncate text-sm font-bold text-slate-950 dark:text-white">@customerName</p>
                                            <p class="truncate text-xs text-slate-500 dark:text-slate-400">@customerCode</p>
                                        </div>
                                    </div>
                                    <div class="mt-4 space-y-2">
                                        @if (!string.IsNullOrWhiteSpace(openPortalLabel))
                                        {
                                            <a asp-controller="CustomerPortal" asp-action="Index" class="flex items-center gap-3 rounded-[1.2rem] px-4 py-3 text-sm font-semibold text-primary transition hover:bg-primary/10 dark:hover:bg-sky-500/10">
                                                <span class="material-symbols-outlined text-[20px]">account_circle</span>
                                                <span>@openPortalLabel</span>
                                            </a>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(logoutLabel))
                                        {
                                            <form asp-controller="CustomerAuth" asp-action="Logout" method="post">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="flex w-full items-center gap-3 rounded-[1.2rem] px-4 py-3 text-sm font-semibold text-slate-600 transition hover:bg-slate-100 hover:text-slate-900 dark:text-slate-200 dark:hover:bg-slate-800 dark:hover:text-white">
                                                    <span class="material-symbols-outlined text-[20px]">logout</span>
                                                    <span>@logoutLabel</span>
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                        else
                        {
                            @if (!string.IsNullOrWhiteSpace(loginLabel))
                            {
                                <a asp-controller="CustomerAuth" asp-action="Login" class="inline-flex items-center gap-2 rounded-full bg-primary px-4 py-2 text-[0.86rem] font-bold text-white shadow-lg shadow-primary/25 transition duration-200 hover:-translate-y-0.5 hover:bg-primary-dark hover:shadow-primary/40 active:scale-95">
                                    <span class="material-symbols-outlined text-[18px]">login</span>
                                    @loginLabel
                                </a>
                            }
                        }
                    </div>
                    <button id="mobile-menu-btn" type="button" class="inline-flex size-10 items-center justify-center rounded-full border border-slate-200/80 bg-white/90 text-slate-700 shadow-sm shadow-slate-200/40 transition duration-200 hover:-translate-y-0.5 hover:border-primary/30 hover:text-primary hover:shadow-lg hover:shadow-sky-200/30 dark:border-slate-800 dark:bg-slate-900/90 dark:text-slate-200 dark:shadow-black/20 dark:hover:border-primary/40 dark:hover:text-primary xl:hidden" aria-expanded="false" aria-controls="mobile-menu">
                        <span class="material-symbols-outlined text-[24px]">menu</span>
                    </button>
                </div>
            </div>
            <div id="mobile-menu" class="hidden border-t border-slate-200/70 py-4 dark:border-slate-800 xl:hidden">
                <div class="py-4">
                    <nav class="space-y-1" aria-label="Điều hướng di động">
                        @foreach (var item in mobileNavItems)
                        {
                            <a asp-controller="@item.Controller" asp-action="@item.Action" class="@MobileNavLinkClass(item.ActivePage)">
                                <span class="material-symbols-outlined text-[20px]">@item.Icon</span>
                                <span>@item.Label</span>
                            </a>
                        }
                    </nav>
                    <div class="mt-4 border-t border-slate-200/70 pt-4 dark:border-slate-800">
                        @if (!string.IsNullOrWhiteSpace(bookingLookupLabel))
                        {
