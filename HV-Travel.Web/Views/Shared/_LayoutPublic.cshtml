@inject IPublicContentService ContentService
@{
    var siteSettings = await ContentService.GetSiteSettingsAsync();
    var headerGroup = siteSettings.GetGroup("header");
    var footerBrandGroup = siteSettings.GetGroup("footerBrand");
    var footerExploreGroup = siteSettings.GetGroup("footerExplore");
    var footerCompanyGroup = siteSettings.GetGroup("footerCompany");
    var contactGroup = siteSettings.GetGroup("contactInfo");
    var socialGroup = siteSettings.GetGroup("socialLinks");
    var seoGroup = siteSettings.GetGroup("seo");

    var brandName = headerGroup?.Fields.GetFieldValue("brandName", "HV Travel") ?? "HV Travel";
    var brandTagline = headerGroup?.Fields.GetFieldValue("brandTagline", "Khám phá Việt Nam") ?? "Khám phá Việt Nam";
    var navHomeLabel = headerGroup?.Fields.GetFieldValue("navHomeLabel", "Trang chủ") ?? "Trang chủ";
    var navToursLabel = headerGroup?.Fields.GetFieldValue("navToursLabel", "Tour du lịch") ?? "Tour du lịch";
    var navAboutLabel = headerGroup?.Fields.GetFieldValue("navAboutLabel", "Giới thiệu") ?? "Giới thiệu";
    var navContactLabel = headerGroup?.Fields.GetFieldValue("navContactLabel", "Liên hệ") ?? "Liên hệ";
    var registerLabel = headerGroup?.Fields.GetFieldValue("registerLabel", "Đăng ký") ?? "Đăng ký";
    var loginLabel = headerGroup?.Fields.GetFieldValue("loginLabel", "Đăng nhập") ?? "Đăng nhập";
    var defaultDescription = seoGroup?.Fields.GetFieldValue("defaultMetaDescription", "HV Travel - Khám phá Việt Nam cùng những tour du lịch tuyệt vời nhất")
        ?? "HV Travel - Khám phá Việt Nam cùng những tour du lịch tuyệt vời nhất";

    var footerBrandTitle = footerBrandGroup?.Fields.GetFieldValue("title", "HV Travel") ?? "HV Travel";
    var footerBrandTagline = footerBrandGroup?.Fields.GetFieldValue("tagline", "Khám phá Việt Nam") ?? "Khám phá Việt Nam";
    var footerBrandDescription = footerBrandGroup?.Fields.GetFieldValue("description", "Khám phá vẻ đẹp Việt Nam với những tour du lịch được thiết kế riêng. Trải nghiệm văn hóa, ẩm thực và thiên nhiên tuyệt vời.")
        ?? "Khám phá vẻ đẹp Việt Nam với những tour du lịch được thiết kế riêng. Trải nghiệm văn hóa, ẩm thực và thiên nhiên tuyệt vời.";

    var footerExploreTitle = footerExploreGroup?.Fields.GetFieldValue("title", "Khám phá") ?? "Khám phá";
    var allToursLabel = footerExploreGroup?.Fields.GetFieldValue("allToursLabel", "Tất cả tour") ?? "Tất cả tour";
    var popularToursLabel = footerExploreGroup?.Fields.GetFieldValue("popularToursLabel", "Tour phổ biến") ?? "Tour phổ biến";
    var hotDestinationsLabel = footerExploreGroup?.Fields.GetFieldValue("hotDestinationsLabel", "Điểm đến hot") ?? "Điểm đến hot";
    var specialOffersLabel = footerExploreGroup?.Fields.GetFieldValue("specialOffersLabel", "Ưu đãi đặc biệt") ?? "Ưu đãi đặc biệt";

    var footerCompanyTitle = footerCompanyGroup?.Fields.GetFieldValue("title", "Công ty") ?? "Công ty";
    var footerAboutLabel = footerCompanyGroup?.Fields.GetFieldValue("aboutLabel", "Giới thiệu") ?? "Giới thiệu";
    var footerContactLabel = footerCompanyGroup?.Fields.GetFieldValue("contactLabel", "Liên hệ") ?? "Liên hệ";
    var privacyLabel = footerCompanyGroup?.Fields.GetFieldValue("privacyLabel", "Chính sách bảo mật") ?? "Chính sách bảo mật";
    var termsLabel = footerCompanyGroup?.Fields.GetFieldValue("termsLabel", "Điều khoản sử dụng") ?? "Điều khoản sử dụng";

    var contactTitle = contactGroup?.Fields.GetFieldValue("title", "Liên hệ") ?? "Liên hệ";
    var contactAddress = contactGroup?.Fields.GetFieldValue("address", "123 Đường Nguyễn Huệ, Quận 1, TP.HCM") ?? "123 Đường Nguyễn Huệ, Quận 1, TP.HCM";
    var contactPhone = contactGroup?.Fields.GetFieldValue("phoneNumber", "+84 (28) 3822 9999") ?? "+84 (28) 3822 9999";
    var contactEmail = contactGroup?.Fields.GetFieldValue("email", "info@hvtravel.vn") ?? "info@hvtravel.vn";
    var businessHours = contactGroup?.Fields.GetFieldValue("businessHours", "T2 - T7: 8:00 - 18:00") ?? "T2 - T7: 8:00 - 18:00";

    var facebookUrl = socialGroup?.Fields.GetFieldValue("facebookUrl", "#") ?? "#";
    var instagramUrl = socialGroup?.Fields.GetFieldValue("instagramUrl", "#") ?? "#";
    var youtubeUrl = socialGroup?.Fields.GetFieldValue("youtubeUrl", "#") ?? "#";
}
<!DOCTYPE html>
<html class="light" lang="vi">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>@ViewData["Title"] - @brandName</title>
    <meta name="description" content="@(RichTextContentFormatter.ToPlainTextSummary(ViewData["Description"]?.ToString() ?? defaultDescription, 160))" />

    <link href="https://fonts.googleapis.com" rel="preconnect" />
    <link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect" />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script src="~/js/tailwind.theme.js" asp-append-version="true"></script>
    <link rel="stylesheet" href="~/css/theme-ocean.css" asp-append-version="true" />
    <style>
        .tour-card:hover .tour-card-img {
            transform: scale(1.08);
        }
        .nav-link {
            position: relative;
        }
        .nav-link::after {
            content: '';
            position: absolute;
            bottom: -2px;
            left: 50%;
            width: 0;
            height: 2px;
            background: linear-gradient(90deg, #14B8D4, #1D4ED8);
            transition: all 0.3s ease;
            transform: translateX(-50%);
        }
        .nav-link:hover::after, .nav-link.active::after {
            width: 100%;
        }

        [data-animate] {
            opacity: 0;
            transition: opacity 1.1s cubic-bezier(.22,1,.36,1), transform 1.1s cubic-bezier(.22,1,.36,1);
            will-change: opacity, transform;
        }
        [data-animate="fade-up"] { transform: translateY(40px); }
        [data-animate="fade-down"] { transform: translateY(-40px); }
        [data-animate="fade-in"] { transform: none; }
        [data-animate="slide-left"] { transform: translateX(-60px); }
        [data-animate="slide-right"] { transform: translateX(60px); }
        [data-animate="scale-in"] { transform: scale(0.9); }
        [data-animate="zoom-in"] { transform: scale(0.85); }
        [data-animate].is-visible {
            opacity: 1;
            transform: none;
        }
        [data-stagger] > * { opacity: 0; transform: translateY(24px); transition: opacity 0.5s ease, transform 0.5s ease; }
        [data-stagger].is-visible > *:nth-child(1) { transition-delay: 0.05s; }
        [data-stagger].is-visible > *:nth-child(2) { transition-delay: 0.12s; }
        [data-stagger].is-visible > *:nth-child(3) { transition-delay: 0.19s; }
        [data-stagger].is-visible > *:nth-child(4) { transition-delay: 0.26s; }
        [data-stagger].is-visible > *:nth-child(5) { transition-delay: 0.33s; }
        [data-stagger].is-visible > *:nth-child(6) { transition-delay: 0.40s; }
        [data-stagger].is-visible > *:nth-child(n+7) { transition-delay: 0.47s; }
        .nav-link:hover::after, .nav-link.active::after {
            width: 100%;
        }

        [data-animate] {
            opacity: 0;
            transition: opacity 1.1s cubic-bezier(.22,1,.36,1), transform 1.1s cubic-bezier(.22,1,.36,1);
            will-change: opacity, transform;
        }
        [data-animate="fade-up"] { transform: translateY(40px); }
        [data-animate="fade-down"] { transform: translateY(-40px); }
        [data-animate="fade-in"] { transform: none; }
        [data-animate="slide-left"] { transform: translateX(-60px); }
        [data-animate="slide-right"] { transform: translateX(60px); }
        [data-animate="scale-in"] { transform: scale(0.9); }
        [data-animate="zoom-in"] { transform: scale(0.85); }
        [data-animate].is-visible {
            opacity: 1;
            transform: none;
        }
        [data-stagger] > * { opacity: 0; transform: translateY(24px); transition: opacity 0.5s ease, transform 0.5s ease; }
        [data-stagger].is-visible > *:nth-child(1) { transition-delay: 0.05s; }
        [data-stagger].is-visible > *:nth-child(2) { transition-delay: 0.12s; }
        [data-stagger].is-visible > *:nth-child(3) { transition-delay: 0.19s; }
        [data-stagger].is-visible > *:nth-child(4) { transition-delay: 0.26s; }
        [data-stagger].is-visible > *:nth-child(5) { transition-delay: 0.33s; }
        [data-stagger].is-visible > *:nth-child(6) { transition-delay: 0.40s; }
        [data-stagger].is-visible > *:nth-child(n+7) { transition-delay: 0.47s; }
        [data-stagger].is-visible > * { opacity: 1; transform: none; }
    </style>
    <script>
        if (localStorage.theme === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark');
        } else {
            document.documentElement.classList.remove('dark');
        }
    </script>
</head>
<body class="public-page-shell bg-background-light dark:bg-background-dark text-text-strong-light dark:text-text-strong-dark font-display min-h-screen flex flex-col selection:bg-primary selection:text-white">
    <header class="public-site-header sticky top-0 z-50 bg-surface-light/82 dark:bg-surface-dark/82 backdrop-blur-xl border-b border-border-light/60 dark:border-border-dark/60 transition-all duration-300" id="site-header">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex items-center justify-between h-16 sm:h-20">
                <a asp-controller="Home" asp-action="Index" class="public-brand-lockup flex items-center gap-3 group">
                    <div class="bg-gradient-to-br from-primary to-accent text-white rounded-xl size-10 flex items-center justify-center shadow-lg shadow-primary/30 group-hover:shadow-primary/50 transition-all group-hover:scale-105">
                        <span class="material-symbols-outlined">flight_takeoff</span>
                    </div>
                    <div>
                        <h1 class="text-lg font-extrabold leading-none tracking-tight text-slate-900 dark:text-white">@brandName</h1>
                        <p class="text-[10px] font-semibold text-primary tracking-widest uppercase">@brandTagline</p>
                    </div>
                </a>

                <nav class="hidden md:flex items-center gap-8">
                    <a asp-controller="Home" asp-action="Index" class="nav-link text-sm font-semibold text-slate-600 dark:text-slate-300 hover:text-primary dark:hover:text-primary transition-colors @(ViewData["ActivePage"]?.ToString() == "Home" ? "active text-primary dark:text-primary" : "")">
                        @navHomeLabel
                    </a>
                    <a asp-controller="PublicTours" asp-action="Index" class="nav-link text-sm font-semibold text-slate-600 dark:text-slate-300 hover:text-primary dark:hover:text-primary transition-colors @(ViewData["ActivePage"]?.ToString() == "Tours" ? "active text-primary dark:text-primary" : "")">
                        @navToursLabel
                    </a>
                    <a asp-controller="Home" asp-action="About" class="nav-link text-sm font-semibold text-slate-600 dark:text-slate-300 hover:text-primary dark:hover:text-primary transition-colors @(ViewData["ActivePage"]?.ToString() == "About" ? "active text-primary dark:text-primary" : "")">
                        @navAboutLabel
                    </a>
                    <a asp-controller="Home" asp-action="Contact" class="nav-link text-sm font-semibold text-slate-600 dark:text-slate-300 hover:text-primary dark:hover:text-primary transition-colors @(ViewData["ActivePage"]?.ToString() == "Contact" ? "active text-primary dark:text-primary" : "")">
                        @navContactLabel
                    </a>
                </nav>

                <div class="public-nav-actions flex items-center gap-2 sm:gap-3">
                    <button id="theme-toggle-public"
                            class="group inline-flex items-center justify-center w-10 h-10 rounded-full text-slate-500 dark:text-text-muted-dark hover:text-primary hover:bg-surface-muted-light dark:hover:bg-surface-elevated-dark transition-all font-medium"
                            aria-label="Chuyển chế độ tối">
                        <span class="material-symbols-outlined dark:hidden text-[20px] leading-none transition-transform duration-200 group-hover:rotate-12">dark_mode</span>
                        <span class="material-symbols-outlined hidden dark:block text-[20px] leading-none transition-transform duration-200 group-hover:-rotate-12">light_mode</span>
                    </button>

                    <div class="hidden sm:flex items-center gap-2">
                        @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Customer"))
                        {
                            var customerName = User.FindFirst("FullName")?.Value ?? User.Identity?.Name ?? "Khách hàng";
                            customerName = string.IsNullOrWhiteSpace(customerName) ? "Khách hàng" : customerName.Trim();
                            var customerInitial = customerName[0].ToString().ToUpperInvariant();
                            <div class="flex items-center gap-3 rounded-2xl border border-border-light/80 bg-surface-light/80 px-3 py-2 shadow-sm dark:border-border-dark dark:bg-surface-elevated-dark/85">
                                <div class="flex size-10 items-center justify-center rounded-full bg-gradient-to-br from-primary to-accent text-sm font-extrabold text-white">
                                    @customerInitial
                                </div>
                                <div class="max-w-[180px]">
                                    <p class="truncate text-sm font-bold text-slate-900 dark:text-white">@customerName</p>
                                    <p class="truncate text-xs text-slate-500 dark:text-slate-400">@(User.FindFirst("CustomerCode")?.Value ?? "Khách hàng HV Travel")</p>
                                </div>
                                <form asp-controller="CustomerAuth" asp-action="Logout" method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="inline-flex items-center gap-2 rounded-xl bg-slate-100 px-3 py-2 text-sm font-bold text-slate-600 transition-all hover:bg-slate-200 hover:text-slate-900 dark:bg-slate-700 dark:text-slate-200 dark:hover:bg-slate-600">
                                        <span class="material-symbols-outlined text-[18px]">logout</span>
                                        Đăng xuất
                                    </button>
                                </form>
                            </div>
                        }
                        else
                        {
                            <a asp-controller="CustomerAuth" asp-action="Register" class="flex items-center gap-2 text-slate-600 dark:text-slate-300 hover:text-primary dark:hover:text-primary px-4 py-2.5 rounded-xl text-sm font-bold transition-all active:scale-95">
                                @registerLabel
                            </a>
                            <a asp-controller="CustomerAuth" asp-action="Login" class="flex items-center gap-2 bg-primary hover:bg-primary-dark text-white px-5 py-2.5 rounded-xl text-sm font-bold shadow-lg shadow-primary/25 hover:shadow-primary/40 transition-all active:scale-95 hover:-translate-y-0.5">
                                <span class="material-symbols-outlined text-[18px]">login</span>
                                @loginLabel
                            </a>
                        }
                    </div>

                    <button id="mobile-menu-btn" class="md:hidden p-2.5 rounded-xl text-slate-500 hover:bg-surface-muted-light dark:hover:bg-surface-elevated-dark transition-all">
                        <span class="material-symbols-outlined text-[24px]">menu</span>
                    </button>
                </div>
            </div>

            <div id="mobile-menu" class="md:hidden hidden pb-4 border-t border-border-light dark:border-border-dark mt-2">
                <nav class="flex flex-col gap-1 pt-3">
                    <a asp-controller="Home" asp-action="Index" class="flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-semibold text-slate-600 dark:text-slate-300 hover:bg-primary/10 hover:text-primary transition-all">
                        <span class="material-symbols-outlined text-[20px]">home</span> @navHomeLabel
                    </a>
                    <a asp-controller="PublicTours" asp-action="Index" class="flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-semibold text-slate-600 dark:text-slate-300 hover:bg-primary/10 hover:text-primary transition-all">
                        <span class="material-symbols-outlined text-[20px]">map</span> @navToursLabel
                    </a>
                    <a asp-controller="Home" asp-action="About" class="flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-semibold text-slate-600 dark:text-slate-300 hover:bg-primary/10 hover:text-primary transition-all">
                        <span class="material-symbols-outlined text-[20px]">info</span> @navAboutLabel
                    </a>
                    <a asp-controller="Home" asp-action="Contact" class="flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-semibold text-slate-600 dark:text-slate-300 hover:bg-primary/10 hover:text-primary transition-all">
                        <span class="material-symbols-outlined text-[20px]">call</span> @navContactLabel
                    </a>

                    @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Customer"))
                    {
                        var mobileCustomerName = User.FindFirst("FullName")?.Value ?? User.Identity?.Name ?? "Khách hàng";
                        mobileCustomerName = string.IsNullOrWhiteSpace(mobileCustomerName) ? "Khách hàng" : mobileCustomerName.Trim();
                        <div class="px-4 py-3 border-t border-border-light dark:border-border-dark mt-2">
                            <div class="rounded-2xl bg-surface-muted-light dark:bg-surface-elevated-dark px-4 py-4">
                                <p class="text-sm font-bold text-slate-900 dark:text-white">@mobileCustomerName</p>
                                <p class="text-xs text-slate-500 dark:text-slate-400 mt-1">@(User.FindFirst("CustomerCode")?.Value ?? "Khách hàng HV Travel")</p>
                                <form asp-controller="CustomerAuth" asp-action="Logout" method="post" class="mt-4">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="flex w-full items-center justify-center gap-2 rounded-xl bg-gradient-to-r from-surface-dark to-surface-elevated-dark px-4 py-3 text-sm font-bold text-white dark:from-primary dark:to-accent">
                                        <span class="material-symbols-outlined text-[18px]">logout</span>
                                        Đăng xuất
                                    </button>
                                </form>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="grid grid-cols-2 gap-2 px-4 py-3 sm:hidden border-t border-border-light dark:border-border-dark mt-2">
                            <a asp-controller="CustomerAuth" asp-action="Register" class="flex items-center justify-center gap-2 px-4 py-3 rounded-xl text-sm font-bold text-slate-600 dark:text-slate-300 bg-surface-muted-light dark:bg-surface-elevated-dark transition-all">
                                @registerLabel
                            </a>
                            <a asp-controller="CustomerAuth" asp-action="Login" class="flex items-center justify-center gap-2 px-4 py-3 rounded-xl text-sm font-bold bg-primary text-white shadow-lg shadow-primary/20 transition-all">
                                @loginLabel
                            </a>
                        </div>
                    }
                </nav>
            </div>
        </div>
    </header>

    <main class="public-page-main flex-1">
        @RenderBody()
    </main>

    <footer class="bg-surface-dark dark:bg-background-dark text-white">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
            <div class="public-footer-grid grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12" data-animate="fade-up" data-stagger>
                <div class="lg:col-span-1">
                    <div class="flex items-center gap-3 mb-5">
                        <div class="bg-gradient-to-br from-primary to-accent text-white rounded-xl size-10 flex items-center justify-center shadow-lg shadow-primary/30">
                            <span class="material-symbols-outlined">flight_takeoff</span>
                        </div>
                        <div>
                            <h3 class="text-lg font-extrabold leading-none">@footerBrandTitle</h3>
                            <p class="text-[10px] font-semibold text-primary tracking-widest uppercase">@footerBrandTagline</p>
                        </div>
                    </div>
                    <div class="text-slate-400 text-sm leading-relaxed mb-6">
                        @Html.Raw(footerBrandDescription)
                    </div>
                    <div class="flex gap-3">
                        <a href="@facebookUrl" class="size-10 rounded-xl bg-surface-elevated-dark hover:bg-primary text-slate-400 hover:text-white flex items-center justify-center transition-all" target="_blank" rel="noopener noreferrer">
                            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                        </a>
                        <a href="@instagramUrl" class="size-10 rounded-xl bg-surface-elevated-dark hover:bg-primary text-slate-400 hover:text-white flex items-center justify-center transition-all" target="_blank" rel="noopener noreferrer">
                            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
                        </a>
                        <a href="@youtubeUrl" class="size-10 rounded-xl bg-surface-elevated-dark hover:bg-primary text-slate-400 hover:text-white flex items-center justify-center transition-all" target="_blank" rel="noopener noreferrer">
                            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M19.615 3.184c-3.604-.246-11.631-.245-15.23 0-3.897.266-4.356 2.62-4.385 8.816.029 6.185.484 8.549 4.385 8.816 3.6.245 11.626.246 15.23 0 3.897-.266 4.356-2.62 4.385-8.816-.029-6.185-.484-8.549-4.385-8.816zm-10.615 12.816v-8l8 3.993-8 4.007z"/></svg>
                        </a>
                    </div>
                </div>

                <div>
                    <h4 class="text-sm font-bold uppercase tracking-wider text-slate-300 mb-5">@footerExploreTitle</h4>
                    <ul class="space-y-3">
                        <li><a asp-controller="PublicTours" asp-action="Index" class="text-slate-400 hover:text-primary text-sm transition-colors flex items-center gap-2"><span class="material-symbols-outlined text-[14px]">chevron_right</span>@allToursLabel</a></li>
                        <li><a href="#" class="text-slate-400 hover:text-primary text-sm transition-colors flex items-center gap-2"><span class="material-symbols-outlined text-[14px]">chevron_right</span>@popularToursLabel</a></li>
                        <li><a href="#" class="text-slate-400 hover:text-primary text-sm transition-colors flex items-center gap-2"><span class="material-symbols-outlined text-[14px]">chevron_right</span>@hotDestinationsLabel</a></li>
                        <li><a href="#" class="text-slate-400 hover:text-primary text-sm transition-colors flex items-center gap-2"><span class="material-symbols-outlined text-[14px]">chevron_right</span>@specialOffersLabel</a></li>
                    </ul>
                </div>

                <div>
                    <h4 class="text-sm font-bold uppercase tracking-wider text-slate-300 mb-5">@footerCompanyTitle</h4>
                    <ul class="space-y-3">
                        <li><a asp-controller="Home" asp-action="About" class="text-slate-400 hover:text-primary text-sm transition-colors flex items-center gap-2"><span class="material-symbols-outlined text-[14px]">chevron_right</span>@footerAboutLabel</a></li>
                        <li><a asp-controller="Home" asp-action="Contact" class="text-slate-400 hover:text-primary text-sm transition-colors flex items-center gap-2"><span class="material-symbols-outlined text-[14px]">chevron_right</span>@footerContactLabel</a></li>
                        <li><a href="#" class="text-slate-400 hover:text-primary text-sm transition-colors flex items-center gap-2"><span class="material-symbols-outlined text-[14px]">chevron_right</span>@privacyLabel</a></li>
                        <li><a href="#" class="text-slate-400 hover:text-primary text-sm transition-colors flex items-center gap-2"><span class="material-symbols-outlined text-[14px]">chevron_right</span>@termsLabel</a></li>
                    </ul>
                </div>

                <div>
                    <h4 class="text-sm font-bold uppercase tracking-wider text-slate-300 mb-5">@contactTitle</h4>
                    <ul class="space-y-4">
                        <li class="flex items-start gap-3">
                            <span class="material-symbols-outlined text-primary text-[20px] mt-0.5">location_on</span>
                            <span class="text-slate-400 text-sm">@contactAddress</span>
                        </li>
                        <li class="flex items-start gap-3">
                            <span class="material-symbols-outlined text-primary text-[20px] mt-0.5">call</span>
                            <a class="text-slate-400 text-sm hover:text-primary transition-colors" href="tel:@contactPhone">@contactPhone</a>
                        </li>
                        <li class="flex items-start gap-3">
                            <span class="material-symbols-outlined text-primary text-[20px] mt-0.5">mail</span>
                            <a class="text-slate-400 text-sm hover:text-primary transition-colors" href="mailto:@contactEmail">@contactEmail</a>
                        </li>
                        <li class="flex items-start gap-3">
                            <span class="material-symbols-outlined text-primary text-[20px] mt-0.5">schedule</span>
                            <span class="text-slate-400 text-sm">@businessHours</span>
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="border-t border-border-dark">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 flex flex-col sm:flex-row justify-between items-center gap-4">
                <p class="text-slate-500 text-xs">&copy; @DateTime.Now.Year @brandName. Bảo lưu mọi quyền.</p>
                <div class="flex flex-wrap items-center justify-center gap-4 sm:gap-6">
                    <a href="#" class="text-slate-500 hover:text-primary text-xs transition-colors">@privacyLabel</a>
                    <a href="#" class="text-slate-500 hover:text-primary text-xs transition-colors">@termsLabel</a>
                    <a href="#" class="text-slate-500 hover:text-primary text-xs transition-colors">Sơ đồ trang</a>
                </div>
            </div>
        </div>
    </footer>

    @await Html.PartialAsync("_SupportChatWidget")

    @await RenderSectionAsync("Scripts", required: false)

    <script>
        const themeToggle = document.getElementById('theme-toggle-public');
        if (themeToggle) {
            themeToggle.addEventListener('click', () => {
                document.documentElement.classList.toggle('dark');
                localStorage.theme = document.documentElement.classList.contains('dark') ? 'dark' : 'light';
            });
        }

        const mobileMenuBtn = document.getElementById('mobile-menu-btn');
        const mobileMenu = document.getElementById('mobile-menu');
        if (mobileMenuBtn && mobileMenu) {
            mobileMenuBtn.addEventListener('click', () => {
                mobileMenu.classList.toggle('hidden');
            });
        }

        const header = document.getElementById('site-header');
        window.addEventListener('scroll', () => {
            if (window.scrollY > 10) {
                header.classList.add('shadow-lg', 'shadow-slate-200/20', 'dark:shadow-slate-900/30');
            } else {
                header.classList.remove('shadow-lg', 'shadow-slate-200/20', 'dark:shadow-slate-900/30');
            }
        });

        (function() {
            const els = document.querySelectorAll('[data-animate], [data-stagger]');
            if (!els.length) return;
            const io = new IntersectionObserver((entries) => {
                entries.forEach(e => {
                    if (e.isIntersecting) {
                        const delay = e.target.dataset.delay || 0;
                        setTimeout(() => e.target.classList.add('is-visible'), delay);
                        io.unobserve(e.target);
                    }
                });
            }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });
            els.forEach(el => io.observe(el));
        })();
    </script>
</body>
</html>

