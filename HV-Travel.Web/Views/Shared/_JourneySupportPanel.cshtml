@model BookingSupportVm

<section class="public-journey-panel public-journey-support-card">
    <div class="public-journey-badge-group">
        <p class="public-journey-card-eyebrow">Hỗ trợ nhanh</p>
    </div>
    <h2 class="public-journey-panel-title">@Model.Title</h2>
    <p class="public-journey-support-copy public-journey-section-lead">@Model.Description</p>
    @if (!string.IsNullOrWhiteSpace(Model.Phone) || !string.IsNullOrWhiteSpace(Model.Email))
    {
        <div class="public-journey-support-meta public-journey-info-list">
            @if (!string.IsNullOrWhiteSpace(Model.Phone))
            {
                <span class="public-journey-info-item">
                    <span class="public-journey-field-label">Hotline</span>
                    <a href="tel:@Model.Phone">@Model.Phone</a>
                </span>
            }
            @if (!string.IsNullOrWhiteSpace(Model.Email))
            {
                <span class="public-journey-info-item">
                    <span class="public-journey-field-label">Email</span>
                    <a href="mailto:@Model.Email">@Model.Email</a>
                </span>
            }
        </div>
    }
    @if (!string.IsNullOrWhiteSpace(Model.SecondaryNote))
    {
        <p class="public-journey-support-note public-journey-field-hint">@Model.SecondaryNote</p>
    }
    @if (Model.Actions.Any())
    {
        <div class="public-journey-action-row">
            @foreach (var action in Model.Actions)
            {
                <a href="@action.Url" class="public-journey-action public-journey-action--@action.Tone">@action.Label</a>
            }
        </div>
    }
</section>
