@model BookingJourneyStatusVm

<section class="public-journey-panel public-journey-status-card public-journey-status-card--@Model.Tone">
    <p class="public-journey-card-eyebrow">@Model.Eyebrow</p>
    <h2 class="public-journey-panel-title">@Model.Title</h2>
    @if (!string.IsNullOrWhiteSpace(Model.Description))
    {
        <p class="public-journey-status-description">@Model.Description</p>
    }
    @if (!string.IsNullOrWhiteSpace(Model.Reference))
    {
        <p class="public-journey-reference">Mã booking: <strong>@Model.Reference</strong></p>
    }
    @if (Model.Actions.Any())
    {
        <div class="public-booking-status-actions public-journey-action-row">
            @foreach (var action in Model.Actions)
            {
                <a href="@action.Url" class="public-journey-action public-journey-action--@action.Tone">@action.Label</a>
            }
        </div>
    }
</section>
