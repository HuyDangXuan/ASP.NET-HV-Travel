@model BookingJourneyPageVm

<header class="public-journey-header-block">
    <div class="public-journey-badge-group">
        <p class="public-journey-eyebrow">@Model.Eyebrow</p>
    </div>
    <div class="public-journey-heading-row">
        <div class="public-journey-heading-stack">
            <h1 class="public-journey-title">@Model.Title</h1>
            @if (!string.IsNullOrWhiteSpace(Model.Description))
            {
                <p class="public-journey-description public-journey-section-lead">@Model.Description</p>
            }
        </div>
    </div>
</header>
