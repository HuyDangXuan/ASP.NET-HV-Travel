@model BookingJourneyPageVm

<header class="public-journey-header-block">
    <p class="public-journey-eyebrow">@Model.Eyebrow</p>
    <div class="public-journey-heading-row">
        <div>
            <h1 class="public-journey-title">@Model.Title</h1>
            @if (!string.IsNullOrWhiteSpace(Model.Description))
            {
                <p class="public-journey-description">@Model.Description</p>
            }
        </div>
    </div>
</header>
