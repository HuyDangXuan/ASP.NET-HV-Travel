@model BookingViewModel
@{
    var journey = Model.Journey;
    var tour = Model.Tour ?? new Tour();
    var detailId = string.IsNullOrWhiteSpace(tour.Slug) ? tour.Id : tour.Slug;
    var departures = tour.EffectiveDepartures.OrderBy(item => item.StartDate).ToList();
    var selectedDeparture = tour.ResolveDeparture(Model.DepartureId, Model.SelectedStartDate) ?? departures.FirstOrDefault();
    var adultPrice = selectedDeparture?.AdultPrice > 0m ? selectedDeparture.AdultPrice : tour.Price?.Adult ?? 0m;
    var childPrice = selectedDeparture?.ChildPrice > 0m ? selectedDeparture.ChildPrice : tour.Price?.Child ?? 0m;
    var infantPrice = selectedDeparture?.InfantPrice > 0m ? selectedDeparture.InfantPrice : tour.Price?.Infant ?? 0m;
    var subtotal = (adultPrice * Model.AdultCount) + (childPrice * Model.ChildCount) + (infantPrice * Model.InfantCount);
    var amountDueNow = string.Equals(Model.PaymentPlanType, "Deposit", StringComparison.OrdinalIgnoreCase)
        ? Math.Round(subtotal * 0.30m, 0, MidpointRounding.AwayFromZero)
        : subtotal;
    var balanceDue = Math.Max(0m, subtotal - amountDueNow);
    var selectedDateText = selectedDeparture?.StartDate.ToString("dd/MM/yyyy") ?? "Chưa chọn ngày khởi hành";
    var selectedCapacityText = selectedDeparture != null ? $"{selectedDeparture.RemainingCapacity} chỗ còn lại" : "Chưa có lịch khởi hành khả dụng";
    var selectedPlanText = string.Equals(Model.PaymentPlanType, "Deposit", StringComparison.OrdinalIgnoreCase) ? "Đặt cọc 30%" : "Thanh toán toàn bộ";
}

<section class="public-journey-shell public-journey-shell--builder public-booking-runway">
    <div class="public-journey-shell-inner">
        @await Html.PartialAsync("_JourneyHeader", Model.Journey)
        <div class="public-journey-stagebar">
            @await Html.PartialAsync("_JourneyStageBar", Model.Journey)
        </div>

        <div class="public-journey-desk public-journey-desk--builder">
            <form asp-action="Create" method="post" id="booking-form" class="public-journey-main public-booking-builder-form">
                @Html.AntiForgeryToken()
                <input asp-for="TourId" type="hidden" />
                <input asp-for="SelectedStartDate" type="hidden" />

                <section class="public-journey-panel public-booking-intro public-booking-overview-grid">
                    <div class="public-booking-intro-copy">
                        <p class="public-journey-card-eyebrow">Giữ chỗ theo nhịp chuyến đi</p>
                        <h2 class="public-journey-panel-title">@tour.Name</h2>
                        <p class="public-journey-note">Chốt ngày khởi hành, số khách và phương án thanh toán trước khi điền thông tin liên hệ.</p>
                    </div>
                    <div class="public-journey-tour-meta public-booking-intro-metrics">
                        <span>@(tour.Destination?.City ?? "HV Travel")</span>
                        <span>@(tour.Duration?.Text ?? "Liên hệ tư vấn")</span>
                        <span data-booking-selected-date>@selectedDateText</span>
                        <a asp-controller="PublicTours" asp-action="Details" asp-route-id="@detailId">Xem tour đầy đủ</a>
                    </div>
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div asp-validation-summary="All" class="public-journey-validation"></div>
                    }
                </section>

                <section class="public-journey-panel public-booking-section public-booking-section--departures">
                    <div class="public-journey-panel-heading">
                        <h2 class="public-journey-panel-title">Chọn lịch khởi hành</h2>
                        <p class="public-journey-note">Mỗi lịch hiển thị ngay giá người lớn, kiểu xác nhận và số chỗ còn lại.</p>
                    </div>
                    @if (departures.Any())
                    {
                        <div class="public-journey-choice-grid public-booking-departure-matrix">
                            @foreach (var departure in departures)
                            {
                                var isSelected = string.Equals(Model.DepartureId, departure.Id, StringComparison.Ordinal) || (string.IsNullOrWhiteSpace(Model.DepartureId) && selectedDeparture?.Id == departure.Id);
                                <label class="public-journey-choice @(isSelected ? "is-selected" : string.Empty)" data-departure-card>
                                    <input asp-for="DepartureId"
                                           type="radio"
                                           value="@departure.Id"
                                           data-start-date="@departure.StartDate.ToString("yyyy-MM-dd")"
                                           data-display-date="@departure.StartDate.ToString("dd/MM/yyyy")"
                                           data-remaining-capacity="@departure.RemainingCapacity"
                                           checked="@(isSelected ? "checked" : null)" />
                                    <span class="public-journey-choice-title">@departure.StartDate.ToString("dd/MM/yyyy")</span>
                                    <span class="public-journey-choice-copy">@(string.Equals(departure.ConfirmationType, "Instant", StringComparison.OrdinalIgnoreCase) ? "Xác nhận tức thì" : "Chờ xác nhận từ điều hành")</span>
                                    <span class="public-journey-choice-meta">@departure.RemainingCapacity chỗ còn lại</span>
                                    <strong class="public-journey-choice-price">@((departure.AdultPrice > 0m ? departure.AdultPrice : tour.Price?.Adult ?? 0m).ToString("N0"))₫ / người lớn</strong>
                                </label>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="public-journey-empty">Tour này hiện chưa có lịch khởi hành khả dụng.</p>
                    }
                </section>

                <section class="public-journey-panel public-booking-section public-journey-quote public-booking-finance-panel">
                    <div class="public-journey-panel-heading">
                        <h2 class="public-journey-panel-title">Chi phí và kế hoạch thanh toán</h2>
                        <p class="public-journey-note">Chọn trả toàn bộ hoặc đặt cọc trước. Báo giá sẽ đổi theo lịch đi, số khách và mã ưu đãi.</p>
                    </div>
                    <div class="public-journey-choice-grid public-journey-choice-grid--plans">
                        <label class="public-journey-choice @(string.Equals(Model.PaymentPlanType, "Full", StringComparison.OrdinalIgnoreCase) || string.IsNullOrWhiteSpace(Model.PaymentPlanType) ? "is-selected" : string.Empty)" data-payment-plan-card>
                            <input asp-for="PaymentPlanType" type="radio" value="Full" data-plan-label="Thanh toán toàn bộ" checked="@((string.Equals(Model.PaymentPlanType, "Full", StringComparison.OrdinalIgnoreCase) || string.IsNullOrWhiteSpace(Model.PaymentPlanType)) ? "checked" : null)" />
                            <span class="public-journey-choice-title">Thanh toán toàn bộ</span>
                            <span class="public-journey-choice-copy">Chốt toàn bộ giá trị booking ngay ở bước kế tiếp.</span>
                        </label>
                        <label class="public-journey-choice @(string.Equals(Model.PaymentPlanType, "Deposit", StringComparison.OrdinalIgnoreCase) ? "is-selected" : string.Empty)" data-payment-plan-card>
                            <input asp-for="PaymentPlanType" type="radio" value="Deposit" data-plan-label="Đặt cọc 30%" checked="@(string.Equals(Model.PaymentPlanType, "Deposit", StringComparison.OrdinalIgnoreCase) ? "checked" : null)" />
                            <span class="public-journey-choice-title">Đặt cọc 30%</span>
                            <span class="public-journey-choice-copy">Giữ chỗ trước, phần còn lại xử lý sau cùng điều hành.</span>
                        </label>
                    </div>
                    <div class="public-journey-quote-grid public-booking-finance-grid">
                        <div><span>Tạm tính</span><strong id="subtotal">@subtotal.ToString("N0")₫</strong></div>
                        <div><span>Giảm giá</span><strong id="discountTotal">0₫</strong></div>
                        <div><span>Tổng thanh toán</span><strong id="grandTotal">@subtotal.ToString("N0")₫</strong></div>
                        <div><span>Thanh toán ngay</span><strong id="amountDueNow">@amountDueNow.ToString("N0")₫</strong></div>
                        <div><span>Còn lại</span><strong id="balanceDue">@balanceDue.ToString("N0")₫</strong></div>
                    </div>
                    <p id="quote-status" class="public-journey-note">Báo giá sẽ được tính lại ngay khi bạn đổi lịch khởi hành, số khách hoặc mã ưu đãi.</p>
                    <div class="public-journey-action-row">
                        <button form="booking-form" type="submit" id="submit-booking" class="public-journey-submit">Tiếp tục sang thanh toán</button>
                        <a asp-controller="PublicTours" asp-action="Details" asp-route-id="@detailId" class="public-journey-action public-journey-action--secondary">Quay lại xem tour</a>
                    </div>
                </section>

                <section class="public-journey-panel public-booking-section public-booking-section--contact">
                    <div class="public-journey-panel-heading">
                        <h2 class="public-journey-panel-title">Thông tin liên hệ</h2>
                        <p class="public-journey-note">Chỉ giữ lại phần dữ liệu cần để tạo booking và gửi xác nhận lại cho bạn.</p>
                    </div>

                    <div class="public-booking-party-grid">
                        <label>
                            <span>Người lớn</span>
                            <input asp-for="AdultCount" type="number" min="1" class="traveller-input" />
                        </label>
                        <label>
                            <span>Trẻ em</span>
                            <input asp-for="ChildCount" type="number" min="0" class="traveller-input" />
                        </label>
                        <label>
                            <span>Em bé</span>
                            <input asp-for="InfantCount" type="number" min="0" class="traveller-input" />
                        </label>
                    </div>

                    <div class="public-journey-field-grid public-booking-field-grid">
                        <label class="public-booking-field">
                            <span class="sr-only">Họ và tên</span>
                            <input asp-for="ContactName" placeholder="Họ và tên người liên hệ" />
                        </label>
                        <label class="public-booking-field">
                            <span class="sr-only">Email</span>
                            <input asp-for="ContactEmail" placeholder="Email để nhận xác nhận" />
                        </label>
                        <label class="public-booking-field">
                            <span class="sr-only">Số điện thoại</span>
                            <input asp-for="ContactPhone" placeholder="Số điện thoại liên hệ" />
                        </label>
                    </div>

                    <details class="public-booking-coupon-disclosure">
                        <summary>Có mã ưu đãi?</summary>
                        <label class="public-booking-field public-booking-field--compact">
                            <span class="sr-only">Mã ưu đãi</span>
                            <input asp-for="CouponCode" placeholder="Nhập mã nếu bạn đang có" />
                        </label>
                    </details>

                    <label class="public-booking-field public-booking-field--full">
                        <span class="sr-only">Ghi chú cho điều hành</span>
                        <textarea asp-for="SpecialRequests" rows="4" placeholder="Ghi chú cho điều hành (không bắt buộc)"></textarea>
                    </label>
                </section>
            </form>

            <aside class="public-journey-rail">
                <div class="public-journey-summary">
                    @await Html.PartialAsync("_JourneySummaryRail", Model.Journey.Summary)
                </div>
                <section class="public-journey-panel public-booking-section public-booking-section--selection public-booking-selection-card">
                    <p class="public-journey-card-eyebrow">Lựa chọn hiện tại</p>
                    <dl class="public-journey-summary-list">
                        <div class="public-journey-summary-row"><dt>Khởi hành</dt><dd data-booking-selected-date>@selectedDateText</dd></div>
                        <div class="public-journey-summary-row"><dt>Sức chứa</dt><dd data-booking-selected-capacity>@selectedCapacityText</dd></div>
                        <div class="public-journey-summary-row"><dt>Kế hoạch</dt><dd data-booking-selected-plan>@selectedPlanText</dd></div>
                    </dl>
                </section>
                <div class="public-journey-support">
                    @await Html.PartialAsync("_JourneySupportPanel", Model.Journey.Support)
                </div>
            </aside>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (() => {
            const quoteUrl = '@Url.Action("Quote", "Booking")';
            const form = document.getElementById('booking-form');
            if (!form) return;
            const selectedStartDate = document.getElementById('SelectedStartDate');
            const formatCurrency = (value) => `${new Intl.NumberFormat('vi-VN').format(value || 0)}₫`;
            const setTextForAll = (selector, value) => document.querySelectorAll(selector).forEach((node) => node.textContent = value);
            const syncSelectionCards = () => {
                document.querySelectorAll('[data-departure-card]').forEach((card) => {
                    const input = card.querySelector('input[name="DepartureId"]');
                    card.classList.toggle('is-selected', Boolean(input && input.checked));
                });
                document.querySelectorAll('[data-payment-plan-card]').forEach((card) => {
                    const input = card.querySelector('input[name="PaymentPlanType"]');
                    card.classList.toggle('is-selected', Boolean(input && input.checked));
                });
            };
            const syncSelectionMeta = () => {
                const activeDeparture = document.querySelector('input[name="DepartureId"]:checked');
                const activePlan = document.querySelector('input[name="PaymentPlanType"]:checked');
                const departureText = activeDeparture?.dataset.displayDate || 'Chưa chọn ngày khởi hành';
                const capacityText = activeDeparture ? `${activeDeparture.dataset.remainingCapacity} chỗ còn lại` : 'Chưa có lịch khởi hành khả dụng';
                const planText = activePlan?.dataset.planLabel || 'Thanh toán toàn bộ';
                if (selectedStartDate) selectedStartDate.value = activeDeparture?.dataset.startDate || '';
                setTextForAll('[data-booking-selected-date]', departureText);
                setTextForAll('[data-booking-selected-capacity]', capacityText);
                setTextForAll('[data-booking-selected-plan]', planText);
                syncSelectionCards();
            };
            const collectParams = () => {
                const activeDeparture = document.querySelector('input[name="DepartureId"]:checked');
                return new URLSearchParams({
                    tourId: document.getElementById('TourId').value,
                    departureId: activeDeparture ? activeDeparture.value : '',
                    adultCount: document.getElementById('AdultCount').value || '1',
                    childCount: document.getElementById('ChildCount').value || '0',
                    infantCount: document.getElementById('InfantCount').value || '0',
                    couponCode: document.getElementById('CouponCode').value || '',
                    paymentPlanType: document.querySelector('input[name="PaymentPlanType"]:checked')?.value || 'Full'
                });
            };
            const refreshQuote = async () => {
                syncSelectionMeta();
                try {
                    const response = await fetch(`${quoteUrl}?${collectParams().toString()}`);
                    const data = await response.json();
                    document.getElementById('subtotal').textContent = formatCurrency(data.subtotal);
                    document.getElementById('discountTotal').textContent = formatCurrency(data.discountTotal);
                    document.getElementById('grandTotal').textContent = formatCurrency(data.grandTotal);
                    document.getElementById('amountDueNow').textContent = formatCurrency(data.amountDueNow);
                    document.getElementById('balanceDue').textContent = formatCurrency(data.balanceDue);
                    document.getElementById('quote-status').textContent = data.errorMessage || (data.appliedCouponCode ? `Đã áp dụng mã ${data.appliedCouponCode}.` : 'Báo giá đã sẵn sàng, bạn có thể sang bước thanh toán.');
                } catch {
                    document.getElementById('quote-status').textContent = 'Chưa thể cập nhật báo giá tức thời. Bạn vẫn có thể gửi form để hệ thống kiểm tra lại ở bước kế tiếp.';
                }
            };
            form.querySelectorAll('input, textarea').forEach((element) => {
                if (element.type !== 'hidden' && element.name !== '__RequestVerificationToken') {
                    element.addEventListener('change', refreshQuote);
                }
            });
            syncSelectionMeta();
            refreshQuote();
        })();
    </script>
}
