@inject IPublicContentService ContentService
@using System.Text.Json
@using HVTravel.Domain.Entities
@using HVTravel.Web.Services
@model HVTravel.Web.Models.BookingViewModel
@{
    var sections = await ContentService.GetPageSectionsAsync("booking");
    var createHero = sections.GetSection("createHero");
    var createStepper = sections.GetSection("createStepper");
    var travellerForm = sections.GetSection("travellerForm");
    var pricingPanel = sections.GetSection("pricingPanel");
    var tour = Model.Tour ?? new Tour();
    var detailId = string.IsNullOrWhiteSpace(tour.Slug) ? tour.Id : tour.Slug;
    var departures = tour.EffectiveDepartures.OrderBy(item => item.StartDate).ToList();
    var selectedDeparture = tour.ResolveDeparture(Model.DepartureId, Model.SelectedStartDate) ?? departures.FirstOrDefault();
    var adultPrice = selectedDeparture?.AdultPrice > 0m ? selectedDeparture.AdultPrice : tour.Price?.Adult ?? 0m;
    var childPrice = selectedDeparture?.ChildPrice > 0m ? selectedDeparture.ChildPrice : tour.Price?.Child ?? 0m;
    var infantPrice = selectedDeparture?.InfantPrice > 0m ? selectedDeparture.InfantPrice : tour.Price?.Infant ?? 0m;
    var subtotal = (adultPrice * Model.AdultCount) + (childPrice * Model.ChildCount) + (infantPrice * Model.InfantCount);
    var amountDueNow = string.Equals(Model.PaymentPlanType, "Deposit", StringComparison.OrdinalIgnoreCase) ? Math.Round(subtotal * 0.30m, 0, MidpointRounding.AwayFromZero) : subtotal;
    var balanceDue = Math.Max(0m, subtotal - amountDueNow);
    var remainingCapacityFormat = travellerForm?.Fields.GetVisibleFieldValue("remainingCapacityFormat", "{0} chỗ") ?? "{0} chỗ";
    var couponAppliedFormat = pricingPanel?.Fields.GetVisibleFieldValue("couponAppliedFormat", "Đã áp dụng coupon {0}.") ?? "Đã áp dụng coupon {0}.";
    var quoteReadyText = pricingPanel?.Fields.GetVisibleFieldValue("quoteReadyText", "Báo giá hợp lệ, có thể tiếp tục giữ chỗ.") ?? "Báo giá hợp lệ, có thể tiếp tục giữ chỗ.";
}

@if (createHero?.IsEnabled != false)
{
    <section class="public-top-section public-top-section--compact hero-gradient @ContentPresentationViewHelper.GetSectionBackgroundClass(createHero)" style="@ContentPresentationViewHelper.GetSectionStyle(createHero)">
        <div class="public-top-section-shell mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8 @ContentPresentationViewHelper.GetSectionTextClass(createHero)">
            <span class="public-badge public-top-section-badge" style="@ContentPresentationViewHelper.GetFieldTextStyle(createHero, "badgeText")">@createHero.Fields.GetVisibleFieldValue("badgeText", "Bước 1 trong hành trình đặt tour")</span>
            <h1 class="public-top-section-title text-white" style="@ContentPresentationViewHelper.GetFieldTextStyle(createHero, "title")">@createHero.Fields.GetVisibleFieldValue("title", "Đặt tour và xác nhận hành khách")</h1>
            <div class="public-top-section-lead" style="@ContentPresentationViewHelper.GetFieldTextStyle(createHero, "description")">@Html.Raw(createHero.Fields.GetVisibleFieldValue("description", "Chọn lịch khởi hành phù hợp, kiểm tra báo giá theo thời gian thực và xác nhận thông tin liên hệ trước khi chuyển sang thanh toán."))</div>
        </div>
    </section>
}

@if (createStepper?.IsEnabled != false)
{
    <div class="border-b border-border-light bg-surface-light py-4 dark:border-border-dark dark:bg-surface-dark @ContentPresentationViewHelper.GetSectionTextClass(createStepper) @ContentPresentationViewHelper.GetSectionBackgroundClass(createStepper)" style="@ContentPresentationViewHelper.GetSectionStyle(createStepper)">
        <div class="mx-auto flex max-w-5xl items-center justify-center gap-4 px-4 text-sm sm:px-6 lg:px-8">
            <span style="@ContentPresentationViewHelper.GetFieldTextStyle(createStepper, "detailsStepLabel")">1. @createStepper.Fields.GetVisibleFieldValue("detailsStepLabel", "Thông tin")</span>
            <span style="@ContentPresentationViewHelper.GetFieldTextStyle(createStepper, "paymentStepLabel")">2. @createStepper.Fields.GetVisibleFieldValue("paymentStepLabel", "Thanh toán")</span>
            <span style="@ContentPresentationViewHelper.GetFieldTextStyle(createStepper, "completeStepLabel")">3. @createStepper.Fields.GetVisibleFieldValue("completeStepLabel", "Hoàn tất")</span>
        </div>
    </div>
}

<section class="bg-background-light py-10 dark:bg-background-dark">
    <div class="mx-auto grid max-w-7xl gap-8 px-4 sm:px-6 lg:grid-cols-[minmax(0,1fr)_320px] lg:px-8">
        <form asp-action="Create" method="post" id="booking-form" class="space-y-6">
            @Html.AntiForgeryToken()
            <input asp-for="TourId" type="hidden" />
            <input asp-for="SelectedStartDate" type="hidden" />

            <div class="rounded-3xl border border-border-light bg-surface-light p-6 dark:border-border-dark dark:bg-surface-dark">
                <p class="text-xs font-bold uppercase tracking-[0.25em] text-primary" style="@ContentPresentationViewHelper.GetFieldTextStyle(travellerForm, "tourSnapshotEyebrow")">@travellerForm?.Fields.GetVisibleFieldValue("tourSnapshotEyebrow", "Tour snapshot")</p>
                <div class="mt-2 flex items-start justify-between gap-4">
                    <div>
                        <h2 class="text-2xl font-black">@tour.Name</h2>
                        <p class="mt-2 text-sm text-slate-500 dark:text-slate-400">@(tour.Destination?.City ?? "Việt Nam") • @(tour.Duration?.Text ?? "Liên hệ tư vấn")</p>
                    </div>
                    <a asp-controller="PublicTours" asp-action="Details" asp-route-id="@detailId" class="text-sm font-bold text-primary">@travellerForm?.Fields.GetVisibleFieldValue("viewDetailsText", "Xem chi tiết")</a>
                </div>
                <div class="public-rich-text mt-4 text-sm">@Html.Raw(RichTextContentFormatter.ToTrustedHtml(tour.ShortDescription ?? tour.Description))</div>
                @if (!ViewData.ModelState.IsValid)
                {
                    <div asp-validation-summary="All" class="mt-4 rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700"></div>
                }
            </div>

            <div class="rounded-3xl border border-border-light bg-surface-light p-6 dark:border-border-dark dark:bg-surface-dark @ContentPresentationViewHelper.GetSectionTextClass(travellerForm)" style="@ContentPresentationViewHelper.GetSectionStyle(travellerForm)">
                <h3 class="text-xl font-black" style="@ContentPresentationViewHelper.GetFieldTextStyle(travellerForm, "departureTitle")">@travellerForm?.Fields.GetVisibleFieldValue("departureTitle", "Chọn đợt khởi hành")</h3>
                @if (departures.Any())
                {
                    <div class="mt-4 grid gap-3 sm:grid-cols-2">
                        @foreach (var departure in departures)
                        {
                            var isSelected = string.Equals(Model.DepartureId, departure.Id, StringComparison.Ordinal) || (string.IsNullOrWhiteSpace(Model.DepartureId) && selectedDeparture?.Id == departure.Id);
                            var confirmationText = string.Equals(departure.ConfirmationType, "Instant", StringComparison.OrdinalIgnoreCase)
                                ? travellerForm?.Fields.GetVisibleFieldValue("instantConfirmationLabel", "Xác nhận tức thì")
                                : travellerForm?.Fields.GetVisibleFieldValue("requestConfirmationLabel", "Chờ xác nhận");
                            <label class="rounded-2xl border border-border-light p-4 dark:border-border-dark">
                                <input asp-for="DepartureId" type="radio" value="@departure.Id" checked="@isSelected" class="departure-choice sr-only" data-start-date="@departure.StartDate.ToString("yyyy-MM-dd")" data-remaining-capacity="@departure.RemainingCapacity" />
                                <strong>@departure.StartDate.ToString("dd/MM/yyyy")</strong>
                                <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">@confirmationText</p>
                                <p class="mt-2 text-sm">@string.Format(remainingCapacityFormat, departure.RemainingCapacity)</p>
                                <p class="mt-2 text-sm">@departure.AdultPrice.ToString("N0")₫ / @departure.ChildPrice.ToString("N0")₫ / @departure.InfantPrice.ToString("N0")₫</p>
                            </label>
                        }
                    </div>
                }
                else
                {
                    <p class="mt-4 text-sm text-slate-500 dark:text-slate-400">@travellerForm?.Fields.GetVisibleFieldValue("departureEmptyText", "Tour này hiện chưa có lịch khởi hành khả dụng.")</p>
                }
            </div>

            <div class="grid gap-6 lg:grid-cols-2">
                <div class="rounded-3xl border border-border-light bg-surface-light p-6 dark:border-border-dark dark:bg-surface-dark @ContentPresentationViewHelper.GetSectionTextClass(travellerForm)" style="@ContentPresentationViewHelper.GetSectionStyle(travellerForm)">
                    <p class="text-xs font-bold uppercase tracking-[0.25em] text-primary" style="@ContentPresentationViewHelper.GetFieldTextStyle(travellerForm, "travellerEyebrow")">@travellerForm?.Fields.GetVisibleFieldValue("travellerEyebrow", "Traveller")</p>
                    <h3 class="mt-2 text-xl font-black" style="@ContentPresentationViewHelper.GetFieldTextStyle(travellerForm, "travellerTitle")">@travellerForm?.Fields.GetVisibleFieldValue("travellerTitle", "Thông tin liên hệ và số khách")</h3>
                    <div class="mt-4 space-y-4">
                        <div>
                            <label class="mb-2 block text-sm font-semibold">@travellerForm?.Fields.GetVisibleFieldValue("contactNameLabel", "Họ và tên")</label>
                            <input asp-for="ContactName" class="w-full rounded-2xl border border-border-light bg-transparent px-4 py-3 text-sm dark:border-border-dark" placeholder="@(travellerForm?.Fields.GetVisibleFieldValue("contactNamePlaceholder", "Nguyễn Văn A"))" />
                        </div>
                        <div>
                            <label class="mb-2 block text-sm font-semibold">@travellerForm?.Fields.GetVisibleFieldValue("contactEmailLabel", "Email")</label>
                            <input asp-for="ContactEmail" class="w-full rounded-2xl border border-border-light bg-transparent px-4 py-3 text-sm dark:border-border-dark" placeholder="@(travellerForm?.Fields.GetVisibleFieldValue("contactEmailPlaceholder", "email@example.com"))" />
                        </div>
                        <div>
                            <label class="mb-2 block text-sm font-semibold">@travellerForm?.Fields.GetVisibleFieldValue("contactPhoneLabel", "Số điện thoại")</label>
                            <input asp-for="ContactPhone" class="w-full rounded-2xl border border-border-light bg-transparent px-4 py-3 text-sm dark:border-border-dark" placeholder="@(travellerForm?.Fields.GetVisibleFieldValue("contactPhonePlaceholder", "0901 234 567"))" />
                        </div>
                        <div class="grid grid-cols-3 gap-3">
                            <input asp-for="AdultCount" type="number" min="1" class="traveller-input rounded-2xl border border-border-light bg-transparent px-4 py-3 text-sm dark:border-border-dark" />
                            <input asp-for="ChildCount" type="number" min="0" class="traveller-input rounded-2xl border border-border-light bg-transparent px-4 py-3 text-sm dark:border-border-dark" />
                            <input asp-for="InfantCount" type="number" min="0" class="traveller-input rounded-2xl border border-border-light bg-transparent px-4 py-3 text-sm dark:border-border-dark" />
                        </div>
                        <textarea asp-for="SpecialRequests" rows="3" class="w-full rounded-2xl border border-border-light bg-transparent px-4 py-3 text-sm dark:border-border-dark" placeholder="@(travellerForm?.Fields.GetVisibleFieldValue("specialRequestsPlaceholder", "Ví dụ: ăn chay, ghế gần cửa sổ, hỗ trợ xe đón..."))"></textarea>
                    </div>
                </div>

                <div class="rounded-3xl border border-border-light bg-surface-light p-6 dark:border-border-dark dark:bg-surface-dark @ContentPresentationViewHelper.GetSectionTextClass(pricingPanel)" style="@ContentPresentationViewHelper.GetSectionStyle(pricingPanel)">
                    <p class="text-xs font-bold uppercase tracking-[0.25em] text-primary" style="@ContentPresentationViewHelper.GetFieldTextStyle(pricingPanel, "eyebrowText")">@pricingPanel?.Fields.GetVisibleFieldValue("eyebrowText", "Pricing controls")</p>
                    <h3 class="mt-2 text-xl font-black" style="@ContentPresentationViewHelper.GetFieldTextStyle(pricingPanel, "title")">@pricingPanel?.Fields.GetVisibleFieldValue("title", "Coupon và kế hoạch thanh toán")</h3>
                    <div class="mt-4 space-y-4">
                        <input asp-for="CouponCode" class="w-full rounded-2xl border border-border-light bg-transparent px-4 py-3 text-sm dark:border-border-dark" placeholder="@(pricingPanel?.Fields.GetVisibleFieldValue("couponPlaceholder", "WELCOME10"))" />
                        <div class="grid grid-cols-2 gap-3">
                            <label class="rounded-2xl border border-border-light px-4 py-3 text-sm dark:border-border-dark"><input asp-for="PaymentPlanType" type="radio" value="Full" class="mr-2" />@pricingPanel?.Fields.GetVisibleFieldValue("paymentPlanFullLabel", "Full")</label>
                            <label class="rounded-2xl border border-border-light px-4 py-3 text-sm dark:border-border-dark"><input asp-for="PaymentPlanType" type="radio" value="Deposit" class="mr-2" />@pricingPanel?.Fields.GetVisibleFieldValue("paymentPlanDepositLabel", "Deposit")</label>
                        </div>
                    </div>
                </div>
            </div>
        </form>

        <aside>
            <div class="rounded-3xl border border-border-light bg-surface-light p-6 dark:border-border-dark dark:bg-surface-dark @ContentPresentationViewHelper.GetSectionTextClass(pricingPanel)" style="@ContentPresentationViewHelper.GetSectionStyle(pricingPanel)">
                <p class="text-xs font-bold uppercase tracking-[0.25em] text-primary" style="@ContentPresentationViewHelper.GetFieldTextStyle(pricingPanel, "quoteEyebrowText")">@pricingPanel?.Fields.GetVisibleFieldValue("quoteEyebrowText", "Quote")</p>
                <h3 class="mt-2 text-xl font-black" style="@ContentPresentationViewHelper.GetFieldTextStyle(pricingPanel, "quoteTitle")">@pricingPanel?.Fields.GetVisibleFieldValue("quoteTitle", "Xem báo giá trước khi giữ chỗ")</h3>
                <div id="quote-badges" class="mt-4 flex flex-wrap gap-2"></div>
                <div class="mt-4 space-y-2 text-sm">
                    <div class="flex justify-between"><span>@pricingPanel?.Fields.GetVisibleFieldValue("subtotalLabel", "Tạm tính")</span><span id="subtotal">@subtotal.ToString("N0")₫</span></div>
                    <div class="flex justify-between"><span>@pricingPanel?.Fields.GetVisibleFieldValue("discountLabel", "Giảm giá")</span><span id="discountTotal">0₫</span></div>
                    <div class="flex justify-between"><span>@pricingPanel?.Fields.GetVisibleFieldValue("grandTotalLabel", "Tổng thanh toán")</span><span id="grandTotal">@subtotal.ToString("N0")₫</span></div>
                    <div class="flex justify-between"><span>@pricingPanel?.Fields.GetVisibleFieldValue("amountDueNowLabel", "Thanh toán ngay")</span><span id="amountDueNow">@amountDueNow.ToString("N0")₫</span></div>
                    <div class="flex justify-between"><span>@pricingPanel?.Fields.GetVisibleFieldValue("balanceDueLabel", "Còn lại")</span><span id="balanceDue">@balanceDue.ToString("N0")₫</span></div>
                </div>
                <p id="quote-status" class="mt-4 text-sm text-slate-500 dark:text-slate-400">@pricingPanel?.Fields.GetVisibleFieldValue("quoteStatusText", "Máy chủ sẽ tính lại báo giá khi bạn đổi departure, số khách, coupon hoặc payment plan.")</p>
                <button form="booking-form" type="submit" id="submit-booking" class="mt-6 w-full rounded-2xl bg-primary px-4 py-3 font-bold text-white" style="@ContentPresentationViewHelper.GetFieldTextStyle(pricingPanel, "submitText")">@pricingPanel?.Fields.GetVisibleFieldValue("submitText", "Tiếp tục sang thanh toán")</button>
                <p class="mt-3 text-xs text-slate-400" style="@ContentPresentationViewHelper.GetFieldTextStyle(pricingPanel, "submitHelperText")">@pricingPanel?.Fields.GetVisibleFieldValue("submitHelperText", "Ghế chỉ được giữ khi máy chủ xác nhận báo giá và tạo booking thành công.")</p>
            </div>
        </aside>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (() => {
            const quoteUrl = '@Url.Action("Quote", "Booking")';
            const form = document.getElementById('booking-form');
            const selectedStartDate = document.getElementById('SelectedStartDate');
            const remainingCapacityFormat = @Html.Raw(JsonSerializer.Serialize(remainingCapacityFormat));
            const couponAppliedFormat = @Html.Raw(JsonSerializer.Serialize(couponAppliedFormat));
            const quoteReadyText = @Html.Raw(JsonSerializer.Serialize(quoteReadyText));
            const formatCurrency = (value) => `${new Intl.NumberFormat('vi-VN').format(value || 0)}₫`;
            const formatRemaining = (value) => remainingCapacityFormat.replace('{0}', value || 0);
            const formatCoupon = (value) => couponAppliedFormat.replace('{0}', value || '');
            const renderBadges = (badges) => document.getElementById('quote-badges').innerHTML = (badges || []).map((badge) => `<span class="rounded-full bg-primary/10 px-3 py-1 text-xs font-bold text-primary">${badge}</span>`).join('');
            const collectParams = () => {
                const activeDeparture = document.querySelector('input[name="DepartureId"]:checked');
                return new URLSearchParams({ tourId: document.getElementById('TourId').value, departureId: activeDeparture ? activeDeparture.value : '', adultCount: document.getElementById('AdultCount').value || '1', childCount: document.getElementById('ChildCount').value || '0', infantCount: document.getElementById('InfantCount').value || '0', couponCode: document.getElementById('CouponCode').value || '', paymentPlanType: document.querySelector('input[name="PaymentPlanType"]:checked')?.value || 'Full' });
            };
            const refreshQuote = async () => {
                const activeDeparture = document.querySelector('input[name="DepartureId"]:checked');
                if (activeDeparture && selectedStartDate) { selectedStartDate.value = activeDeparture.dataset.startDate || ''; }
                const data = await (await fetch(`${quoteUrl}?${collectParams().toString()}`)).json();
                document.getElementById('subtotal').textContent = formatCurrency(data.subtotal);
                document.getElementById('discountTotal').textContent = formatCurrency(data.discountTotal);
                document.getElementById('grandTotal').textContent = formatCurrency(data.grandTotal);
                document.getElementById('amountDueNow').textContent = formatCurrency(data.amountDueNow);
                document.getElementById('balanceDue').textContent = formatCurrency(data.balanceDue);
                document.getElementById('quote-status').textContent = data.errorMessage || (data.appliedCouponCode ? formatCoupon(data.appliedCouponCode) : quoteReadyText);
                renderBadges(data.badges);
            };
            form.querySelectorAll('input, textarea').forEach((element) => { if (element.type !== 'hidden' && element.name !== '__RequestVerificationToken') { element.addEventListener('change', refreshQuote); } });
            refreshQuote();
        })();
    </script>
}
