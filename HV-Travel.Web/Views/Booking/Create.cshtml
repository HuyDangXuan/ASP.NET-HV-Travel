@using HVTravel.Domain.Entities
@using HVTravel.Web.Services
@model HVTravel.Web.Models.BookingViewModel
@{
    var tour = Model.Tour ?? new Tour();
    var detailId = string.IsNullOrWhiteSpace(tour.Slug) ? tour.Id : tour.Slug;
    var visibleDepartures = tour.EffectiveDepartures.Where(item => item.StartDate >= DateTime.UtcNow.Date).OrderBy(item => item.StartDate).ToList();
    if (!visibleDepartures.Any())
    {
        visibleDepartures = tour.EffectiveDepartures.OrderBy(item => item.StartDate).ToList();
    }
    var selectedDeparture = tour.ResolveDeparture(Model.DepartureId, Model.SelectedStartDate) ?? visibleDepartures.FirstOrDefault();
    var adultPrice = selectedDeparture?.AdultPrice > 0m ? selectedDeparture.AdultPrice : tour.Price?.Adult ?? 0m;
    var childPrice = selectedDeparture?.ChildPrice > 0m ? selectedDeparture.ChildPrice : tour.Price?.Child ?? 0m;
    var infantPrice = selectedDeparture?.InfantPrice > 0m ? selectedDeparture.InfantPrice : tour.Price?.Infant ?? 0m;
    var subtotal = (adultPrice * Model.AdultCount) + (childPrice * Model.ChildCount) + (infantPrice * Model.InfantCount);
    var amountDueNow = string.Equals(Model.PaymentPlanType, "Deposit", StringComparison.OrdinalIgnoreCase)
        ? Math.Round(subtotal * 0.30m, 0, MidpointRounding.AwayFromZero)
        : subtotal;
    var balanceDue = Math.Max(0m, subtotal - amountDueNow);
    var breadcrumb = new HVTravel.Web.Models.BreadcrumbViewModel
    {
        Items = new List<HVTravel.Web.Models.BreadcrumbItemViewModel>
        {
            new() { Label = "Trang chủ", Url = Url.Action("Index", "Home") },
            new() { Label = "Tour du lịch", Url = Url.Action("Index", "PublicTours") },
            new() { Label = tour.Name, Url = Url.Action("Details", "PublicTours", new { id = detailId }) },
            new() { Label = "Đặt tour", IsCurrent = true }
        }
    };
}

@await Html.PartialAsync("_PublicBreadcrumb", breadcrumb)

<section class="public-top-section public-top-section--compact hero-gradient relative overflow-hidden">
    <div class="public-top-section-shell mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="public-top-section-content is-left" data-animate="fade-up">
            <span class="public-badge public-top-section-badge">
                <span class="material-symbols-outlined text-[16px] text-primary">shopping_bag</span>
                Bước 1 trong hành trình đặt tour
            </span>
            <h1 class="public-top-section-title text-white">Đặt tour và xác nhận hành khách</h1>
            <p class="public-top-section-lead">Chọn lịch khởi hành phù hợp, kiểm tra báo giá theo thời gian thực và xác nhận thông tin liên hệ trước khi chuyển sang thanh toán.</p>
        </div>
    </div>
</section>

<div class="border-b border-border-light bg-surface-light py-6 dark:border-border-dark dark:bg-surface-dark">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="public-stepper flex items-center justify-center gap-0" data-animate="fade-in">
            <div class="flex items-center gap-2">
                <div class="flex size-9 items-center justify-center rounded-full bg-primary text-sm font-bold text-white shadow-lg shadow-primary/30">1</div>
                <span class="hidden text-sm font-bold text-primary sm:inline">Thông tin</span>
            </div>
            <div class="public-stepper-divider mx-2 h-0.5 w-12 bg-slate-200 dark:bg-slate-700 sm:w-20"></div>
            <div class="flex items-center gap-2">
                <div class="flex size-9 items-center justify-center rounded-full bg-slate-200 text-sm font-bold text-slate-400 dark:bg-slate-700">2</div>
                <span class="hidden text-sm font-medium text-slate-400 sm:inline">Thanh toán</span>
            </div>
            <div class="public-stepper-divider mx-2 h-0.5 w-12 bg-slate-200 dark:bg-slate-700 sm:w-20"></div>
            <div class="flex items-center gap-2">
                <div class="flex size-9 items-center justify-center rounded-full bg-slate-200 text-sm font-bold text-slate-400 dark:bg-slate-700">3</div>
                <span class="hidden text-sm font-medium text-slate-400 sm:inline">Hoàn tất</span>
            </div>
        </div>
    </div>
</div>

<section class="bg-background-light py-10 dark:bg-background-dark">
    <div class="mx-auto grid max-w-7xl gap-8 px-4 sm:px-6 lg:grid-cols-[minmax(0,1fr)_360px] lg:px-8">
        <form asp-action="Create" method="post" id="booking-form" class="space-y-6">
            @Html.AntiForgeryToken()
            <input asp-for="TourId" type="hidden" />
            <input asp-for="SelectedStartDate" type="hidden" />

            <div class="public-form-card rounded-[2rem] border border-border-light bg-surface-light p-6 shadow-sm dark:border-border-dark dark:bg-surface-dark">
                <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
                    <div class="min-w-0">
                        <p class="text-xs font-bold uppercase tracking-[0.25em] text-primary">Tour snapshot</p>
                        <h2 class="mt-2 text-2xl font-black text-slate-900 dark:text-white">@tour.Name</h2>
                        <p class="mt-2 text-sm text-slate-500 dark:text-slate-400">@(tour.Destination?.City ?? "Việt Nam") • @(tour.Duration?.Text ?? "Liên hệ tư vấn")</p>
                    </div>
                    <a asp-controller="PublicTours" asp-action="Details" asp-route-id="@detailId" class="text-sm font-bold text-primary">Xem chi tiết</a>
                </div>
                @if (!ViewData.ModelState.IsValid)
                {
                    <div asp-validation-summary="All" class="mt-4 rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700 dark:border-rose-900/40 dark:bg-rose-950/20 dark:text-rose-300"></div>
                }
            </div>

            <div class="public-form-card rounded-[2rem] border border-border-light bg-surface-light p-6 shadow-sm dark:border-border-dark dark:bg-surface-dark">
                <div class="mb-5 flex items-center gap-3">
                    <span class="material-symbols-outlined text-primary">description</span>
                    <h3 class="text-xl font-black text-slate-900 dark:text-white">Thông tin tour</h3>
                </div>
                <div class="grid gap-4">
                    <div class="public-rich-text rounded-2xl bg-surface-muted-light px-4 py-4 text-sm text-slate-600 dark:bg-surface-elevated-dark dark:text-slate-300">
                        @Html.Raw(RichTextContentFormatter.ToTrustedHtml(tour.ShortDescription))
                    </div>
                    <div class="public-rich-text rounded-2xl bg-surface-muted-light px-4 py-4 text-sm text-slate-600 dark:bg-surface-elevated-dark dark:text-slate-300">
                        @Html.Raw(RichTextContentFormatter.ToTrustedHtml(tour.Description))
                    </div>
                </div>
            </div>

            <div class="public-form-card rounded-[2rem] border border-border-light bg-surface-light p-6 shadow-sm dark:border-border-dark dark:bg-surface-dark">
                <div class="mb-4 flex items-center justify-between gap-4">
                    <div>
                        <p class="text-xs font-bold uppercase tracking-[0.25em] text-primary">Departure</p>
                        <h3 class="mt-2 text-xl font-black text-slate-900 dark:text-white">Chọn đợt khởi hành</h3>
                    </div>
                    <span id="remaining-capacity" class="rounded-full bg-primary/10 px-3 py-2 text-xs font-bold text-primary">@(selectedDeparture?.RemainingCapacity ?? 0) chỗ</span>
                </div>

                @if (visibleDepartures.Any())
                {
                    <div class="grid gap-4 sm:grid-cols-2">
                        @foreach (var departure in tour.EffectiveDepartures.Where(item => visibleDepartures.Any(match => match.Id == item.Id)))
                        {
                            var isSelected = string.Equals(Model.DepartureId, departure.Id, StringComparison.Ordinal) || (string.IsNullOrWhiteSpace(Model.DepartureId) && selectedDeparture?.Id == departure.Id);
                            <label class="cursor-pointer rounded-2xl border border-border-light p-4 transition hover:border-primary dark:border-border-dark">
                                <input asp-for="DepartureId" type="radio" value="@departure.Id" checked="@isSelected" class="departure-choice sr-only" data-start-date="@departure.StartDate.ToString("yyyy-MM-dd")" data-remaining-capacity="@departure.RemainingCapacity" data-confirmation="@departure.ConfirmationType" />
                                <div class="space-y-3">
                                    <div class="flex items-start justify-between gap-3">
                                        <div>
                                            <p class="text-base font-black text-slate-900 dark:text-white">@departure.StartDate.ToString("dd/MM/yyyy")</p>
                                            <p class="text-xs text-slate-500 dark:text-slate-400">@(string.Equals(departure.ConfirmationType, "Instant", StringComparison.OrdinalIgnoreCase) ? "Xác nhận tức thì" : "Chờ xác nhận") • cutoff @departure.CutoffHours giờ</p>
                                        </div>
                                        <span class="rounded-full bg-surface-muted-light px-3 py-1 text-xs font-bold text-slate-600 dark:bg-surface-elevated-dark dark:text-slate-300">@departure.RemainingCapacity chỗ</span>
                                    </div>
                                    <div class="grid grid-cols-3 gap-3 text-xs text-slate-500 dark:text-slate-400">
                                        <div>
                                            <span class="block">Người lớn</span>
                                            <span class="font-bold text-slate-900 dark:text-white">@departure.AdultPrice.ToString("N0")₫</span>
                                        </div>
                                        <div>
                                            <span class="block">Trẻ em</span>
                                            <span class="font-bold text-slate-900 dark:text-white">@departure.ChildPrice.ToString("N0")₫</span>
                                        </div>
                                        <div>
                                            <span class="block">Em bé</span>
                                            <span class="font-bold text-slate-900 dark:text-white">@departure.InfantPrice.ToString("N0")₫</span>
                                        </div>
                                    </div>
                                    <p class="text-xs text-slate-500 dark:text-slate-400">@(tour.CancellationPolicy?.IsFreeCancellation == true ? $"Hủy miễn phí trước {tour.CancellationPolicy.FreeCancellationBeforeHours} giờ." : "Chính sách hủy áp dụng theo điều kiện của tour.")</p>
                                </div>
                            </label>
                        }
                    </div>
                }
                else
                {
                    <p class="text-sm text-slate-500 dark:text-slate-400">Tour này hiện chưa có lịch khởi hành khả dụng.</p>
                }
            </div>

            <div class="public-form-card rounded-[2rem] border border-border-light bg-surface-light p-6 shadow-sm dark:border-border-dark dark:bg-surface-dark">
                <p class="text-xs font-bold uppercase tracking-[0.25em] text-primary">Traveller</p>
                <h3 class="mt-2 text-xl font-black text-slate-900 dark:text-white">Thông tin liên hệ và số khách</h3>
                <div class="mt-5 grid gap-4 sm:grid-cols-2">
                    <div class="sm:col-span-2">
                        <label class="mb-2 block text-sm font-semibold">Họ và tên</label>
                        <input asp-for="ContactName" class="w-full rounded-2xl border border-border-light bg-transparent px-4 py-3 text-sm dark:border-border-dark" placeholder="Nguyễn Văn A" />
                        <span asp-validation-for="ContactName" class="mt-1 block text-xs text-rose-500"></span>
                    </div>
                    <div>
                        <label class="mb-2 block text-sm font-semibold">Email</label>
                        <input asp-for="ContactEmail" class="w-full rounded-2xl border border-border-light bg-transparent px-4 py-3 text-sm dark:border-border-dark" placeholder="email@example.com" />
                        <span asp-validation-for="ContactEmail" class="mt-1 block text-xs text-rose-500"></span>
                    </div>
                    <div>
                        <label class="mb-2 block text-sm font-semibold">Số điện thoại</label>
                        <input asp-for="ContactPhone" class="w-full rounded-2xl border border-border-light bg-transparent px-4 py-3 text-sm dark:border-border-dark" placeholder="0901 234 567" />
                        <span asp-validation-for="ContactPhone" class="mt-1 block text-xs text-rose-500"></span>
                    </div>
                    <div>
                        <label class="mb-2 block text-sm font-semibold">Người lớn</label>
                        <input asp-for="AdultCount" type="number" min="1" class="traveller-input w-full rounded-2xl border border-border-light bg-transparent px-4 py-3 text-sm dark:border-border-dark" />
                    </div>
                    <div>
                        <label class="mb-2 block text-sm font-semibold">Trẻ em</label>
                        <input asp-for="ChildCount" type="number" min="0" class="traveller-input w-full rounded-2xl border border-border-light bg-transparent px-4 py-3 text-sm dark:border-border-dark" />
                    </div>
                    <div>
                        <label class="mb-2 block text-sm font-semibold">Em bé</label>
                        <input asp-for="InfantCount" type="number" min="0" class="traveller-input w-full rounded-2xl border border-border-light bg-transparent px-4 py-3 text-sm dark:border-border-dark" />
                    </div>
                    <div class="sm:col-span-2">
                        <label class="mb-2 block text-sm font-semibold">Yêu cầu đặc biệt</label>
                        <textarea asp-for="SpecialRequests" rows="3" class="w-full rounded-2xl border border-border-light bg-transparent px-4 py-3 text-sm dark:border-border-dark" placeholder="Ví dụ: ăn chay, ghế gần cửa sổ, hỗ trợ xe đón..."></textarea>
                    </div>
                </div>
            </div>

            <div class="public-form-card rounded-[2rem] border border-border-light bg-surface-light p-6 shadow-sm dark:border-border-dark dark:bg-surface-dark">
                <p class="text-xs font-bold uppercase tracking-[0.25em] text-primary">Pricing controls</p>
                <h3 class="mt-2 text-xl font-black text-slate-900 dark:text-white">Coupon và kế hoạch thanh toán</h3>
                <div class="mt-5 grid gap-4 sm:grid-cols-2">
                    <div>
                        <label class="mb-2 block text-sm font-semibold">Coupon</label>
                        <input asp-for="CouponCode" class="w-full rounded-2xl border border-border-light bg-transparent px-4 py-3 text-sm dark:border-border-dark" placeholder="WELCOME10" />
                        <span asp-validation-for="CouponCode" class="mt-1 block text-xs text-rose-500"></span>
                    </div>
                    <div>
                        <label class="mb-2 block text-sm font-semibold">Payment plan</label>
                        <div class="grid grid-cols-2 gap-3">
                            <label class="rounded-2xl border border-border-light px-4 py-3 text-sm font-semibold dark:border-border-dark">
                                <input asp-for="PaymentPlanType" type="radio" value="Full" class="mr-2" /> Full
                            </label>
                            <label class="rounded-2xl border border-border-light px-4 py-3 text-sm font-semibold dark:border-border-dark">
                                <input asp-for="PaymentPlanType" type="radio" value="Deposit" class="mr-2" /> Deposit
                            </label>
                        </div>
                    </div>
                </div>
            </div>
        </form>

        <aside class="space-y-6">
            <div class="public-summary-card rounded-[2rem] border border-border-light bg-surface-light p-6 shadow-sm dark:border-border-dark dark:bg-surface-dark">
                <p class="text-xs font-bold uppercase tracking-[0.25em] text-primary">Quote</p>
                <h3 class="mt-2 text-xl font-black text-slate-900 dark:text-white">Xem báo giá trước khi giữ chỗ</h3>
                <div id="quote-badges" class="mt-4 flex flex-wrap gap-2"></div>
                <div class="mt-5 space-y-3 text-sm">
                    <div class="flex items-center justify-between"><span>Tạm tính</span><span id="subtotal">@subtotal.ToString("N0")₫</span></div>
                    <div class="flex items-center justify-between"><span>Giảm giá</span><span id="discountTotal">0₫</span></div>
                    <div class="flex items-center justify-between"><span>Tổng thanh toán</span><span id="grandTotal">@subtotal.ToString("N0")₫</span></div>
                    <div class="flex items-center justify-between"><span>Thanh toán ngay</span><span id="amountDueNow">@amountDueNow.ToString("N0")₫</span></div>
                    <div class="flex items-center justify-between"><span>Còn lại</span><span id="balanceDue">@balanceDue.ToString("N0")₫</span></div>
                </div>
                <div id="quote-status" class="mt-4 rounded-2xl bg-surface-muted-light px-4 py-3 text-sm text-slate-600 dark:bg-surface-elevated-dark dark:text-slate-300">Máy chủ sẽ tính lại báo giá khi bạn đổi departure, số khách, coupon hoặc payment plan.</div>
                <button form="booking-form" type="submit" id="submit-booking" class="mt-6 w-full rounded-2xl bg-primary px-5 py-4 text-sm font-bold text-white">Tiếp tục sang thanh toán</button>
                <p class="mt-3 text-center text-xs text-slate-400">Ghế chỉ được giữ khi máy chủ xác nhận báo giá và tạo booking thành công.</p>
            </div>
        </aside>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (() => {
            const quoteUrl = '@Url.Action("Quote", "Booking")';
            const form = document.getElementById('booking-form');
            const selectedStartDate = document.getElementById('SelectedStartDate');
            const remainingCapacity = document.getElementById('remaining-capacity');
            const quoteBadges = document.getElementById('quote-badges');
            const quoteStatus = document.getElementById('quote-status');
            const submitButton = document.getElementById('submit-booking');
            const formatCurrency = (value) => `${new Intl.NumberFormat('vi-VN').format(value || 0)}₫`;

            const updateSelectedStartDate = () => {
                const activeDeparture = document.querySelector('input[name="DepartureId"]:checked');
                if (activeDeparture && selectedStartDate) {
                    selectedStartDate.value = activeDeparture.dataset.startDate || '';
                    remainingCapacity.textContent = `${activeDeparture.dataset.remainingCapacity || 0} chỗ`;
                }
            };

            const renderBadges = (badges) => {
                quoteBadges.innerHTML = (badges || [])
                    .map((badge) => `<span class="rounded-full bg-primary/10 px-3 py-2 text-xs font-bold text-primary">${badge}</span>`)
                    .join('');
            };

            const collectParams = () => {
                const activeDeparture = document.querySelector('input[name="DepartureId"]:checked');
                return new URLSearchParams({
                    tourId: document.getElementById('TourId').value,
                    departureId: activeDeparture ? activeDeparture.value : '',
                    adultCount: document.getElementById('AdultCount').value || '1',
                    childCount: document.getElementById('ChildCount').value || '0',
                    infantCount: document.getElementById('InfantCount').value || '0',
                    couponCode: document.getElementById('CouponCode').value || '',
                    paymentPlanType: document.querySelector('input[name="PaymentPlanType"]:checked')?.value || 'Full'
                });
            };

            const refreshQuote = async () => {
                updateSelectedStartDate();
                const response = await fetch(`${quoteUrl}?${collectParams().toString()}`);
                const data = await response.json();
                document.getElementById('subtotal').textContent = formatCurrency(data.subtotal);
                document.getElementById('discountTotal').textContent = formatCurrency(data.discountTotal);
                document.getElementById('grandTotal').textContent = formatCurrency(data.grandTotal);
                document.getElementById('amountDueNow').textContent = formatCurrency(data.amountDueNow);
                document.getElementById('balanceDue').textContent = formatCurrency(data.balanceDue);
                renderBadges(data.badges);
                remainingCapacity.textContent = `${data.remainingCapacity || 0} chỗ`;
                quoteStatus.textContent = data.errorMessage || (data.appliedCouponCode
                    ? `Đã áp dụng coupon ${data.appliedCouponCode}.`
                    : 'Báo giá hợp lệ, có thể tiếp tục giữ chỗ.');
                submitButton.disabled = !data.isAvailable;
                submitButton.classList.toggle('opacity-50', !data.isAvailable);
                submitButton.classList.toggle('cursor-not-allowed', !data.isAvailable);
            };

            form.querySelectorAll('input, textarea').forEach((element) => {
                if (element.type === 'hidden' || element.name === '__RequestVerificationToken') {
                    return;
                }
                element.addEventListener('change', refreshQuote);
                if (element.id === 'CouponCode') {
                    element.addEventListener('input', refreshQuote);
                }
            });

            updateSelectedStartDate();
            refreshQuote();
        })();
    </script>
}
