@model BookingResultViewModel

<section class="public-journey-shell public-journey-shell--status public-booking-status-shell public-booking-status-shell--error">
    <div class="public-journey-shell-inner">
        <span class="sr-only">Trang chủ</span>
        @await Html.PartialAsync("_JourneyHeader", Model.Journey)
        <div class="public-journey-desk public-journey-desk--status">
            <div class="public-journey-main">
                <section class="public-journey-panel public-booking-section public-booking-status-intro">
                    <p class="public-journey-card-eyebrow">Không thể hoàn tất thao tác</p>
                    <h2 class="public-journey-panel-title">Hệ thống đang cần thêm một lần thử lại</h2>
                    <p class="public-journey-note">Bạn có thể tải lại trang, quay lại bước trước hoặc nhờ đội hỗ trợ tiếp tục xử lý thủ công.</p>
                </section>
                <div class="public-journey-status-panel">
                    @await Html.PartialAsync("_JourneyStatusPanel", Model.Journey.Status)
                </div>
            </div>
            <aside class="public-journey-rail">
                <div class="public-journey-support">
                    @await Html.PartialAsync("_JourneySupportPanel", Model.Journey.Support)
                </div>
                <section class="public-journey-panel public-booking-section">
                    <div class="public-booking-status-actions public-journey-action-row">
                        <button type="button" onclick="location.reload()" class="public-journey-submit">Tải lại</button>
                        <a asp-controller="Home" asp-action="Index" class="public-journey-action public-journey-action--secondary">Trang chủ</a>
                    </div>
                </section>
            </aside>
        </div>
    </div>
</section>
