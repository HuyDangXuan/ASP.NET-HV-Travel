@model BookingResultViewModel
@{
    var booking = Model.Booking;
    var paymentSessionCount = booking.PaymentSessions?.Count ?? 0;
    var amountDueNow = booking.PaymentPlan?.AmountDueNow > 0m ? booking.PaymentPlan.AmountDueNow : booking.TotalAmount;
    var balanceDue = booking.PaymentPlan?.BalanceDue ?? 0m;
    var grandTotal = booking.PricingBreakdown?.GrandTotal ?? booking.TotalAmount;
    var planLabel = string.Equals(booking.PaymentPlan?.PlanType, "Deposit", StringComparison.OrdinalIgnoreCase) ? "Đặt cọc 30%" : "Thanh toán toàn bộ";
    var nextStepText = balanceDue > 0m
        ? "Phần còn lại sẽ được đội vận hành nhắc trước ngày khởi hành."
        : "Hoàn tất một lần để booking chuyển sang trạng thái xác nhận ngay.";

    string FormatCurrency(decimal amount) => $"{amount:N0}₫";
}

<section class="public-journey-shell public-booking-payment-shell">
    <div class="public-journey-shell-inner">
        @await Html.PartialAsync("_JourneyHeader", Model.Journey)
        <div class="public-journey-stagebar">
            @await Html.PartialAsync("_JourneyStageBar", Model.Journey)
        </div>

        <div class="public-journey-desk public-journey-desk--payment">
            <div class="public-journey-main">
                @if (TempData["PaymentSuccess"] != null)
                {
                    <div class="public-journey-flash public-journey-flash--success">@TempData["PaymentSuccess"]</div>
                }
                @if (TempData["PaymentError"] != null)
                {
                    <div class="public-journey-flash public-journey-flash--danger">@TempData["PaymentError"]</div>
                }

                <section class="public-journey-panel public-booking-section public-journey-status-hero">
                    <div class="public-journey-badge-group">
                        <p class="public-journey-card-eyebrow">Thanh toán booking</p>
                        <span class="public-badge is-info">@booking.BookingCode</span>
                        <span class="public-badge @(balanceDue > 0m ? "is-warning" : "is-success")">@planLabel</span>
                    </div>
                    <h2 class="public-journey-panel-title">Chọn phương thức và hoàn tất bước thanh toán</h2>
                    <p class="public-journey-note public-journey-section-lead">Đọc nhanh số tiền cần xử lý, chọn phương thức phù hợp và hoàn tất ngay trong cùng một luồng.</p>
                </section>

                <div class="public-journey-status-panel">
                    @await Html.PartialAsync("_JourneyStatusPanel", Model.Journey.Status)
                </div>

                <section class="public-journey-panel public-booking-section public-booking-payment-glance">
                    <div class="public-journey-panel-heading">
                        <div class="public-journey-badge-group">
                            <p class="public-journey-card-eyebrow">Đọc nhanh trước khi chọn phương thức</p>
                        </div>
                        <h2 class="public-journey-panel-title">Thanh toán trong một lần nhìn</h2>
                    </div>
                    <div class="public-booking-glance-grid">
                        <article class="public-booking-glance-card">
                            <span>Thanh toán ngay</span>
                            <strong>@FormatCurrency(amountDueNow)</strong>
                            <p>@planLabel</p>
                        </article>
                        <article class="public-booking-glance-card">
                            <span>Còn lại</span>
                            <strong>@FormatCurrency(balanceDue)</strong>
                            <p>@nextStepText</p>
                        </article>
                        <article class="public-booking-glance-card">
                            <span>Tổng giá trị</span>
                            <strong>@FormatCurrency(grandTotal)</strong>
                            <p>Booking @booking.BookingCode</p>
                        </article>
                    </div>
                </section>

                <section class="public-journey-panel public-journey-payment-switcher public-booking-section" data-session-count="@paymentSessionCount" data-checkout-session="@booking.CheckoutSessionId">
                    <div class="public-journey-panel-heading">
                        <div class="public-journey-badge-group">
                            <p class="public-journey-card-eyebrow">Chọn cách bạn muốn thanh toán</p>
                        </div>
                        <h2 class="public-journey-panel-title">Một bước chốt phương thức, một bước hoàn tất</h2>
                    </div>
                    @await Html.PartialAsync("_JourneyPaymentMethodSwitcher", Model)
                </section>

                <section class="public-journey-panel public-booking-section" data-transfer-proof-block hidden>
                    <div class="public-journey-panel-heading">
                        <div class="public-journey-badge-group">
                            <p class="public-journey-card-eyebrow">Tải minh chứng khi đã chuyển khoản</p>
                            <span class="public-badge is-info">Đối soát nhanh</span>
                        </div>
                        <h2 class="public-journey-panel-title">Gửi minh chứng chuyển khoản</h2>
                    </div>
                    <div class="public-journey-callout public-journey-callout--info">
                        Nếu bạn chọn chuyển khoản ngân hàng, hãy tải minh chứng tại đây để đội vận hành đối soát và xác nhận nhanh hơn.
                    </div>
                    <form asp-action="UploadTransferProof" method="post" enctype="multipart/form-data" class="public-journey-upload-form public-journey-form-grid">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="bookingId" value="@booking.Id" />
                        <label class="public-journey-field-block public-journey-field-block--full">
                            <span class="public-journey-field-label">Minh chứng chuyển khoản</span>
                            <span class="public-journey-field-hint">Tải ảnh chụp hoặc file xác nhận giao dịch.</span>
                            <input type="file" name="proofFile" />
                        </label>
                        <label class="public-journey-field-block public-journey-field-block--full">
                            <span class="public-journey-field-label">Ghi chú giao dịch</span>
                            <span class="public-journey-field-hint">Ví dụ: mã tham chiếu, thời gian chuyển khoản, ngân hàng gửi.</span>
                            <textarea name="note" rows="4" placeholder="Ghi chú mã giao dịch hoặc thông tin cần đội vận hành lưu ý"></textarea>
                        </label>
                        <button type="submit" class="public-journey-submit public-journey-submit--ghost">Gửi minh chứng</button>
                    </form>
                </section>
            </div>

            <aside class="public-journey-rail">
                <div class="public-journey-summary">
                    @await Html.PartialAsync("_JourneySummaryRail", Model.Journey.Summary)
                </div>
                <div class="public-journey-timeline">
                    @await Html.PartialAsync("_JourneyTimeline", Model.Journey.Timeline)
                </div>
                <div class="public-journey-support">
                    @await Html.PartialAsync("_JourneySupportPanel", Model.Journey.Support)
                </div>
            </aside>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        (() => {
            document.querySelectorAll('[data-journey-payment-switcher]').forEach((switcher) => {
                const radios = switcher.querySelectorAll('input[data-payment-method]');
                const panels = switcher.querySelectorAll('[data-payment-panel]');
                const submitLabel = switcher.querySelector('[data-payment-cta-label]');
                const transferProofBlock = document.querySelector('[data-transfer-proof-block]');
                const sync = () => {
                    const active = Array.from(radios).find((radio) => radio.checked);
                    panels.forEach((panel) => panel.classList.toggle('is-active', panel.dataset.paymentPanel === active?.dataset.paymentMethod));
                    switcher.querySelectorAll('[data-payment-option]').forEach((option) => {
                        const input = option.querySelector('input[data-payment-method]');
                        option.classList.toggle('is-selected', Boolean(input && input.checked));
                    });
                    if (submitLabel && active?.dataset.paymentCta) {
                        submitLabel.textContent = active.dataset.paymentCta;
                    }
                    if (transferProofBlock) {
                        transferProofBlock.hidden = active?.dataset.paymentMethod !== 'BankTransfer';
                    }
                };
                radios.forEach((radio) => radio.addEventListener('change', sync));
                sync();
            });
        })();
    </script>
}
