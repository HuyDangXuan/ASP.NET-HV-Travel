@using HVTravel.Domain.Entities
@model HVTravel.Web.Models.BookingResultViewModel
@{
    var booking = Model.Booking;
    var tour = Model.Tour;
    var departure = tour?.ResolveDeparture(booking.DepartureId, booking.TourSnapshot?.StartDate);
    var activePaymentSession = booking.PaymentSessions.OrderByDescending(item => item.UpdatedAt).FirstOrDefault();
    var timeline = booking.Events ?? new List<BookingEvent>();
    var breadcrumb = new HVTravel.Web.Models.BreadcrumbViewModel
    {
        Items = new List<HVTravel.Web.Models.BreadcrumbItemViewModel>
        {
            new() { Label = "Trang chủ", Url = Url.Action("Index", "Home") },
            new() { Label = "Tour du lịch", Url = Url.Action("Index", "PublicTours") },
            new() { Label = tour?.Name ?? "Tour", Url = tour != null ? Url.Action("Details", "PublicTours", new { id = string.IsNullOrWhiteSpace(tour.Slug) ? tour.Id : tour.Slug }) : null },
            new() { Label = "Đặt tour" },
            new() { Label = "Thanh toán", IsCurrent = true }
        }
    };
}

@await Html.PartialAsync("_PublicBreadcrumb", breadcrumb)

<section class="public-top-section public-top-section--compact hero-gradient relative overflow-hidden">
    <div class="public-top-section-shell mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="public-top-section-content is-left" data-animate="fade-up">
            <span class="public-badge public-top-section-badge">
                <span class="material-symbols-outlined text-[16px] text-primary">payments</span>
                Bước 2 trong hành trình đặt tour
            </span>
            <h1 class="public-top-section-title text-white">Xác nhận thanh toán booking</h1>
            <p class="public-top-section-lead">Chọn phương thức thanh toán, tải minh chứng nếu chuyển khoản và tiếp tục từ phiên checkout hiện tại khi cần.</p>
        </div>
    </div>
</section>

<div class="border-b border-border-light bg-surface-light py-6 dark:border-border-dark dark:bg-surface-dark">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="public-stepper flex items-center justify-center gap-0" data-animate="fade-in">
            <div class="flex items-center gap-2">
                <div class="flex size-9 items-center justify-center rounded-full bg-primary text-sm font-bold text-white"><span class="material-symbols-outlined text-[16px]">check</span></div>
                <span class="hidden text-sm font-medium text-primary sm:inline">Thông tin</span>
            </div>
            <div class="public-stepper-divider mx-2 h-0.5 w-12 bg-primary sm:w-20"></div>
            <div class="flex items-center gap-2">
                <div class="flex size-9 items-center justify-center rounded-full bg-primary text-sm font-bold text-white shadow-lg shadow-primary/30">2</div>
                <span class="hidden text-sm font-bold text-primary sm:inline">Thanh toán</span>
            </div>
            <div class="public-stepper-divider mx-2 h-0.5 w-12 bg-slate-200 dark:bg-slate-700 sm:w-20"></div>
            <div class="flex items-center gap-2">
                <div class="flex size-9 items-center justify-center rounded-full bg-slate-200 text-sm font-bold text-slate-400 dark:bg-slate-700">3</div>
                <span class="hidden text-sm font-medium text-slate-400 sm:inline">Hoàn tất</span>
            </div>
        </div>
    </div>
</div>

<section class="bg-background-light py-10 dark:bg-background-dark">
    <div class="mx-auto grid max-w-7xl gap-8 px-4 sm:px-6 lg:grid-cols-[minmax(0,1fr)_360px] lg:px-8">
        <div class="space-y-6">
            @if (TempData["PaymentSuccess"] != null)
            {
                <div class="rounded-2xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm font-semibold text-emerald-700 dark:border-emerald-900/40 dark:bg-emerald-950/20 dark:text-emerald-300">@TempData["PaymentSuccess"]</div>
            }
            @if (TempData["PaymentError"] != null)
            {
                <div class="rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm font-semibold text-rose-700 dark:border-rose-900/40 dark:bg-rose-950/20 dark:text-rose-300">@TempData["PaymentError"]</div>
            }

            <div class="public-form-card rounded-[2rem] border border-border-light bg-surface-light p-6 shadow-sm dark:border-border-dark dark:bg-surface-dark">
                <p class="text-xs font-bold uppercase tracking-[0.25em] text-primary">Payment methods</p>
                <h2 class="mt-2 text-2xl font-black text-slate-900 dark:text-white">Chọn cách thu tiền cho booking này</h2>
                <form asp-action="ProcessPayment" method="post" class="mt-6 space-y-4">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="bookingId" value="@booking.Id" />

                    <label class="block cursor-pointer rounded-2xl border border-border-light p-4 transition hover:border-primary dark:border-border-dark">
                        <input type="radio" name="paymentMethod" value="BankTransfer" checked class="mr-2" />
                        <span class="font-semibold text-slate-900 dark:text-white">Chuyển khoản thủ công</span>
                        <p class="mt-2 text-sm text-slate-500 dark:text-slate-400">Tải minh chứng chuyển khoản để đội vận hành đối soát trên admin.</p>
                    </label>

                    <label class="block cursor-pointer rounded-2xl border border-border-light p-4 transition hover:border-primary dark:border-border-dark">
                        <input type="radio" name="paymentMethod" value="CreditCard" class="mr-2" />
                        <span class="font-semibold text-slate-900 dark:text-white">Mock online gateway</span>
                        <p class="mt-2 text-sm text-slate-500 dark:text-slate-400">Luồng demo nội bộ sẽ gọi callback idempotent để mô phỏng gateway online.</p>
                    </label>

                    <label class="block cursor-pointer rounded-2xl border border-border-light p-4 transition hover:border-primary dark:border-border-dark">
                        <input type="radio" name="paymentMethod" value="Cash" class="mr-2" />
                        <span class="font-semibold text-slate-900 dark:text-white">Cash hold</span>
                        <p class="mt-2 text-sm text-slate-500 dark:text-slate-400">Giữ chỗ trước và thanh toán bằng tiền mặt tại văn phòng hoặc khi khởi hành.</p>
                    </label>

                    <button type="submit" class="w-full rounded-2xl bg-primary px-5 py-4 text-sm font-bold text-white">Xác nhận thanh toán</button>
                </form>
            </div>

            <div class="public-form-card rounded-[2rem] border border-border-light bg-surface-light p-6 shadow-sm dark:border-border-dark dark:bg-surface-dark">
                <div class="flex items-center justify-between gap-3">
                    <div>
                        <p class="text-xs font-bold uppercase tracking-[0.25em] text-primary">Transfer proof</p>
                        <h3 class="mt-2 text-xl font-black text-slate-900 dark:text-white">Tải minh chứng chuyển khoản</h3>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(booking.CheckoutSessionId))
                    {
                        <a asp-action="Resume" asp-route-checkoutSessionId="@booking.CheckoutSessionId" class="text-sm font-bold text-primary">Resume checkout</a>
                    }
                </div>
                <form asp-action="UploadTransferProof" method="post" enctype="multipart/form-data" class="mt-5 space-y-4">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="bookingId" value="@booking.Id" />
                    <input type="file" name="proofFile" class="w-full rounded-2xl border border-border-light bg-transparent px-4 py-3 text-sm dark:border-border-dark" />
                    <textarea name="note" rows="3" class="w-full rounded-2xl border border-border-light bg-transparent px-4 py-3 text-sm dark:border-border-dark" placeholder="Ghi chú đối soát hoặc mã tham chiếu giao dịch"></textarea>
                    <button type="submit" class="rounded-2xl border border-border-light px-5 py-3 text-sm font-bold dark:border-border-dark">Gửi minh chứng</button>
                </form>
            </div>
        </div>

        <aside class="space-y-6">
            <div class="public-summary-card rounded-[2rem] border border-border-light bg-surface-light p-6 shadow-sm dark:border-border-dark dark:bg-surface-dark">
                <p class="text-xs font-bold uppercase tracking-[0.25em] text-primary">Order summary</p>
                <h3 class="mt-2 text-xl font-black text-slate-900 dark:text-white">Booking @booking.BookingCode</h3>

                @if (tour != null)
                {
                    <div class="mt-5 flex gap-3 border-b border-border-light pb-5 dark:border-border-dark">
                        @if (tour.Images != null && tour.Images.Any())
                        {
                            <img src="@tour.Images.First()" alt="@tour.Name" class="h-16 w-20 rounded-xl object-cover" />
                        }
                        <div class="min-w-0">
                            <p class="text-sm font-bold text-slate-900 dark:text-white">@tour.Name</p>
                            <p class="text-xs text-slate-500 dark:text-slate-400">@(tour.Duration?.Text ?? booking.TourSnapshot?.Duration)</p>
                        </div>
                    </div>
                }

                <div class="mt-5 space-y-3 text-sm">
                    <div class="flex items-center justify-between"><span>Mã đơn</span><span class="font-bold font-mono text-primary">@booking.BookingCode</span></div>
                    <div class="flex items-center justify-between"><span>Khởi hành</span><span class="font-bold">@(departure?.StartDate.ToString("dd/MM/yyyy") ?? booking.TourSnapshot?.StartDate?.ToString("dd/MM/yyyy") ?? "-")</span></div>
                    <div class="flex items-center justify-between"><span>Coupon</span><span data-model-field="booking.CouponCode" class="font-bold">@(string.IsNullOrWhiteSpace(booking.CouponCode) ? "-" : booking.CouponCode)</span></div>
                    <div class="flex items-center justify-between"><span>Trạng thái thanh toán</span><span class="font-bold">@booking.PaymentStatus</span></div>
                    <div class="flex items-center justify-between"><span>Tạm tính</span><span class="font-bold">@booking.PricingBreakdown.Subtotal.ToString("N0")₫</span></div>
                    <div class="flex items-center justify-between"><span>Giảm giá</span><span class="font-bold">@booking.PricingBreakdown.DiscountTotal.ToString("N0")₫</span></div>
                    <div class="flex items-center justify-between"><span>Tổng thanh toán</span><span class="font-bold">@booking.PricingBreakdown.GrandTotal.ToString("N0")₫</span></div>
                    <div class="flex items-center justify-between"><span>Kế hoạch</span><span class="font-bold">@booking.PaymentPlan.PlanType</span></div>
                    <div class="flex items-center justify-between" data-model-field="booking.PaymentPlan.AmountDueNow"><span>Thanh toán ngay</span><span class="font-bold">@booking.PaymentPlan.AmountDueNow.ToString("N0")₫</span></div>
                    <div class="flex items-center justify-between" data-model-field="booking.PaymentPlan.BalanceDue"><span>Còn lại</span><span class="font-bold">@booking.PaymentPlan.BalanceDue.ToString("N0")₫</span></div>
                    <div class="flex items-center justify-between" data-model-field="booking.CheckoutSessionId"><span>Checkout session</span><span class="font-mono text-xs font-bold">@(string.IsNullOrWhiteSpace(booking.CheckoutSessionId) ? "-" : booking.CheckoutSessionId)</span></div>
                    <div class="flex items-center justify-between" data-model-field="booking.PaymentSessions"><span>Payment session</span><span class="font-mono text-xs font-bold">@(activePaymentSession?.Reference ?? activePaymentSession?.Id ?? "Pending")</span></div>
                </div>
            </div>

            @if (timeline.Any())
            {
                <div class="rounded-[2rem] border border-border-light bg-surface-light p-6 shadow-sm dark:border-border-dark dark:bg-surface-dark">
                    <p class="text-xs font-bold uppercase tracking-[0.25em] text-primary">Timeline</p>
                    <div class="mt-4 space-y-3">
                        @foreach (var evt in timeline.OrderByDescending(item => item.OccurredAt).Take(4))
                        {
                            <div class="rounded-2xl bg-surface-muted-light px-4 py-3 text-sm dark:bg-surface-elevated-dark">
                                <p class="font-bold text-slate-900 dark:text-white">@evt.Title</p>
                                <p class="mt-1 text-xs text-slate-500 dark:text-slate-400">@evt.Description</p>
                            </div>
                        }
                    </div>
                </div>
            }
        </aside>
    </div>
</section>
