@inject IPublicContentService ContentService
@using HVTravel.Web.Services
@model HVTravel.Web.Models.BookingResultViewModel
@{
    var sections = await ContentService.GetPageSectionsAsync("booking");
    var siteSettings = await ContentService.GetSiteSettingsAsync();
    var statusCopy = sections.GetSection("statusCopy");
    var booking = Model.Booking;
    var tour = Model.Tour;
    var phone = siteSettings.GetGroup("contactInfo")?.Fields.GetFieldValue("phoneNumber", "028 3822 9999") ?? "028 3822 9999";
    var breadcrumbItems = new List<HVTravel.Web.Models.BreadcrumbItemViewModel>
    {
        new() { Label = "Trang chủ", Url = Url.Action("Index", "Home") }
    };
    if (tour != null)
    {
        breadcrumbItems.Add(new HVTravel.Web.Models.BreadcrumbItemViewModel { Label = "Tour du lịch", Url = Url.Action("Index", "PublicTours") });
        breadcrumbItems.Add(new HVTravel.Web.Models.BreadcrumbItemViewModel { Label = tour.Name, Url = Url.Action("Details", "PublicTours", new { id = string.IsNullOrWhiteSpace(tour.Slug) ? tour.Id : tour.Slug }) });
    }
    breadcrumbItems.Add(new HVTravel.Web.Models.BreadcrumbItemViewModel { Label = "Đặt tour" });
    breadcrumbItems.Add(new HVTravel.Web.Models.BreadcrumbItemViewModel { Label = "Thanh toán" });
    breadcrumbItems.Add(new HVTravel.Web.Models.BreadcrumbItemViewModel { Label = "Thất bại", IsCurrent = true });
    var breadcrumb = new HVTravel.Web.Models.BreadcrumbViewModel { Items = breadcrumbItems };
}

@await Html.PartialAsync("_PublicBreadcrumb", breadcrumb)

<section class="relative overflow-hidden bg-[radial-gradient(circle_at_top_left,rgba(59,130,246,0.22),transparent_36%),linear-gradient(135deg,#020617_0%,#0f172a_45%,#1e3a8a_100%)] py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl" data-animate="fade-up">
            <span class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/10 px-4 py-2 text-xs font-bold uppercase tracking-[0.25em] text-white/90 backdrop-blur-md">
                <span class="material-symbols-outlined text-[16px] text-primary">warning</span>
                Cần hoàn tất bước thanh toán
            </span>
            <h1 class="mt-6 text-4xl font-extrabold tracking-tight text-white">Booking vẫn đang chờ thanh toán</h1>
            <p class="mt-4 max-w-2xl text-base leading-relaxed text-slate-300">Bạn có thể thử lại thanh toán, đổi phương thức khác hoặc khôi phục phiên checkout hiện tại để tiếp tục.</p>
        </div>
    </div>
</section>

<section class="bg-background-light py-12 dark:bg-background-dark">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
        <div class="rounded-[2rem] border border-border-light bg-surface-light p-8 text-center shadow-sm dark:border-border-dark dark:bg-surface-dark">
            <p class="text-xs font-bold uppercase tracking-[0.25em] text-rose-500">Failed state</p>
            <h2 class="mt-2 text-3xl font-black text-slate-900 dark:text-white" style="@ContentPresentationViewHelper.GetFieldTextStyle(statusCopy, "failedTitle")">@statusCopy?.Fields.GetFieldValue("failedTitle", "Thanh Toán Thất Bại")</h2>
            <div class="mt-4 text-sm text-slate-500 dark:text-slate-400" style="@ContentPresentationViewHelper.GetFieldTextStyle(statusCopy, "failedDescription")">
                @Html.Raw(string.IsNullOrWhiteSpace(Model.ErrorMessage)
                    ? statusCopy?.Fields.GetFieldValue("failedDescription", "Thanh toán không thành công. Vui lòng thử lại hoặc chọn phương thức khác.")
                    : Model.ErrorMessage)
            </div>
            @if (!string.IsNullOrWhiteSpace(booking.CheckoutSessionId))
            {
                <p class="mt-4 text-xs text-slate-400" data-model-field="booking.CheckoutSessionId">checkout session: @booking.CheckoutSessionId</p>
            }

            <div class="mt-6 rounded-2xl border border-amber-200 bg-amber-50 px-4 py-4 text-left text-sm text-amber-800 dark:border-amber-900/30 dark:bg-amber-900/10 dark:text-amber-300">
                <p class="font-bold">Đơn đặt tour của bạn vẫn được giữ chỗ</p>
                <p class="mt-2">Bạn có thể tiếp tục thanh toán hoặc liên hệ hotline <strong>@phone</strong> để được hỗ trợ nhanh.</p>
            </div>

            <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:justify-center">
                @if (!string.IsNullOrWhiteSpace(booking.Id))
                {
                    <a asp-action="Payment" asp-route-bookingId="@booking.Id" class="rounded-2xl bg-primary px-5 py-3 text-sm font-bold text-white">Thử Lại</a>
                }
                @if (!string.IsNullOrWhiteSpace(booking.CheckoutSessionId))
                {
                    <a asp-action="Resume" asp-route-checkoutSessionId="@booking.CheckoutSessionId" title="Resume checkout" class="rounded-2xl border border-border-light px-5 py-3 text-sm font-bold text-slate-700 dark:border-border-dark dark:text-slate-300">Khôi phục checkout</a>
                }
                <a asp-controller="Home" asp-action="Index" class="rounded-2xl border border-border-light px-5 py-3 text-sm font-bold text-slate-700 dark:border-border-dark dark:text-slate-300">Về Trang Chủ</a>
                <a href="tel:@phone" class="rounded-2xl border border-border-light px-5 py-3 text-sm font-bold text-slate-700 dark:border-border-dark dark:text-slate-300">Gọi Hỗ Trợ</a>
            </div>
        </div>
    </div>
</section>

