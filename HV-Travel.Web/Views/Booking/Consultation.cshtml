@model ConsultationViewModel
@{
    var success = string.Equals(Model.Journey.Status.Variant, "ConsultationSubmitted", StringComparison.Ordinal);
}

<section class="public-journey-shell public-journey-shell--consultation public-booking-support-shell">
    <div class="public-journey-shell-inner">
        @await Html.PartialAsync("_JourneyHeader", Model.Journey)
        <div class="public-journey-desk public-journey-desk--consultation">
            <div class="public-journey-main">
                <section class="public-journey-panel public-booking-section">
                    <p class="public-journey-card-eyebrow">Nhờ tư vấn theo cách của bạn</p>
                    <h2 class="public-journey-panel-title">Trao đổi với chuyên viên trước khi chốt</h2>
                    <p class="public-journey-note">Gửi mô tả ngắn về lịch đi, ngân sách và số khách để đội ngũ đề xuất phương án phù hợp ngay trong cùng luồng đặt tour.</p>
                </section>
                <div class="public-journey-status-panel">
                    @if (success)
                    {
                        <section class="public-journey-panel public-booking-section">
                            <p class="public-journey-card-eyebrow">Gửi yêu cầu tư vấn thành công</p>
                            <h2 class="public-journey-panel-title">Đội ngũ tư vấn đã nhận yêu cầu của bạn</h2>
                            <p class="public-journey-note">Chúng tôi sẽ liên hệ lại theo khung giờ bạn mong muốn hoặc trong giờ làm việc kế tiếp.</p>
                        </section>
                    }
                    @await Html.PartialAsync("_JourneyStatusPanel", Model.Journey.Status)
                </div>
                @if (!success)
                {
                    <section class="public-journey-panel public-booking-section">
                        <div class="public-journey-panel-heading">
                            <p class="public-journey-card-eyebrow">Gửi yêu cầu tư vấn</p>
                            <h2 class="public-journey-panel-title">Điền mô tả ngắn để đội ngũ gọi lại</h2>
                        </div>
                        <form asp-action="Consultation" method="post" class="public-journey-form-grid">
                            @Html.AntiForgeryToken()
                            <div asp-validation-summary="ModelOnly" class="public-journey-validation"></div>
                            <label class="public-booking-field"><span class="sr-only">Họ và tên</span><input asp-for="FullName" placeholder="Họ và tên" /></label>
                            <label class="public-booking-field"><span class="sr-only">Số điện thoại</span><input asp-for="Phone" placeholder="Số điện thoại" /></label>
                            <label class="public-booking-field"><span class="sr-only">Email</span><input asp-for="Email" placeholder="Email (nếu có)" /></label>
                            <label class="public-booking-field"><span class="sr-only">Tour quan tâm</span><input asp-for="TourInterest" placeholder="Tour hoặc điểm đến bạn quan tâm" /></label>
                            <label class="public-booking-field"><span class="sr-only">Thời gian liên hệ mong muốn</span><input asp-for="PreferredContactTime" placeholder="Khung giờ liên hệ mong muốn" /></label>
                            <label class="public-booking-field public-booking-field--full">
                                <span class="sr-only">Nội dung yêu cầu</span>
                                <textarea asp-for="Message" rows="5" placeholder="Nội dung bạn cần tư vấn"></textarea>
                            </label>
                            <button type="submit" class="public-journey-submit">Gửi yêu cầu tư vấn</button>
                        </form>
                    </section>
                }
            </div>
            <aside class="public-journey-rail">
                <div class="public-journey-support">
                    @await Html.PartialAsync("_JourneySupportPanel", Model.Journey.Support)
                </div>
            </aside>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}


