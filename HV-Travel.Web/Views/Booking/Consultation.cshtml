@model ConsultationViewModel
@{
    var success = string.Equals(Model.Journey.Status.Variant, "ConsultationSubmitted", StringComparison.Ordinal);
}

<section class="public-journey-shell public-journey-shell--consultation public-booking-support-shell">
    <div class="public-journey-shell-inner">
        @await Html.PartialAsync("_JourneyHeader", Model.Journey)
        <div class="public-journey-desk public-journey-desk--consultation">
            <div class="public-journey-main">
                <section class="public-journey-panel public-booking-section public-journey-status-hero">
                    <div class="public-journey-badge-group">
                        <p class="public-journey-card-eyebrow">Nhờ tư vấn theo cách của bạn</p>
                        <span class="public-badge is-info">Phản hồi trong giờ làm việc</span>
                    </div>
                    <h2 class="public-journey-panel-title">Trao đổi với chuyên viên trước khi chốt</h2>
                    <p class="public-journey-note public-journey-section-lead">Gửi mô tả ngắn về lịch đi, ngân sách và số khách để đội ngũ đề xuất phương án phù hợp ngay trong cùng luồng đặt tour.</p>
                </section>
                <div class="public-journey-status-panel">
                    @if (success)
                    {
                        <section class="public-journey-panel public-booking-section public-journey-status-hero">
                            <div class="public-journey-badge-group">
                                <p class="public-journey-card-eyebrow">Gửi yêu cầu tư vấn thành công</p>
                                <span class="public-badge is-success">Đã tiếp nhận</span>
                            </div>
                            <h2 class="public-journey-panel-title">Đội ngũ tư vấn đã nhận yêu cầu của bạn</h2>
                            <p class="public-journey-note public-journey-section-lead">Chúng tôi sẽ liên hệ lại theo khung giờ bạn mong muốn hoặc trong giờ làm việc kế tiếp.</p>
                        </section>
                    }
                    @await Html.PartialAsync("_JourneyStatusPanel", Model.Journey.Status)
                </div>
                @if (!success)
                {
                    <section class="public-journey-panel public-booking-section">
                        <div class="public-journey-panel-heading">
                            <div class="public-journey-badge-group">
                                <p class="public-journey-card-eyebrow">Gửi yêu cầu tư vấn</p>
                            </div>
                            <h2 class="public-journey-panel-title">Điền mô tả ngắn để đội ngũ gọi lại</h2>
                        </div>
                        <div class="public-journey-callout public-journey-callout--info">
                            Nêu rõ điểm đến, số khách, ngân sách và thời gian mong muốn để đội tư vấn phản hồi sát nhu cầu hơn.
                        </div>
                        <form asp-action="Consultation" method="post" class="public-journey-form-grid">
                            @Html.AntiForgeryToken()
                            <div asp-validation-summary="ModelOnly" class="public-journey-validation"></div>
                            <label class="public-booking-field">
                                <span class="public-journey-field-label">Họ và tên</span>
                                <span class="public-journey-field-hint">Người chúng tôi sẽ liên hệ lại.</span>
                                <input asp-for="FullName" placeholder="Nguyễn Văn A" />
                            </label>
                            <label class="public-booking-field">
                                <span class="public-journey-field-label">Số điện thoại</span>
                                <span class="public-journey-field-hint">Ưu tiên số có thể nghe máy trong giờ làm việc.</span>
                                <input asp-for="Phone" placeholder="0901 234 567" />
                            </label>
                            <label class="public-booking-field">
                                <span class="public-journey-field-label">Email</span>
                                <span class="public-journey-field-hint">Không bắt buộc nhưng hữu ích để gửi phương án.</span>
                                <input asp-for="Email" placeholder="guest@example.com" />
                            </label>
                            <label class="public-booking-field">
                                <span class="public-journey-field-label">Tour hoặc điểm đến</span>
                                <span class="public-journey-field-hint">Ví dụ: Đà Nẵng 3N2Đ, Nhật mùa lá đỏ.</span>
                                <input asp-for="TourInterest" placeholder="Tour hoặc điểm đến bạn quan tâm" />
                            </label>
                            <label class="public-booking-field">
                                <span class="public-journey-field-label">Thời gian liên hệ mong muốn</span>
                                <span class="public-journey-field-hint">Ghi khung giờ thuận tiện cho bạn.</span>
                                <input asp-for="PreferredContactTime" placeholder="Khung giờ liên hệ mong muốn" />
                            </label>
                            <label class="public-booking-field public-booking-field--full">
                                <span class="public-journey-field-label">Nội dung yêu cầu</span>
                                <span class="public-journey-field-hint">Nêu thêm ngân sách, số khách, yêu cầu về lịch hoặc dịch vụ.</span>
                                <textarea asp-for="Message" rows="5" placeholder="Nội dung bạn cần tư vấn"></textarea>
                            </label>
                            <button type="submit" class="public-journey-submit">Gửi yêu cầu tư vấn</button>
                        </form>
                    </section>
                }
            </div>
            <aside class="public-journey-rail">
                <div class="public-journey-support">
                    @await Html.PartialAsync("_JourneySupportPanel", Model.Journey.Support)
                </div>
            </aside>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
