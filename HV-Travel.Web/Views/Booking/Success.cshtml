@inject IPublicContentService ContentService
@using HVTravel.Web.Services
@model HVTravel.Web.Models.BookingResultViewModel
@{
    var sections = await ContentService.GetPageSectionsAsync("booking");
    var statusCopy = sections.GetSection("statusCopy");
    var booking = Model.Booking;
    var tour = Model.Tour;
    var successTitle = BookingDisplayTextHelper.NormalizeCmsText(statusCopy?.Fields.GetFieldValue("successTitle", "Đặt tour thành công!"));
    var successDescription = BookingDisplayTextHelper.NormalizeCmsText(statusCopy?.Fields.GetFieldValue("successDescription", "Cảm ơn bạn đã đặt tour tại HV Travel. Chúng tôi sẽ tiếp tục cập nhật trạng thái booking qua tiến trình xử lý và cổng khách hàng."));
    var fulfillmentStatusText = BookingDisplayTextHelper.FulfillmentStatus(booking.FulfillmentStatus);
    var paymentPlanText = BookingDisplayTextHelper.PaymentPlan(booking.PaymentPlan?.PlanType);
}

<section class="relative overflow-hidden bg-[radial-gradient(circle_at_top_left,rgba(59,130,246,0.22),transparent_36%),linear-gradient(135deg,#020617_0%,#0f172a_45%,#1e3a8a_100%)] py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl" data-animate="fade-up">
            <span class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/10 px-4 py-2 text-xs font-bold uppercase tracking-[0.25em] text-white/90 backdrop-blur-md">
                <span class="material-symbols-outlined text-[16px] text-primary">verified</span>
                Bước 3 trong hành trình đặt tour
            </span>
            <h1 class="mt-6 text-4xl font-extrabold tracking-tight text-white">Hoàn tất đặt tour thành công</h1>
            <p class="mt-4 max-w-2xl text-base leading-relaxed text-slate-300">Booking đã được ghi nhận cùng thông tin thanh toán và liên kết quản lý trong cổng khách hàng.</p>
        </div>
    </div>
</section>

<section class="bg-background-light py-12 dark:bg-background-dark">
    <div class="mx-auto max-w-5xl space-y-6 px-4 sm:px-6 lg:px-8">
        <div class="text-center" data-animate="scale-in">
            <div class="mx-auto flex size-24 items-center justify-center rounded-full bg-emerald-100 dark:bg-emerald-900/30">
                <span class="material-symbols-outlined text-5xl text-emerald-500">check_circle</span>
            </div>
            <h2 class="mt-6 text-3xl font-extrabold text-slate-900 dark:text-white" style="@ContentPresentationViewHelper.GetFieldTextStyle(statusCopy, "successTitle")">@successTitle</h2>
            <div class="mx-auto mt-3 max-w-2xl text-slate-500 dark:text-slate-400" style="@ContentPresentationViewHelper.GetFieldTextStyle(statusCopy, "successDescription")">
                @Html.Raw(successDescription)
            </div>
        </div>

        <div class="grid gap-6 lg:grid-cols-[minmax(0,1fr)_320px]">
            <div class="rounded-[2rem] border border-border-light bg-surface-light p-6 shadow-sm dark:border-border-dark dark:bg-surface-dark">
                <div class="flex items-center justify-between gap-4">
                    <h3 class="text-xl font-black text-slate-900 dark:text-white">Thông tin đặt tour</h3>
                    <span class="inline-flex items-center gap-1 rounded-full bg-emerald-100 px-3 py-1 text-[11px] font-bold text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-300">
                        <span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span>
                        Đã ghi nhận
                    </span>
                </div>

                <div class="mt-5 grid gap-4 text-sm sm:grid-cols-2">
                    <div><span class="block text-xs text-slate-500">Mã đơn</span><span class="font-mono text-lg font-bold text-primary">@booking.BookingCode</span></div>
                    <div><span class="block text-xs text-slate-500">Tour</span><span class="font-bold text-slate-900 dark:text-white">@(booking.TourSnapshot?.Name ?? tour?.Name ?? "Tour đang cập nhật")</span></div>
                    <div><span class="block text-xs text-slate-500">Khởi hành</span><span class="font-bold text-slate-900 dark:text-white">@(booking.TourSnapshot?.StartDate?.ToString("dd/MM/yyyy") ?? "-")</span></div>
                    <div><span class="block text-xs text-slate-500">Khách hàng</span><span class="font-bold text-slate-900 dark:text-white">@booking.ContactInfo?.Name</span></div>
                    <div><span class="block text-xs text-slate-500">Email</span><span class="font-bold text-slate-900 dark:text-white">@booking.ContactInfo?.Email</span></div>
                    <div><span class="block text-xs text-slate-500">Số hành khách</span><span class="font-bold text-slate-900 dark:text-white">@booking.ParticipantsCount người</span></div>
                    <div><span class="block text-xs text-slate-500">Mã ưu đãi</span><span class="font-bold text-slate-900 dark:text-white">@(string.IsNullOrWhiteSpace(booking.CouponCode) ? "-" : booking.CouponCode)</span></div>
                    <div><span class="block text-xs text-slate-500">Xử lý dịch vụ</span><span class="font-bold text-slate-900 dark:text-white">@fulfillmentStatusText</span></div>
                </div>

                <div class="mt-6 rounded-2xl bg-surface-muted-light px-4 py-4 text-sm dark:bg-surface-elevated-dark">
                    <div class="flex items-center justify-between"><span>Tổng thanh toán</span><span class="font-bold">@booking.PricingBreakdown.GrandTotal.ToString("N0")₫</span></div>
                    <div class="mt-2 flex items-center justify-between" data-model-field="booking.PaymentPlan.AmountDueNow"><span>Thanh toán ngay</span><span class="font-bold">@booking.PaymentPlan.AmountDueNow.ToString("N0")₫</span></div>
                    <div class="mt-2 flex items-center justify-between" data-model-field="booking.PaymentPlan.BalanceDue"><span>Còn lại</span><span class="font-bold">@booking.PaymentPlan.BalanceDue.ToString("N0")₫</span></div>
                    <div class="mt-2 flex items-center justify-between"><span>Kế hoạch</span><span class="font-bold">@paymentPlanText</span></div>
                    <div class="mt-2 flex items-center justify-between"><span>Phiên checkout</span><span class="font-mono text-xs font-bold">@(string.IsNullOrWhiteSpace(booking.CheckoutSessionId) ? "-" : booking.CheckoutSessionId)</span></div>
                </div>
            </div>

            <aside class="space-y-6">
                <div class="rounded-[2rem] border border-border-light bg-surface-light p-6 shadow-sm dark:border-border-dark dark:bg-surface-dark">
                    <p class="text-xs font-bold uppercase tracking-[0.25em] text-primary">Bước tiếp theo</p>
                    <div class="mt-4 flex flex-col gap-3">
                        <a asp-controller="BookingLookup" asp-action="Index" class="rounded-2xl bg-primary px-5 py-3 text-center text-sm font-bold text-white">Tra cứu booking</a>
                        <a asp-controller="CustomerPortal" asp-action="Index" class="rounded-2xl border border-border-light px-5 py-3 text-center text-sm font-bold text-slate-700 dark:border-border-dark dark:text-slate-300">Mở cổng khách hàng</a>
                        @if (!string.IsNullOrWhiteSpace(booking.CheckoutSessionId))
                        {
                            <a asp-action="Resume" asp-route-checkoutSessionId="@booking.CheckoutSessionId" class="rounded-2xl border border-border-light px-5 py-3 text-center text-sm font-bold text-slate-700 dark:border-border-dark dark:text-slate-300">Khôi phục checkout</a>
                        }
                        <a asp-controller="Home" asp-action="Index" class="rounded-2xl border border-border-light px-5 py-3 text-center text-sm font-bold text-slate-700 dark:border-border-dark dark:text-slate-300">Về trang chủ</a>
                    </div>
                </div>
            </aside>
        </div>
    </div>
</section>
