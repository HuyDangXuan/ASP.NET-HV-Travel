@inject IPublicContentService ContentService
@using HVTravel.Domain.Entities
@using HVTravel.Web.Services
@model HVTravel.Web.Models.BookingResultViewModel
@{
    var sections = await ContentService.GetPageSectionsAsync("booking");
    var statusCopy = sections.GetSection("statusCopy");
    var booking = Model.Booking;
    var tour = Model.Tour;
    var timeline = booking.Events ?? new List<BookingEvent>();
    var breadcrumbItems = new List<HVTravel.Web.Models.BreadcrumbItemViewModel>
    {
        new() { Label = "Trang chủ", Url = Url.Action("Index", "Home") }
    };
    if (tour != null)
    {
        breadcrumbItems.Add(new HVTravel.Web.Models.BreadcrumbItemViewModel { Label = "Tour du lịch", Url = Url.Action("Index", "PublicTours") });
        breadcrumbItems.Add(new HVTravel.Web.Models.BreadcrumbItemViewModel { Label = tour.Name, Url = Url.Action("Details", "PublicTours", new { id = string.IsNullOrWhiteSpace(tour.Slug) ? tour.Id : tour.Slug }) });
    }
    breadcrumbItems.Add(new HVTravel.Web.Models.BreadcrumbItemViewModel { Label = "Đặt tour" });
    breadcrumbItems.Add(new HVTravel.Web.Models.BreadcrumbItemViewModel { Label = "Thanh toán" });
    breadcrumbItems.Add(new HVTravel.Web.Models.BreadcrumbItemViewModel { Label = "Hoàn tất", IsCurrent = true });
    var breadcrumb = new HVTravel.Web.Models.BreadcrumbViewModel { Items = breadcrumbItems };
}

@await Html.PartialAsync("_PublicBreadcrumb", breadcrumb)

<section class="public-top-section public-top-section--compact hero-gradient relative overflow-hidden">
    <div class="public-top-section-shell mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="public-top-section-content is-left" data-animate="fade-up">
            <span class="public-badge public-top-section-badge">
                <span class="material-symbols-outlined text-[16px] text-primary">verified</span>
                Bước 3 trong hành trình đặt tour
            </span>
            <h1 class="public-top-section-title text-white">Hoàn tất đặt tour thành công</h1>
            <p class="public-top-section-lead">Booking đã được ghi nhận cùng breakdown thanh toán, timeline và liên kết tiếp tục quản lý trong portal khách hàng.</p>
        </div>
    </div>
</section>

<div class="border-b border-border-light bg-surface-light py-6 dark:border-border-dark dark:bg-surface-dark">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="public-stepper flex items-center justify-center gap-0" data-animate="fade-in">
            <div class="flex items-center gap-2">
                <div class="flex size-9 items-center justify-center rounded-full bg-primary text-sm font-bold text-white"><span class="material-symbols-outlined text-[16px]">check</span></div>
                <span class="hidden text-sm font-medium text-primary sm:inline">Thông tin</span>
            </div>
            <div class="public-stepper-divider mx-2 h-0.5 w-12 bg-primary sm:w-20"></div>
            <div class="flex items-center gap-2">
                <div class="flex size-9 items-center justify-center rounded-full bg-primary text-sm font-bold text-white"><span class="material-symbols-outlined text-[16px]">check</span></div>
                <span class="hidden text-sm font-medium text-primary sm:inline">Thanh toán</span>
            </div>
            <div class="public-stepper-divider mx-2 h-0.5 w-12 bg-primary sm:w-20"></div>
            <div class="flex items-center gap-2">
                <div class="flex size-9 items-center justify-center rounded-full bg-primary text-sm font-bold text-white shadow-lg shadow-primary/30"><span class="material-symbols-outlined text-[16px]">check</span></div>
                <span class="hidden text-sm font-bold text-primary sm:inline">Hoàn tất</span>
            </div>
        </div>
    </div>
</div>

<section class="bg-background-light py-12 dark:bg-background-dark">
    <div class="mx-auto max-w-5xl space-y-6 px-4 sm:px-6 lg:px-8">
        <div class="text-center" data-animate="scale-in">
            <div class="mx-auto flex size-24 items-center justify-center rounded-full bg-emerald-100 dark:bg-emerald-900/30">
                <span class="material-symbols-outlined text-5xl text-emerald-500">check_circle</span>
            </div>
            <h1 class="public-section-title mt-6 text-3xl font-extrabold text-slate-900 dark:text-white" style="@ContentPresentationViewHelper.GetFieldTextStyle(statusCopy, "successTitle")">@statusCopy?.Fields.GetFieldValue("successTitle", "Đặt Tour Thành Công!")</h1>
            <div class="public-body-copy mx-auto mt-3 max-w-2xl text-slate-500 dark:text-slate-400" style="@ContentPresentationViewHelper.GetFieldTextStyle(statusCopy, "successDescription")">
                @Html.Raw(statusCopy?.Fields.GetFieldValue("successDescription", "Cảm ơn bạn đã đặt tour tại HV Travel. Chúng tôi sẽ tiếp tục cập nhật trạng thái booking qua timeline và portal khách hàng."))
            </div>
        </div>

        <div class="grid gap-6 lg:grid-cols-[minmax(0,1fr)_320px]">
            <div class="public-form-card rounded-[2rem] border border-border-light bg-surface-light p-6 shadow-sm dark:border-border-dark dark:bg-surface-dark">
                <div class="flex items-center justify-between gap-4">
                    <h3 class="text-xl font-black text-slate-900 dark:text-white">Thông Tin Đặt Tour</h3>
                    <span class="inline-flex items-center gap-1 rounded-full bg-emerald-100 px-3 py-1 text-[11px] font-bold text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-300">
                        <span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span>
                        Đã ghi nhận
                    </span>
                </div>

                <div class="mt-5 grid gap-4 text-sm sm:grid-cols-2">
                    <div><span class="block text-xs text-slate-500">Mã đơn</span><span class="font-mono text-lg font-bold text-primary">@booking.BookingCode</span></div>
                    <div><span class="block text-xs text-slate-500">Tour</span><span class="font-bold text-slate-900 dark:text-white">@(booking.TourSnapshot?.Name ?? tour?.Name)</span></div>
                    <div><span class="block text-xs text-slate-500">Khởi hành</span><span class="font-bold text-slate-900 dark:text-white">@(booking.TourSnapshot?.StartDate?.ToString("dd/MM/yyyy") ?? "-")</span></div>
                    <div><span class="block text-xs text-slate-500">Khách hàng</span><span class="font-bold text-slate-900 dark:text-white">@booking.ContactInfo?.Name</span></div>
                    <div><span class="block text-xs text-slate-500">Email</span><span class="font-bold text-slate-900 dark:text-white">@booking.ContactInfo?.Email</span></div>
                    <div><span class="block text-xs text-slate-500">Số hành khách</span><span class="font-bold text-slate-900 dark:text-white">@booking.ParticipantsCount người</span></div>
                    <div><span class="block text-xs text-slate-500">Coupon</span><span class="font-bold text-slate-900 dark:text-white">@(string.IsNullOrWhiteSpace(booking.CouponCode) ? "-" : booking.CouponCode)</span></div>
                    <div><span class="block text-xs text-slate-500">Fulfillment</span><span class="font-bold text-slate-900 dark:text-white">@booking.FulfillmentStatus</span></div>
                </div>

                <div class="mt-6 rounded-2xl bg-surface-muted-light px-4 py-4 text-sm dark:bg-surface-elevated-dark">
                    <div class="flex items-center justify-between"><span>Tổng thanh toán</span><span class="font-bold">@booking.PricingBreakdown.GrandTotal.ToString("N0")₫</span></div>
                    <div class="mt-2 flex items-center justify-between" data-model-field="booking.PaymentPlan.AmountDueNow"><span>Thanh toán ngay</span><span class="font-bold">@booking.PaymentPlan.AmountDueNow.ToString("N0")₫</span></div>
                    <div class="mt-2 flex items-center justify-between" data-model-field="booking.PaymentPlan.BalanceDue"><span>Còn lại</span><span class="font-bold">@booking.PaymentPlan.BalanceDue.ToString("N0")₫</span></div>
                    <div class="mt-2 flex items-center justify-between"><span>Kế hoạch</span><span class="font-bold">@booking.PaymentPlan.PlanType</span></div>
                    <div class="mt-2 flex items-center justify-between"><span>Checkout session</span><span class="font-mono text-xs font-bold">@(string.IsNullOrWhiteSpace(booking.CheckoutSessionId) ? "-" : booking.CheckoutSessionId)</span></div>
                </div>
            </div>

            <aside class="space-y-6">
                <div class="rounded-[2rem] border border-border-light bg-surface-light p-6 shadow-sm dark:border-border-dark dark:bg-surface-dark">
                    <p class="text-xs font-bold uppercase tracking-[0.25em] text-primary">Next actions</p>
                    <div class="mt-4 flex flex-col gap-3">
                        <a asp-controller="BookingLookup" asp-action="Index" class="rounded-2xl bg-primary px-5 py-3 text-center text-sm font-bold text-white">Tra cứu booking</a>
                        <a asp-controller="CustomerPortal" asp-action="Index" class="rounded-2xl border border-border-light px-5 py-3 text-center text-sm font-bold text-slate-700 dark:border-border-dark dark:text-slate-300">Mở CustomerPortal</a>
                        @if (!string.IsNullOrWhiteSpace(booking.CheckoutSessionId))
                        {
                            <a asp-action="Resume" asp-route-checkoutSessionId="@booking.CheckoutSessionId" class="rounded-2xl border border-border-light px-5 py-3 text-center text-sm font-bold text-slate-700 dark:border-border-dark dark:text-slate-300">Resume checkout</a>
                        }
                        <a asp-controller="Home" asp-action="Index" class="rounded-2xl border border-border-light px-5 py-3 text-center text-sm font-bold text-slate-700 dark:border-border-dark dark:text-slate-300">Về Trang Chủ</a>
                    </div>
                </div>

                @if (timeline.Any())
                {
                    <div class="rounded-[2rem] border border-border-light bg-surface-light p-6 shadow-sm dark:border-border-dark dark:bg-surface-dark">
                        <p class="text-xs font-bold uppercase tracking-[0.25em] text-primary">Timeline</p>
                        <div class="mt-4 space-y-3">
                            @foreach (var evt in timeline.OrderByDescending(item => item.OccurredAt).Take(5))
                            {
                                <div class="rounded-2xl bg-surface-muted-light px-4 py-3 text-sm dark:bg-surface-elevated-dark">
                                    <p class="font-bold text-slate-900 dark:text-white">@evt.Title</p>
                                    <p class="mt-1 text-xs text-slate-500 dark:text-slate-400">@evt.Description</p>
                                </div>
                            }
                        </div>
                    </div>
                }
            </aside>
        </div>
    </div>
</section>
