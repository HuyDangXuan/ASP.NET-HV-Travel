@inject IPublicContentService ContentService
@model HVTravel.Web.Models.BookingResultViewModel
@{
    var sections = await ContentService.GetPageSectionsAsync("booking");
    var statusCopy = sections.GetSection("statusCopy");
    var booking = Model.Booking;
    var tour = Model.Tour;
    var breadcrumbItems = new List<HVTravel.Web.Models.BreadcrumbItemViewModel>
    {
        new() { Label = "Trang chủ", Url = Url.Action("Index", "Home") }
    };
    if (tour != null)
    {
        breadcrumbItems.Add(new HVTravel.Web.Models.BreadcrumbItemViewModel { Label = "Tour du lịch", Url = Url.Action("Index", "PublicTours") });
        breadcrumbItems.Add(new HVTravel.Web.Models.BreadcrumbItemViewModel { Label = tour.Name, Url = Url.Action("Details", "PublicTours", new { id = tour.Id }) });
    }
    breadcrumbItems.Add(new HVTravel.Web.Models.BreadcrumbItemViewModel { Label = "Đặt tour" });
    breadcrumbItems.Add(new HVTravel.Web.Models.BreadcrumbItemViewModel { Label = "Thanh toán" });
    breadcrumbItems.Add(new HVTravel.Web.Models.BreadcrumbItemViewModel { Label = "Hoàn tất", IsCurrent = true });
    var breadcrumb = new HVTravel.Web.Models.BreadcrumbViewModel { Items = breadcrumbItems };
}

@await Html.PartialAsync("_PublicBreadcrumb", breadcrumb)

<section class="public-top-section public-top-section--compact hero-gradient relative overflow-hidden">
    <div class="public-top-section-shell max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="public-top-section-content is-left" data-animate="fade-up">
            <span class="public-badge public-top-section-badge">
                <span class="material-symbols-outlined text-[16px] text-primary">verified</span>
                Bước 3 trong hành trình đặt tour
            </span>
            <h1 class="public-top-section-title text-white">Hoàn tất đặt tour thành công</h1>
            <p class="public-top-section-lead">Thông tin booking đã được ghi nhận. Bạn có thể kiểm tra mã đơn, in xác nhận và quay lại trang chủ để tiếp tục khám phá thêm hành trình mới.</p>
        </div>
    </div>
</section>

<div class="bg-surface-light dark:bg-surface-dark border-b border-border-light dark:border-border-dark py-6">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="public-stepper flex items-center justify-center gap-0" data-animate="fade-in">
            <div class="flex items-center gap-2">
                <div class="size-9 rounded-full bg-primary text-white flex items-center justify-center text-sm font-bold"><span class="material-symbols-outlined text-[16px]">check</span></div>
                <span class="text-sm font-medium text-primary hidden sm:inline">Thông Tin</span>
            </div>
            <div class="public-stepper-divider w-12 sm:w-20 h-0.5 bg-primary mx-2"></div>
            <div class="flex items-center gap-2">
                <div class="size-9 rounded-full bg-primary text-white flex items-center justify-center text-sm font-bold"><span class="material-symbols-outlined text-[16px]">check</span></div>
                <span class="text-sm font-medium text-primary hidden sm:inline">Thanh Toán</span>
            </div>
            <div class="public-stepper-divider w-12 sm:w-20 h-0.5 bg-primary mx-2"></div>
            <div class="flex items-center gap-2">
                <div class="size-9 rounded-full bg-primary text-white flex items-center justify-center text-sm font-bold shadow-lg shadow-primary/30"><span class="material-symbols-outlined text-[16px]">check</span></div>
                <span class="text-sm font-bold text-primary hidden sm:inline">Hoàn Tất</span>
            </div>
        </div>
    </div>
</div>

<section class="py-16 bg-background-light dark:bg-background-dark">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <div class="mb-8" data-animate="scale-in">
            <div class="success-checkmark mx-auto size-24 rounded-full bg-emerald-100 dark:bg-emerald-900/30 flex items-center justify-center animate-bounce-once">
                <span class="material-symbols-outlined text-5xl text-emerald-500">check_circle</span>
            </div>
        </div>

        <h1 class="public-section-title text-3xl font-extrabold text-slate-900 dark:text-white mb-3">@statusCopy?.Fields.GetFieldValue("successTitle", "Đặt Tour Thành Công!")</h1>
        <div class="public-body-copy text-slate-500 dark:text-slate-400 mb-8 max-w-md mx-auto">
            @Html.Raw(statusCopy?.Fields.GetFieldValue("successDescription", "Cảm ơn bạn đã đặt tour tại HV Travel. Chúng tôi sẽ liên hệ xác nhận trong thời gian sớm nhất."))
        </div>

        <div class="public-form-card bg-surface-light dark:bg-surface-dark rounded-2xl p-6 border border-border-light dark:border-border-dark text-left mb-8" data-animate="fade-up" data-delay="200">
            <div class="flex items-center justify-between mb-5">
                <h3 class="text-base font-bold text-slate-900 dark:text-white">Thông Tin Đặt Tour</h3>
                <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full text-[11px] font-bold bg-emerald-100 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-400">
                    <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span> Đã xác nhận
                </span>
            </div>
            <div class="grid sm:grid-cols-2 gap-4 text-sm">
                <div class="space-y-3">
                    <div><span class="text-slate-500 block text-xs mb-0.5">Mã đơn</span><span class="font-bold font-mono text-primary text-lg">@booking.BookingCode</span></div>
                    <div><span class="text-slate-500 block text-xs mb-0.5">Tour</span><span class="font-bold text-slate-900 dark:text-white">@(booking.TourSnapshot?.Name ?? tour?.Name)</span></div>
                    <div><span class="text-slate-500 block text-xs mb-0.5">Khởi hành</span><span class="font-bold text-slate-900 dark:text-white">@(booking.TourSnapshot?.StartDate?.ToString("dd/MM/yyyy") ?? "-")</span></div>
                </div>
                <div class="space-y-3">
                    <div><span class="text-slate-500 block text-xs mb-0.5">Khách hàng</span><span class="font-bold text-slate-900 dark:text-white">@booking.ContactInfo?.Name</span></div>
                    <div><span class="text-slate-500 block text-xs mb-0.5">Email</span><span class="font-bold text-slate-900 dark:text-white">@booking.ContactInfo?.Email</span></div>
                    <div><span class="text-slate-500 block text-xs mb-0.5">Số hành khách</span><span class="font-bold text-slate-900 dark:text-white">@booking.ParticipantsCount người</span></div>
                </div>
            </div>
            <div class="border-t border-border-light dark:border-border-dark mt-5 pt-5 flex justify-between items-center">
                <span class="text-base font-bold text-slate-900 dark:text-white">Tổng thanh toán</span>
                <span class="text-2xl font-extrabold text-primary">@booking.TotalAmount.ToString("N0")₫</span>
            </div>
        </div>

        <div class="public-action-stack flex flex-col sm:flex-row justify-center gap-3" data-animate="fade-up" data-delay="400">
            <button onclick="window.print()" class="flex items-center justify-center gap-2 px-6 py-3 bg-surface-light dark:bg-surface-dark text-slate-700 dark:text-slate-300 rounded-xl text-sm font-bold border border-border-light dark:border-border-dark hover:bg-slate-50 transition-all">
                <span class="material-symbols-outlined text-[18px]">print</span> In Vé
            </button>
            <a asp-controller="Home" asp-action="Index" class="flex items-center justify-center gap-2 px-6 py-3 bg-primary hover:bg-primary-dark text-white rounded-xl text-sm font-bold shadow-lg shadow-primary/25 transition-all">
                <span class="material-symbols-outlined text-[18px]">home</span> Về Trang Chủ
            </a>
        </div>
    </div>
</section>

<style>
    .animate-bounce-once { animation: bounceIn 0.6s ease-out; }
    @@keyframes bounceIn { 0% { transform: scale(0); opacity: 0; } 50% { transform: scale(1.15); } 100% { transform: scale(1); opacity: 1; } }
</style>



