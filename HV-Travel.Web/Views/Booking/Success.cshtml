@model BookingResultViewModel
@{
    var booking = Model.Booking;
}

<section class="public-journey-shell public-journey-shell--status public-booking-status-shell public-booking-status-shell--success">
    <div class="public-journey-shell-inner">
        <span class="sr-only">Trang chủ</span>
        @await Html.PartialAsync("_JourneyHeader", Model.Journey)
        <div class="public-journey-stagebar">
            @await Html.PartialAsync("_JourneyStageBar", Model.Journey)
        </div>

        <div class="public-journey-desk public-journey-desk--status">
            <div class="public-journey-main">
                <section class="public-journey-panel public-booking-section public-booking-status-intro public-journey-status-hero">
                    <div class="public-journey-badge-group">
                        <p class="public-journey-card-eyebrow">Booking đã được ghi nhận</p>
                        <span class="public-badge is-success">@booking.BookingCode</span>
                    </div>
                    <h2 class="public-journey-panel-title">Thông tin giữ chỗ đã sẵn sàng cho bước tiếp theo</h2>
                    <p class="public-journey-note public-journey-section-lead">Theo dõi trạng thái thanh toán, tiến trình xử lý và những việc tiếp theo ngay trong cùng một màn hình.</p>
                </section>
                <div class="public-journey-status-panel">
                    @await Html.PartialAsync("_JourneyStatusPanel", Model.Journey.Status)
                </div>
            </div>
            <aside class="public-journey-rail">
                <div class="public-journey-summary">
                    @await Html.PartialAsync("_JourneySummaryRail", Model.Journey.Summary)
                </div>
                <div class="public-journey-timeline">
                    @await Html.PartialAsync("_JourneyTimeline", Model.Journey.Timeline)
                </div>
                <div class="public-journey-support">
                    @await Html.PartialAsync("_JourneySupportPanel", Model.Journey.Support)
                </div>
            </aside>
        </div>
    </div>
</section>
