@model HVTravel.Web.Models.BookingLookupViewModel
@{
    var breadcrumb = new HVTravel.Web.Models.BreadcrumbViewModel
    {
        Items = new List<HVTravel.Web.Models.BreadcrumbItemViewModel>
        {
            new() { Label = "Trang ch?", Url = Url.Action("Index", "Home") },
            new() { Label = "Tra c?u booking", IsCurrent = true }
        }
    };
}

@await Html.PartialAsync("_PublicBreadcrumb", breadcrumb)

<section class="hero-gradient relative overflow-hidden">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-20 relative z-10 text-center">
        <span class="public-badge inline-flex items-center gap-2 bg-white/10 backdrop-blur-md text-white/90 text-xs font-semibold px-4 py-2 rounded-full mb-6 border border-white/10">
            <span class="material-symbols-outlined text-[16px]">confirmation_number</span>
            T? tra c?u don d?t tour
        </span>
        <h1 class="public-hero-title text-4xl sm:text-5xl font-extrabold text-white leading-tight mb-4">Tra c?u booking trong vŕi giây</h1>
        <p class="public-body-copy text-lg text-slate-300 max-w-2xl mx-auto">Nh?p mă booking cůng email ho?c s? di?n tho?i d? xem těnh tr?ng don, thanh toán vŕ l?ch kh?i hŕnh.</p>
    </div>
</section>

<section class="py-12 bg-background-light dark:bg-background-dark">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 grid gap-8 lg:grid-cols-[minmax(0,0.95fr)_minmax(0,1.05fr)]">
        <div class="bg-surface-light dark:bg-surface-dark rounded-3xl p-6 sm:p-8 border border-border-light dark:border-border-dark shadow-sm">
            <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-6">Thông tin tra c?u</h2>
            <form asp-action="Lookup" method="post" class="space-y-4">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="rounded-2xl bg-red-50 text-red-600 px-4 py-3 text-sm dark:bg-red-900/20 dark:text-red-300"></div>
                <div>
                    <label class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-2">Mă booking</label>
                    <input name="bookingCode" value="@Model.QueryBookingCode" class="w-full rounded-2xl border border-border-light dark:border-border-dark bg-surface-muted-light dark:bg-surface-elevated-dark px-4 py-3 text-sm outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary" placeholder="Ví d?: HV20260328001" />
                </div>
                <div>
                    <label class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-2">Email</label>
                    <input name="email" value="@Model.QueryEmail" class="w-full rounded-2xl border border-border-light dark:border-border-dark bg-surface-muted-light dark:bg-surface-elevated-dark px-4 py-3 text-sm outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary" placeholder="email@example.com" />
                </div>
                <div>
                    <label class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-2">Ho?c s? di?n tho?i</label>
                    <input name="phone" value="@Model.QueryPhone" class="w-full rounded-2xl border border-border-light dark:border-border-dark bg-surface-muted-light dark:bg-surface-elevated-dark px-4 py-3 text-sm outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary" placeholder="0901 234 567" />
                </div>
                <button type="submit" class="w-full inline-flex items-center justify-center gap-2 bg-primary hover:bg-primary-dark text-white px-6 py-3.5 rounded-2xl text-sm font-bold shadow-lg shadow-primary/25 transition-all active:scale-[0.98]">
                    <span class="material-symbols-outlined text-[18px]">search</span>
                    Tra c?u booking
                </button>
            </form>
        </div>

        <div class="bg-surface-light dark:bg-surface-dark rounded-3xl p-6 sm:p-8 border border-border-light dark:border-border-dark shadow-sm">
            @if (Model.HasResult)
            {
                <div class="flex items-start justify-between gap-4 mb-6">
                    <div>
                        <p class="text-xs font-bold uppercase tracking-[0.24em] text-primary mb-2">K?t qu? booking</p>
                        <h2 class="text-2xl font-bold text-slate-900 dark:text-white">@Model.BookingCode</h2>
                        <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">@Model.TourName</p>
                    </div>
                    <div class="rounded-2xl bg-primary/10 text-primary px-4 py-2 text-sm font-bold">@Model.PaymentStatus</div>
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm mb-6">
                    <div class="rounded-2xl bg-surface-muted-light dark:bg-surface-elevated-dark px-4 py-4">
                        <p class="text-slate-400 text-xs uppercase tracking-wider mb-1">Tr?ng thái don</p>
                        <p class="font-bold text-slate-900 dark:text-white">@Model.BookingStatus</p>
                    </div>
                    <div class="rounded-2xl bg-surface-muted-light dark:bg-surface-elevated-dark px-4 py-4">
                        <p class="text-slate-400 text-xs uppercase tracking-wider mb-1">Ngŕy kh?i hŕnh</p>
                        <p class="font-bold text-slate-900 dark:text-white">@(Model.StartDate?.ToString("dd/MM/yyyy") ?? "Chua xác d?nh")</p>
                    </div>
                    <div class="rounded-2xl bg-surface-muted-light dark:bg-surface-elevated-dark px-4 py-4">
                        <p class="text-slate-400 text-xs uppercase tracking-wider mb-1">S? hŕnh khách</p>
                        <p class="font-bold text-slate-900 dark:text-white">@Model.ParticipantsCount</p>
                    </div>
                    <div class="rounded-2xl bg-surface-muted-light dark:bg-surface-elevated-dark px-4 py-4">
                        <p class="text-slate-400 text-xs uppercase tracking-wider mb-1">T?ng ti?n</p>
                        <p class="font-bold text-slate-900 dark:text-white">@Model.TotalAmount.ToString("N0")?</p>
                    </div>
                </div>

                <div class="rounded-3xl border border-border-light dark:border-border-dark px-5 py-5">
                    <h3 class="text-base font-bold text-slate-900 dark:text-white mb-4">Timeline x? lý</h3>
                    @if (Model.History.Count > 0)
                    {
                        <div class="space-y-3">
                            @foreach (var item in Model.History)
                            {
                                <div class="flex items-start gap-3 text-sm text-slate-600 dark:text-slate-400">
                                    <span class="material-symbols-outlined text-primary text-[18px] mt-0.5">schedule</span>
                                    <span>@item</span>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-sm text-slate-500 dark:text-slate-400">Booking chua có m?c x? lý chi ti?t.</p>
                    }
                </div>
            }
            else
            {
                <div class="h-full min-h-[320px] flex flex-col items-center justify-center text-center">
                    <span class="material-symbols-outlined text-6xl text-primary/40 mb-4">travel_explore</span>
                    <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-3">S?n sŕng tra c?u</h2>
                    <p class="text-sm text-slate-500 dark:text-slate-400 max-w-sm">Sau khi nh?p dúng mă booking vŕ thông tin lięn h?, b?n s? th?y tr?ng thái don vŕ m?c x? lý m?i nh?t ngay t?i dây.</p>
                </div>
            }
        </div>
    </div>
</section>
