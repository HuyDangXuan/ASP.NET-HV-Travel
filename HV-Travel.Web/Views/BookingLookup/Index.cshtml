@model BookingLookupViewModel

<section class="public-journey-shell public-journey-shell--lookup public-booking-lookup-shell">
    <div class="public-journey-shell-inner">
        <span class="sr-only">Trang chủ</span>
        @await Html.PartialAsync("_JourneyHeader", Model.Journey)
        <div class="public-journey-desk public-journey-desk--lookup">
            <section class="public-journey-panel public-booking-section public-booking-lookup-intro">
                <div class="public-journey-panel-heading">
                    <p class="public-journey-card-eyebrow">Tra cứu booking</p>
                    <h2 class="public-journey-panel-title">Nhập mã booking và thông tin liên hệ</h2>
                </div>
                <form asp-action="Lookup" method="post" class="public-journey-form-grid">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="public-journey-validation"></div>
                    <label class="public-booking-field"><span class="sr-only">Mã booking</span><input name="bookingCode" value="@Model.QueryBookingCode" placeholder="Mã booking" /></label>
                    <label class="public-booking-field"><span class="sr-only">Email</span><input name="email" value="@Model.QueryEmail" placeholder="Email đã dùng khi đặt" /></label>
                    <label class="public-booking-field"><span class="sr-only">Số điện thoại</span><input name="phone" value="@Model.QueryPhone" placeholder="Hoặc số điện thoại liên hệ" /></label>
                    <button type="submit" class="public-journey-submit">Tra cứu booking</button>
                </form>
            </section>

            <aside class="public-journey-rail">
                @if (Model.HasResult)
                {
                    <div class="public-journey-status-panel">
                        @await Html.PartialAsync("_JourneyStatusPanel", Model.Journey.Status)
                    </div>
                    <div class="public-journey-summary">
                        @await Html.PartialAsync("_JourneySummaryRail", Model.Journey.Summary)
                    </div>
                    <div class="public-journey-timeline">
                        @await Html.PartialAsync("_JourneyTimeline", Model.Journey.Timeline)
                    </div>
                }
                else
                {
                    <section class="public-journey-panel public-journey-status-panel public-booking-section public-booking-lookup-intro-card">
                        <p class="public-journey-card-eyebrow">Sẵn sàng tra cứu</p>
                        <h2 class="public-journey-panel-title">Quản lý booking từ một màn hình</h2>
                        <p class="public-journey-note">Sau khi nhập đúng mã booking và thông tin liên hệ, bạn sẽ thấy trạng thái, tiến trình và các hành động tiếp theo ngay tại đây.</p>
                    </section>
                }
                <div class="public-journey-support">
                    @await Html.PartialAsync("_JourneySupportPanel", Model.Journey.Support)
                </div>
            </aside>
        </div>
    </div>
</section>
