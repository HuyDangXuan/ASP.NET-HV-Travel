@inject IPublicContentService ContentService
@using HVTravel.Web.Services
@model HVTravel.Domain.Entities.TravelArticle
@{
    var sections = await ContentService.GetPageSectionsAsync("inspirationDetails");
    var hero = sections.GetSection("hero");
    var body = sections.GetSection("body");
    var tags = sections.GetSection("tags");
}

@if (hero?.IsEnabled != false)
{
    <section class="public-top-section public-top-section--compact hero-gradient @ContentPresentationViewHelper.GetSectionBackgroundClass(hero)" style="@ContentPresentationViewHelper.GetSectionStyle(hero)">
        <div class="public-top-section-shell mx-auto max-w-4xl px-4 py-16 sm:px-6 lg:px-8 @ContentPresentationViewHelper.GetSectionTextClass(hero)">
            <p class="public-top-section-badge text-xs uppercase tracking-[0.3em] text-cyan-200" style="@ContentPresentationViewHelper.GetFieldTextStyle(hero, "eyebrowText")">@Model.Category</p>
            <h1 class="public-top-section-title mt-4 text-white">@Model.Title</h1>
            <p class="public-top-section-lead mt-5 text-slate-200">@Model.Summary</p>
            <p class="mt-4 text-sm text-slate-300" style="@ContentPresentationViewHelper.GetFieldTextStyle(hero, "description")">@hero.Fields.GetVisibleFieldValue("description", "Bài viết giữ nội dung động từ hệ thống, còn hero copy và helper text có thể chỉnh trong CMS.")</p>
        </div>
    </section>
}

<section class="bg-background-light py-12 dark:bg-background-dark">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 space-y-6">
        @if (!string.IsNullOrWhiteSpace(Model.HeroImageUrl))
        {
            <img src="@Model.HeroImageUrl" alt="@Model.Title" class="h-[420px] w-full rounded-[2rem] object-cover" />
        }

        <article class="rounded-[2rem] border border-border-light bg-surface-light p-8 shadow-sm dark:border-border-dark dark:bg-surface-dark @ContentPresentationViewHelper.GetSectionTextClass(body)" style="@ContentPresentationViewHelper.GetSectionStyle(body)">
            <h2 class="text-2xl font-black" style="@ContentPresentationViewHelper.GetFieldTextStyle(body, "title")">@body?.Fields.GetVisibleFieldValue("title", "Nội dung bài viết")</h2>
            <p class="mt-3 text-sm text-slate-500 dark:text-slate-400" style="@ContentPresentationViewHelper.GetFieldTextStyle(body, "description")">@body?.Fields.GetVisibleFieldValue("description", "Đội ngũ có thể thay đổi phần mở đầu của khu vực body mà không can thiệp nội dung bài viết gốc.")</p>
            @if (!string.IsNullOrWhiteSpace(Model.Body))
            {
                <div class="prose prose-slate mt-6 max-w-none dark:prose-invert">@Html.Raw(Model.Body)</div>
            }
            else
            {
                <p class="mt-6 text-sm text-slate-500 dark:text-slate-400">@body?.Fields.GetVisibleFieldValue("emptyStateText", "Bài viết này đang được cập nhật nội dung.")</p>
            }
        </article>

        <section class="rounded-[2rem] border border-border-light bg-surface-light p-6 shadow-sm dark:border-border-dark dark:bg-surface-dark @ContentPresentationViewHelper.GetSectionTextClass(tags)" style="@ContentPresentationViewHelper.GetSectionStyle(tags)">
            <h2 class="text-xl font-black" style="@ContentPresentationViewHelper.GetFieldTextStyle(tags, "title")">@tags?.Fields.GetVisibleFieldValue("title", "Chủ đề liên quan")</h2>
            @if (Model.Tags.Any())
            {
                <div class="mt-4 flex flex-wrap gap-3">
                    @foreach (var tag in Model.Tags)
                    {
                        <span class="rounded-full border border-border-light px-4 py-2 text-xs font-bold uppercase tracking-[0.25em] dark:border-border-dark">@tag</span>
                    }
                </div>
            }
            else
            {
                <p class="mt-4 text-sm text-slate-500 dark:text-slate-400">@tags?.Fields.GetVisibleFieldValue("emptyStateText", "Bài viết chưa có tag hiển thị.")</p>
            }
        </section>
    </div>
</section>
