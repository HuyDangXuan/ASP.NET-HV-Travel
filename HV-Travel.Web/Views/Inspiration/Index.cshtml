@inject IPublicContentService ContentService
@model HVTravel.Web.Models.ContentHubIndexViewModel
@{
    var sections = await ContentService.GetPageSectionsAsync("inspiration");
    var hero = sections.GetSection("hero");
    var featuredIntro = sections.GetSection("featuredIntro");
    var latestIntro = sections.GetSection("latestIntro");

    ViewData["Description"] = hero?.Fields.GetFieldValue("description", "Khu vực nội dung giúp đội marketing làm hub cho bài viết nổi bật, nhóm chủ đề và bài mới nhất.")
        ?? "Khu vực nội dung giúp đội marketing làm hub cho bài viết nổi bật, nhóm chủ đề và bài mới nhất.";
}

@if (hero?.IsEnabled != false)
{
    <section class="public-top-section public-top-section--hero public-page-hero hero-gradient relative overflow-hidden">
        <div class="absolute inset-0 opacity-20">
            <div class="absolute left-10 top-10 h-72 w-72 rounded-full bg-amber-300/20 blur-3xl"></div>
            <div class="absolute right-0 bottom-0 h-96 w-96 rounded-full bg-cyan-400/20 blur-3xl"></div>
        </div>
        <div class="public-top-section-shell public-page-hero-shell max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="public-top-section-content public-page-hero-content is-centered max-w-4xl" data-animate="fade-up">
                <span class="public-badge public-top-section-badge public-page-hero-badge">
                    <span class="material-symbols-outlined text-[16px] text-primary">article</span>
                    @hero.Fields.GetFieldValue("eyebrowText", "Cẩm nang hành trình")
                </span>
                <h1 class="public-top-section-title public-hero-title text-white">@hero.Fields.GetFieldValue("title", "Cẩm nang, visa tips, mùa lễ hội và những landing SEO có thể tự quản trị.")</h1>
                <div class="public-top-section-lead public-body-copy public-page-hero-copy">
                    @Html.Raw(hero.Fields.GetFieldValue("description", "Khu vực nội dung giúp đội marketing làm hub cho bài viết nổi bật, nhóm chủ đề và bài mới nhất."))
                </div>
            </div>
        </div>
    </section>
}

<section class="py-12 bg-background-light dark:bg-background-dark">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 space-y-10">
        @if (featuredIntro?.IsEnabled != false && Model.FeaturedArticle != null)
        {
            <div class="space-y-6">
                <div>
                    <p class="text-xs uppercase tracking-[0.3em] text-primary">@featuredIntro.Fields.GetFieldValue("eyebrowText", "Featured")</p>
                    <h2 class="public-section-title mt-2">@featuredIntro.Fields.GetFieldValue("title", "Bài viết nổi bật")</h2>
                    <div class="mt-3 max-w-3xl text-sm leading-7 text-slate-500 dark:text-slate-400">
                        @Html.Raw(featuredIntro.Fields.GetFieldValue("description", "Khối bài nổi bật giúp kéo traffic vào nội dung chủ lực và landing SEO quan trọng."))
                    </div>
                </div>
                <article class="overflow-hidden rounded-[2rem] border border-border-light bg-surface-light shadow-sm dark:border-border-dark dark:bg-surface-dark lg:grid lg:grid-cols-[1.1fr_0.9fr]">
                    <div class="p-8 lg:p-10">
                        <p class="text-xs uppercase tracking-[0.3em] text-primary">Featured</p>
                        <h2 class="mt-3 text-3xl font-black text-slate-900 dark:text-white">@Model.FeaturedArticle.Title</h2>
                        <p class="mt-4 text-sm leading-8 text-slate-500 dark:text-slate-400">@Model.FeaturedArticle.Summary</p>
                        <a asp-action="Details" asp-route-slug="@Model.FeaturedArticle.Slug" class="mt-6 inline-flex items-center gap-2 rounded-2xl bg-primary px-5 py-3 text-sm font-bold text-white">Đọc bài viết</a>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(Model.FeaturedArticle.HeroImageUrl))
                    {
                        <img src="@Model.FeaturedArticle.HeroImageUrl" alt="@Model.FeaturedArticle.Title" class="h-full w-full object-cover" />
                    }
                </article>
            </div>
        }

        @if (latestIntro?.IsEnabled != false)
        {
            <div class="space-y-6">
                <div>
                    <p class="text-xs uppercase tracking-[0.3em] text-primary">@latestIntro.Fields.GetFieldValue("eyebrowText", "Latest stories")</p>
                    <h2 class="public-section-title mt-2">@latestIntro.Fields.GetFieldValue("title", "Bài viết mới nhất")</h2>
                    <div class="mt-3 max-w-3xl text-sm leading-7 text-slate-500 dark:text-slate-400">
                        @Html.Raw(latestIntro.Fields.GetFieldValue("description", "Danh sách bài mới hỗ trợ giữ nhịp xuất bản đều và mở rộng chiều sâu cho content hub."))
                    </div>
                </div>

                @if (Model.Categories.Any())
                {
                    <div class="flex flex-wrap gap-3">
                        @foreach (var category in Model.Categories)
                        {
                            <span class="rounded-full border border-border-light px-4 py-2 text-xs font-bold uppercase tracking-[0.25em] text-slate-500 dark:border-border-dark dark:text-slate-400">@category</span>
                        }
                    </div>
                }

                <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3" data-animate="fade-in" data-stagger>
                    @foreach (var article in Model.LatestArticles)
                    {
                        <article class="overflow-hidden rounded-[2rem] border border-border-light bg-surface-light shadow-sm dark:border-border-dark dark:bg-surface-dark">
                            @if (!string.IsNullOrWhiteSpace(article.HeroImageUrl))
                            {
                                <img src="@article.HeroImageUrl" alt="@article.Title" class="h-56 w-full object-cover" />
                            }
                            <div class="p-6">
                                <p class="text-xs uppercase tracking-[0.3em] text-slate-400">@article.Category</p>
                                <h3 class="mt-3 text-xl font-black text-slate-900 dark:text-white">@article.Title</h3>
                                <p class="mt-3 text-sm leading-7 text-slate-500 dark:text-slate-400">@article.Summary</p>
                                <a asp-action="Details" asp-route-slug="@article.Slug" class="mt-4 inline-flex items-center gap-2 text-sm font-bold text-primary">Xem chi tiết <span class="material-symbols-outlined text-[18px]">arrow_forward</span></a>
                            </div>
                        </article>
                    }
                </div>
            </div>
        }
    </div>
</section>



