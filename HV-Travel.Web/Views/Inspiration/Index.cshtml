@inject IPublicContentService ContentService
@using HVTravel.Web.Services
@model HVTravel.Web.Models.ContentHubIndexViewModel
@{
    var sections = await ContentService.GetPageSectionsAsync("inspiration");
    var hero = sections.GetSection("hero");
    var featuredIntro = sections.GetSection("featuredIntro");
    var latestIntro = sections.GetSection("latestIntro");

    ViewData["Description"] = hero?.Fields.GetFieldValue("description", "Khu vực nội dung giúp đội marketing làm hub cho bài viết nổi bật, nhóm chủ đề và bài mới nhất.")
        ?? "Khu vực nội dung giúp đội marketing làm hub cho bài viết nổi bật, nhóm chủ đề và bài mới nhất.";
}

@if (hero?.IsEnabled != false)
{
    <section class="@($"relative overflow-hidden bg-[radial-gradient(circle_at_top_left,rgba(59,130,246,0.24),transparent_36%),linear-gradient(135deg,#020617_0%,#0f172a_45%,#1e3a8a_100%)] {ContentPresentationViewHelper.GetSectionBackgroundClass(hero)}")" style="@ContentPresentationViewHelper.GetSectionStyle(hero)">
        <div class="absolute inset-0 opacity-20">
            <div class="absolute left-10 top-20 h-72 w-72 rounded-full bg-primary/30 blur-3xl animate-pulse"></div>
            <div class="absolute bottom-10 right-20 h-96 w-96 rounded-full bg-blue-500/20 blur-3xl animate-pulse" style="animation-delay: 1s;"></div>
        </div>
        <div class="relative z-10 mx-auto max-w-7xl px-4 py-24 sm:px-6 sm:py-32 lg:px-8 lg:py-40">
            <div class="mx-auto flex max-w-4xl flex-col items-center text-center @ContentPresentationViewHelper.GetSectionTextClass(hero)" data-animate="fade-up">
                <span class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/10 px-4 py-2 text-xs font-bold uppercase tracking-[0.25em] text-white/90 backdrop-blur-md" style="@ContentPresentationViewHelper.GetFieldTextStyle(hero, "eyebrowText")">
                    <span class="material-symbols-outlined text-[16px] text-primary">article</span>
                    @hero.Fields.GetFieldValue("eyebrowText", "Cẩm nang hành trình")
                </span>
                <h1 class="mt-6 text-4xl font-extrabold leading-tight tracking-tight text-white sm:text-5xl lg:text-6xl" style="@ContentPresentationViewHelper.GetFieldTextStyle(hero, "title")">@hero.Fields.GetFieldValue("title", "Cẩm nang, visa tips, mùa lễ hội và những landing SEO có thể tự quản trị.")</h1>
                <div class="mt-6 max-w-2xl text-lg leading-relaxed text-slate-300 sm:text-xl" style="@ContentPresentationViewHelper.GetFieldTextStyle(hero, "description")">
                    @Html.Raw(hero.Fields.GetFieldValue("description", "Khu vực nội dung giúp đội marketing làm hub cho bài viết nổi bật, nhóm chủ đề và bài mới nhất."))
                </div>
            </div>
        </div>
    </section>
}

<section class="bg-background-light py-12 dark:bg-background-dark">
    <div class="mx-auto max-w-7xl space-y-10 px-4 sm:px-6 lg:px-8">
        @if (featuredIntro?.IsEnabled != false && Model.FeaturedArticle != null)
        {
            <div class="space-y-6 @ContentPresentationViewHelper.GetSectionTextClass(featuredIntro) @ContentPresentationViewHelper.GetSectionBackgroundClass(featuredIntro)" style="@ContentPresentationViewHelper.GetSectionStyle(featuredIntro)">
                <div>
                    <p class="text-xs uppercase tracking-[0.3em] text-primary" style="@ContentPresentationViewHelper.GetFieldTextStyle(featuredIntro, "eyebrowText")">@featuredIntro.Fields.GetFieldValue("eyebrowText", "Featured")</p>
                    <h2 class="mt-2 text-3xl font-extrabold tracking-tight text-slate-900 dark:text-white" style="@ContentPresentationViewHelper.GetFieldTextStyle(featuredIntro, "title")">@featuredIntro.Fields.GetFieldValue("title", "Bài viết nổi bật")</h2>
                    <div class="mt-3 max-w-3xl text-sm leading-7 text-slate-500 dark:text-slate-400" style="@ContentPresentationViewHelper.GetFieldTextStyle(featuredIntro, "description")">
                        @Html.Raw(featuredIntro.Fields.GetFieldValue("description", "Khối bài nổi bật giúp kéo traffic vào nội dung chủ lực và landing SEO quan trọng."))
                    </div>
                </div>
                <article class="overflow-hidden rounded-[2rem] border border-border-light bg-surface-light shadow-sm dark:border-border-dark dark:bg-surface-dark lg:grid lg:grid-cols-[1.1fr_0.9fr]">
                    <div class="p-8 lg:p-10">
                        <p class="text-xs uppercase tracking-[0.3em] text-primary">Featured</p>
                        <h2 class="mt-3 text-3xl font-black text-slate-900 dark:text-white">@Model.FeaturedArticle.Title</h2>
                        <p class="mt-4 text-sm leading-8 text-slate-500 dark:text-slate-400">@Model.FeaturedArticle.Summary</p>
                        <a asp-action="Details" asp-route-slug="@Model.FeaturedArticle.Slug" class="mt-6 inline-flex items-center gap-2 rounded-2xl bg-primary px-5 py-3 text-sm font-bold text-white">Đọc bài viết</a>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(Model.FeaturedArticle.HeroImageUrl))
                    {
                        <img src="@Model.FeaturedArticle.HeroImageUrl" alt="@Model.FeaturedArticle.Title" class="h-full w-full object-cover" />
                    }
                </article>
            </div>
        }

        @if (latestIntro?.IsEnabled != false)
        {
            <div class="space-y-6 @ContentPresentationViewHelper.GetSectionTextClass(latestIntro) @ContentPresentationViewHelper.GetSectionBackgroundClass(latestIntro)" style="@ContentPresentationViewHelper.GetSectionStyle(latestIntro)">
                <div>
                    <p class="text-xs uppercase tracking-[0.3em] text-primary" style="@ContentPresentationViewHelper.GetFieldTextStyle(latestIntro, "eyebrowText")">@latestIntro.Fields.GetFieldValue("eyebrowText", "Latest stories")</p>
                    <h2 class="mt-2 text-3xl font-extrabold tracking-tight text-slate-900 dark:text-white" style="@ContentPresentationViewHelper.GetFieldTextStyle(latestIntro, "title")">@latestIntro.Fields.GetFieldValue("title", "Bài viết mới nhất")</h2>
                    <div class="mt-3 max-w-3xl text-sm leading-7 text-slate-500 dark:text-slate-400" style="@ContentPresentationViewHelper.GetFieldTextStyle(latestIntro, "description")">
                        @Html.Raw(latestIntro.Fields.GetFieldValue("description", "Danh sách bài mới hỗ trợ giữ nhịp xuất bản đều và mở rộng chiều sâu cho content hub."))
                    </div>
                </div>

                @if (Model.CategoryCarousels.Any())
                {
                    <div class="flex flex-wrap gap-3">
                        @foreach (var categoryCarousel in Model.CategoryCarousels)
                        {
                            <a href="#@categoryCarousel.AnchorId" class="inline-flex items-center gap-2 rounded-full border border-border-light bg-surface-light px-4 py-2 text-xs font-bold uppercase tracking-[0.22em] text-slate-500 transition duration-200 hover:-translate-y-0.5 hover:border-primary/35 hover:text-primary dark:border-border-dark dark:bg-surface-dark dark:text-slate-400 dark:hover:border-primary/40 dark:hover:text-primary">
                                <span>@categoryCarousel.CategoryName</span>
                                <span class="inline-flex min-w-[2rem] items-center justify-center rounded-full bg-sky-50 px-2 py-1 text-[10px] tracking-[0.18em] text-primary dark:bg-sky-500/10">@categoryCarousel.ArticleCount</span>
                            </a>
                        }
                    </div>

                    <div class="space-y-8" data-animate="fade-in">
                        @foreach (var categoryCarousel in Model.CategoryCarousels)
                        {
                            <section id="@categoryCarousel.AnchorId" class="overflow-hidden rounded-[2.2rem] border border-slate-200/80 bg-white p-6 shadow-[0_24px_70px_-55px_rgba(15,23,42,0.55)] dark:border-slate-800/80 dark:bg-slate-950/80 dark:shadow-black/25 sm:p-7">
                                <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
                                    <div class="min-w-0">
                                        <div class="flex flex-wrap items-center gap-2 text-[11px] font-bold uppercase tracking-[0.26em] text-slate-400 dark:text-slate-500">
                                            <span>Chủ đề</span>
                                            <span class="inline-flex items-center rounded-full bg-sky-50 px-3 py-1 text-[10px] tracking-[0.22em] text-primary dark:bg-sky-500/10">@categoryCarousel.ArticleCount bài</span>
                                        </div>
                                        <h3 class="mt-3 text-2xl font-black tracking-tight text-slate-900 dark:text-white sm:text-[2rem]">@categoryCarousel.CategoryName</h3>
                                    </div>
                                    <div class="flex flex-wrap items-center gap-2 text-sm text-slate-500 dark:text-slate-400">
                                        <span class="inline-flex items-center gap-2 rounded-full border border-slate-200 bg-slate-50 px-4 py-2 font-semibold dark:border-slate-800 dark:bg-slate-900/70">
                                            <span class="material-symbols-outlined text-[18px] text-primary">swipe</span>
                                            <span>Kéo hoặc vuốt để xem thêm</span>
                                        </span>
                                        <div class="hidden items-center gap-2" data-tour-card-carousel-controls>
                                            <button type="button"
                                                    class="inline-flex size-11 items-center justify-center rounded-full border border-slate-200 bg-white text-slate-700 shadow-sm transition duration-200 hover:-translate-y-0.5 hover:border-primary/35 hover:text-primary disabled:pointer-events-none disabled:translate-y-0 disabled:opacity-35 dark:border-slate-800 dark:bg-slate-900/70 dark:text-slate-100 dark:hover:border-primary/40"
                                                    data-tour-card-carousel-prev
                                                    aria-label="Nhóm bài viết trước của chủ đề @categoryCarousel.CategoryName">
                                                <span class="material-symbols-outlined text-[18px]">arrow_back_ios_new</span>
                                            </button>
                                            <button type="button"
                                                    class="inline-flex size-11 items-center justify-center rounded-full border border-slate-200 bg-white text-slate-700 shadow-sm transition duration-200 hover:-translate-y-0.5 hover:border-primary/35 hover:text-primary disabled:pointer-events-none disabled:translate-y-0 disabled:opacity-35 dark:border-slate-800 dark:bg-slate-900/70 dark:text-slate-100 dark:hover:border-primary/40"
                                                    data-tour-card-carousel-next
                                                    aria-label="Nhóm bài viết tiếp theo của chủ đề @categoryCarousel.CategoryName">
                                                <span class="material-symbols-outlined text-[18px]">arrow_forward_ios</span>
                                            </button>
                                        </div>
                                    </div>
                                </div>

                                <div class="relative mt-7" data-tour-card-carousel aria-label="Danh sách bài viết @categoryCarousel.CategoryName">
                                    <div class="px-4 pb-4 sm:px-5 lg:px-6">
                                        <div class="overflow-hidden cursor-grab rounded-[1.9rem] [touch-action:pan-y]" data-tour-card-carousel-viewport>
                                            <div class="flex gap-5 will-change-transform" data-tour-card-carousel-track>
                                                @foreach (var article in categoryCarousel.Articles)
                                                {
                                                    <div class="min-w-0 shrink-0 basis-full md:basis-[calc((100%-1.25rem)/2)] xl:basis-[calc((100%-2.5rem)/3)]" data-tour-card-carousel-item>
                                                        @await Html.PartialAsync("_ArticleCarouselCard", article)
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </section>
                        }
                    </div>
                }
                else
                {
                    <div class="rounded-[2rem] border border-dashed border-slate-200 bg-slate-50/80 px-6 py-10 dark:border-slate-700 dark:bg-slate-900/40">
                        <p class="text-[11px] font-bold uppercase tracking-[0.22em] text-slate-400 dark:text-slate-500">Đang cập nhật</p>
                        <h3 class="mt-3 text-2xl font-black tracking-tight text-slate-900 dark:text-white">Chưa có cụm bài viết theo chủ đề</h3>
                        <p class="mt-3 max-w-2xl text-sm leading-7 text-slate-500 dark:text-slate-400">@latestIntro.Fields.GetFieldValue("emptyStateText", "Bài viết sẽ xuất hiện tại đây khi có thêm nội dung đã xuất bản trong từng chuyên mục.")</p>
                    </div>
                }
            </div>
        }
    </div>
</section>

@section Scripts {
    <script src="~/js/tour-card-carousel.js" asp-append-version="true"></script>
}
