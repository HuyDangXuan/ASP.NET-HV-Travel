@model List<HVTravel.Domain.Entities.TravelArticle>
@{
    ViewData["Title"] = "Content Hub";
}

<div class="mb-8 flex flex-col gap-5 xl:flex-row xl:items-end xl:justify-between">
    <div class="max-w-3xl">
        @await Html.PartialAsync("_AdminBreadcrumb", new HVTravel.Web.Models.BreadcrumbViewModel
        {
            Items = new List<HVTravel.Web.Models.BreadcrumbItemViewModel>
            {
                new() { Label = "Trang chủ", Url = Url.Action("Index", "Dashboard") },
                new() { Label = "Content hub", IsCurrent = true }
            }
        })
        <h1 class="mt-3 text-3xl font-black tracking-tight text-slate-900 dark:text-white">Content Hub</h1>
        <p class="mt-3 max-w-2xl text-sm leading-6 text-slate-500 dark:text-slate-400">
            Quản lý các bài viết truyền cảm hứng với card trực quan hơn để quét nhanh trạng thái xuất bản, điểm đến và lịch cập nhật.
        </p>
    </div>

    <a asp-action="Create"
       class="inline-flex items-center justify-center gap-2 rounded-2xl bg-primary px-5 py-3 text-sm font-bold text-white shadow-sm shadow-primary/30 transition-all hover:-translate-y-0.5 hover:shadow-lg hover:shadow-primary/20">
        <span class="material-symbols-outlined text-[18px]">edit_square</span>
        Tạo bài viết
    </a>
</div>

@if (Model.Count == 0)
{
    <section class="rounded-[2rem] border border-dashed border-slate-300 bg-white/80 p-10 text-center shadow-sm dark:border-slate-700 dark:bg-surface-dark">
        <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-2xl bg-primary/10 text-primary">
            <span class="material-symbols-outlined text-[30px]">newsmode</span>
        </div>
        <h2 class="mt-5 text-2xl font-black tracking-tight text-slate-900 dark:text-white">Chưa có bài viết nào trong content hub</h2>
        <p class="mx-auto mt-3 max-w-xl text-sm leading-6 text-slate-500 dark:text-slate-400">
            Hãy tạo bài viết đầu tiên để bắt đầu quản lý danh mục cảm hứng, theo dõi trạng thái xuất bản và xây dựng kho nội dung du lịch.
        </p>
        <a asp-action="Create"
           class="mt-6 inline-flex items-center justify-center gap-2 rounded-2xl bg-primary px-5 py-3 text-sm font-bold text-white shadow-sm shadow-primary/30 transition-all hover:-translate-y-0.5 hover:shadow-lg hover:shadow-primary/20">
            <span class="material-symbols-outlined text-[18px]">add</span>
            Tạo bài viết đầu tiên
        </a>
    </section>
}
else
{
    <div class="grid items-stretch gap-6 xl:grid-cols-2">
        @foreach (var item in Model)
        {
            var hasHeroImage = !string.IsNullOrWhiteSpace(item.HeroImageUrl);
            var category = string.IsNullOrWhiteSpace(item.Category) ? "Chưa phân loại" : item.Category.Trim();
            var destination = string.IsNullOrWhiteSpace(item.Destination) ? null : item.Destination.Trim();
            var summary = string.IsNullOrWhiteSpace(item.Summary)
                ? "Bài viết này chưa có phần tóm tắt. Hãy bổ sung mô tả ngắn để người quản trị và biên tập viên quét nhanh nội dung."
                : item.Summary.Trim();
            var slug = string.IsNullOrWhiteSpace(item.Slug) ? "slug-chua-thiet-lap" : item.Slug.Trim();
            var statusLabel = item.IsPublished ? "Đã xuất bản" : "Nháp";
            var statusClasses = item.IsPublished
                ? "bg-emerald-500/15 text-emerald-700 ring-emerald-200 dark:bg-emerald-400/15 dark:text-emerald-300 dark:ring-emerald-400/20"
                : "bg-amber-500/15 text-amber-700 ring-amber-200 dark:bg-amber-400/15 dark:text-amber-300 dark:ring-amber-400/20";
            var publishedAt = item.PublishedAt.ToLocalTime();
            var updatedAt = item.UpdatedAt.ToLocalTime();

            <article class="group flex h-full flex-col overflow-hidden rounded-[2rem] border border-slate-200 bg-white shadow-sm transition-all duration-200 hover:-translate-y-1 hover:shadow-xl hover:shadow-slate-200/70 dark:border-slate-800 dark:bg-surface-dark dark:hover:shadow-black/20">
                <div class="relative aspect-[16/9] overflow-hidden bg-slate-950">
                    @if (hasHeroImage)
                    {
                        <img src="@item.HeroImageUrl"
                             alt="@item.Title"
                             class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.03]" />
                    }
                    else
                    {
                        <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,_rgba(56,189,248,0.75),_transparent_40%),linear-gradient(135deg,_#0f172a,_#1d4ed8_55%,_#38bdf8)]"></div>
                        <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(15,23,42,0.08),rgba(15,23,42,0.72))]"></div>
                        <div class="absolute inset-x-0 bottom-0 flex items-end justify-between p-5 text-white/80">
                            <div>
                                <p class="text-[11px] font-bold uppercase tracking-[0.35em] text-white/60">Travel Article</p>
                                <p class="mt-2 text-lg font-black text-white">Nội dung đang chờ ảnh bìa</p>
                            </div>
                            <span class="material-symbols-outlined text-[34px] text-white/80">image</span>
                        </div>
                    }

                    <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(15,23,42,0.08),rgba(15,23,42,0.72))]"></div>

                    <div class="absolute inset-x-0 top-0 flex flex-wrap items-start justify-between gap-2 p-4">
                        <div class="flex flex-wrap items-center gap-2">
                            <span class="inline-flex items-center rounded-full bg-white/95 px-3 py-1 text-[11px] font-bold uppercase tracking-[0.22em] text-slate-700 shadow-sm">
                                @category
                            </span>
                            @if (item.Featured)
                            {
                                <span class="inline-flex items-center gap-1 rounded-full bg-primary px-3 py-1 text-[11px] font-bold uppercase tracking-[0.18em] text-white shadow-sm shadow-primary/40">
                                    <span class="material-symbols-outlined text-[14px]">star</span>
                                    Nổi bật
                                </span>
                            }
                        </div>

                        <span class="inline-flex items-center rounded-full px-3 py-1 text-[11px] font-bold ring-1 backdrop-blur-sm @statusClasses">
                            @statusLabel
                        </span>
                    </div>

                    <div class="absolute inset-x-0 bottom-0 p-4">
                        <div class="flex flex-wrap items-center gap-2 text-[11px] font-semibold text-white/90">
                            @if (!string.IsNullOrWhiteSpace(destination))
                            {
                                <span class="inline-flex items-center gap-1 rounded-full bg-white/12 px-3 py-1 backdrop-blur-sm">
                                    <span class="material-symbols-outlined text-[14px]">location_on</span>
                                    @destination
                                </span>
                            }
                            <span class="inline-flex items-center gap-1 rounded-full bg-white/12 px-3 py-1 backdrop-blur-sm">
                                <span class="material-symbols-outlined text-[14px]">calendar_month</span>
                                @publishedAt.ToString("dd/MM/yyyy")
                            </span>
                        </div>
                    </div>
                </div>

                <div class="flex flex-1 flex-col p-6">
                    <div class="flex items-start justify-between gap-4">
                        <div class="min-w-0">
                            <h2 class="text-2xl font-black tracking-tight text-slate-900 dark:text-white"
                                style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">
                                @item.Title
                            </h2>
                            <p class="mt-3 text-sm leading-6 text-slate-500 dark:text-slate-400"
                               style="display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden;">
                                @summary
                            </p>
                        </div>
                    </div>

                    <div class="mt-6 grid gap-3 sm:grid-cols-2">
                        <div class="rounded-2xl border border-slate-200 bg-slate-50/80 p-4 dark:border-slate-700 dark:bg-slate-900/50">
                            <p class="text-[11px] font-bold uppercase tracking-[0.2em] text-slate-400">Slug</p>
                            <p class="mt-2 truncate font-mono text-sm font-semibold text-slate-700 dark:text-slate-200">@slug</p>
                        </div>
                        <div class="rounded-2xl border border-slate-200 bg-slate-50/80 p-4 dark:border-slate-700 dark:bg-slate-900/50">
                            <p class="text-[11px] font-bold uppercase tracking-[0.2em] text-slate-400">Cập nhật lần cuối</p>
                            <p class="mt-2 text-sm font-semibold text-slate-700 dark:text-slate-200">@updatedAt.ToString("dd/MM/yyyy HH:mm")</p>
                        </div>
                    </div>

                    <div class="mt-6 flex flex-wrap items-center justify-between gap-3 border-t border-slate-100 pt-5 dark:border-slate-800">
                        <div class="space-y-1 text-xs text-slate-500 dark:text-slate-400">
                            <p class="font-semibold text-slate-700 dark:text-slate-300">ID bài viết</p>
                            <p class="font-mono">@item.Id</p>
                        </div>

                        <a asp-action="Edit"
                           asp-route-id="@item.Id"
                           class="inline-flex items-center justify-center gap-2 rounded-2xl border border-slate-200 px-4 py-2.5 text-sm font-bold text-slate-700 transition-all hover:border-primary/40 hover:bg-primary/5 hover:text-primary dark:border-slate-700 dark:text-slate-200 dark:hover:border-primary/40 dark:hover:bg-primary/10 dark:hover:text-primary">
                            <span class="material-symbols-outlined text-[18px]">edit</span>
                            Chỉnh sửa
                        </a>
                    </div>
                </div>
            </article>
        }
    </div>
}
