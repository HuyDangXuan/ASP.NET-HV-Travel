                {
                    <tr class="group hover:bg-slate-50 dark:hover:bg-slate-800/50 transition-colors">
                        <td class="p-4 pl-6 font-mono font-semibold text-primary">#@item.BookingCode</td>
                        <td class="p-4">
                            <div class="flex items-center gap-3">
