@using System.Globalization
@using System.Text.Json
@model HVTravel.Web.Models.DashboardViewModel
@{
    ViewData["Title"] = "Tổng Quan";

    var bookingStatusMapping = new Dictionary<string, string>
    {
        { "Pending", "Chờ xử lý" },
        { "Paid", "Đã thanh toán" },
        { "Confirmed", "Đã xác nhận" },
        { "Completed", "Hoàn thành" },
        { "Cancelled", "Đã hủy" },
        { "Refunded", "Đã hoàn tiền" }
    };

    var paymentStatusMapping = new Dictionary<string, string>
    {
        { "Unpaid", "Chưa thanh toán" },
        { "Partial", "Thanh toán 1 phần" },
        { "Full", "Đã thanh toán" },
        { "Refunded", "Đã hoàn tiền" }
    };

    var revenueChart = Model.RevenueChart ?? new HVTravel.Application.Models.DashboardRevenueStatsResult();
    var revenuePoints = revenueChart.Points ?? new List<HVTravel.Application.Models.DashboardRevenuePoint>();
    var revenueMax = revenuePoints.Any() ? Math.Max(revenuePoints.Max(point => point.Value), 1m) : 1m;
    var jsonOptions = new JsonSerializerOptions(JsonSerializerDefaults.Web);

    string GetStatusVietnamese(string status)
    {
        if (string.IsNullOrEmpty(status)) return "Chưa có";

        if (bookingStatusMapping.ContainsKey(status)) return bookingStatusMapping[status];
        if (paymentStatusMapping.ContainsKey(status)) return paymentStatusMapping[status];

        foreach (var key in bookingStatusMapping.Keys)
        {
            if (key.Equals(status, StringComparison.OrdinalIgnoreCase)) return bookingStatusMapping[key];
        }
        foreach (var key in paymentStatusMapping.Keys)
        {
            if (key.Equals(status, StringComparison.OrdinalIgnoreCase)) return paymentStatusMapping[key];
        }

        return status;
    }

    string FormatGrowth(double? growth)
    {
        if (!growth.HasValue) return "Mới";
        var prefix = growth.Value > 0 ? "+" : string.Empty;
        return $"{prefix}{growth.Value.ToString("0.#", CultureInfo.InvariantCulture)}%";
    }

    string GetGrowthBadgeClasses(double? growth)
    {
        if (!growth.HasValue || growth.Value > 0)
        {
            return "bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400";
        }

        if (growth.Value < 0)
        {
            return "bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-400";
        }

        return "bg-slate-100 text-slate-700 dark:bg-slate-800 dark:text-slate-300";
    }

    var revenueStatusText = revenueChart.TotalRevenue > 0
        ? $"Đang hiển thị doanh thu thực thu cho {revenueChart.PeriodLabel}."
        : $"Chưa có doanh thu thực thu cho {revenueChart.PeriodLabel}.";
}
