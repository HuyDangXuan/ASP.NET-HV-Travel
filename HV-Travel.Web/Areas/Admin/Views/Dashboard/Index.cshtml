                                    <span class="w-1.5 h-1.5 rounded-full bg-yellow-500"></span> @GetStatusVietnamese(item.Status)
                                </span>
                            }
                            else if (item.Status == "Cancelled")
                            {
                                <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[11px] font-bold bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-400 border border-red-200 dark:border-red-900">
                                    <span class="w-1.5 h-1.5 rounded-full bg-red-500"></span> @GetStatusVietnamese(item.Status)
                                </span>
                            }
                            else
                            {
                                <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[11px] font-bold bg-slate-100 text-slate-700 dark:bg-slate-800 dark:text-slate-300 border border-slate-200 dark:border-slate-700">
                                    <span class="w-1.5 h-1.5 rounded-full bg-slate-500"></span> @GetStatusVietnamese(item.Status)
                                </span>
                            }
                        </td>
                        <td class="p-4 pr-6 text-right">
                            <div class="flex items-center justify-end gap-2">
                                <a asp-controller="Bookings" asp-action="Details" asp-route-id="@item.Id" class="w-8 h-8 rounded-lg flex items-center justify-center bg-slate-100 hover:bg-slate-200 dark:bg-slate-800 dark:hover:bg-slate-700 text-slate-600 dark:text-slate-400 transition-colors" title="Xem chi tiết">
                                    <span class="material-symbols-outlined text-lg">visibility</span>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>





@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        (() => {
            const initialData = @Html.Raw(JsonSerializer.Serialize(revenueChart, jsonOptions));
            const apiUrl = '/api/dashboard/revenue';
            const chartCanvas = document.getElementById('dashboard-revenue-chart');
            const statusElement = document.getElementById('dashboard-revenue-status');
            const currentValueElement = document.getElementById('dashboard-revenue-current-value');
            const periodLabelElement = document.getElementById('dashboard-revenue-period-label');
            const previousValueElement = document.getElementById('dashboard-revenue-previous-value');
            const previousLabelElement = document.getElementById('dashboard-revenue-previous-label');
            const growthValueElement = document.getElementById('dashboard-revenue-growth-value');
            const comparisonLabelElement = document.getElementById('dashboard-revenue-comparison-label');
            const growthBadgeElement = document.getElementById('dashboard-revenue-growth-badge');
            const rangeButtons = Array.from(document.querySelectorAll('.dashboard-range-button'));

            if (!chartCanvas || !window.Chart) {
                return;
            }

            let revenueChartInstance;
            let currentRangeKey = initialData.rangeKey || 'week';
            const growthBaseClasses = ['inline-flex', 'items-center', 'gap-1.5', 'px-3', 'py-1', 'rounded-full', 'text-[11px]', 'font-bold'];
            const growthToneClasses = {
                positive: ['bg-green-100', 'text-green-700', 'dark:bg-green-900/30', 'dark:text-green-400'],
                negative: ['bg-red-100', 'text-red-700', 'dark:bg-red-900/30', 'dark:text-red-400'],
                neutral: ['bg-slate-100', 'text-slate-700', 'dark:bg-slate-800', 'dark:text-slate-300']
            };

            function formatCurrency(value) {
                return `${new Intl.NumberFormat('vi-VN').format(Number(value || 0))} ₫`;
            }

            function formatCompactCurrency(value) {
                const amount = Number(value || 0);
                if (Math.abs(amount) >= 1000000) {
                    return `${new Intl.NumberFormat('vi-VN', { maximumFractionDigits: 1 }).format(amount / 1000000)}tr`;
                }

                if (Math.abs(amount) >= 1000) {
                    return `${new Intl.NumberFormat('vi-VN', { maximumFractionDigits: 0 }).format(amount / 1000)}k`;
                }

                return new Intl.NumberFormat('vi-VN', { maximumFractionDigits: 0 }).format(amount);
            }

            function formatGrowth(value) {
                if (value === null || value === undefined) {
                    return 'Mới';
                }

                const formatted = new Intl.NumberFormat('vi-VN', {
                    minimumFractionDigits: 0,
                    maximumFractionDigits: 1
                }).format(Number(value));

                return `${Number(value) > 0 ? '+' : ''}${formatted}%`;
            }

            function getGrowthTone(value) {
                if (value === null || value === undefined || Number(value) > 0) {
                    return 'positive';
                }

                if (Number(value) < 0) {
                    return 'negative';
                }

                return 'neutral';
            }

            function applyGrowthTone(value) {
                const tone = getGrowthTone(value);
                growthBadgeElement.className = [...growthBaseClasses, ...growthToneClasses[tone]].join(' ');
            }

            function setRangeButtons(selectedRange, disabled) {
                rangeButtons.forEach((button) => {
                    const isActive = button.dataset.range === selectedRange;
                    button.disabled = disabled;
                    button.classList.toggle('bg-white', isActive);
                    button.classList.toggle('dark:bg-slate-700', isActive);
                    button.classList.toggle('text-slate-900', isActive);
                    button.classList.toggle('dark:text-white', isActive);
                    button.classList.toggle('shadow-sm', isActive);
                    button.classList.toggle('text-slate-500', !isActive);
                    button.classList.toggle('dark:text-slate-400', !isActive);
                    button.classList.toggle('hover:text-slate-900', !isActive);
                    button.classList.toggle('dark:hover:text-white', !isActive);
                    button.classList.toggle('opacity-60', disabled);
                    button.classList.toggle('cursor-not-allowed', disabled);
                });
            }

            function updateSummary(data) {
                currentValueElement.textContent = formatCurrency(data.totalRevenue);
                periodLabelElement.textContent = data.periodLabel;
                previousValueElement.textContent = formatCurrency(data.previousPeriodRevenue);
                previousLabelElement.textContent = data.previousPeriodLabel;
                growthValueElement.textContent = formatGrowth(data.growthPercentage);
                comparisonLabelElement.textContent = `So với ${data.previousPeriodLabel}`;
                applyGrowthTone(data.growthPercentage);
            }

            function updateStatus(data, mode) {
                statusElement.classList.remove('text-red-500', 'dark:text-red-400');
                statusElement.classList.add('text-slate-500', 'dark:text-slate-400');

                if (mode === 'loading') {
                    statusElement.textContent = 'Đang tải dữ liệu doanh thu...';
                    return;
                }

                if (mode === 'error') {
                    statusElement.textContent = 'Không thể tải dữ liệu doanh thu. Đang giữ lại số liệu gần nhất.';
                    statusElement.classList.remove('text-slate-500', 'dark:text-slate-400');
                    statusElement.classList.add('text-red-500', 'dark:text-red-400');
                    return;
                }

                if (Number(data.totalRevenue) <= 0) {
                    statusElement.textContent = `Chưa có doanh thu thực thu cho ${data.periodLabel.toLowerCase()}.`;
                    return;
                }

                statusElement.textContent = `Đang hiển thị doanh thu thực thu cho ${data.periodLabel}.`;
            }

            function renderChart(data) {
                const context = chartCanvas.getContext('2d');
                const gradient = context.createLinearGradient(0, 0, 0, chartCanvas.height || 280);
                gradient.addColorStop(0, 'rgba(43, 205, 238, 0.75)');
                gradient.addColorStop(1, 'rgba(43, 205, 238, 0.18)');

                if (revenueChartInstance) {
                    revenueChartInstance.destroy();
                }

                revenueChartInstance = new Chart(context, {
                    type: 'bar',
                    data: {
                        labels: data.points.map(point => point.label),
                        datasets: [
                            {
                                label: 'Doanh thu',
                                data: data.points.map(point => Number(point.value || 0)),
                                backgroundColor: gradient,
                                borderColor: '#2bcdee',
                                borderWidth: 1,
                                borderRadius: 12,
                                barPercentage: 0.72,
                                categoryPercentage: 0.76
                            }
                        ]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: {
                                display: false
                            },
                            tooltip: {
                                callbacks: {
                                    label(context) {
                                        return `Doanh thu: ${formatCurrency(context.raw)}`;
                                    }
                                }
                            }
                        },
                        scales: {
                            x: {
                                grid: {
                                    display: false
                                },
                                ticks: {
                                    color: '#64748b'
                                }
                            },
                            y: {
                                beginAtZero: true,
                                grid: {
                                    color: 'rgba(148, 163, 184, 0.12)'
                                },
                                ticks: {
                                    color: '#94a3b8',
                                    callback(value) {
                                        return formatCompactCurrency(value);
                                    }
                                }
                            }
                        }
                    }
                });
            }

            async function loadRange(rangeKey) {
                updateStatus(null, 'loading');
                setRangeButtons(rangeKey, true);

                try {
                    const response = await fetch(`${apiUrl}?range=${encodeURIComponent(rangeKey)}`, {
                        headers: {
                            'X-Requested-With': 'XMLHttpRequest'
                        }
                    });

                    if (!response.ok) {
                        throw new Error(`Request failed with status ${response.status}`);
                    }

                    const data = await response.json();
                    currentRangeKey = data.rangeKey || rangeKey;
                    updateSummary(data);
                    renderChart(data);
                    updateStatus(data);
                    setRangeButtons(currentRangeKey, false);
                } catch (error) {
                    console.error(error);
                    setRangeButtons(currentRangeKey, false);
                    updateStatus(null, 'error');
                }
            }

            rangeButtons.forEach((button) => {
                button.addEventListener('click', () => {
                    const nextRange = button.dataset.range;
                    if (!nextRange || nextRange === currentRangeKey) {
                        return;
                    }

                    loadRange(nextRange);
                });
            });

            updateSummary(initialData);
            renderChart(initialData);
            updateStatus(initialData);
            setRangeButtons(currentRangeKey, false);
        })();
    </script>
}


