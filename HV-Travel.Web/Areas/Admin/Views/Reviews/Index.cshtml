@model List<HVTravel.Domain.Entities.Review>
@{
    ViewData["Title"] = "Reviews";
}

<div class="flex items-end justify-between gap-4 mb-8">
    <div>
        @await Html.PartialAsync("_AdminBreadcrumb", new HVTravel.Web.Models.BreadcrumbViewModel
        {
            Items = new List<HVTravel.Web.Models.BreadcrumbItemViewModel>
            {
                new() { Label = "Trang chủ", Url = Url.Action("Index", "Dashboard") },
                new() { Label = "Reviews", IsCurrent = true }
            }
        })
        <h1 class="text-2xl font-bold text-slate-900 dark:text-white mt-3">Review Moderation</h1>
    </div>
</div>

<div class="space-y-4">
    @foreach (var review in Model)
    {
        <article class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-surface-dark">
            <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
                <div>
                    <p class="text-xs uppercase tracking-[0.3em] text-slate-400">@review.ModerationStatus • @review.DisplayName</p>
                    <h2 class="mt-2 text-xl font-bold text-slate-900 dark:text-white">@review.Rating sao</h2>
                    <p class="mt-3 text-sm leading-7 text-slate-500">@review.Comment</p>
                </div>
                <div class="flex gap-2">
                    <form asp-action="Moderate" method="post">
                        <input type="hidden" name="id" value="@review.Id" />
                        <input type="hidden" name="decision" value="approve" />
                        <button type="submit" class="rounded-xl bg-emerald-600 px-4 py-2 text-xs font-bold text-white">Approve</button>
                    </form>
                    <form asp-action="Moderate" method="post">
                        <input type="hidden" name="id" value="@review.Id" />
                        <input type="hidden" name="decision" value="reject" />
                        <button type="submit" class="rounded-xl bg-rose-600 px-4 py-2 text-xs font-bold text-white">Reject</button>
                    </form>
                </div>
            </div>
        </article>
    }
</div>
