@model HVTravel.Domain.Entities.Promotion
@{
    ViewData["Title"] = "Promotion Form";

    string FormatDateLabel(DateTime value, string placeholder)
        => value == default ? placeholder : value.ToString("dd/MM/yyyy");

    var validFromLabel = FormatDateLabel(Model.ValidFrom, "Chọn ngày bắt đầu");
    var validToLabel = FormatDateLabel(Model.ValidTo, "Chọn ngày kết thúc");
}

<div class="max-w-4xl">
    @await Html.PartialAsync("_AdminBreadcrumb", new HVTravel.Web.Models.BreadcrumbViewModel
    {
        Items = new List<HVTravel.Web.Models.BreadcrumbItemViewModel>
        {
            new() { Label = "Trang chủ", Url = Url.Action("Index", "Dashboard") },
            new() { Label = "Promotions", Url = Url.Action("Index") },
            new() { Label = "Biểu mẫu", IsCurrent = true }
        }
    })

    <div class="mt-6 rounded-3xl border border-slate-200 bg-white p-8 shadow-sm dark:border-slate-800 dark:bg-surface-dark">
        <form method="post" class="space-y-5">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />
            <div class="grid gap-5 md:grid-cols-2">
                <div>
                    <label class="mb-2 block text-sm font-semibold">Code</label>
                    <input asp-for="Code" class="w-full rounded-2xl border border-slate-200 bg-transparent px-4 py-3 dark:border-slate-700" />
                </div>
                <div>
                    <label class="mb-2 block text-sm font-semibold">Title</label>
                    <input asp-for="Title" class="w-full rounded-2xl border border-slate-200 bg-transparent px-4 py-3 dark:border-slate-700" />
                </div>
            </div>
            <div class="grid gap-5 md:grid-cols-3">
                <div>
                    <label class="mb-2 block text-sm font-semibold">CampaignType</label>
                    <input asp-for="CampaignType" class="w-full rounded-2xl border border-slate-200 bg-transparent px-4 py-3 dark:border-slate-700" />
                </div>
                <div>
                    <label class="mb-2 block text-sm font-semibold">Discount %</label>
                    <input asp-for="DiscountPercentage" class="w-full rounded-2xl border border-slate-200 bg-transparent px-4 py-3 dark:border-slate-700" />
                </div>
                <div>
                    <label class="mb-2 block text-sm font-semibold">MinimumSpend</label>
                    <input asp-for="MinimumSpend" class="w-full rounded-2xl border border-slate-200 bg-transparent px-4 py-3 dark:border-slate-700" />
                </div>
            </div>
            <div class="grid gap-5 md:grid-cols-2">
                <div>
                    <label class="mb-2 block text-sm font-semibold">ValidFrom</label>
                    <div class="admin-date-input-shell public-date-input-shell">
                        <input asp-for="ValidFrom" type="datetime-local" class="admin-date-native-input w-full rounded-2xl border border-slate-200 bg-transparent px-4 py-3 dark:border-slate-700" data-public-date-input data-public-datetime-input data-placeholder="Chọn ngày bắt đầu" />
                        <div class="admin-date-enhanced-grid">
                            <div class="admin-date-shell">
                                <button type="button" class="public-date-trigger admin-date-trigger" data-public-date-trigger>
                                    <span class="material-symbols-outlined public-date-trigger-icon">calendar_month</span>
                                    <span class="public-date-trigger-meta">
                                        <span class="public-date-trigger-caption">Bắt đầu</span>
                                        <span class="public-date-trigger-label">@validFromLabel</span>
                                    </span>
                                    <span class="material-symbols-outlined public-date-trigger-arrow">expand_more</span>
                                </button>
                            </div>
                            <input type="time" class="admin-date-time-input" data-public-time-input value="@Model.ValidFrom.ToString("HH:mm")" step="60" />
                        </div>
                    </div>
                </div>
                <div>
                    <label class="mb-2 block text-sm font-semibold">ValidTo</label>
                    <div class="admin-date-input-shell public-date-input-shell">
                        <input asp-for="ValidTo" type="datetime-local" class="admin-date-native-input w-full rounded-2xl border border-slate-200 bg-transparent px-4 py-3 dark:border-slate-700" data-public-date-input data-public-datetime-input data-placeholder="Chọn ngày kết thúc" />
                        <div class="admin-date-enhanced-grid">
                            <div class="admin-date-shell">
                                <button type="button" class="public-date-trigger admin-date-trigger" data-public-date-trigger>
                                    <span class="material-symbols-outlined public-date-trigger-icon">event_repeat</span>
                                    <span class="public-date-trigger-meta">
                                        <span class="public-date-trigger-caption">Kết thúc</span>
                                        <span class="public-date-trigger-label">@validToLabel</span>
                                    </span>
                                    <span class="material-symbols-outlined public-date-trigger-arrow">expand_more</span>
                                </button>
                            </div>
                            <input type="time" class="admin-date-time-input" data-public-time-input value="@Model.ValidTo.ToString("HH:mm")" step="60" />
                        </div>
                    </div>
                </div>
            </div>
            <div>
                <label class="mb-2 block text-sm font-semibold">Description</label>
                <textarea asp-for="Description" rows="5" class="w-full rounded-2xl border border-slate-200 bg-transparent px-4 py-3 dark:border-slate-700"></textarea>
            </div>
            <div class="flex items-center gap-3">
                <button type="submit" class="rounded-2xl bg-primary px-5 py-3 text-sm font-bold text-white">Lưu promotion</button>
                <a asp-action="Index" class="rounded-2xl border border-slate-200 px-5 py-3 text-sm font-bold dark:border-slate-700">Quay lại</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="~/js/public-date-picker.js" asp-append-version="true"></script>
}