@model HVTravel.Domain.Entities.Promotion
@{
    ViewData["Title"] = "Biểu mẫu khuyến mãi";
}

<div class="max-w-4xl">
    @await Html.PartialAsync("_AdminBreadcrumb", new HVTravel.Web.Models.BreadcrumbViewModel
    {
        Items = new List<HVTravel.Web.Models.BreadcrumbItemViewModel>
        {
            new() { Label = "Trang chủ", Url = Url.Action("Index", "Dashboard") },
            new() { Label = "Khuyến mãi", Url = Url.Action("Index") },
            new() { Label = "Biểu mẫu", IsCurrent = true }
        }
    })

    <div class="mt-6 rounded-3xl border border-slate-200 bg-white p-8 shadow-sm dark:border-slate-800 dark:bg-surface-dark">
        <form method="post" class="space-y-5">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />
            <div class="grid gap-5 md:grid-cols-2">
                <div>
                    <label class="mb-2 block text-sm font-semibold">Mã khuyến mãi</label>
                    <input asp-for="Code" class="w-full rounded-2xl border border-slate-200 bg-transparent px-4 py-3 dark:border-slate-700" />
                </div>
                <div>
                    <label class="mb-2 block text-sm font-semibold">Tiêu đề</label>
                    <input asp-for="Title" class="w-full rounded-2xl border border-slate-200 bg-transparent px-4 py-3 dark:border-slate-700" />
                </div>
            </div>
            <div class="grid gap-5 md:grid-cols-3">
                <div>
                    <label class="mb-2 block text-sm font-semibold">Loại chiến dịch</label>
                    <input asp-for="CampaignType" class="w-full rounded-2xl border border-slate-200 bg-transparent px-4 py-3 dark:border-slate-700" />
                </div>
                <div>
                    <label class="mb-2 block text-sm font-semibold">Giảm giá (%)</label>
                    <input asp-for="DiscountPercentage" class="w-full rounded-2xl border border-slate-200 bg-transparent px-4 py-3 dark:border-slate-700" />
                </div>
                <div>
                    <label class="mb-2 block text-sm font-semibold">Chi tiêu tối thiểu</label>
                    <input asp-for="MinimumSpend" class="w-full rounded-2xl border border-slate-200 bg-transparent px-4 py-3 dark:border-slate-700" />
                </div>
            </div>
            <div class="grid gap-5 md:grid-cols-2">
                <div>
                    <label class="mb-2 block text-sm font-semibold">Hiệu lực từ</label>
                    <div class="admin-picker" data-admin-picker="datetime" data-picker-placeholder="Chọn thời điểm hiệu lực" data-picker-icon="schedule">
                        <input asp-for="ValidFrom" type="datetime-local" step="300" class="admin-picker-input" />
                    </div>
                </div>
                <div>
                    <label class="mb-2 block text-sm font-semibold">Hiệu lực đến</label>
                    <div class="admin-picker" data-admin-picker="datetime" data-picker-placeholder="Chọn thời điểm kết thúc" data-picker-icon="schedule">
                        <input asp-for="ValidTo" type="datetime-local" step="300" class="admin-picker-input" />
                    </div>
                </div>
            </div>
            <div>
                <label class="mb-2 block text-sm font-semibold">Mô tả</label>
                <textarea asp-for="Description" rows="5" class="w-full rounded-2xl border border-slate-200 bg-transparent px-4 py-3 dark:border-slate-700" data-rich-editor="true" data-editor-height="240"></textarea>
            </div>
            <div class="flex items-center gap-3">
                <button type="submit" class="rounded-2xl bg-primary px-5 py-3 text-sm font-bold text-white">Lưu khuyến mãi</button>
                <a asp-action="Index" class="rounded-2xl border border-slate-200 px-5 py-3 text-sm font-bold dark:border-slate-700">Quay lại</a>
            </div>
        </form>
    </div>
</div>

