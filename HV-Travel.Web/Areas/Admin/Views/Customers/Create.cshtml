@{
    ViewData["Title"] = "Thêm Khách Hàng";
}
@model HVTravel.Domain.Entities.Customer

<style type="text/tailwindcss">
    @@layer components {
        .input-field {
            @@apply w-full bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl h-14 px-4 text-[#111718] dark:text-white font-semibold focus:ring-2 focus:ring-primary/50 transition-all placeholder:text-[#618389]/50 dark:placeholder:text-slate-500 shadow-sm;
        }
        .section-card {
            @@apply bg-white dark:bg-surface-dark rounded-2xl border border-[#f0f4f4] dark:border-slate-800 p-6 shadow-sm space-y-6;
        }
        .label-text {
            @@apply text-[#111718] dark:text-white text-sm font-bold uppercase tracking-wider mb-2 block;
        }
    }
</style>

<form id="create-customer-form" asp-action="Create" method="post">
<div class="pb-24">
    <div class="flex flex-col gap-1 mb-10">
        @await Html.PartialAsync("_AdminBreadcrumb", new HVTravel.Web.Models.BreadcrumbViewModel
        {
            Items = new List<HVTravel.Web.Models.BreadcrumbItemViewModel>
            {
                new() { Label = "Trang chủ", Url = Url.Action("Index", "Dashboard") },
                new() { Label = "Khách hàng", Url = Url.Action("Index", "Customers") },
                new() { Label = "Thêm mới", IsCurrent = true }
            }
        })
        <h1 class="text-2xl font-bold text-slate-900 dark:text-white">Thêm Khách Hàng Mới</h1>
        <p class="text-slate-500 dark:text-gray-400 mt-1">Nhập thông tin cá nhân và chi tiết liên hệ của khách hàng.</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
        <div class="lg:col-span-8 space-y-8">
            <!-- Basic Info -->
            <section class="section-card">
                <div class="flex items-center gap-2 mb-2">
                    <span class="material-symbols-outlined text-primary">person</span>
                    <h2 class="text-[#111718] dark:text-white text-xl font-bold">Thông tin cá nhân</h2>
                </div>
                <div class="space-y-6">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label class="label-text">Họ và tên <span class="text-red-500">*</span></label>
                            <input asp-for="FullName" class="input-field" placeholder="Ví dụ: Nguyen Van A" type="text" required />
                            <span asp-validation-for="FullName" class="text-red-500 text-xs"></span>
                        </div>
                        <div>
                            <label class="label-text">Mã khách hàng</label>
                            <input asp-for="CustomerCode" class="input-field" placeholder="Tự động tạo nếu để trống (KH-...)" type="text" />
                        </div>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label class="label-text">Email <span class="text-red-500">*</span></label>
                            <input asp-for="Email" class="input-field" placeholder="customer@example.com" type="email" required />
                            <span asp-validation-for="Email" class="text-red-500 text-xs"></span>
                        </div>
                        <div>
                            <label class="label-text">Số điện thoại <span class="text-red-500">*</span></label>
                            <input asp-for="PhoneNumber" class="input-field" placeholder="09xxxxxxxx" type="tel" required />
                            <span asp-validation-for="PhoneNumber" class="text-red-500 text-xs"></span>
                        </div>
                    </div>
                     <div>
                        <label class="label-text">Ảnh đại diện (URL)</label>
                        <input asp-for="AvatarUrl" id="avatar-input" class="input-field" placeholder="https://..." type="text" />
                        <div class="flex flex-wrap items-center gap-3 mt-3">
                            <button type="button" id="customer-avatar-upload" class="px-4 py-2 rounded-xl bg-primary text-white text-sm font-bold shadow-sm hover:brightness-110 transition-all">
                                <span class="material-symbols-outlined text-lg align-[-3px] mr-1">cloud_upload</span> Tải ảnh lên
                            </button>
                            <button type="button" id="customer-avatar-browse-library" class="px-4 py-2 rounded-xl border border-sky-200 text-sky-700 text-sm font-bold hover:bg-sky-50 transition-all">
                                <span class="material-symbols-outlined text-lg align-[-3px] mr-1">photo_library</span> Chọn từ thư viện Cloudinary
                            </button>
                            <button type="button" id="customer-avatar-remove" class="px-4 py-2 rounded-xl border border-red-200 text-red-500 text-sm font-bold hover:bg-red-50 transition-all">
                                <span class="material-symbols-outlined text-lg align-[-3px] mr-1">delete</span> Xóa ảnh
                            </button>
                        </div>
                    </div>
                </div>
            </section>

             <!-- Address Info -->
            <section class="section-card">
                <div class="flex items-center gap-2 mb-2">
                    <span class="material-symbols-outlined text-primary">location_on</span>
                    <h2 class="text-[#111718] dark:text-white text-xl font-bold">Địa chỉ liên hệ</h2>
                </div>
                <div class="space-y-6">
                    <div>
                        <label class="label-text">Địa chỉ (Số nhà, đường)</label>
                        <input asp-for="Address.Street" class="input-field" placeholder="Ví dụ: 123 Đường ABC" type="text" />
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label class="label-text">Thành phố / Tỉnh</label>
                            <input asp-for="Address.City" id="city-input" class="input-field" placeholder="Ví dụ: Hà Nội" type="text" />
                        </div>
                        <div>
                            <label class="label-text">Quốc gia</label>
                            <input asp-for="Address.Country" class="input-field" placeholder="Ví dụ: Việt Nam" type="text" value="Việt Nam" />
                        </div>
                    </div>
                </div>
            </section>

             <!-- Notes -->
            <section class="section-card">
                 <div class="flex items-center gap-2 mb-2">
                    <span class="material-symbols-outlined text-primary">description</span>
                    <h2 class="text-[#111718] dark:text-white text-xl font-bold">Ghi chú</h2>
                </div>
                <div>
                     <textarea asp-for="Notes" class="input-field h-32 py-4 resize-none" data-rich-editor="true" data-editor-height="220" placeholder="Ghi chú thêm về khách hàng này..."></textarea>
                </div>
            </section>
        </div>

        <!-- Sidebar / Settings -->
        <div class="lg:col-span-4 space-y-8">
            <!-- Preview Card -->
             <div class="bg-white dark:bg-surface-dark rounded-2xl border border-[#f0f4f4] dark:border-slate-800 p-6 shadow-sm">
                <h3 class="text-[#111718] dark:text-white text-lg font-bold mb-4">Xem trước hồ sơ</h3>
                <div class="flex flex-col items-center text-center p-4 bg-slate-50 dark:bg-slate-800/50 rounded-xl">
                    <div class="size-20 rounded-full bg-slate-200 overflow-hidden mb-3 shadow-sm border-2 border-white dark:border-slate-700">
                         <img id="preview-avatar" src="https://ui-avatars.com/api/?name=Kh%C3%A1ch+H%C3%A0ng" alt="Preview" class="w-full h-full object-cover" />
                    </div>
                    <h4 id="preview-name" class="font-bold text-slate-900 dark:text-white text-lg">Tên Khách Hàng</h4>
                    <p id="preview-email" class="text-sm text-slate-500">email@example.com</p>
                    <p id="preview-location" class="text-xs font-semibold text-primary mt-2 uppercase tracking-wide">ĐỊA CHỈ</p>
                    
                    <div class="flex gap-2 mt-4 w-full">
                        <div class="flex-1 p-2 bg-white dark:bg-slate-900 rounded-lg border border-slate-100 dark:border-slate-700">
                            <span class="block text-[10px] text-slate-400 uppercase">Phân khúc</span>
                            <span id="preview-segment" class="text-sm font-bold text-slate-700 dark:text-slate-300">Tiêu chuẩn</span>
                        </div>
                         <div class="flex-1 p-2 bg-white dark:bg-slate-900 rounded-lg border border-slate-100 dark:border-slate-700">
                            <span class="block text-[10px] text-slate-400 uppercase">Trạng thái</span>
                             <span id="preview-status" class="text-sm font-bold text-green-600">Đang hoạt động</span>
                        </div>
                    </div>
                </div>
            </div>

            <section class="section-card">
                 <div class="flex items-center gap-2 mb-2">
                    <span class="material-symbols-outlined text-primary">settings</span>
                    <h2 class="text-[#111718] dark:text-white text-xl font-bold">Cấu hình</h2>
                </div>
                <div class="space-y-4">
                    <div class="relative custom-select-container" data-id="Segment">
                        <label class="label-text">Phân khúc khách hàng</label>
                        <div class="custom-select-trigger" onclick="toggleCustomSelect('Segment')">
                            <div class="flex items-center gap-3 min-w-0">
                                <span class="custom-select-leading material-symbols-outlined">loyalty</span>
                                <div class="custom-select-meta">
                                    <span class="custom-select-caption">Segment</span>
                                    <span class="selected-label">Standard (Tiêu chuẩn)</span>
                                </div>
                            </div>
                            <span class="material-symbols-outlined transition-transform duration-300 arrow-icon">expand_more</span>
                        </div>
                        <div class="options-menu">
                            <div class="custom-option selected" data-value="Standard" data-label="Standard (Tiêu chuẩn)" onclick="selectCustomOption('Segment', 'Standard', 'Standard (Tiêu chuẩn)')">
                                <span class="custom-option-main"><span class="custom-option-dot"></span><span>Standard (Tiêu chuẩn)</span></span>
                                <span class="material-symbols-outlined text-lg check-icon">check</span>
                            </div>
                            <div class="custom-option" data-value="VIP" data-label="VIP" onclick="selectCustomOption('Segment', 'VIP', 'VIP')">
                                <span class="custom-option-main"><span class="custom-option-dot"></span><span>VIP</span></span>
                            </div>
                            <div class="custom-option" data-value="New" data-label="New (Mới)" onclick="selectCustomOption('Segment', 'New', 'New (Mới)')">
                                <span class="custom-option-main"><span class="custom-option-dot"></span><span>New (Mới)</span></span>
                            </div>
                            <div class="custom-option" data-value="ChurnRisk" data-label="Churn Risk (Nguy cơ)" onclick="selectCustomOption('Segment', 'ChurnRisk', 'Churn Risk (Nguy cơ)')">
                                <span class="custom-option-main"><span class="custom-option-dot"></span><span>Churn Risk (Nguy cơ)</span></span>
                            </div>
                        </div>
                        <select asp-for="Segment" id="segment-select" class="hidden">
                            <option value="Standard">Standard (Tiêu chuẩn)</option>
                            <option value="VIP">VIP</option>
                            <option value="New">New (Mới)</option>
                            <option value="ChurnRisk">Churn Risk (Nguy cơ)</option>
                        </select>
                    </div>
                    <div class="relative custom-select-container" data-id="Status">
                        <label class="label-text">Trạng thái tài khoản</label>
                        <div class="custom-select-trigger" onclick="toggleCustomSelect('Status')">
                            <div class="flex items-center gap-3 min-w-0">
                                <span class="custom-select-leading material-symbols-outlined">manage_accounts</span>
                                <div class="custom-select-meta">
                                    <span class="custom-select-caption">Account status</span>
                                    <span class="selected-label">Active (Hoạt động)</span>
                                </div>
                            </div>
                            <span class="material-symbols-outlined transition-transform duration-300 arrow-icon">expand_more</span>
                        </div>
                        <div class="options-menu">
                            <div class="custom-option selected" data-value="Active" data-label="Active (Hoạt động)" onclick="selectCustomOption('Status', 'Active', 'Active (Hoạt động)')">
                                <span class="custom-option-main"><span class="custom-option-dot"></span><span>Active (Hoạt động)</span></span>
                                <span class="material-symbols-outlined text-lg check-icon">check</span>
                            </div>
                            <div class="custom-option" data-value="Banned" data-label="Banned (Bị khóa)" onclick="selectCustomOption('Status', 'Banned', 'Banned (Bị khóa)')">
                                <span class="custom-option-main"><span class="custom-option-dot"></span><span>Banned (Bị khóa)</span></span>
                            </div>
                            <div class="custom-option" data-value="Inactive" data-label="Inactive (Ngừng hoạt động)" onclick="selectCustomOption('Status', 'Inactive', 'Inactive (Ngừng hoạt động)')">
                                <span class="custom-option-main"><span class="custom-option-dot"></span><span>Inactive (Ngừng hoạt động)</span></span>
                            </div>
                        </div>
                        <select asp-for="Status" id="status-select" class="hidden">
                            <option value="Active">Active (Hoạt động)</option>
                            <option value="Banned">Banned (Bị khóa)</option>
                             <option value="Inactive">Inactive (Ngưng hoạt động)</option>
                        </select>
                    </div>
                </div>
            </section>
        </div>
    </div>
</div>

<footer class="fixed bottom-0 left-0 right-0 md:left-64 bg-white dark:bg-surface-dark border-t border-[#f0f4f4] dark:border-slate-800 p-5 md:px-10 shadow-[0_-8px_30px_rgba(0,0,0,0.04)] z-40 transition-all duration-300">
    <div class="max-w-[1440px] mx-auto flex items-center justify-end gap-4">
        <a asp-action="Index" class="px-8 py-4 rounded-2xl text-[#111718] dark:text-white font-bold text-sm hover:bg-[#f0f4f4] dark:hover:bg-white/5 transition-all text-center">
            Hủy
        </a>
        <button type="submit" class="px-10 py-4 rounded-2xl bg-gradient-to-r from-primary to-[#25b9d7] hover:brightness-110 text-white font-extrabold text-sm transition-all shadow-xl shadow-primary/30 flex items-center justify-center gap-2 group">
            Lưu Khách Hàng
            <span class="material-symbols-outlined text-xl group-hover:translate-x-1 transition-transform">save</span>
        </button>
    </div>
</footer>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/admin-custom-select.js" asp-append-version="true"></script>
    <script>
        // Live Preview Logic
        const inputs = {
            name: document.querySelector('input[name="FullName"]'),
            email: document.querySelector('input[name="Email"]'),
            city: document.getElementById('city-input'),
            avatar: document.getElementById('avatar-input'),
            segment: document.getElementById('segment-select'),
            status: document.getElementById('status-select')
        };

        const preview = {
            name: document.getElementById('preview-name'),
            email: document.getElementById('preview-email'),
            location: document.getElementById('preview-location'),
            avatar: document.getElementById('preview-avatar'),
            segment: document.getElementById('preview-segment'),
            status: document.getElementById('preview-status')
        };

        function updatePreview() {
            if(inputs.name) preview.name.textContent = inputs.name.value || 'Tên Khách Hàng';
            if(inputs.email) preview.email.textContent = inputs.email.value || 'email@example.com';
            if(inputs.city) preview.location.textContent = inputs.city.value || 'ĐỊA CHỈ';
            
            if(inputs.avatar && inputs.avatar.value) {
                preview.avatar.src = inputs.avatar.value;
            } else if (inputs.name && inputs.name.value) {
                preview.avatar.src = `https://ui-avatars.com/api/?name=${encodeURIComponent(inputs.name.value)}`;
            }

            if(inputs.segment) preview.segment.textContent = inputs.segment.value;
            if(inputs.status) {
                preview.status.textContent = inputs.status.value;
                if(inputs.status.value === 'Active') preview.status.className = "text-sm font-bold text-green-600";
                else if(inputs.status.value === 'Banned') preview.status.className = "text-sm font-bold text-red-600";
                else preview.status.className = "text-sm font-bold text-slate-500";
            }
        }

        // Add listeners
        Object.values(inputs).forEach(input => {
            if(input) input.addEventListener('input', updatePreview);
        });

        const uploadButton = document.getElementById('customer-avatar-upload');
        if (uploadButton && inputs.avatar) {
            uploadButton.addEventListener('click', function () {
                window.openCloudinaryWidget({ multiple: false, folder: 'HV-Travel ASP.NET' }, function (url) {
                    inputs.avatar.value = url;
                    updatePreview();
                });
            });
        }

        const browseLibraryButton = document.getElementById('customer-avatar-browse-library');
        if (browseLibraryButton && inputs.avatar) {
            browseLibraryButton.addEventListener('click', function () {
                window.openCloudinaryAssetBrowser({ multiple: false, folder: 'HV-Travel ASP.NET' }, function (url) {
                    inputs.avatar.value = url;
                    updatePreview();
                });
            });
        }

        const removeButton = document.getElementById('customer-avatar-remove');
        if (removeButton && inputs.avatar) {
            removeButton.addEventListener('click', function () {
                inputs.avatar.value = '';
                updatePreview();
            });
        }
        
    </script>
}
