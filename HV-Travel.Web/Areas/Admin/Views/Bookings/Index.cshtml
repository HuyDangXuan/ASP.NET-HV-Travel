@model HVTravel.Domain.Models.PaginatedResult<HVTravel.Domain.Entities.Booking>
@{
    ViewData["Title"] = "Đơn Đặt Vé";

    var bookingStatusMapping = new Dictionary<string, string>
    {
        { "Pending", "Chờ xử lý" },
        { "Paid", "Đã thanh toán" },
        { "Confirmed", "Đã xác nhận" },
        { "Completed", "Hoàn thành" },
        { "Cancelled", "Đã hủy" },
        { "Refunded", "Đã hoàn tiền" }
    };

    var paymentStatusMapping = new Dictionary<string, string>
    {
        { "Unpaid", "Chưa thanh toán" },
        { "Partial", "Thanh toán 1 phần" },
        { "Full", "Đã thanh toán" },
        { "Refunded", "Đã hoàn tiền" }
    };
    
    // Helper function to safely get translated status
    string GetStatusVietnamese(string status)
    {
        if (string.IsNullOrEmpty(status)) return "N/A";
        
        // Try exact match
        if (bookingStatusMapping.ContainsKey(status)) return bookingStatusMapping[status];
        if (paymentStatusMapping.ContainsKey(status)) return paymentStatusMapping[status];

        // Try case-insensitive keys
        foreach(var key in bookingStatusMapping.Keys)
        {
            if(key.Equals(status, StringComparison.OrdinalIgnoreCase)) return bookingStatusMapping[key];
        }
        foreach(var key in paymentStatusMapping.Keys)
        {
            if(key.Equals(status, StringComparison.OrdinalIgnoreCase)) return paymentStatusMapping[key];
        }

        return status;
    }
}

<!-- Page Header -->
<div data-animate="fade-in-up" data-delay="0.05" class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6">
    <div class="flex flex-col gap-1">
        <nav class="flex items-center gap-2 text-sm text-slate-500">
            <a class="hover:text-primary transition-colors" href="@Url.Action("Index", "Dashboard")">Trang Chủ</a>
            <span class="material-symbols-outlined text-[16px]">chevron_right</span>
            <span class="text-slate-900 dark:text-white font-medium">Đơn Đặt Vé</span>
        </nav>
        <h1 class="text-2xl font-bold text-slate-900 dark:text-white">Quản Lý Đơn Đặt Vé</h1>
    </div>
    <div class="flex items-center gap-2">
        <button class="flex items-center gap-2 h-10 px-4 bg-white dark:bg-slate-800 text-slate-600 dark:text-slate-300 rounded-lg text-sm font-bold border border-slate-200 dark:border-slate-700 hover:bg-slate-50 transition-colors">
            <span class="material-symbols-outlined text-lg">download</span>
            Xuất File
        </button>
    </div>
</div>

<!-- KPI Cards -->
<div data-animate="fade-in-up" data-delay="0.1" class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
    <div onclick="filterByCard('today')" class="bg-white dark:bg-surface-dark p-6 rounded-2xl shadow-sm border border-slate-100 dark:border-slate-800 flex items-center gap-4 relative overflow-hidden group cursor-pointer hover:shadow-md transition-all active:scale-[0.98]">
        <div class="absolute -right-6 -top-6 w-24 h-24 bg-primary/5 rounded-full group-hover:bg-primary/10 transition-colors"></div>
        <div class="bg-primary/10 text-primary p-3 rounded-xl relative z-10">
            <span class="material-symbols-outlined">today</span>
        </div>
        <div class="relative z-10">
            <p class="text-slate-500 dark:text-slate-400 text-xs font-semibold uppercase tracking-wider">Đơn Đặt Hôm Nay</p>
            <h3 class="text-2xl font-bold text-slate-900 dark:text-white">@ViewBag.TodayBookingsCount</h3>
            <p class="text-green-500 text-xs font-bold mt-1">Hôm nay</p>
        </div>
    </div>
    <div onclick="filterByCard('pending')" class="bg-white dark:bg-surface-dark p-6 rounded-2xl shadow-sm border border-slate-100 dark:border-slate-800 flex items-center gap-4 relative overflow-hidden group cursor-pointer hover:shadow-md transition-all active:scale-[0.98]">
        <div class="absolute -right-6 -top-6 w-24 h-24 bg-orange-500/5 rounded-full group-hover:bg-orange-500/10 transition-colors"></div>
        <div class="bg-orange-100 text-orange-600 p-3 rounded-xl relative z-10">
            <span class="material-symbols-outlined">payments</span>
        </div>
        <div class="relative z-10">
            <p class="text-slate-500 dark:text-slate-400 text-xs font-semibold uppercase tracking-wider">Thanh Toán Chờ Xử Lý</p>
            <h3 class="text-2xl font-bold text-slate-900 dark:text-white">@ViewBag.PendingPaymentCount</h3>
            <p class="text-slate-400 text-xs mt-1">@((ViewBag.PendingPaymentTotal ?? 0).ToString("N0")) ₫ tổng cộng</p>
        </div>
    </div>
    <div onclick="filterByCard('refund')" class="bg-white dark:bg-surface-dark p-6 rounded-2xl shadow-sm border border-slate-100 dark:border-slate-800 flex items-center gap-4 relative overflow-hidden group cursor-pointer hover:shadow-md transition-all active:scale-[0.98]">
        <div class="absolute -right-6 -top-6 w-24 h-24 bg-red-500/5 rounded-full group-hover:bg-red-500/10 transition-colors"></div>
        <div class="bg-red-100 text-red-600 p-3 rounded-xl relative z-10">
            <span class="material-symbols-outlined">assignment_return</span>
        </div>
        <div class="relative z-10">
            <p class="text-slate-500 dark:text-slate-400 text-xs font-semibold uppercase tracking-wider">Yêu Cầu Hoàn Tiền</p>
            <h3 class="text-2xl font-bold text-slate-900 dark:text-white">@ViewBag.RefundRequestCount</h3>
            <p class="text-red-500 text-xs font-bold mt-1">Cần xử lý</p>
        </div>
    </div>
</div>

<!-- Filters Form -->
<form data-animate="fade-in-up" data-delay="0.2" method="get" id="filter-form" class="relative z-20 bg-white dark:bg-surface-dark p-4 rounded-2xl shadow-sm border border-slate-100 dark:border-slate-800 mb-6 flex flex-wrap items-center gap-4">
    <!-- Hidden Inputs for State -->
    <input type="hidden" name="sortOrder" value="@ViewBag.CurrentSort" id="sortOrder-input">
    <input type="hidden" name="startDate" value="@ViewData["CurrentStartDate"]" id="startDate-input">
    <input type="hidden" name="endDate" value="@ViewData["CurrentEndDate"]" id="endDate-input">
    <input type="hidden" name="pageSize" value="@ViewData["CurrentPageSize"]" id="pageSize-input">

    <div class="flex-1 min-w-[200px]">
        <div class="relative">
            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-lg">search</span>
            <input name="searchString" value="@ViewData["CurrentSearch"]" class="w-full pl-10 pr-4 py-2.5 bg-slate-50 dark:bg-slate-800/50 border-slate-200 dark:border-slate-700 rounded-xl text-sm focus:ring-primary focus:border-primary" placeholder="Tìm mã vé, tên khách, email..." type="text" />
        </div>
    </div>
    <div class="flex items-center gap-3">
        <!-- Filter Panel -->
        <div class="relative group">
            <button type="button" onclick="toggleFilterMenu()" class="flex items-center justify-center size-10 rounded-xl bg-slate-50 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700 text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors">
                <span class="material-symbols-outlined !text-[20px]">filter_list</span>
            </button>

            <div id="filter-menu" class="absolute right-0 top-full mt-2 w-80 bg-white dark:bg-slate-900 rounded-2xl shadow-xl border border-slate-100 dark:border-slate-800 z-30 hidden origin-top-right transition-all menu-hidden animate-scale-in">
                <div class="p-4 border-b border-slate-100 dark:border-slate-800">
                    <h3 class="font-bold text-slate-900 dark:text-white">Bộ Lọc</h3>
                </div>

                <div class="p-4 flex flex-col gap-6 max-h-[60vh] overflow-y-auto custom-scrollbar">
                    <!-- Status Filter -->
                    <div>
                        <label class="block text-xs font-bold text-slate-500 uppercase mb-3">Trạng Thái Đơn</label>
                        <div class="flex flex-col gap-3">
                            <label class="flex items-center gap-2 cursor-pointer">
                                <input type="radio" name="status" value="all" class="text-primary focus:ring-primary w-4 h-4" @(ViewData["CurrentStatus"]?.ToString() == "all" || string.IsNullOrEmpty(ViewData["CurrentStatus"]?.ToString()) ? "checked" : "")>
                                <span class="text-sm text-slate-700 dark:text-slate-300">Tất Cả</span>
                            </label>
                            <label class="flex items-center gap-2 cursor-pointer">
                                <input type="radio" name="status" value="paid" class="text-primary focus:ring-primary w-4 h-4" @(ViewData["CurrentStatus"]?.ToString() == "paid" ? "checked" : "")>
                                <span class="text-sm text-slate-700 dark:text-slate-300 flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-emerald-500"></span>Đã Thanh Toán</span>
                            </label>
                            <label class="flex items-center gap-2 cursor-pointer">
                                <input type="radio" name="status" value="pending" class="text-primary focus:ring-primary w-4 h-4" @(ViewData["CurrentStatus"]?.ToString() == "pending" ? "checked" : "")>
                                <span class="text-sm text-slate-700 dark:text-slate-300 flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-amber-500"></span>Chờ Xử Lý</span>
                            </label>
                            <label class="flex items-center gap-2 cursor-pointer">
                                <input type="radio" name="status" value="cancelled" class="text-primary focus:ring-primary w-4 h-4" @(ViewData["CurrentStatus"]?.ToString() == "cancelled" ? "checked" : "")>
                                <span class="text-sm text-slate-700 dark:text-slate-300 flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-red-500"></span>Đã Hủy</span>
                            </label>
                            <label class="flex items-center gap-2 cursor-pointer">
                                <input type="radio" name="status" value="deleted" class="text-primary focus:ring-primary w-4 h-4" @(ViewData["CurrentStatus"]?.ToString() == "deleted" ? "checked" : "")>
                                <span class="text-sm text-slate-700 dark:text-slate-300 flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-rose-500"></span>Đã Bị Xóa</span>
                            </label>
                        </div>
                    </div>

                    <!-- Spacer -->
                    <div class="w-full h-px bg-slate-100 dark:bg-slate-800 my-2"></div>

                    <!-- Date Range Picker embed -->
                    <div>
                        <label class="block text-xs font-bold text-slate-500 uppercase mb-3">Thời Gian Đặt</label>
                        <div class="relative">
                            <button type="button" onclick="toggleBookingFilter('date-dropdown')" class="flex justify-between items-center w-full px-3 py-2 bg-slate-50 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700 rounded-xl text-sm text-slate-700 dark:text-slate-300 hover:border-primary transition-colors">
                                <div class="flex items-center gap-2">
                                    <span class="material-symbols-outlined text-slate-400 text-[16px]">calendar_today</span>
                                    <span id="date-label-small">@(string.IsNullOrEmpty(ViewData["CurrentStartDate"]?.ToString()) ? "Tùy chọn ngày..." : ViewData["CurrentStartDate"] + " - " + ViewData["CurrentEndDate"])</span>
                                </div>
                                <span class="material-symbols-outlined text-slate-400 text-[18px]">expand_more</span>
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Actions -->
                <div class="p-4 border-t border-slate-100 dark:border-slate-800 flex gap-2">
                    <button type="button" onclick="resetFilters()" class="flex-1 py-2 text-sm font-bold text-slate-500 hover:bg-slate-50 dark:hover:bg-slate-800 rounded-lg transition-colors">Đặt Lại</button>
                    <button type="submit" class="flex-1 py-2 text-sm font-bold text-white bg-primary hover:bg-primary-dark rounded-lg shadow-lg shadow-primary/30 transition-all">Áp Dụng</button>
                </div>

                <!-- Fly-out calendar -->
                <div id="date-dropdown" class="absolute right-[calc(100%+0.5rem)] top-0 w-80 bg-white dark:bg-slate-900 rounded-2xl shadow-2xl border border-slate-100 dark:border-slate-800 z-[60] hidden origin-right transition-all animate-scale-in">
                    <div class="p-5">
                        <div class="flex justify-between items-center mb-5">
                            <span class="text-sm font-bold text-slate-900 dark:text-white uppercase tracking-wider">Chọn Thời Gian</span>
                            <div class="flex gap-1 bg-slate-50 dark:bg-slate-800/50 p-1 rounded-lg">
                                 <button type="button" onclick="changeMonth(-1)" class="p-1 rounded-md hover:bg-white dark:hover:bg-slate-700 text-slate-500 hover:text-primary transition-all active:scale-95"><span class="material-symbols-outlined text-[20px]">chevron_left</span></button>
                                 <span id="calendar-month-year" class="text-xs font-bold text-slate-700 dark:text-slate-300 min-w-[100px] text-center flex items-center justify-center">Tháng 10, 2023</span>
                                 <button type="button" onclick="changeMonth(1)" class="p-1 rounded-md hover:bg-white dark:hover:bg-slate-700 text-slate-500 hover:text-primary transition-all active:scale-95"><span class="material-symbols-outlined text-[20px]">chevron_right</span></button>
                            </div>
                        </div>
                        <!-- Calendar Grid -->
                        <div class="grid grid-cols-7 gap-1 text-center mb-2 border-b border-slate-100 dark:border-slate-800 pb-2">
                            <span class="text-[10px] text-slate-400 font-extrabold uppercase">T2</span>
                            <span class="text-[10px] text-slate-400 font-extrabold uppercase">T3</span>
                            <span class="text-[10px] text-slate-400 font-extrabold uppercase">T4</span>
                            <span class="text-[10px] text-slate-400 font-extrabold uppercase">T5</span>
                            <span class="text-[10px] text-slate-400 font-extrabold uppercase">T6</span>
                            <span class="text-[10px] text-slate-400 font-extrabold uppercase">T7</span>
                            <span class="text-[10px] text-red-500 font-extrabold uppercase">CN</span>
                        </div>
                        <div id="calendar-days" class="grid grid-cols-7 gap-1 text-center mb-5">
                            <!-- Dynamic Days -->
                        </div>
                        
                        <div class="grid grid-cols-2 gap-3">
                             <button type="button" onclick="clearDateFilter()" class="py-2.5 text-xs font-bold text-slate-500 hover:text-slate-700 dark:hover:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-xl transition-all active:scale-95">Đặt Lại</button>
                             <button type="button" onclick="applyDateFilter()" class="py-2.5 text-xs font-bold text-white bg-primary hover:bg-primary-dark rounded-xl shadow-lg shadow-primary/20 transition-all active:scale-95">Xác Nhận</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="relative">
            <button type="button" onclick="toggleColumnMenu()" class="flex items-center justify-center size-10 rounded-xl bg-slate-50 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700 text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors">
                <span class="material-symbols-outlined text-[20px] text-slate-500">view_column</span>
            </button>
            <div id="column-menu" class="absolute right-0 top-full mt-2 w-48 bg-white dark:bg-slate-900 rounded-xl shadow-xl border border-slate-100 dark:border-slate-800 hidden origin-top-right transition-all menu-hidden animate-scale-in z-50 p-2">
                <label class="flex items-center gap-2 px-2 py-1.5 hover:bg-slate-50 dark:hover:bg-slate-800 rounded-lg cursor-pointer">
                    <input type="checkbox" checked onchange="toggleColumn('col-code')" class="text-primary focus:ring-primary rounded">
                    <span class="text-sm text-slate-700 dark:text-slate-300">Mã Đơn</span>
                </label>
                <label class="flex items-center gap-2 px-2 py-1.5 hover:bg-slate-50 dark:hover:bg-slate-800 rounded-lg cursor-pointer">
                    <input type="checkbox" checked onchange="toggleColumn('col-customer')" class="text-primary focus:ring-primary rounded">
                    <span class="text-sm text-slate-700 dark:text-slate-300">Khách Hàng</span>
                </label>
                <label class="flex items-center gap-2 px-2 py-1.5 hover:bg-slate-50 dark:hover:bg-slate-800 rounded-lg cursor-pointer">
                    <input type="checkbox" checked onchange="toggleColumn('col-tour')" class="text-primary focus:ring-primary rounded">
                    <span class="text-sm text-slate-700 dark:text-slate-300">Tour</span>
                </label>
                <label class="flex items-center gap-2 px-2 py-1.5 hover:bg-slate-50 dark:hover:bg-slate-800 rounded-lg cursor-pointer">
                    <input type="checkbox" checked onchange="toggleColumn('col-quantity')" class="text-primary focus:ring-primary rounded">
                    <span class="text-sm text-slate-700 dark:text-slate-300">Số Lượng</span>
                </label>
                <label class="flex items-center gap-2 px-2 py-1.5 hover:bg-slate-50 dark:hover:bg-slate-800 rounded-lg cursor-pointer">
                    <input type="checkbox" checked onchange="toggleColumn('col-total')" class="text-primary focus:ring-primary rounded">
                    <span class="text-sm text-slate-700 dark:text-slate-300">Tổng Tiền</span>
                </label>
                <label class="flex items-center gap-2 px-2 py-1.5 hover:bg-slate-50 dark:hover:bg-slate-800 rounded-lg cursor-pointer">
                    <input type="checkbox" checked onchange="toggleColumn('col-payment')" class="text-primary focus:ring-primary rounded">
                    <span class="text-sm text-slate-700 dark:text-slate-300">Thanh Toán</span>
                </label>
                <label class="flex items-center gap-2 px-2 py-1.5 hover:bg-slate-50 dark:hover:bg-slate-800 rounded-lg cursor-pointer">
                    <input type="checkbox" checked onchange="toggleColumn('col-status')" class="text-primary focus:ring-primary rounded">
                    <span class="text-sm text-slate-700 dark:text-slate-300">Trạng Thái</span>
                </label>
                <label class="flex items-center gap-2 px-2 py-1.5 hover:bg-slate-50 dark:hover:bg-slate-800 rounded-lg cursor-pointer">
                    <input type="checkbox" onchange="toggleColumn('col-deleted-by')" class="text-primary focus:ring-primary rounded">
                    <span class="text-sm text-slate-700 dark:text-slate-300">Người Xóa</span>
                </label>
                <label class="flex items-center gap-2 px-2 py-1.5 hover:bg-slate-50 dark:hover:bg-slate-800 rounded-lg cursor-pointer">
                    <input type="checkbox" onchange="toggleColumn('col-deleted-at')" class="text-primary focus:ring-primary rounded">
                    <span class="text-sm text-slate-700 dark:text-slate-300">Thời Gian Xóa</span>
                </label>
            </div>
        </div>
    </div>
</form>

<!-- Bookings Table -->
<div data-animate="fade-in-up" data-delay="0.3" class="bg-white dark:bg-surface-dark rounded-2xl shadow-sm border border-slate-100 dark:border-slate-800 overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-slate-50/50 dark:bg-slate-800/50 text-slate-500 dark:text-slate-400 text-xs uppercase tracking-wider font-bold">
                    <th class="p-4 pl-6 text-center w-10">
                        <label class="flex items-center justify-center cursor-pointer group">
                            <input type="checkbox" onchange="toggleSelectAll(this)" class="w-4 h-4 rounded border-slate-300 text-primary focus:ring-primary dark:bg-slate-800 dark:border-slate-700 transition-all cursor-pointer">
                        </label>
                    </th>
                    <th class="p-4 cursor-pointer hover:text-primary transition-colors select-none col-code" onclick="applySort('@ViewBag.DateSortParm')">
                        <div class="flex items-center gap-1">
                            Mã Đơn
                             @if(string.IsNullOrEmpty(ViewBag.CurrentSort)) {
                                <span class="material-symbols-outlined text-[16px]">arrow_downward</span>
                            } else if (ViewBag.CurrentSort == "date_asc") {
                                 <span class="material-symbols-outlined text-[16px] text-primary">arrow_upward</span>
                            } else {
                                <span class="material-symbols-outlined text-[16px] opacity-30">unfold_more</span>
                            }
                        </div>
                    </th>
                    <th class="p-4 col-customer">Khách hàng</th>
                    <th class="p-4 col-tour">Tour</th>
                    <th class="p-4 text-center col-quantity">Số lượng</th>
                    <th class="p-4 cursor-pointer hover:text-primary transition-colors select-none col-total" onclick="applySort('@ViewBag.TotalSortParm')">
                         <div class="flex items-center gap-1">
                            Tổng tiền
                            @if (ViewBag.CurrentSort == "total") {
                                <span class="material-symbols-outlined text-[16px] text-primary">arrow_upward</span>
                            } else if (ViewBag.CurrentSort == "total_desc") {
                                 <span class="material-symbols-outlined text-[16px] text-primary">arrow_downward</span>
                            } else {
                                <span class="material-symbols-outlined text-[16px] opacity-30">unfold_more</span>
                            }
                        </div>
                    </th>
                    <th class="p-4 col-payment">Thanh toán</th>
                    <th class="p-4 cursor-pointer hover:text-primary transition-colors select-none col-status" onclick="applySort('@ViewBag.StatusSortParm')">
                         <div class="flex items-center gap-1">
                            Trạng thái
                            @if (ViewBag.CurrentSort == "status") {
                                <span class="material-symbols-outlined text-[16px] text-primary">arrow_upward</span>
                            } else if (ViewBag.CurrentSort == "status_desc") {
                                 <span class="material-symbols-outlined text-[16px] text-primary">arrow_downward</span>
                            } else {
                                <span class="material-symbols-outlined text-[16px] opacity-30">unfold_more</span>
                            }
                        </div>
                    </th>
                    <th class="p-4 col-deleted-by col-collapsed">Người xóa</th>
                    <th class="p-4 col-deleted-at col-collapsed">Thời gian xóa</th>
                    <th class="p-4 pr-6 text-right">Thao tác</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 dark:divide-slate-800 text-sm">
                @foreach (var item in Model.Items)
                {
                    var isDeletedRow = item.IsDeleted;
                    <tr class="group transition-colors @(isDeletedRow ? "bg-red-50/30 dark:bg-rose-900/10 opacity-75 grayscale-[0.2]" : "hover:bg-slate-50 dark:hover:bg-slate-800/50")">
                        <td class="p-4 pl-6 text-center w-10">
                            <label class="flex items-center justify-center cursor-pointer">
                                <input type="checkbox" class="booking-checkbox w-4 h-4 rounded border-slate-300 text-primary focus:ring-primary dark:bg-slate-800 dark:border-slate-700 transition-all cursor-pointer" value="@item.Id" onchange="updateBulkState()">
                            </label>
                        </td>
                        <td class="p-4 font-mono font-semibold text-primary col-code">#@item.BookingCode</td>
                        <td class="p-4 col-customer">
                            <div class="flex items-center gap-3">
                                <div class="w-9 h-9 rounded-full bg-primary/10 flex items-center justify-center text-primary font-bold text-xs uppercase border-2 border-white dark:border-slate-700 shadow-sm">
                                    @if (!string.IsNullOrEmpty(item.ContactInfo?.Name) && item.ContactInfo.Name.Length >= 2)
                                    {
                                        @item.ContactInfo.Name.Substring(0, 2)
                                    }
                                    else
                                    {
                                        <span>KH</span>
                                    }
                                </div>
                                <div>
                                    <p class="font-bold @(isDeletedRow ? "text-slate-500 dark:text-slate-400 line-through decoration-red-500/70 decoration-2" : "text-slate-900 dark:text-white")">@item.ContactInfo?.Name</p>
                                    <p class="text-xs text-slate-500">@item.ContactInfo?.Email</p>
                                </div>
                            </div>
                        </td>
                        <td class="p-4 col-tour">
                            <p class="font-medium text-slate-700 dark:text-slate-300">@item.TourSnapshot?.Name</p>
                            <p class="text-xs text-slate-400">Khởi hành: @(item.TourSnapshot?.StartDate?.ToString("dd/MM/yyyy") ?? "Đang cập nhật...")</p>
                        </td>
                        <td class="p-4 text-center font-medium col-quantity">@item.ParticipantsCount</td>
                        <td class="p-4 font-bold text-slate-900 dark:text-white col-total">@item.TotalAmount.ToString("N0") ₫</td>
                        <td class="p-4 col-payment">
                           <div class="flex items-center gap-2">
                                <div class="w-6 h-6 rounded bg-slate-100 dark:bg-slate-700 flex items-center justify-center">
                                    <span class="material-symbols-outlined text-xs">payments</span>
                                </div>
                                <span class="text-xs font-medium text-slate-600 dark:text-slate-400">@GetStatusVietnamese(item.PaymentStatus)</span>
                            </div>
                        </td>
                        <td class="p-4 col-status">
                            @if (item.IsDeleted)
                            {
                                <div class="relative group/tooltip">
                                    <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[11px] font-bold bg-rose-100 text-rose-700 dark:bg-rose-900/30 dark:text-rose-400 border border-rose-200 dark:border-rose-900">
                                        <span class="w-1.5 h-1.5 rounded-full bg-rose-500 animate-pulse"></span> Đã Xóa
                                    </span>
                                    <div class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 w-48 p-2 bg-slate-900 text-white text-[10px] rounded-lg shadow-xl opacity-0 invisible group-hover/tooltip:opacity-100 group-hover/tooltip:visible transition-all z-50">
                                        <p class="font-bold border-b border-slate-700 pb-1 mb-1">Thông tin xóa</p>
                                        <p>Bởi: <span class="text-rose-400">@item.DeletedBy</span></p>
                                        <p>Lúc: <span class="text-rose-400">@(item.DeletedAt?.ToString("dd/MM/yyyy HH:mm"))</span></p>
                                        <div class="absolute top-full left-1/2 -translate-x-1/2 border-8 border-transparent border-t-slate-900"></div>
                                    </div>
                                </div>
                            }
                            else
                            {
                                var statusClass = item.Status switch {
                                    "Paid" or "Completed" or "Confirmed" => "bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400 border-green-200 dark:border-green-900",
                                    "Pending" => "bg-yellow-100 text-yellow-700 dark:bg-yellow-900/30 dark:text-yellow-400 border-yellow-200 dark:border-yellow-900",
                                    "Cancelled" => "bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-400 border-red-200 dark:border-red-900",
                                    _ => "bg-slate-100 text-slate-700 dark:bg-slate-800 dark:text-slate-300 border-slate-200 dark:border-slate-700"
                                };
                                var dotClass = item.Status switch {
                                    "Paid" or "Completed" or "Confirmed" => "bg-green-500",
                                    "Pending" => "bg-yellow-500",
                                    "Cancelled" => "bg-red-500",
                                    _ => "bg-slate-500"
                                };
                                <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[11px] font-bold @statusClass border">
                                    <span class="w-1.5 h-1.5 rounded-full @dotClass"></span> @GetStatusVietnamese(item.Status)
                                </span>
                            }
                        </td>
                        <td class="p-4 text-xs font-medium text-slate-600 dark:text-slate-400 col-deleted-by col-collapsed">
                            @(isDeletedRow ? item.DeletedBy : "-")
                        </td>
                        <td class="p-4 text-xs text-slate-500 col-deleted-at col-collapsed">
                            @(isDeletedRow && item.DeletedAt.HasValue ? item.DeletedAt.Value.ToString("dd/MM/yyyy HH:mm") : "-")
                        </td>
                        <td class="p-4 pr-6 text-right">
                            <div class="flex items-center justify-end gap-2">
                                <a asp-action="Details" asp-route-id="@item.Id" class="w-8 h-8 rounded-lg flex items-center justify-center bg-slate-100 hover:bg-slate-200 dark:bg-slate-800 dark:hover:bg-slate-700 text-slate-600 dark:text-slate-400 transition-colors" title="Xem chi tiết">
                                    <span class="material-symbols-outlined text-lg">visibility</span>
                                </a>
                                @if (!isDeletedRow)
                                {
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="w-8 h-8 rounded-lg flex items-center justify-center bg-blue-50 hover:bg-blue-100 dark:bg-blue-900/30 dark:hover:bg-blue-900/50 text-blue-600 dark:text-blue-400 transition-colors" title="Chỉnh sửa">
                                        <span class="material-symbols-outlined text-lg">edit</span>
                                    </a>
                                    <form id="delete-form-@item.Id" asp-area="Admin" asp-controller="Bookings" asp-action="Delete" asp-route-id="@item.Id" method="post" class="inline">
                                        <button type="button" onclick="confirmDelete('@item.Id', '@item.BookingCode')" class="w-8 h-8 rounded-lg flex items-center justify-center bg-red-50 hover:bg-red-100 dark:bg-red-900/30 dark:hover:bg-red-900/50 text-red-600 dark:text-red-400 transition-colors" title="Xóa">
                                            <span class="material-symbols-outlined text-lg">delete</span>
                                        </button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    
    <!-- Pagination -->
    <div class="p-6 border-t border-slate-100 dark:border-slate-800 flex flex-col sm:flex-row justify-between items-center gap-4 bg-slate-50/30 dark:bg-slate-800/20">
        @{
            var startItem = (Model.PageIndex - 1) * Model.PageSize + 1;
            var endItem = Math.Min(Model.PageIndex * Model.PageSize, Model.TotalCount);
            int[] pageSizes = { 10, 15, 20, 50, 100 };
            int currentPageSize = (int?)ViewData["CurrentPageSize"] ?? 10;
        }
        <div class="flex items-center gap-4">
             <p class="text-xs text-slate-500 dark:text-slate-400">Hiển thị <span class="font-bold text-slate-900 dark:text-white">@startItem - @endItem</span> trong số <span class="font-bold text-slate-900 dark:text-white">@Model.TotalCount</span> Vé</p>
             <div class="flex items-center gap-2">
                 <label for="pageSize" class="text-xs font-medium text-slate-500 dark:text-slate-400">Hiển thị:</label>
                 <div class="relative group">
                     <select id="pageSize" onchange="changePageSize(this.value)" 
                             class="appearance-none h-9 pl-3 pr-10 py-1 text-xs font-bold bg-white dark:bg-surface-dark border border-slate-200 dark:border-slate-700 text-slate-700 dark:text-slate-200 rounded-lg focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none transition-all cursor-pointer shadow-sm hover:border-primary/50">
                         @foreach(var size in pageSizes)
                         {
                             <option value="@size" selected="@(size == currentPageSize)">@size</option>
                         }
                     </select>
                     <span class="absolute right-2.5 top-1/2 -translate-y-1/2 pointer-events-none text-slate-400 group-hover:text-primary transition-colors flex items-center">
                        <span class="material-symbols-outlined text-[18px]">expand_more</span>
                    </span>
                 </div>
             </div>
        </div>

        <div class="flex items-center gap-2">
            <button onclick="location.href='@Url.Action("Index", new { page = Model.PageIndex - 1, status = ViewData["CurrentStatus"], pageSize = currentPageSize, searchString = ViewData["CurrentSearch"], startDate = ViewData["CurrentStartDate"], endDate = ViewData["CurrentEndDate"] })'" @(Model.HasPreviousPage ? "" : "disabled") class="p-2 rounded-lg border border-slate-200 dark:border-slate-700 text-slate-400 hover:bg-white dark:hover:bg-slate-800 transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
                <span class="material-symbols-outlined text-lg">chevron_left</span>
            </button>
            
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                if (Math.Abs(i - Model.PageIndex) <= 2 || i == 1 || i == Model.TotalPages)
                {
                    <button onclick="location.href='@Url.Action("Index", new { page = i, status = ViewData["CurrentStatus"], pageSize = currentPageSize, searchString = ViewData["CurrentSearch"], startDate = ViewData["CurrentStartDate"], endDate = ViewData["CurrentEndDate"] })'" 
                            class="w-8 h-8 rounded-lg @(i == Model.PageIndex ? "bg-primary text-white shadow-sm shadow-primary/30" : "hover:bg-white dark:hover:bg-slate-800 text-slate-600 dark:text-slate-400") text-xs font-bold transition-colors">@i</button>
                }
                else if (Math.Abs(i - Model.PageIndex) == 3)
                {
                    <span class="text-slate-400 text-xs">...</span>
                }
            }

            <button onclick="location.href='@Url.Action("Index", new { page = Model.PageIndex + 1, status = ViewData["CurrentStatus"], pageSize = currentPageSize, searchString = ViewData["CurrentSearch"], startDate = ViewData["CurrentStartDate"], endDate = ViewData["CurrentEndDate"] })'" @(Model.HasNextPage ? "" : "disabled") class="p-2 rounded-lg border border-slate-200 dark:border-slate-700 text-slate-400 hover:bg-white dark:hover:bg-slate-800 transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
                <span class="material-symbols-outlined text-lg">chevron_right</span>
            </button>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div id="deleteModal" class="fixed inset-0 z-[100] hidden" aria-labelledby="modal-title" role="dialog" aria-modal="true">
    <div class="fixed inset-0 bg-slate-900/50 backdrop-blur-sm transition-opacity opacity-0 duration-300" id="deleteModalOverlay" onclick="closeDeleteModal()"></div>
    
    <div class="fixed inset-0 z-10 overflow-y-auto pointer-events-none">
        <div class="flex min-h-full items-end justify-center p-4 text-center sm:items-center sm:p-0">
            <div id="deleteModalPanel" class="relative transform overflow-hidden rounded-2xl bg-white dark:bg-surface-dark text-left shadow-2xl transition-all duration-300 opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95 border border-slate-100 dark:border-slate-800 pointer-events-auto sm:my-8 sm:w-full sm:max-w-lg">
                <div class="px-6 pt-6 pb-4">
                    <div class="sm:flex sm:items-start">
                        <div class="mx-auto flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-full bg-red-100 dark:bg-red-900/30 sm:mx-0 sm:h-10 sm:w-10">
                            <span class="material-symbols-outlined text-red-600 dark:text-red-400 text-xl">warning</span>
                        </div>
                        <div class="mt-3 text-center sm:ml-4 sm:mt-0 sm:text-left">
                            <h3 class="text-lg font-bold leading-6 text-slate-900 dark:text-white" id="modal-title">Xác nhận xóa mềm</h3>
                            <div class="mt-2 text-sm text-slate-500 dark:text-slate-400">
                                <p>Bạn có chắc chắn muốn xóa đơn đặt vé <span id="deleteModalCode" class="font-bold text-slate-900 dark:text-white"></span> không?</p>
                                <p class="mt-1">Dữ liệu này sẽ được chuyển sang trạng thái "Đã bị xóa" và có thể khôi phục lại khi cần thiết.</p>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="bg-slate-50 dark:bg-slate-800/50 px-6 py-4 flex items-center justify-end gap-3 border-t border-slate-100 dark:border-slate-800">
                    <button type="button" onclick="closeDeleteModal()" class="px-4 py-2 text-sm font-bold text-slate-700 dark:text-slate-300 hover:bg-slate-200 dark:hover:bg-slate-700 rounded-lg transition-colors">Hủy</button>
                    <button type="button" onclick="executeDelete()" class="px-4 py-2 text-sm font-bold text-white bg-red-600 hover:bg-red-700 rounded-lg shadow-lg shadow-red-600/20 transition-all">Xác nhận xóa</button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Bulk Actions Bar -->
<div id="bulk-actions" class="fixed bottom-8 left-1/2 -translate-x-1/2 z-[100] max-w-[calc(100vw-2rem)] bg-white/95 dark:bg-slate-800 text-slate-900 dark:text-white px-6 py-4 rounded-2xl shadow-2xl flex items-center gap-4 border border-slate-200/80 dark:border-slate-700/50 backdrop-blur-xl translate-y-32 opacity-0 transition-all duration-500 invisible">
    <div class="flex items-center gap-3 pr-4 border-r border-slate-200 dark:border-slate-700">
        <div class="w-8 h-8 rounded-full bg-primary flex items-center justify-center text-sm font-bold" id="selected-count">0</div>
        <span class="text-sm font-medium text-slate-600 dark:text-slate-300">Đã chọn</span>
    </div>
    
    <div class="flex flex-wrap items-center justify-center gap-2">
        <button type="button" onclick="handleBulkAction('BulkUpdateStatus', 'Confirmed')" class="flex items-center gap-2 px-3 py-2 rounded-xl hover:bg-slate-100 dark:hover:bg-slate-700 text-slate-600 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white transition-all group">
            <span class="material-symbols-outlined text-[20px] group-hover:scale-110 transition-transform">check_circle</span>
            <span class="text-sm font-bold italic">Xác nhận</span>
        </button>
        <button type="button" onclick="handleBulkAction('BulkUpdateStatus', 'Completed')" class="flex items-center gap-2 px-3 py-2 rounded-xl hover:bg-slate-100 dark:hover:bg-slate-700 text-slate-600 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white transition-all group">
            <span class="material-symbols-outlined text-[20px] group-hover:scale-110 transition-transform">task_alt</span>
            <span class="text-sm font-bold italic">Hoàn thành</span>
        </button>
        <button type="button" onclick="handleBulkAction('BulkUpdateStatus', 'Cancelled')" class="flex items-center gap-2 px-3 py-2 rounded-xl hover:bg-slate-100 dark:hover:bg-slate-700 text-slate-600 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white transition-all group">
            <span class="material-symbols-outlined text-[20px] group-hover:scale-110 transition-transform">cancel</span>
            <span class="text-sm font-bold italic">Hủy đơn</span>
        </button>
        <button type="button" onclick="handleBulkAction('BulkDelete')" class="flex items-center gap-2 px-3 py-2 rounded-xl hover:bg-red-500/20 text-red-400 hover:text-red-300 transition-all group">
            <span class="material-symbols-outlined text-[20px] group-hover:scale-110 transition-transform">delete</span>
            <span class="text-sm font-bold italic">Xóa mục đã chọn</span>
        </button>
    </div>

    <button type="button" onclick="clearSelection()" class="p-2 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-700 text-slate-400 hover:text-slate-900 dark:hover:text-white transition-colors">
        <span class="material-symbols-outlined text-[20px]">close</span>
    </button>
</div>

<!-- Hidden Bulk Form -->
<form id="bulk-form" method="post" class="hidden">
    @Html.AntiForgeryToken()
</form>

@section Scripts {
    <script>
        const bulkActionUrls = {
            BulkDelete: '@Url.Action("BulkDelete", "Bookings", new { area = "Admin" })',
            BulkUpdateStatus: '@Url.Action("BulkUpdateStatus", "Bookings", new { area = "Admin" })'
        };

        // Multi-select & Bulk actions
        function toggleSelectAll(master) {
            const checkboxes = document.querySelectorAll('.booking-checkbox');
            checkboxes.forEach(cb => {
                cb.checked = master.checked;
            });
            updateBulkState();
        }

        function updateBulkState() {
            const checkboxes = document.querySelectorAll('.booking-checkbox:checked');
            const bulkBar = document.getElementById('bulk-actions');
            const countLabel = document.getElementById('selected-count');
            
            if (checkboxes.length > 0) {
                countLabel.innerText = checkboxes.length;
                bulkBar.classList.remove('translate-y-32', 'opacity-0', 'invisible');
                bulkBar.classList.add('translate-y-0', 'opacity-100', 'visible');
            } else {
                bulkBar.classList.add('translate-y-32', 'opacity-0', 'invisible');
                bulkBar.classList.remove('translate-y-0', 'opacity-100', 'visible');
            }
        }

        function clearSelection() {
            const master = document.querySelector('thead input[type="checkbox"]');
            if (master) master.checked = false;
            
            const checkboxes = document.querySelectorAll('.booking-checkbox');
            checkboxes.forEach(cb => cb.checked = false);
            updateBulkState();
        }

        function handleBulkAction(action, param = null) {
            const selectedIds = Array.from(document.querySelectorAll('.booking-checkbox:checked'))
                .map(cb => cb.value)
                .filter(id => id && id.length === 24);

            if (selectedIds.length === 0) {
                alert('Vui lòng chọn ít nhất một mục hợp lệ.');
                return;
            }

            const confirmMsg = action === 'BulkDelete' 
                ? `Bạn có chắc chắn muốn xóa ${selectedIds.length} mục đã chọn?` 
                : `Bạn có chắc chắn muốn cập nhật trạng thái cho ${selectedIds.length} mục đã chọn?`;

            if (!confirm(confirmMsg)) return;

            const form = document.getElementById('bulk-form');
            const existingToken = form.querySelector('input[name="__RequestVerificationToken"]')?.value
                || document.querySelector('input[name="__RequestVerificationToken"]')?.value;

            if (!existingToken) {
                console.error('Missing antiforgery token for bulk booking action.');
                return;
            }

            const actionUrl = bulkActionUrls[action];
            if (!actionUrl) {
                console.error(`Unknown bulk booking action: ${action}`);
                return;
            }

            form.action = actionUrl;
            form.innerHTML = '';
            
            // Re-add Antiforgery Token
            const tokenInput = document.createElement('input');
            tokenInput.type = 'hidden';
            tokenInput.name = '__RequestVerificationToken';
            tokenInput.value = existingToken;
            form.appendChild(tokenInput);
            
            selectedIds.forEach(id => {
                const input = document.createElement('input');
                input.type = 'hidden';
                input.name = 'ids';
                input.value = id;
                form.appendChild(input);
            });

            if (param) {
                const statusInput = document.createElement('input');
                statusInput.type = 'hidden';
                statusInput.name = 'newStatus';
                statusInput.value = param;
                form.appendChild(statusInput);
            }

            form.submit();
        }

        let currentDeleteId = null;

        function confirmDelete(id, code) {
            currentDeleteId = id;
            document.getElementById('deleteModalCode').textContent = '#' + code;
            
            const modal = document.getElementById('deleteModal');
            const overlay = document.getElementById('deleteModalOverlay');
            const panel = document.getElementById('deleteModalPanel');
            
            modal.classList.remove('hidden');
            
            // Trigger reflow
            void modal.offsetWidth;
            
            overlay.classList.remove('opacity-0');
            panel.classList.remove('opacity-0', 'translate-y-4', 'sm:translate-y-0', 'sm:scale-95');
            panel.classList.add('opacity-100', 'translate-y-0', 'sm:scale-100');
        }

        function closeDeleteModal() {
            const modal = document.getElementById('deleteModal');
            const overlay = document.getElementById('deleteModalOverlay');
            const panel = document.getElementById('deleteModalPanel');
            
            overlay.classList.add('opacity-0');
            panel.classList.remove('opacity-100', 'translate-y-0', 'sm:scale-100');
            panel.classList.add('opacity-0', 'translate-y-4', 'sm:translate-y-0', 'sm:scale-95');
            
            setTimeout(() => {
                modal.classList.add('hidden');
                currentDeleteId = null;
            }, 300);
        }

        function executeDelete() {
            if (currentDeleteId) {
                const form = document.getElementById('delete-form-' + currentDeleteId);
                if (form) {
                    form.submit();
                }
            }
        }

        function toggleColumn(colClass) {
            const cols = document.querySelectorAll('.' + colClass);
            cols.forEach(col => col.classList.toggle('col-collapsed'));
        }
        
        function toggleColumnMenu() {
            const menu = document.getElementById('column-menu');
            if (!menu) return;
            window.AdminMenu?.toggle(menu);
        }

        // Close dropdowns when clicking outside
        document.addEventListener('click', function(event) {
            // Filter Menu
            const filterMenu = document.getElementById('filter-menu');
            const filterBtn = event.target.closest('button[onclick="toggleFilterMenu()"]');
            const insideFilter = event.target.closest('#filter-menu');

            if (filterMenu && !filterBtn && !insideFilter && filterMenu.classList.contains('menu-visible')) {
                window.AdminMenu?.close(filterMenu);
            }

            // Column Menu
            const colMenu = document.getElementById('column-menu');
            const colBtn = event.target.closest('button[onclick="toggleColumnMenu()"]');
            const insideCol = event.target.closest('#column-menu');
            if (colMenu && !colBtn && !insideCol && colMenu.classList.contains('menu-visible')) {
                window.AdminMenu?.close(colMenu);
            }

            // Date Dropdown (Fly-out Calendar)
            const dateMenu = document.getElementById('date-dropdown');
            const dateBtn = event.target.closest('button[onclick*="toggleBookingFilter(\'date-dropdown\')"]');
            const insideDate = event.target.closest('#date-dropdown');
            if (dateMenu && !dateBtn && !insideDate && dateMenu.classList.contains('menu-visible')) {
                window.AdminMenu?.close(dateMenu);
            }
        });

        function toggleFilterMenu() {
            const menu = document.getElementById('filter-menu');
            if (!menu) return;
            window.AdminMenu?.toggle(menu);
        }

        function filterByCard(type) {
            const form = document.getElementById('filter-form');
            if (!form) return;

            // Reset other filters first
            const searchInput = form.querySelector('input[name="searchString"]');
            if (searchInput) searchInput.value = '';
            document.getElementById('startDate-input').value = '';
            document.getElementById('endDate-input').value = '';
            
            const statusRadios = form.querySelectorAll('input[name="status"]');
            
            if (type === 'today') {
                const now = new Date();
                const year = now.getFullYear();
                const month = (now.getMonth() + 1).toString().padStart(2, '0');
                const day = now.getDate().toString().padStart(2, '0');
                const dateStr = `${year}-${month}-${day}`;
                
                document.getElementById('startDate-input').value = dateStr;
                document.getElementById('endDate-input').value = dateStr;
                if (statusRadios.length > 0) statusRadios[0].checked = true;
            } else if (type === 'pending') {
                statusRadios.forEach(r => {
                    if (r.value === 'pending') r.checked = true;
                });
            } else if (type === 'refund') {
                let statusInput = form.querySelector('input[name="status"][value="refunded"]');
                if (!statusInput) {
                    statusInput = document.createElement('input');
                    statusInput.type = 'hidden';
                    statusInput.name = 'status';
                    statusInput.value = 'refunded';
                    form.appendChild(statusInput);
                } else {
                    statusInput.checked = true;
                }
            }

            form.submit();
        }

        function resetFilters() {
            const form = document.getElementById('filter-form');
            const searchInput = form.querySelector('input[name="searchString"]');
            if (searchInput) searchInput.value = '';
            document.getElementById('startDate-input').value = '';
            document.getElementById('endDate-input').value = '';
            const statusRadios = form.querySelectorAll('input[name="status"]');
            if (statusRadios.length > 0) statusRadios[0].checked = true;
            
            const dynamicStatus = form.querySelector('input[type="hidden"][name="status"]');
            if (dynamicStatus) dynamicStatus.remove();

            form.submit();
        }

        function toggleBookingFilter(id) {
            const el = document.getElementById(id);
            if (!el) return;
            
            if (el.classList.contains('menu-visible')) {
                window.AdminMenu?.close(el);
            } else {
                window.AdminMenu?.open(el);
            }
        }

        function changePageSize(size) {
            const url = new URL(window.location.href);
            url.searchParams.set('pageSize', size);
            url.searchParams.set('page', 1);
            window.location.href = url.toString();
        }

        function clearDateFilter() {
             document.getElementById('startDate-input').value = '';
             document.getElementById('endDate-input').value = '';
             const smallLbl = document.getElementById('date-label-small');
             if (smallLbl) smallLbl.innerText = "Chọn khoảng ngày...";
             
             selectedStartDate = null;
             selectedEndDate = null;
             
             const dateMenu = document.getElementById('date-dropdown');
             if (dateMenu && dateMenu.classList.contains('menu-visible')) {
                  window.AdminMenu?.close(dateMenu);
             }
             renderCalendar();
        }

        // Calendar Logic
        let currentDate = new Date();
        let selectedStartDate = null;
        let selectedEndDate = null;

        document.addEventListener('DOMContentLoaded', function() {
            const startVal = document.getElementById('startDate-input').value;
            const endVal = document.getElementById('endDate-input').value;
            if (startVal) selectedStartDate = new Date(startVal);
            if (endVal) selectedEndDate = new Date(endVal);
            renderCalendar();
        });

        function renderCalendar() {
            const monthYearEl = document.getElementById('calendar-month-year');
            const daysEl = document.getElementById('calendar-days');
            if (!daysEl || !monthYearEl) return;

            const year = currentDate.getFullYear();
            const month = currentDate.getMonth();
            const monthNames = ["Tháng 1", "Tháng 2", "Tháng 3", "Tháng 4", "Tháng 5", "Tháng 6", "Tháng 7", "Tháng 8", "Tháng 9", "Tháng 10", "Tháng 11", "Tháng 12"];
            monthYearEl.innerText = `${monthNames[month]}, ${year}`;

            daysEl.innerHTML = "";
            const firstDay = new Date(year, month, 1).getDay();
            const startOffset = (firstDay + 6) % 7; 
            const daysInMonth = new Date(year, month + 1, 0).getDate();
            const prevMonthDays = new Date(year, month, 0).getDate();

            for (let i = 0; i < startOffset; i++) {
                const dayNum = prevMonthDays - startOffset + 1 + i;
                const span = document.createElement('span');
                span.className = "h-8 w-8 flex items-center justify-center text-xs text-slate-300 dark:text-slate-600";
                span.innerText = dayNum;
                daysEl.appendChild(span);
            }

            for (let i = 1; i <= daysInMonth; i++) {
                const btn = document.createElement('button');
                btn.type = "button";
                const d = new Date(year, month, i);
                
                let className = "h-8 w-8 rounded-lg text-sm flex items-center justify-center transition-all ";
                
                const isSelectedStart = selectedStartDate && d.toDateString() === selectedStartDate.toDateString();
                const isSelectedEnd = selectedEndDate && d.toDateString() === selectedEndDate.toDateString();
                const isInRange = selectedStartDate && selectedEndDate && d > selectedStartDate && d < selectedEndDate;

                if (isSelectedStart || isSelectedEnd) {
                    className += "bg-primary text-white font-bold shadow-sm shadow-primary/30";
                } else if (isInRange) {
                    className += "bg-primary/20 text-primary font-medium";
                } else {
                    className += "hover:bg-slate-100 dark:hover:bg-slate-800 text-slate-700 dark:text-slate-300";
                }

                const today = new Date();
                if (i === today.getDate() && month === today.getMonth() && year === today.getFullYear()) {
                    btn.classList.add('ring-1', 'ring-primary', 'ring-inset');
                }

                btn.className = className;
                btn.innerText = i;
                
                btn.onclick = (e) => {
                    e.stopPropagation();
                    if (!selectedStartDate || (selectedStartDate && selectedEndDate)) {
                        selectedStartDate = d;
                        selectedEndDate = null;
                    } else if (selectedStartDate && !selectedEndDate) {
                        if (d < selectedStartDate) {
                            selectedEndDate = selectedStartDate;
                            selectedStartDate = d;
                        } else {
                            selectedEndDate = d;
                        }
                    }
                    renderCalendar();
                };

                daysEl.appendChild(btn);
            }
        }

        function changeMonth(offset) {
            currentDate.setMonth(currentDate.getMonth() + offset);
            renderCalendar();
        }
        
        function applyDateFilter() {
            if (selectedStartDate) {
                const formatDate = (date) => {
                    const day = date.getDate().toString().padStart(2, '0');
                    const month = (date.getMonth() + 1).toString().padStart(2, '0');
                    const year = date.getFullYear();
                    return { display: `${day}/${month}/${year}`, value: `${year}-${month}-${day}` };
                };

                const start = formatDate(selectedStartDate);
                const end = selectedEndDate ? formatDate(selectedEndDate) : start;

                const displayStr = selectedEndDate && selectedStartDate.toDateString() !== selectedEndDate.toDateString() 
                    ? `${start.display} - ${end.display}` 
                    : start.display;

                const smallLbl = document.getElementById('date-label-small');
                if (smallLbl) smallLbl.innerText = displayStr;
                
                document.getElementById('startDate-input').value = start.value;
                document.getElementById('endDate-input').value = end.value;
            }
            toggleBookingFilter('date-dropdown');
        }

        renderCalendar();

        function applySort(sortOrder) {
            const form = document.getElementById('filter-form');
            let input = document.getElementById('sortOrder-input');
            if (!input) {
                input = document.createElement('input');
                input.type = 'hidden';
                input.name = 'sortOrder';
                input.id = 'sortOrder-input';
                form.appendChild(input);
            }
            input.value = sortOrder;
            form.submit();
        }
    </script>
}
