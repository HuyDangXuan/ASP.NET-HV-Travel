@model HVTravel.Domain.Entities.Tour
@{
    ViewData["Title"] = "Chỉnh sửa Tour";
    
    string GetStatusText(string status) => status switch
    {
        "Draft" => "Bản nháp",
        "Active" => "Hoạt động",
        "SoldOut" => "Hết chỗ",
        "ComingSoon" => "Sắp ra mắt",
        "Hidden" => "Ẩn",
        _ => status
    };

}

<style type="text/tailwindcss">
    @@layer components {
        .input-field {
            @@apply w-full bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl h-14 px-4 text-[#111718] dark:text-white font-semibold focus:ring-2 focus:ring-primary/50 transition-all placeholder:text-[#618389]/50 shadow-sm;
        }
        .section-card {
            @@apply bg-white dark:bg-surface-dark rounded-2xl border border-[#f0f4f4] dark:border-slate-800 p-6 shadow-sm space-y-6;
        }
        .label-text {
            @@apply text-[#111718] dark:text-white text-sm font-bold uppercase tracking-wider mb-2 block;
        }
    }
</style>
<link rel="stylesheet" href="~/css/admin-tour-date-picker.css" asp-append-version="true" />

<form id="edit-tour-form" asp-action="Edit" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data">
<input type="hidden" asp-for="Id" />
<input type="hidden" asp-for="Version" />
<div class="pb-24">
    <div class="flex flex-col gap-1 mb-10">
        @await Html.PartialAsync("_AdminBreadcrumb", new HVTravel.Web.Models.BreadcrumbViewModel
        {
            Items = new List<HVTravel.Web.Models.BreadcrumbItemViewModel>
            {
                new() { Label = "Trang chủ", Url = Url.Action("Index", "Dashboard") },
                new() { Label = "Danh sách tour", Url = Url.Action("Index", "Tours") },
                new() { Label = "Chỉnh sửa tour", IsCurrent = true }
            }
        })
        <h1 class="text-2xl font-bold text-slate-900 dark:text-white">Chỉnh Sửa Tour: @Model.Name</h1>
        <p class="text-slate-500 dark:text-gray-400 mt-1">Cập nhật thông tin chi tiết, giá cả và lịch trình cho tour của bạn.</p>
    </div>
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
        <div class="lg:col-span-7 space-y-8">
            <section class="section-card">
                <div class="flex items-center gap-2 mb-2">
                    <span class="material-symbols-outlined text-primary">info</span>
                    <h2 class="text-[#111718] dark:text-white text-xl font-bold">Thông tin cơ bản</h2>
                </div>
                <div class="space-y-6">
                    <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
                        <div class="md:col-span-1">
                            <label class="label-text">Mã Tour</label>
                            <input asp-for="Code" class="input-field" placeholder="Ví dụ: TOUR-001" type="text" />
                            <span asp-validation-for="Code" class="text-red-500 text-xs"></span>
                        </div>
                        <div class="md:col-span-3">
                            <label class="label-text">Tên Tour</label>
                            <input asp-for="Name" class="input-field" placeholder="Ví dụ: Khám phá Vịnh Hạ Long 2 ngày 1 đêm" type="text" />
                            <span asp-validation-for="Name" class="text-red-500 text-xs"></span>
                        </div>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <!-- Custom Select: Status -->
                        <div class="relative custom-select-container" data-id="Status">
                             <label class="label-text">Trạng thái</label>
                             <div class="custom-select-trigger" onclick="toggleCustomSelect('Status')">
                                 <div class="flex items-center gap-3 min-w-0">
                                     <span class="custom-select-leading material-symbols-outlined">verified</span>
                                     <div class="custom-select-meta">
                                         <span class="custom-select-caption">Tour status</span>
                                         <span class="selected-label">@GetStatusText(Model.Status)</span>
                                     </div>
                                 </div>
                                 <span class="material-symbols-outlined transition-transform duration-300 arrow-icon">expand_more</span>
                             </div>
                             <div class="options-menu">
                                 @foreach (var status in new[] { "Draft", "Active", "SoldOut", "ComingSoon", "Hidden" })
                                 {
                                     <div class="custom-option @(Model.Status == status ? "selected" : "")" data-value="@status" data-label="@GetStatusText(status)" onclick="selectCustomOption('Status', '@status', '@GetStatusText(status)')">
                                         <span class="custom-option-main">
                                             <span class="custom-option-dot"></span>
                                             <span>@GetStatusText(status)</span>
                                         </span>
                                         @if (Model.Status == status) { <span class="material-symbols-outlined text-lg check-icon">check</span> }
                                     </div>
                                 }
                             </div>
                             <select asp-for="Status" class="hidden">
                                <option value="Draft">Bản nháp (Draft)</option>
                                <option value="Active">Hoạt động (Active)</option>
                                <option value="SoldOut">Hết chỗ (Sold Out)</option>
                                <option value="ComingSoon">Sắp ra mắt (Coming Soon)</option>
                                <option value="Hidden">Ẩn (Hidden)</option>
                            </select>
                        </div>

                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                         <div>
                            <label class="label-text">Thành phố / Tỉnh</label>
                             <input asp-for="Destination.City" class="input-field" placeholder="Ví dụ: Hạ Long" type="text" />
                        </div>
                        <div>
                             <label class="label-text">Quốc gia</label>
                             <input asp-for="Destination.Country" class="input-field" placeholder="Ví dụ: Việt Nam" type="text" />
                        </div>
                         <div>
                             <label class="label-text">Vùng / Miền</label>
                             <input asp-for="Destination.Region" class="input-field" placeholder="Ví dụ: Miền Bắc" type="text" />
                        </div>
                    </div>
                    <div>
                        <label class="label-text">Mô tả ngắn</label>
                        <textarea asp-for="ShortDescription" class="input-field h-32 py-4 resize-none" data-rich-editor="true" data-editor-height="220" placeholder="Viết một đoạn giới thiệu ngắn gọn về tour này..."></textarea>
                    </div>
                    <div>
                        <label class="label-text">Mô tả chi tiết</label>
                        <textarea asp-for="Description" class="input-field h-48 py-4 resize-none" data-rich-editor="true" data-editor-height="320" placeholder="Mô tả chi tiết về tour, các điểm nổi bật..."></textarea>
                    </div>
                    <div>
                        <label class="label-text">Hình ảnh</label>
                        <div class="flex flex-wrap items-center gap-3">
                            <button type="button" id="tour-images-upload" class="px-4 py-2 rounded-xl bg-primary text-white text-sm font-bold shadow-sm hover:brightness-110 transition-all">
                                <span class="material-symbols-outlined text-lg align-[-3px] mr-1">cloud_upload</span> Tải ảnh lên
                            </button>
                            <button type="button" id="tour-images-browse-library" class="px-4 py-2 rounded-xl border border-sky-200 text-sky-700 text-sm font-bold hover:bg-sky-50 transition-all">
                                <span class="material-symbols-outlined text-lg align-[-3px] mr-1">photo_library</span> Chọn từ thư viện Cloudinary
                            </button>
                            <button type="button" onclick="addImage()" class="px-4 py-2 rounded-xl border border-primary/30 text-primary text-sm font-bold hover:bg-primary/5 transition-all">
                                <span class="material-symbols-outlined text-lg align-[-3px] mr-1">add_photo_alternate</span> Thêm ảnh từ URL
                            </button>
                        </div>
                        <div id="images-container" class="space-y-3 mt-4">
                            @if (Model.Images != null && Model.Images.Any())
                            {
                                for (int i = 0; i < Model.Images.Count; i++)
                                {
                                    var hasImage = !string.IsNullOrWhiteSpace(Model.Images[i]);
                                    <div class="group flex min-w-0 items-center gap-3 rounded-2xl border border-slate-200 bg-slate-50/70 px-3 py-3 shadow-sm transition-colors dark:border-slate-700 dark:bg-slate-900/40 image-item">
                                        <div class="image-drag-handle flex size-10 flex-shrink-0 cursor-grab touch-none select-none items-center justify-center rounded-xl border border-slate-200 bg-white text-slate-400 transition hover:border-primary/30 hover:text-primary active:cursor-grabbing dark:border-slate-700 dark:bg-slate-900 dark:text-slate-500" title="Kéo để đổi thứ tự ảnh" aria-label="Kéo để đổi thứ tự ảnh">
                                            <span class="material-symbols-outlined text-[20px]">drag_indicator</span>
                                        </div>
                                        <div class="size-16 rounded-xl bg-slate-100 dark:bg-slate-800 overflow-hidden flex items-center justify-center border border-slate-200 dark:border-slate-700 flex-shrink-0">
                                            <img src="@Model.Images[i]" class="image-preview w-full h-full object-cover @(hasImage ? "" : "hidden")" alt="Ảnh tour" />
                                            <span class="image-placeholder text-xs text-slate-400 @(hasImage ? "hidden" : "")">Chưa có ảnh</span>
                                        </div>
                                        <input name="Images[@i]" value="@Model.Images[i]" type="text" class="input-field image-url-input flex-1 min-w-0" placeholder="https://example.com/image.jpg" />
                                        <button type="button" onclick="removeImage(this)" class="text-red-500 hover:bg-red-50 p-2 rounded-full flex-shrink-0"><span class="material-symbols-outlined">delete</span></button>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </div>
            </section>
            <section class="section-card">
                <div class="flex items-center gap-2 mb-2">
                    <span class="material-symbols-outlined text-primary">payments</span>
                    <h2 class="text-[#111718] dark:text-white text-xl font-bold">Giá & Ưu đãi</h2>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="label-text">Giá vé người lớn (Chính)</label>
                        <div class="relative">
                            <span class="absolute left-4 top-1/2 -translate-y-1/2 text-[#618389] font-medium">₫</span>
                            <input asp-for="Price.Adult" id="adult-price-input" class="input-field pl-10" placeholder="0" type="number" />
                        </div>
                    </div>
                    <div>
                        <label class="label-text">Giảm giá (%)</label>
                        <div class="relative">
                            <span class="absolute right-4 top-1/2 -translate-y-1/2 text-[#618389] font-medium">%</span>
                            <input id="discount-input" name="Price.Discount" value="@Model.Price?.Discount" class="input-field pr-10" max="100" min="0" placeholder="0" type="number" />
                        </div>
                    </div>
                    <div>
                        <label class="label-text">Giá vé trẻ em</label>
                        <div class="relative">
                            <span class="absolute left-4 top-1/2 -translate-y-1/2 text-[#618389] font-medium">₫</span>
                            <input asp-for="Price.Child" class="input-field pl-10" placeholder="0" type="number" />
                        </div>
                    </div>
                    <div>
                        <label class="label-text">Giá vé em bé</label>
                        <div class="relative">
                            <span class="absolute left-4 top-1/2 -translate-y-1/2 text-[#618389] font-medium">₫</span>
                            <input asp-for="Price.Infant" class="input-field pl-10" placeholder="0" type="number" />
                        </div>
                    </div>
                </div>
                <div class="p-4 bg-primary/5 rounded-2xl border border-primary/10 flex items-center justify-between">
                    <div>
                        <p class="text-xs font-semibold text-[#618389] uppercase tracking-wider mb-1">Giá hiển thị thực tế (Người lớn)</p>
                        <p id="calculated-price-display" class="text-2xl font-black text-primary">0 ₫</p>
                    </div>
                    <span class="material-symbols-outlined text-primary/40 text-4xl">calculate</span>
                </div>
            </section>
            <section class="section-card">
                <div class="flex items-center gap-2 mb-2">
                    <span class="material-symbols-outlined text-primary">calendar_month</span>
                    <h2 class="text-[#111718] dark:text-white text-xl font-bold">Thời gian & Lịch trình</h2>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="label-text">Số lượng khách tối đa</label>
                        <input asp-for="MaxParticipants" class="input-field" placeholder="20" type="number" />
                    </div>
                    <div>
                        <label class="label-text">Thời lượng (Text)</label>
                        <input asp-for="Duration.Text" class="input-field" placeholder="Ví dụ: 3 ngày 2 đêm" type="text" />
                    </div>
                     <div>
                        <label class="label-text">Số ngày</label>
                        <input asp-for="Duration.Days" class="input-field" placeholder="3" type="number" />
                    </div>
                     <div>
                        <label class="label-text">Số đêm</label>
                        <input asp-for="Duration.Nights" class="input-field" placeholder="2" type="number" />
                    </div>
                </div>

                <!-- Start Dates -->
                <div class="mt-8 border-t border-dashed border-gray-200 dark:border-gray-700 pt-6">
                    <label class="label-text mb-4">Ngày khởi hành</label>
                    <div id="start-dates-container" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                        @if (Model.StartDates != null && Model.StartDates.Any())
                        {
                            for (int i = 0; i < Model.StartDates.Count; i++)
                            {
                                <div class="relative group date-item">
                                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-[18px] group-hover:text-primary transition-colors z-20">calendar_today</span>
                                    <input name="StartDates[@i]" value="@Model.StartDates[i].ToString("yyyy-MM-dd")" type="text" readonly 
                                           onclick="openTourCalendar(this)" placeholder="Chọn ngày..."
                                           class="date-field-custom pl-10 pr-10 cursor-pointer" />
                                    <button type="button" onclick="removeDate(this)" class="absolute right-2 top-1/2 -translate-y-1/2 size-8 flex items-center justify-center text-slate-400 hover:text-red-500 hover:bg-red-50 dark:hover:bg-red-900/20 rounded-full transition-all z-20">
                                        <span class="material-symbols-outlined text-[18px]">delete</span>
                                    </button>
                                </div>
                            }
                        }
                    </div>
                    <button type="button" onclick="addStartDate()" class="mt-4 px-6 py-3 border-2 border-dashed border-primary/30 text-primary font-bold rounded-xl hover:bg-primary/5 transition-colors flex items-center gap-2">
                        <span class="material-symbols-outlined">add_circle</span> Thêm ngày khởi hành
                    </button>
                </div>

                <!-- Schedule -->
                <div class="mt-8 border-t border-dashed border-gray-200 dark:border-gray-700 pt-6">
                    <label class="label-text mb-4">Lịch trình chi tiết</label>
                    <div id="schedule-container" class="space-y-6">
                        @if (Model.Schedule != null && Model.Schedule.Any())
                        {
                            for (int i = 0; i < Model.Schedule.Count; i++)
                            {
                                <div class="schedule-item border border-gray-200 dark:border-gray-700 rounded-xl p-4 bg-gray-50 dark:bg-gray-800/50 relative">
                                    <button type="button" onclick="removeSchedule(this)" class="absolute top-2 right-2 text-red-500 hover:bg-red-50 dark:hover:bg-red-900/20 p-1 rounded-full"><span class="material-symbols-outlined">delete</span></button>
                                    <div class="grid grid-cols-12 gap-4">
                                        <div class="col-span-12 md:col-span-2">
                                            <label class="text-xs font-bold uppercase text-gray-500">Ngày</label>
                                            <input name="Schedule[@i].Day" value="@Model.Schedule[i].Day" type="number" class="input-field h-10 text-sm" placeholder="1" />
                                        </div>
                                        <div class="col-span-12 md:col-span-10">
                                            <label class="text-xs font-bold uppercase text-gray-500">Tiêu đề</label>
                                            <input name="Schedule[@i].Title" value="@Model.Schedule[i].Title" type="text" class="input-field h-10 text-sm" placeholder="Đón sân bay - Check in" />
                                        </div>
                                        <div class="col-span-12">
                                            <label class="text-xs font-bold uppercase text-gray-500">Mô tả hoạt động</label>
                                            <textarea name="Schedule[@i].Description" class="input-field h-24 py-2 text-sm resize-none" data-rich-editor="true" data-editor-height="180" placeholder="Chi tiết hoạt động trong ngày...">@Model.Schedule[i].Description</textarea>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                    <button type="button" onclick="addScheduleItem()" class="mt-4 w-full py-3 border-2 border-dashed border-primary/30 text-primary font-bold rounded-xl hover:bg-primary/5 transition-colors flex items-center justify-center gap-2">
                        <span class="material-symbols-outlined">add_circle</span> Thêm ngày lịch trình
                    </button>
                </div>
            </section>
        </div>
        <div class="lg:col-span-5 lg:sticky lg:top-24">
            <div class="flex items-center justify-between mb-4 px-2">
                <div class="flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary text-sm">visibility</span>
                    <p class="text-sm font-bold text-[#111718] dark:text-white uppercase tracking-[0.2em]">XEM TRƯỚC TRỰC TIẾP</p>
                </div>
                <span class="px-2.5 py-1 bg-primary/20 text-primary text-[10px] font-black rounded-full uppercase">Giao diện người dùng</span>
            </div>
            <div class="bg-white dark:bg-surface-dark rounded-[2rem] overflow-hidden shadow-2xl border border-[#f0f4f4] dark:border-slate-800 group transition-all">
                <div class="relative h-72 overflow-hidden bg-[#f0f4f4] dark:bg-slate-900 flex items-center justify-center group-hover:scale-105 transition-transform duration-700">
                    <div id="preview-image-placeholder" class="flex flex-col items-center gap-2 text-[#618389]">
                        <span class="material-symbols-outlined text-4xl opacity-50">image</span>
                        <p class="text-sm font-medium">Chưa có hình ảnh</p>
                    </div>
                    <img id="preview-image" src="" alt="Preview" class="absolute inset-0 w-full h-full object-cover hidden" />
                    <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
                    
                    <div class="absolute top-6 left-6 bg-white/90 dark:bg-black/80 backdrop-blur px-3 py-2 rounded-xl flex items-center gap-1.5 shadow-sm">
                        <span class="material-symbols-outlined text-primary text-base fill-1">star</span>
                        <span class="text-sm font-bold text-[#111718] dark:text-white">New</span>
                    </div>
                </div>
                <div class="p-8 relative">
                    <div class="flex items-center gap-2 mb-3">
                        <span class="material-symbols-outlined text-primary text-sm">location_on</span>
                        <span id="preview-location" class="text-xs font-bold text-[#618389] uppercase tracking-widest">ĐỊA ĐIỂM</span>
                    </div>
                    <h3 id="preview-title" class="text-2xl font-extrabold text-[#111718] dark:text-white mb-3 leading-tight line-clamp-2">Tên Tour</h3>
                    <p id="preview-description" class="text-sm text-[#618389] dark:text-gray-400 line-clamp-3 mb-8 leading-relaxed">Mô tả ngắn về tour sẽ hiển thị ở đây...</p>
                    <div class="flex items-end justify-between border-t border-[#f0f4f4] dark:border-white/10 pt-6">
                        <div>
                            <p class="text-xs text-[#618389] uppercase font-bold tracking-tighter mb-1">Bắt đầu từ</p>
                            <p id="preview-price" class="text-3xl font-black text-primary">0 <span class="text-sm font-medium">VND</span></p>
                        </div>
                        <button class="bg-primary text-white px-8 py-3.5 rounded-2xl font-bold text-sm transition-all shadow-lg shadow-primary/25 cursor-not-allowed opacity-50">
                            Đặt chỗ ngay
                        </button>
                    </div>
                </div>
            </div>
            <div class="mt-6 p-6 rounded-2xl border-2 border-dashed border-[#dbe4e6] dark:border-white/10 flex items-start gap-4 bg-white/40 dark:bg-slate-800/40">
                <span class="material-symbols-outlined text-primary p-2 bg-primary/10 rounded-lg">tips_and_updates</span>
                <div class="space-y-1">
                    <p class="text-sm font-bold text-[#111718] dark:text-white">Mẹo nhỏ cho bạn</p>
                    <p class="text-xs text-[#618389] leading-relaxed">Sử dụng hình ảnh chất lượng cao và tiêu đề hấp dẫn để tăng tỷ lệ đặt tour lên đến 40%.</p>
                </div>
            </div>
        </div>
    </div>
</div>

<footer class="fixed bottom-0 left-0 right-0 md:left-64 bg-white dark:bg-surface-dark border-t border-[#f0f4f4] dark:border-slate-800 p-5 md:px-10 shadow-[0_-8px_30px_rgba(0,0,0,0.04)] z-40 transition-all duration-300">
    <div class="max-w-[1440px] mx-auto flex items-center justify-between gap-4">
        <div class="hidden sm:flex items-center gap-3">
             <span class="size-2 bg-green-500 rounded-full animate-pulse"></span>
             <span class="text-xs font-bold text-[#618389] uppercase tracking-widest">Đang chỉnh sửa</span>
        </div>
        <div class="flex items-center gap-4 w-full sm:w-auto">
            <a asp-action="Index" class="flex-1 sm:flex-none px-8 py-4 rounded-2xl text-[#111718] dark:text-white font-bold text-sm hover:bg-[#f0f4f4] dark:hover:bg-white/5 transition-all text-center">
                Hủy
            </a>
            <button type="submit" form="edit-tour-form" name="saveAction" value="Draft" class="flex-1 sm:flex-none px-8 py-4 rounded-2xl bg-[#f0f4f4] dark:bg-slate-800 hover:bg-[#e0e4e4] text-[#111718] dark:text-white font-bold text-sm transition-all text-center">
                Lưu bản nháp
            </button>
            <button type="submit" form="edit-tour-form" class="flex-1 sm:flex-none px-10 py-4 rounded-2xl bg-gradient-to-r from-primary to-[#25b9d7] hover:brightness-110 text-white font-extrabold text-sm transition-all shadow-xl shadow-primary/30 flex items-center justify-center gap-2 group">
                Lưu Thay Đổi
                <span class="material-symbols-outlined text-xl group-hover:translate-x-1 transition-transform">save</span>
            </button>
        </div>
    </div>
</footer>

<partial name="_TourDatePicker" />
</form>

<script>
    // --- Images ---
    function createImageItem(url) {
        const container = document.createElement('div');
        container.className = 'group flex min-w-0 items-center gap-3 rounded-2xl border border-slate-200 bg-slate-50/70 px-3 py-3 shadow-sm transition-colors dark:border-slate-700 dark:bg-slate-900/40 image-item';
        container.innerHTML = `
            <div class="image-drag-handle flex size-10 flex-shrink-0 cursor-grab touch-none select-none items-center justify-center rounded-xl border border-slate-200 bg-white text-slate-400 transition hover:border-primary/30 hover:text-primary active:cursor-grabbing dark:border-slate-700 dark:bg-slate-900 dark:text-slate-500" title="Kéo để đổi thứ tự ảnh" aria-label="Kéo để đổi thứ tự ảnh">
                <span class="material-symbols-outlined text-[20px]">drag_indicator</span>
            </div>
            <div class="size-16 rounded-xl bg-slate-100 dark:bg-slate-800 overflow-hidden flex items-center justify-center border border-slate-200 dark:border-slate-700 flex-shrink-0">
                <img class="image-preview w-full h-full object-cover hidden" alt="Ảnh tour" />
                <span class="image-placeholder text-xs text-slate-400">Chưa có ảnh</span>
            </div>
            <input type="text" class="input-field image-url-input flex-1 min-w-0" placeholder="https://example.com/image.jpg" />
            <button type="button" onclick="removeImage(this)" class="text-red-500 hover:bg-red-50 p-2 rounded-full flex-shrink-0"><span class="material-symbols-outlined">delete</span></button>
        `;

        const input = container.querySelector('.image-url-input');
        input.value = url || '';
        input.addEventListener('input', function () {
            updateImagePreview(input);
        });
        updateImagePreview(input);
        enableImageReordering(container);
        return container;
    }

    function normalizeTourImageUrls(urls) {
        const seen = new Set();
        return (Array.isArray(urls) ? urls : [urls])
            .map((url) => String(url || '').trim())
            .filter((url) => {
                if (!url || seen.has(url)) {
                    return false;
                }
                seen.add(url);
                return true;
            });
    }

    let activeImageDrag = null;

    function clearImageReorderState() {
        document.querySelectorAll('#images-container .image-item').forEach((item) => {
            item.classList.remove('scale-[1.01]', 'shadow-2xl', 'shadow-primary/20', 'ring-2', 'ring-primary/25', 'z-50');
            item.style.removeProperty('pointer-events');
            item.style.removeProperty('position');
            item.style.removeProperty('left');
            item.style.removeProperty('top');
            item.style.removeProperty('width');
            item.style.removeProperty('z-index');
        });

        document.querySelectorAll('#images-container .image-reorder-placeholder').forEach((placeholder) => {
            placeholder.classList.remove('border-primary/40', 'bg-primary/10');
        });
    }

    function ensureImageReorderPlaceholder(item) {
        const placeholder = document.createElement('div');
        placeholder.className = 'image-reorder-placeholder rounded-2xl border-2 border-dashed border-primary/40 bg-primary/10 transition-all';
        placeholder.style.height = `${item.offsetHeight}px`;
        return placeholder;
    }

    function reorderImageItem(container, draggedItem, targetItem, clientY) {
        if (!container || !draggedItem || !targetItem || draggedItem === targetItem) {
            return;
        }

        const placeholder = activeImageDrag?.placeholder;
        if (!placeholder) {
            return;
        }

        const targetRect = targetItem.getBoundingClientRect();
        const insertAfterTarget = clientY > targetRect.top + (targetRect.height / 2);
        container.insertBefore(placeholder, insertAfterTarget ? targetItem.nextSibling : targetItem);
    }

    function updateDraggedImagePosition(event) {
        if (!activeImageDrag) {
            return;
        }

        const { item, offsetX, offsetY } = activeImageDrag;
        item.style.left = `${event.clientX - offsetX}px`;
        item.style.top = `${event.clientY - offsetY}px`;
    }

    function finishImagePointerDrag(handle, pointerId) {
        if (!activeImageDrag) {
            return;
        }

        const { item, placeholder } = activeImageDrag;
        if (handle?.hasPointerCapture?.(pointerId)) {
            handle.releasePointerCapture(pointerId);
        }

        placeholder.replaceWith(item);
        clearImageReorderState();
        activeImageDrag = null;
        reindexItems('#images-container .image-url-input', 'Images');
        syncPreviewImage();
    }

    function startImagePointerDrag(handle, item, event) {
        if (event.button !== 0 || activeImageDrag) {
            return;
        }

        const container = item.parentElement;
        if (!container) {
            return;
        }

        event.preventDefault();
        const rect = item.getBoundingClientRect();
        const placeholder = ensureImageReorderPlaceholder(item);
        item.after(placeholder);

        activeImageDrag = {
            handle,
            item,
            container,
            placeholder,
            pointerId: event.pointerId,
            offsetX: event.clientX - rect.left,
            offsetY: event.clientY - rect.top
        };

        item.classList.add('scale-[1.01]', 'shadow-2xl', 'shadow-primary/20', 'ring-2', 'ring-primary/25', 'z-50');
        item.style.pointerEvents = 'none';
        item.style.position = 'fixed';
        item.style.left = `${rect.left}px`;
        item.style.top = `${rect.top}px`;
        item.style.width = `${rect.width}px`;
        item.style.zIndex = '80';

        handle.setPointerCapture(event.pointerId);
        updateDraggedImagePosition(event);
    }

    function enableImageReordering(scope) {
        const root = scope && typeof scope.querySelectorAll === 'function' ? scope : document;
        const items = root.classList && root.classList.contains('image-item')
            ? [root]
            : Array.from(root.querySelectorAll('.image-item'));

        items.forEach((item) => {
            if (item.dataset.reorderReady === 'true') {
                return;
            }

            const handle = item.querySelector('.image-drag-handle');
            if (!handle) {
                return;
            }

            item.dataset.reorderReady = 'true';
            item.classList.add('transition-all', 'duration-200');

            handle.addEventListener('pointerdown', function (event) {
                startImagePointerDrag(handle, item, event);
            });

            handle.addEventListener('pointermove', function (event) {
                if (!activeImageDrag || activeImageDrag.pointerId !== event.pointerId || activeImageDrag.item !== item) {
                    return;
                }

                event.preventDefault();
                updateDraggedImagePosition(event);

                const siblings = Array.from(activeImageDrag.container.querySelectorAll('.image-item'))
                    .filter((candidate) => candidate !== item);

                const targetItem = siblings.find((candidate) => {
                    const rect = candidate.getBoundingClientRect();
                    return event.clientY < rect.bottom;
                });

                if (targetItem) {
                    reorderImageItem(activeImageDrag.container, item, targetItem, event.clientY);
                } else if (activeImageDrag.placeholder !== activeImageDrag.container.lastElementChild) {
                    activeImageDrag.container.appendChild(activeImageDrag.placeholder);
                }
            });

            const finishDrag = function (event) {
                if (!activeImageDrag || activeImageDrag.pointerId !== event.pointerId || activeImageDrag.item !== item) {
                    return;
                }

                finishImagePointerDrag(handle, event.pointerId);
            };

            handle.addEventListener('pointerup', finishDrag);
            handle.addEventListener('pointercancel', finishDrag);
        });
    }

    function getCurrentTourImageUrls() {
        return normalizeTourImageUrls(
            Array.from(document.querySelectorAll('#images-container .image-url-input'))
                .map((input) => input.value)
        );
    }

    function syncTourImages(urls) {
        const imagesContainer = document.getElementById('images-container');
        const normalizedUrls = normalizeTourImageUrls(urls);
        imagesContainer.innerHTML = '';
        if (!normalizedUrls.length) {
            imagesContainer.appendChild(createImageItem(''));
        } else {
            normalizedUrls.forEach((url) => {
                imagesContainer.appendChild(createImageItem(url));
            });
        }
        enableImageReordering(imagesContainer);
        reindexItems('#images-container .image-url-input', 'Images');
        syncPreviewImage();
        return normalizedUrls;
    }

    function addImage(url) {
        const safeUrl = normalizeTourImageUrls([url])[0] || '';
        const currentValues = getCurrentTourImageUrls();
        if (safeUrl && currentValues.includes(safeUrl)) {
            return false;
        }

        const imagesContainer = document.getElementById('images-container');
        const item = createImageItem(safeUrl);
        imagesContainer.appendChild(item);
        enableImageReordering(imagesContainer);
        reindexItems('#images-container .image-url-input', 'Images');
        return true;
    }

    function removeImage(btn) {
        btn.closest('.image-item').remove();
        reindexItems('#images-container .image-url-input', 'Images');
        syncPreviewImage();
    }

    function updateImagePreview(input) {
        const item = input.closest('.image-item');
        if (!item) return;
        const preview = item.querySelector('.image-preview');
        const placeholder = item.querySelector('.image-placeholder');
        const url = input.value.trim();

        if (url) {
            preview.src = url;
            preview.classList.remove('hidden');
            placeholder.classList.add('hidden');
        } else {
            preview.removeAttribute('src');
            preview.classList.add('hidden');
            placeholder.classList.remove('hidden');
        }
    }

    function syncPreviewImage() {
        const previewImage = document.getElementById('preview-image');
        const previewPlaceholder = document.getElementById('preview-image-placeholder');
        const firstInput = document.querySelector('#images-container .image-url-input');
        const url = firstInput ? firstInput.value.trim() : '';

        if (!previewImage || !previewPlaceholder) return;

        if (url) {
            previewImage.src = url;
            previewImage.classList.remove('hidden');
            previewPlaceholder.classList.add('hidden');
        } else {
            previewImage.classList.add('hidden');
            previewPlaceholder.classList.remove('hidden');
        }
    }

    // --- Schedule ---
    function addScheduleItem() {
        const container = document.getElementById('schedule-container');
        const index = container.querySelectorAll('.schedule-item').length;
        const day = index + 1;
        const html = `
            <div class="schedule-item border border-gray-200 dark:border-gray-700 rounded-xl p-4 bg-gray-50 dark:bg-gray-800/50 relative">
                <button type="button" onclick="removeSchedule(this)" class="absolute top-2 right-2 text-red-500 hover:bg-red-50 dark:hover:bg-red-900/20 p-1 rounded-full"><span class="material-symbols-outlined">delete</span></button>
                <div class="grid grid-cols-12 gap-4">
                    <div class="col-span-12 md:col-span-2">
                        <label class="text-xs font-bold uppercase text-gray-500">Ngày</label>
                        <input name="Schedule[${index}].Day" value="${day}" type="number" class="input-field h-10 text-sm" placeholder="1" />
                    </div>
                    <div class="col-span-12 md:col-span-10">
                        <label class="text-xs font-bold uppercase text-gray-500">Tiêu đề</label>
                        <input name="Schedule[${index}].Title" type="text" class="input-field h-10 text-sm" placeholder="Tiêu đề..." />
                    </div>
                    <div class="col-span-12">
                        <label class="text-xs font-bold uppercase text-gray-500">Mô tả hoạt động</label>
                        <textarea name="Schedule[${index}].Description" class="input-field h-24 py-2 text-sm resize-none" data-rich-editor="true" data-editor-height="180" placeholder="Chi tiết hoạt động..."></textarea>
                    </div>
                </div>
            </div>
        `;
        container.insertAdjacentHTML('beforeend', html);
        if (window.AdminRichText) {
            window.AdminRichText.refresh(container.lastElementChild);
        }
    }

    function removeSchedule(btn) {
        const item = btn.closest('.schedule-item');
        if (window.AdminRichText) {
            window.AdminRichText.remove(item);
        }
        item.remove();
        reindexSchedule();
    }

    // --- Helpers ---
    function reindexItems(selector, prefix) {
         const items = document.querySelectorAll(selector);
         items.forEach((input, idx) => {
             input.name = `${prefix}[${idx}]`;
         });
    }

    function reindexSchedule() {
        const items = document.querySelectorAll('#schedule-container .schedule-item');
        items.forEach((item, idx) => {
            item.querySelector('input[name$=".Day"]').name = `Schedule[${idx}].Day`;
            item.querySelector('input[name$=".Title"]').name = `Schedule[${idx}].Title`;
            item.querySelector('textarea[name$=".Description"]').name = `Schedule[${idx}].Description`;
        });
    }

    // --- Live Preview ---
    document.addEventListener('DOMContentLoaded', function() {
        const inputs = {
            name: document.querySelector('input[name="Name"]'),
            desc: document.querySelector('textarea[name="Description"]'),
            price: document.querySelector('input[name="Price.Adult"]'),
            location: document.querySelector('input[name="Destination.City"]'),
            imagesContainer: document.getElementById('images-container')
        };

        const preview = {
            title: document.getElementById('preview-title'),
            desc: document.getElementById('preview-description'),
            price: document.getElementById('preview-price'),
            location: document.getElementById('preview-location'),
            image: document.getElementById('preview-image'),
            imagePlaceholder: document.getElementById('preview-image-placeholder')
        };

        function htmlToPreviewText(html) {
            if (!html) return '';
            const normalizedHtml = String(html)
                .replace(/<\s*br\s*\/?\s*>/gi, ' ')
                .replace(/<\/?(?:p|div|li|ul|ol|h[1-6]|blockquote|section|article|tr|td|th)\b[^>]*>/gi, ' ');
            const container = document.createElement('div');
            container.innerHTML = normalizedHtml;
            return (container.textContent || container.innerText || '')
                .replace(/\u00a0/g, ' ')
                .replace(/\s+/g, ' ')
                .trim();
        }
        function updatePreview() {
            // Name
            if(inputs.name) preview.title.textContent = inputs.name.value || 'Tên Tour';
            
            // Description
            if(inputs.desc) preview.desc.textContent = htmlToPreviewText(inputs.desc.value) || 'Mô tả ngắn về tour sẽ hiển thị ở đây...';
            
            // Price
            if(inputs.price) {
                const price = new Intl.NumberFormat('vi-VN').format(inputs.price.value || 0);
                preview.price.innerHTML = `${price} <span class="text-sm font-medium">VND</span>`;
            }

            // Location
            if(inputs.location) preview.location.textContent = inputs.location.value || 'ĐỊA ĐIỂM';

            // Image
            // Find first image input value
            const firstImgInput = inputs.imagesContainer ? inputs.imagesContainer.querySelector('.image-url-input') : null;
            const imgUrl = firstImgInput ? firstImgInput.value : '';
            
            if(imgUrl) {
                preview.image.src = imgUrl;
                preview.image.classList.remove('hidden');
                preview.imagePlaceholder.classList.add('hidden');
            } else {
                preview.image.classList.add('hidden');
                preview.imagePlaceholder.classList.remove('hidden');
            }
        }

        // Add listeners
        if(inputs.name) inputs.name.addEventListener('input', updatePreview);
        if(inputs.desc) inputs.desc.addEventListener('input', updatePreview);
        if(inputs.price) inputs.price.addEventListener('input', updatePreview);
        if(inputs.location) inputs.location.addEventListener('input', updatePreview);
        
        // Delegate for dynamic images
        if (inputs.imagesContainer) {
            inputs.imagesContainer.addEventListener('input', function(e) {
                if (e.target.tagName === 'INPUT') updatePreview();
            });

            inputs.imagesContainer.querySelectorAll('.image-url-input').forEach(function(input) {
                input.addEventListener('input', function () {
                    updateImagePreview(input);
                });
                updateImagePreview(input);
            });
        }

        const uploadButton = document.getElementById('tour-images-upload');
        const browseLibraryButton = document.getElementById('tour-images-browse-library');
        if (uploadButton) {
            if (typeof window.prewarmCloudinaryWidget === 'function') {
                window.prewarmCloudinaryWidget({ multiple: true, folder: 'HV-Travel ASP.NET' });
            }

            if (typeof window.prewarmCloudinaryAssetBrowser === 'function') {
                window.prewarmCloudinaryAssetBrowser();
            }

            uploadButton.addEventListener('click', function () {
                window.openCloudinaryWidget({ multiple: true, folder: 'HV-Travel ASP.NET' }, function (url) {
                    if (addImage(url)) {
                        updatePreview();
                    }
                });
            });
        }

        if (browseLibraryButton) {
            browseLibraryButton.addEventListener('click', function () {
                window.openCloudinaryAssetBrowser({ multiple: true, folder: 'HV-Travel ASP.NET', selectedUrls: getCurrentTourImageUrls(), syncSelection: true }, function (selectedUrls) {
                    syncTourImages(selectedUrls);
                    updatePreview();
                });
            });
        }

        // Initialize
        enableImageReordering(document.getElementById('images-container'));
        updatePreview();
        calculateActualPrice();
    });

    // --- Price Calculation ---
    const adultPriceInput = document.getElementById('adult-price-input');
    const discountInput = document.getElementById('discount-input');
    const calculatedPriceDisplay = document.getElementById('calculated-price-display');

    function calculateActualPrice() {
        if (!adultPriceInput || !discountInput || !calculatedPriceDisplay) return;

        const price = parseFloat(adultPriceInput.value) || 0;
        const discount = parseFloat(discountInput.value) || 0;
        
        let actualPrice = price;
        if (discount > 0 && discount <= 100) {
            actualPrice = price * (100 - discount) / 100;
        }

        const formattedPrice = new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(actualPrice);
        calculatedPriceDisplay.textContent = formattedPrice;
    }

    if (adultPriceInput) adultPriceInput.addEventListener('input', calculateActualPrice);
    if (discountInput) discountInput.addEventListener('input', calculateActualPrice);
</script>
@section Scripts {
    <script src="~/js/admin-custom-select.js" asp-append-version="true"></script>
    <script src="~/js/admin-tour-date-picker.js" asp-append-version="true"></script>
}

