@model HVTravel.Domain.Entities.Tour
@using System.Linq
@{
    ViewData["Title"] = "Chi tiet tour";
    var routeInsight = ViewData["RouteInsight"] as HVTravel.Application.Models.RouteInsightResult ?? HVTravel.Application.Models.RouteInsightResult.Empty;
    var heroImage = Model.Images != null && Model.Images.Count > 0
        ? Model.Images[0]
        : "https://via.placeholder.com/1200x800?text=Tour";
    var adminDepartures = (Model.Departures ?? new List<HVTravel.Domain.Entities.TourDeparture>()).OrderBy(item => item.StartDate).ToList();
    var routeStops = (Model.Routing?.Stops ?? new List<HVTravel.Domain.Entities.TourRouteStop>()).OrderBy(item => item.Day).ThenBy(item => item.Order).ToList();
    var routeStopNameLookup = routeStops
        .Where(item => !string.IsNullOrWhiteSpace(item.Id))
        .GroupBy(item => item.Id)
        .ToDictionary(group => group.Key!, group => group.First().Name);
    var highlights = Model.Highlights ?? new List<string>();
    var badgeSet = Model.BadgeSet ?? new List<string>();
    string DayPartText(string? value) => value switch
    {
        "early_morning" => "Early morning",
        "morning_peak" => "Morning peak",
        "late_morning" => "Late morning",
        "midday" => "Midday",
        "afternoon" => "Afternoon",
        "evening_peak" => "Evening peak",
        _ => "Night"
    };
    string CongestionText(string? value) => value switch
    {
        "high" => "High",
        "moderate" => "Moderate",
        _ => "Low"
    };
}

@await Html.PartialAsync("_AdminBreadcrumb", new HVTravel.Web.Models.BreadcrumbViewModel
{
    Items = new List<HVTravel.Web.Models.BreadcrumbItemViewModel>
    {
        new() { Label = "Trang chu", Url = Url.Action("Index", "Dashboard") },
        new() { Label = "Danh sach tour", Url = Url.Action("Index", "Tours") },
        new() { Label = $"#{Model.Code}", IsCurrent = true }
    }
})

<div class="mb-6 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <div>
        <div class="flex flex-wrap items-center gap-3">
            <h1 class="text-2xl font-bold text-slate-900 dark:text-white">Chi tiet tour</h1>
            <span class="rounded-full bg-slate-100 px-3 py-1 text-[11px] font-black uppercase tracking-[0.2em] text-slate-600 dark:bg-slate-800 dark:text-slate-300">@Model.Status</span>
        </div>
        <p class="mt-2 text-sm text-slate-500 dark:text-slate-400">Ma tour: <span class="font-bold text-slate-900 dark:text-white">@Model.Code</span> · Cap nhat @Model.UpdatedAt.ToString("HH:mm dd/MM/yyyy")</p>
    </div>
    <div class="flex items-center gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="rounded-xl border border-slate-200 px-4 py-2 text-sm font-bold text-slate-700 transition-colors hover:bg-slate-50 dark:border-slate-700 dark:text-slate-200 dark:hover:bg-slate-800">
            Chinh sua
        </a>
        <a asp-action="Index" class="rounded-xl border border-slate-200 px-4 py-2 text-sm font-bold text-slate-700 transition-colors hover:bg-slate-50 dark:border-slate-700 dark:text-slate-200 dark:hover:bg-slate-800">
            Quay lai
        </a>
    </div>
</div>

<div class="mb-10 overflow-hidden rounded-[2rem] border border-slate-200 bg-white shadow-sm dark:border-slate-700 dark:bg-slate-900">
    <div class="grid gap-0 lg:grid-cols-[1.35fr_0.65fr]">
        <div class="min-h-[320px] bg-slate-100 dark:bg-slate-800">
            <img src="@heroImage" alt="@Model.Name" class="h-full w-full object-cover" />
        </div>
        <div class="space-y-5 p-8">
            <div>
                <p class="text-xs font-black uppercase tracking-[0.24em] text-slate-400 dark:text-slate-500">Overview</p>
                <h2 class="mt-2 text-3xl font-black text-slate-900 dark:text-white">@Model.Name</h2>
                <p class="mt-3 text-sm leading-7 text-slate-500 dark:text-slate-400">@Model.Destination?.City, @Model.Destination?.Country</p>
            </div>
            <div class="grid grid-cols-2 gap-4">
                <div class="rounded-2xl bg-slate-50 p-4 dark:bg-slate-800/70">
                    <p class="text-[11px] font-black uppercase tracking-[0.2em] text-slate-400 dark:text-slate-500">Gia nguoi lon</p>
                    <p class="mt-2 text-xl font-black text-slate-900 dark:text-white">@Model.Price?.Adult.ToString("N0") @Model.Price?.Currency</p>
                </div>
                <div class="rounded-2xl bg-slate-50 p-4 dark:bg-slate-800/70">
                    <p class="text-[11px] font-black uppercase tracking-[0.2em] text-slate-400 dark:text-slate-500">Thoi luong</p>
                    <p class="mt-2 text-xl font-black text-slate-900 dark:text-white">@Model.Duration?.Text</p>
                </div>
            </div>
            <dl class="grid gap-4 text-sm sm:grid-cols-2">
                <div>
                    <dt class="font-black uppercase tracking-[0.18em] text-slate-400 dark:text-slate-500">Slug</dt>
                    <dd class="mt-1 text-slate-700 dark:text-slate-200">@(!string.IsNullOrWhiteSpace(Model.Slug) ? Model.Slug : "Chua co")</dd>
                </div>
                <div>
                    <dt class="font-black uppercase tracking-[0.18em] text-slate-400 dark:text-slate-500">ConfirmationType</dt>
                    <dd class="mt-1 text-slate-700 dark:text-slate-200">@(!string.IsNullOrWhiteSpace(Model.ConfirmationType) ? Model.ConfirmationType : "Instant")</dd>
                </div>
                <div class="sm:col-span-2">
                    <dt class="font-black uppercase tracking-[0.18em] text-slate-400 dark:text-slate-500">MeetingPoint</dt>
                    <dd class="mt-1 text-slate-700 dark:text-slate-200">@(!string.IsNullOrWhiteSpace(Model.MeetingPoint) ? Model.MeetingPoint : "Chua cau hinh")</dd>
                </div>
            </dl>
        </div>
    </div>
</div>

<div class="grid grid-cols-1 gap-10 lg:grid-cols-12">
    <div class="space-y-10 lg:col-span-8">
        <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-700 dark:bg-slate-900/40">
            <h3 class="text-2xl font-bold text-slate-900 dark:text-white">Mo ta</h3>
            <div class="prose mt-4 max-w-none dark:prose-invert">
                @Html.Raw(RichTextContentFormatter.ToTrustedHtml(Model.Description))
            </div>
            @if (!string.IsNullOrWhiteSpace(Model.ShortDescription))
            {
                <div class="mt-4 rounded-2xl bg-slate-50 p-4 text-sm leading-7 text-slate-600 dark:bg-slate-800/60 dark:text-slate-300">
                    @Html.Raw(RichTextContentFormatter.ToTrustedHtml(Model.ShortDescription))
                </div>
            }
        </section>

        <section class="grid gap-6 md:grid-cols-2">
            <article class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-700 dark:bg-slate-900/40">
                <h3 class="text-lg font-bold text-slate-900 dark:text-white">SEO</h3>
                <dl class="mt-4 space-y-4 text-sm">
                    <div>
                        <dt class="font-black uppercase tracking-[0.18em] text-slate-400 dark:text-slate-500">Seo.Title</dt>
                        <dd class="mt-1 text-slate-700 dark:text-slate-200">@(!string.IsNullOrWhiteSpace(Model.Seo?.Title) ? Model.Seo.Title : "Chua cau hinh")</dd>
                    </div>
                    <div>
                        <dt class="font-black uppercase tracking-[0.18em] text-slate-400 dark:text-slate-500">Seo.Description</dt>
                        <dd class="mt-1 text-slate-700 dark:text-slate-200">@(!string.IsNullOrWhiteSpace(Model.Seo?.Description) ? Model.Seo.Description : "Chua cau hinh")</dd>
                    </div>
                    <div>
                        <dt class="font-black uppercase tracking-[0.18em] text-slate-400 dark:text-slate-500">Seo.CanonicalPath</dt>
                        <dd class="mt-1 break-all text-slate-700 dark:text-slate-200">@(!string.IsNullOrWhiteSpace(Model.Seo?.CanonicalPath) ? Model.Seo.CanonicalPath : "Chua cau hinh")</dd>
                    </div>
                    <div>
                        <dt class="font-black uppercase tracking-[0.18em] text-slate-400 dark:text-slate-500">Seo.OpenGraphImageUrl</dt>
                        <dd class="mt-1 break-all text-slate-700 dark:text-slate-200">@(!string.IsNullOrWhiteSpace(Model.Seo?.OpenGraphImageUrl) ? Model.Seo.OpenGraphImageUrl : "Chua cau hinh")</dd>
                    </div>
                </dl>
            </article>

            <article class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-700 dark:bg-slate-900/40">
                <h3 class="text-lg font-bold text-slate-900 dark:text-white">Commerce metadata</h3>
                <dl class="mt-4 space-y-4 text-sm">
                    <div>
                        <dt class="font-black uppercase tracking-[0.18em] text-slate-400 dark:text-slate-500">CancellationPolicy</dt>
                        <dd class="mt-1 text-slate-700 dark:text-slate-200">@(!string.IsNullOrWhiteSpace(Model.CancellationPolicy?.Summary) ? Model.CancellationPolicy.Summary : "Chua cau hinh")</dd>
                    </div>
                    <div>
                        <dt class="font-black uppercase tracking-[0.18em] text-slate-400 dark:text-slate-500">Highlights</dt>
                        <dd class="mt-2 flex flex-wrap gap-2">
                            @if (highlights.Count > 0)
                            {
                                foreach (var highlight in highlights)
                                {
                                    <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-bold text-slate-600 dark:bg-slate-800 dark:text-slate-300">@highlight</span>
                                }
                            }
                            else
                            {
                                <span class="text-slate-500 dark:text-slate-400">Chua cau hinh</span>
                            }
                        </dd>
                    </div>
                    <div>
                        <dt class="font-black uppercase tracking-[0.18em] text-slate-400 dark:text-slate-500">BadgeSet</dt>
                        <dd class="mt-2 flex flex-wrap gap-2">
                            @if (badgeSet.Count > 0)
                            {
                                foreach (var badge in badgeSet)
                                {
                                    <span class="rounded-full bg-primary/10 px-3 py-1 text-xs font-bold text-primary">@badge</span>
                                }
                            }
                            else
                            {
                                <span class="text-slate-500 dark:text-slate-400">Chua cau hinh</span>
                            }
                        </dd>
                    </div>
                </dl>
            </article>
        </section>

        <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-700 dark:bg-slate-900/40">
            <h3 class="text-2xl font-bold text-slate-900 dark:text-white">Lich trinh</h3>
            <div class="mt-6 space-y-6">
                @if (Model.Schedule != null && Model.Schedule.Count > 0)
                {
                    foreach (var item in Model.Schedule.OrderBy(item => item.Day))
                    {
                        <article class="rounded-2xl border border-slate-200 bg-slate-50/80 p-5 dark:border-slate-700 dark:bg-slate-800/60">
                            <h4 class="text-lg font-black text-slate-900 dark:text-white">Day @item.Day · @item.Title</h4>
                            <div class="prose mt-3 max-w-none text-sm dark:prose-invert">
                                @Html.Raw(RichTextContentFormatter.ToTrustedHtml(item.Description))
                            </div>
                            @if (item.Activities != null && item.Activities.Count > 0)
                            {
                                <div class="mt-4 flex flex-wrap gap-2">
                                    @foreach (var activity in item.Activities)
                                    {
                                        <span class="rounded-full bg-white px-3 py-1 text-xs font-bold text-slate-600 dark:bg-slate-900 dark:text-slate-300">@activity</span>
                                    }
                                </div>
                            }
                        </article>
                    }
                }
                else
                {
                    <p class="text-sm text-slate-500 dark:text-slate-400">Chua co lich trinh.</p>
                }
            </div>
        </section>

        <section class="grid gap-6 md:grid-cols-2">
            <article class="rounded-2xl border border-green-200 bg-green-50/70 p-6 shadow-sm dark:border-green-900/50 dark:bg-green-900/10">
                <h3 class="text-lg font-bold text-green-800 dark:text-green-300">Bao gom</h3>
                <ul class="mt-4 space-y-2 text-sm text-green-700 dark:text-green-200">
                    @if (Model.GeneratedInclusions != null && Model.GeneratedInclusions.Count > 0)
                    {
                        foreach (var item in Model.GeneratedInclusions)
                        {
                            <li>@item</li>
                        }
                    }
                    else
                    {
                        <li>Chua cau hinh</li>
                    }
                </ul>
            </article>
            <article class="rounded-2xl border border-red-200 bg-red-50/70 p-6 shadow-sm dark:border-red-900/50 dark:bg-red-900/10">
                <h3 class="text-lg font-bold text-red-800 dark:text-red-300">Khong bao gom</h3>
                <ul class="mt-4 space-y-2 text-sm text-red-700 dark:text-red-200">
                    @if (Model.GeneratedExclusions != null && Model.GeneratedExclusions.Count > 0)
                    {
                        foreach (var item in Model.GeneratedExclusions)
                        {
                            <li>@item</li>
                        }
                    }
                    else
                    {
                        <li>Chua cau hinh</li>
                    }
                </ul>
            </article>
        </section>

        <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-700 dark:bg-slate-900/40">
            <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
                <div>
                    <h3 class="text-2xl font-bold text-slate-900 dark:text-white">Departures</h3>
                    <p class="text-sm text-slate-500 dark:text-slate-400">Danh sach departures dung cho booking va bao gia.</p>
                </div>
                <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-black uppercase tracking-[0.2em] text-slate-600 dark:bg-slate-800 dark:text-slate-300">@adminDepartures.Count item(s)</span>
            </div>

            @if (adminDepartures.Count == 0)
            {
                <p class="mt-6 rounded-2xl bg-slate-50 px-4 py-3 text-sm font-semibold text-slate-600 dark:bg-slate-800/60 dark:text-slate-300">Dang dung fallback tu StartDates.</p>
            }
            else
            {
                <div class="mt-6 space-y-3">
                    @foreach (var departure in adminDepartures)
                    {
                        <article class="rounded-2xl border border-slate-200 bg-slate-50/80 p-4 dark:border-slate-700 dark:bg-slate-800/60">
                            <div class="flex flex-col gap-3 lg:flex-row lg:items-center lg:justify-between">
                                <div>
                                    <p class="text-lg font-black text-slate-900 dark:text-white">@departure.StartDate.ToString("dd/MM/yyyy")</p>
                                    <p class="mt-1 text-xs font-bold uppercase tracking-[0.2em] text-slate-400 dark:text-slate-500">@departure.Status · @departure.ConfirmationType</p>
                                </div>
                                <div class="grid gap-3 text-sm sm:grid-cols-3 lg:text-right">
                                    <div><span class="block text-[11px] font-black uppercase tracking-[0.2em] text-slate-400 dark:text-slate-500">Gia</span><strong class="text-slate-900 dark:text-white">NL @departure.AdultPrice.ToString("N0") · TE @departure.ChildPrice.ToString("N0") · EB @departure.InfantPrice.ToString("N0")</strong></div>
                                    <div><span class="block text-[11px] font-black uppercase tracking-[0.2em] text-slate-400 dark:text-slate-500">Capacity</span><strong class="text-slate-900 dark:text-white">@departure.BookedCount / @departure.Capacity</strong></div>
                                    <div><span class="block text-[11px] font-black uppercase tracking-[0.2em] text-slate-400 dark:text-slate-500">Cutoff</span><strong class="text-slate-900 dark:text-white">@departure.CutoffHours gio</strong></div>
                                </div>
                            </div>
                        </article>
                    }
                </div>
            }
        </section>

        <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-700 dark:bg-slate-900/40">
            <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
                <div>
                    <h3 class="text-2xl font-bold text-slate-900 dark:text-white">Route intelligence</h3>
                    <p class="text-sm text-slate-500 dark:text-slate-400">Heuristic summary cho quang duong, thoi gian di chuyen va warning cua routing hien tai.</p>
                </div>
                <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-black uppercase tracking-[0.2em] text-slate-600 dark:bg-slate-800 dark:text-slate-300">@routeInsight.DayCount day(s)</span>
            </div>
            <div class="mt-6 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
                <div class="rounded-2xl bg-slate-50 p-4 dark:bg-slate-800/60">
                    <p class="text-[11px] font-black uppercase tracking-[0.2em] text-slate-400 dark:text-slate-500">Distance</p>
                    <p class="mt-2 text-xl font-black text-slate-900 dark:text-white">@routeInsight.TotalDistanceKm.ToString("0.0") km</p>
                </div>
                <div class="rounded-2xl bg-slate-50 p-4 dark:bg-slate-800/60">
                    <p class="text-[11px] font-black uppercase tracking-[0.2em] text-slate-400 dark:text-slate-500">Travel</p>
                    <p class="mt-2 text-xl font-black text-slate-900 dark:text-white">@routeInsight.TotalTravelMinutes phut</p>
                </div>
                <div class="rounded-2xl bg-slate-50 p-4 dark:bg-slate-800/60">
                    <p class="text-[11px] font-black uppercase tracking-[0.2em] text-slate-400 dark:text-slate-500">Journey</p>
                    <p class="mt-2 text-xl font-black text-slate-900 dark:text-white">@routeInsight.TotalJourneyMinutes phut</p>
                </div>
                <div class="rounded-2xl bg-slate-50 p-4 dark:bg-slate-800/60">
                    <p class="text-[11px] font-black uppercase tracking-[0.2em] text-slate-400 dark:text-slate-500">Average score</p>
                    <p class="mt-2 text-xl font-black text-slate-900 dark:text-white">@(routeInsight.AverageAttractionScore?.ToString("0.0") ?? "N/A")</p>
                </div>
            </div>
            <div class="mt-6">
                <p class="text-[11px] font-black uppercase tracking-[0.2em] text-slate-400 dark:text-slate-500">Warnings</p>
                @if (routeInsight.Warnings.Count > 0)
                {
                    <div class="mt-3 space-y-2">
                        @foreach (var warning in routeInsight.Warnings)
                        {
                            <div class="rounded-2xl border border-amber-200 bg-amber-50 px-4 py-3 text-sm font-semibold text-amber-800 dark:border-amber-900/50 dark:bg-amber-900/10 dark:text-amber-200">@warning.Message</div>
                        }
                    </div>
                }
                else
                {
                    <p class="mt-3 rounded-2xl bg-slate-50 px-4 py-3 text-sm font-semibold text-slate-600 dark:bg-slate-800/60 dark:text-slate-300">Khong co warning cho routing hien tai.</p>
                }
            </div>
            <div class="mt-8 space-y-5">
                @if (routeInsight.Days.Any(day => day.Legs.Count > 0))
                {
                    foreach (var routeDay in routeInsight.Days.Where(day => day.Legs.Count > 0).OrderBy(day => day.Day))
                    {
                        <article class="rounded-2xl border border-slate-200 bg-slate-50/80 p-5 dark:border-slate-700 dark:bg-slate-800/60">
                            <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
                                <div>
                                    <p class="text-[11px] font-black uppercase tracking-[0.2em] text-slate-400 dark:text-slate-500">Traffic-aware estimate</p>
                                    <h4 class="mt-1 text-lg font-black text-slate-900 dark:text-white">Day @routeDay.Day</h4>
                                </div>
                                <div class="flex flex-wrap gap-2">
                                    @if (!string.IsNullOrWhiteSpace(routeDay.PeakDayPart))
                                    {
                                        <span class="rounded-full bg-white px-3 py-1 text-[11px] font-black uppercase tracking-[0.2em] text-slate-600 dark:bg-slate-900 dark:text-slate-300">Day part: @DayPartText(routeDay.PeakDayPart)</span>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(routeDay.PeakCongestionLevel))
                                    {
                                        <span class="rounded-full bg-white px-3 py-1 text-[11px] font-black uppercase tracking-[0.2em] text-slate-600 dark:bg-slate-900 dark:text-slate-300">Congestion: @CongestionText(routeDay.PeakCongestionLevel)</span>
                                    }
                                </div>
                            </div>
                            <div class="mt-5 overflow-x-auto">
                                <table class="min-w-full text-sm text-slate-600 dark:text-slate-300">
                                    <thead>
                                        <tr class="border-b border-slate-200 text-left text-[11px] font-black uppercase tracking-[0.2em] text-slate-400 dark:border-slate-700 dark:text-slate-500">
                                            <th class="pb-3 pr-4">Leg</th>
                                            <th class="pb-3 pr-4">Distance</th>
                                            <th class="pb-3 pr-4">Drive</th>
                                            <th class="pb-3 pr-4">Junction delay</th>
                                            <th class="pb-3 pr-4">Travel</th>
                                            <th class="pb-3 pr-4">Day part</th>
                                            <th class="pb-3">Congestion</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var leg in routeDay.Legs)
                                        {
                                            var fromName = routeStopNameLookup.TryGetValue(leg.FromStopId, out var resolvedFromName) ? resolvedFromName : leg.FromStopId;
                                            var toName = routeStopNameLookup.TryGetValue(leg.ToStopId, out var resolvedToName) ? resolvedToName : leg.ToStopId;
                                            <tr class="border-b border-slate-100 align-top last:border-b-0 dark:border-slate-800">
                                                <td class="py-3 pr-4 font-semibold text-slate-900 dark:text-white">@fromName -> @toName</td>
                                                <td class="py-3 pr-4">@leg.DistanceKm.ToString("0.0") km</td>
                                                <td class="py-3 pr-4">@leg.DriveMinutes phut</td>
                                                <td class="py-3 pr-4">@leg.JunctionDelayMinutes phut</td>
                                                <td class="py-3 pr-4">@leg.TravelMinutes phut</td>
                                                <td class="py-3 pr-4">@DayPartText(leg.DayPart)</td>
                                                <td class="py-3">@CongestionText(leg.CongestionLevel)</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </article>
                    }
                }
                else
                {
                    <p class="rounded-2xl bg-slate-50 px-4 py-3 text-sm font-semibold text-slate-600 dark:bg-slate-800/60 dark:text-slate-300">Chua co leg estimate hop le de hien thi bang ETA.</p>
                }
            </div>
        </section>

        <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-700 dark:bg-slate-900/40">
            <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
                <div>
                    <h3 class="text-2xl font-bold text-slate-900 dark:text-white">Routing</h3>
                    <p class="text-sm text-slate-500 dark:text-slate-400">Danh sach route stop da embed trong tour.</p>
                </div>
                <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-black uppercase tracking-[0.2em] text-slate-600 dark:bg-slate-800 dark:text-slate-300">Schema v@(Model.Routing?.SchemaVersion ?? 0)</span>
            </div>

            @if (routeStops.Count == 0)
            {
                <p class="mt-6 rounded-2xl bg-slate-50 px-4 py-3 text-sm font-semibold text-slate-600 dark:bg-slate-800/60 dark:text-slate-300">Chua co du lieu routing.</p>
            }
            else
            {
                <div class="mt-6 space-y-3">
                    @foreach (var stop in routeStops)
                    {
                        <article class="rounded-2xl border border-slate-200 bg-slate-50/80 p-4 dark:border-slate-700 dark:bg-slate-800/60">
                            <div class="flex flex-col gap-3 lg:flex-row lg:items-start lg:justify-between">
                                <div>
                                    <p class="text-lg font-black text-slate-900 dark:text-white">Day @stop.Day · Order @stop.Order · @stop.Name</p>
                                    <p class="mt-1 text-xs font-bold uppercase tracking-[0.2em] text-slate-400 dark:text-slate-500">@stop.Type</p>
                                    @if (!string.IsNullOrWhiteSpace(stop.Note))
                                    {
                                        <p class="mt-3 text-sm leading-7 text-slate-600 dark:text-slate-300">@stop.Note</p>
                                    }
                                </div>
                                <div class="grid gap-3 text-sm sm:grid-cols-2 lg:text-right">
                                    <div><span class="block text-[11px] font-black uppercase tracking-[0.2em] text-slate-400 dark:text-slate-500">Coordinates</span><strong class="text-slate-900 dark:text-white">@stop.Coordinates?.Lat, @stop.Coordinates?.Lng</strong></div>
                                    <div><span class="block text-[11px] font-black uppercase tracking-[0.2em] text-slate-400 dark:text-slate-500">Visit</span><strong class="text-slate-900 dark:text-white">@stop.VisitMinutes phut</strong></div>
                                    <div><span class="block text-[11px] font-black uppercase tracking-[0.2em] text-slate-400 dark:text-slate-500">Score</span><strong class="text-slate-900 dark:text-white">@stop.AttractionScore</strong></div>
                                </div>
                            </div>
                        </article>
                    }
                </div>
            }
        </section>
    </div>

    <aside class="space-y-6 lg:col-span-4">
        <section class="sticky top-28 rounded-3xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-700 dark:bg-slate-900/60">
            <h3 class="text-lg font-bold text-slate-900 dark:text-white">Quick summary</h3>
            <dl class="mt-4 space-y-4 text-sm">
                <div>
                    <dt class="font-black uppercase tracking-[0.18em] text-slate-400 dark:text-slate-500">SupplierRef</dt>
                    <dd class="mt-1 text-slate-700 dark:text-slate-200">@(!string.IsNullOrWhiteSpace(Model.SupplierRef?.SupplierName) ? Model.SupplierRef.SupplierName : "Chua cau hinh")</dd>
                </div>
                <div>
                    <dt class="font-black uppercase tracking-[0.18em] text-slate-400 dark:text-slate-500">Danh gia</dt>
                    <dd class="mt-1 text-slate-700 dark:text-slate-200">@Model.Rating / 5 · @Model.ReviewCount review(s)</dd>
                </div>
                <div>
                    <dt class="font-black uppercase tracking-[0.18em] text-slate-400 dark:text-slate-500">Suc chua tour</dt>
                    <dd class="mt-1 text-slate-700 dark:text-slate-200">@Model.CurrentParticipants / @Model.MaxParticipants</dd>
                </div>
                <div>
                    <dt class="font-black uppercase tracking-[0.18em] text-slate-400 dark:text-slate-500">StartDates</dt>
                    <dd class="mt-1 text-slate-700 dark:text-slate-200">
                        @if (Model.StartDates != null && Model.StartDates.Count > 0)
                        {
                            <span>@string.Join(", ", Model.StartDates.OrderBy(item => item).Select(item => item.ToString("dd/MM/yyyy")))</span>
                        }
                        else
                        {
                            <span>Chua cau hinh</span>
                        }
                    </dd>
                </div>
            </dl>
        </section>
    </aside>
</div>
