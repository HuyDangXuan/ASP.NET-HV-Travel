<div id="tour-calendar-dropdown" class="fixed w-80 bg-white dark:bg-slate-900 rounded-2xl shadow-2xl border border-slate-100 dark:border-slate-800 z-[2000] hidden origin-top scale-95 opacity-0 transition-all duration-200">
    <div class="p-5">
        <div class="flex justify-between items-center mb-5">
            <span class="text-xs font-bold text-slate-900 dark:text-white uppercase tracking-widest">Chọn Ngày</span>
            <div class="flex gap-1 bg-slate-50 dark:bg-slate-800/50 p-1 rounded-lg">
                <button type="button" onclick="changeTourMonth(-1)" class="p-1 rounded-md hover:bg-white dark:hover:bg-slate-700 text-slate-500 hover:text-primary transition-all active:scale-95"><span class="material-symbols-outlined text-[20px]">chevron_left</span></button>
                <span id="tour-calendar-month-year" class="text-[11px] font-bold text-slate-700 dark:text-slate-300 min-w-[100px] text-center flex items-center justify-center tracking-tight">Tháng ..., 20...</span>
                <button type="button" onclick="changeTourMonth(1)" class="p-1 rounded-md hover:bg-white dark:hover:bg-slate-700 text-slate-500 hover:text-primary transition-all active:scale-95"><span class="material-symbols-outlined text-[20px]">chevron_right</span></button>
            </div>
        </div>
        <div class="grid grid-cols-7 gap-1 text-center mb-2 border-b border-slate-100 dark:border-slate-800 pb-2">
            <span class="text-[10px] text-slate-400 font-extrabold uppercase">T2</span>
            <span class="text-[10px] text-slate-400 font-extrabold uppercase">T3</span>
            <span class="text-[10px] text-slate-400 font-extrabold uppercase">T4</span>
            <span class="text-[10px] text-slate-400 font-extrabold uppercase">T5</span>
            <span class="text-[10px] text-slate-400 font-extrabold uppercase">T6</span>
            <span class="text-[10px] text-slate-400 font-extrabold uppercase">T7</span>
            <span class="text-[10px] text-red-500 font-extrabold uppercase">CN</span>
        </div>
        <div id="tour-calendar-days" class="grid grid-cols-7 gap-1 text-center"></div>
    </div>
</div>
