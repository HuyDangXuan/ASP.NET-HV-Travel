@{
    Layout = null;
}
<!DOCTYPE html>
<html class="light" lang="vi">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Xác minh số điện thoại/Email - HV Travel Admin</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@100;200;300;400;500;600;700;800;900&amp;display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#2bcdee",
                        "primary-dark": "#0ea5e9",
                        "background-light": "#f6f8f8",
                        "background-dark": "#101f22",
                        "surface-light": "#ffffff",
                        "surface-dark": "#1a2c30",
                    },
                    fontFamily: {
                        "display": ["Be Vietnam Pro", "sans-serif"]
                    },
                    borderRadius: {
                        "DEFAULT": "0.5rem",
                        "lg": "1rem",
                        "xl": "1.5rem",
                        "full": "9999px"
                    },
                },
            },
        }
    </script>
    <style>
        .glass-effect {
            background: rgba(255, 255, 255, 0.15);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.2);
        }

        .mesh-gradient {
            background-color: #f6f8f8;
            background-image: radial-gradient(at 0% 0%, rgba(43, 205, 238, 0.05) 0, transparent 50%), radial-gradient(at 50% 0%, rgba(43, 205, 238, 0.02) 0, transparent 50%), radial-gradient(at 100% 100%, rgba(43, 205, 238, 0.05) 0, transparent 50%);
        }

        .dark .mesh-gradient {
            background-color: #101f22;
            background-image: radial-gradient(at 0% 0%, rgba(43, 205, 238, 0.1) 0, transparent 50%), radial-gradient(at 100% 100%, rgba(43, 205, 238, 0.1) 0, transparent 50%);
        }
    </style>
</head>
<body class="font-display bg-background-light dark:bg-background-dark text-slate-900 dark:text-white transition-colors duration-300">
    <div class="flex min-h-screen w-full">
         <!-- Left Side: Visual/Branding (Consistent with Login) -->
        <div class="hidden lg:flex lg:w-1/2 relative overflow-hidden">
            <div class="absolute inset-0 bg-cover bg-center transition-transform duration-700 hover:scale-105" data-alt="Breath-taking aerial view of Mu Cang Chai rice terraces in Vietnam" style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuCVFPaa2-Ghm50eobjNhSJP5dzUPfhFFB90BgCvIevVUQQ08T6INBGXe-EkSWevqJw8eyRJLjPDP2MBlOrZzjKSLKoq8H_CiOIu3i0PiHxZtTrnIpMV2F_02voW6WT-hSn5qCIE8fQVVq3Uq1k-ZagZghGkKJlMpc7Jp8G0d5IU4uqpYPqBNy2toPkcIXQAVJ6gsWquQkgscA1yWDMEhzj5Q-daoY2xOYCmTef94YOPg5w-oTK6y8My_R0lgn6REfWpEPN0RrL6ww');">
            </div>
            <div class="absolute inset-0 bg-black/20"></div>
            <!-- Glassmorphic Overlay Content -->
            <div class="absolute inset-0 flex flex-col justify-between p-12">
                <div class="flex items-center gap-3 text-white">
                    <div class="bg-primary p-2 rounded-lg">
                        <span class="material-symbols-outlined text-white">explore</span>
                    </div>
                    <h2 class="text-2xl font-bold tracking-tight">HV Travel</h2>
                </div>
                <div class="glass-effect rounded-xl p-10 max-w-lg mb-8">
                    <h1 class="text-white text-5xl font-black leading-tight tracking-tight mb-4">
                        Khám Phá Trái Tim Việt Nam.
                    </h1>
                    <p class="text-white/90 text-lg font-medium leading-relaxed">
                        Quản lý trải nghiệm cao cấp và thiết kế những hành trình khó quên cho du khách hiện đại.
                    </p>
                </div>
            </div>
        </div>

        <!-- Right Side: OTP Verification Form -->
        <div class="w-full lg:w-1/2 mesh-gradient flex items-center justify-center p-6 sm:p-12 lg:p-20 relative">
            <div class="w-full max-w-[440px] flex flex-col gap-8">
                <!-- Page Heading -->
                <div class="flex flex-col gap-2">
                    <h3 class="text-primary font-bold tracking-wider uppercase text-xs">Xác Minh Bảo Mật</h3>
                    <h2 class="text-slate-900 dark:text-white text-4xl font-extrabold tracking-tight">Nhập Mã OTP</h2>
                    <p class="text-slate-500 dark:text-slate-400 text-base">Chúng tôi đã gửi mã xác minh gồm 6 chữ số đến email của bạn. Vui lòng kiểm tra và nhập mã vào bên dưới.</p>
                </div>
                
                @if (ViewBag.Error != null)
                {
                    <div class="p-4 mb-4 text-sm text-red-800 rounded-lg bg-red-50 dark:bg-red-900/30 dark:text-red-400 border border-red-200 dark:border-red-800" role="alert">
                        <span class="font-medium">Lỗi!</span> @ViewBag.Error
                    </div>
                }

                <form class="flex flex-col gap-8" method="post" asp-action="VerifyOTP" asp-controller="Auth" id="otp-form">
                    <!-- OTP Inputs -->
                    <div class="flex flex-col gap-2">
                        <label class="text-slate-900 dark:text-white text-sm font-semibold">Mã Xác Minh</label>
                        <div class="flex justify-between gap-2 max-w-[360px]" id="otp-container">
                            <input name="otp1" type="text" maxlength="1" class="w-12 h-14 text-center text-xl font-bold rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-surface-dark text-slate-900 dark:text-white focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all otp-input" />
                            <input name="otp2" type="text" maxlength="1" class="w-12 h-14 text-center text-xl font-bold rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-surface-dark text-slate-900 dark:text-white focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all otp-input" />
                            <input name="otp3" type="text" maxlength="1" class="w-12 h-14 text-center text-xl font-bold rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-surface-dark text-slate-900 dark:text-white focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all otp-input" />
                            <input name="otp4" type="text" maxlength="1" class="w-12 h-14 text-center text-xl font-bold rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-surface-dark text-slate-900 dark:text-white focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all otp-input" />
                            <input name="otp5" type="text" maxlength="1" class="w-12 h-14 text-center text-xl font-bold rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-surface-dark text-slate-900 dark:text-white focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all otp-input" />
                            <input name="otp6" type="text" maxlength="1" class="w-12 h-14 text-center text-xl font-bold rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-surface-dark text-slate-900 dark:text-white focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all otp-input" />
                        </div>
                    </div>
                    
                    <div class="flex flex-col gap-4">
                        <!-- Verify Button -->
                        <button type="submit" class="w-full h-14 bg-gradient-to-r from-primary to-primary-dark hover:shadow-lg hover:shadow-primary/30 text-white font-bold rounded-xl transition-all transform active:scale-[0.98] flex items-center justify-center gap-2">
                            <span>Xác Nhận</span>
                            <span class="material-symbols-outlined">check_circle</span>
                        </button>
                        
                        <!-- Resend Option -->
                        <div class="text-center">
                            <span class="text-sm text-slate-500 dark:text-slate-400">Bạn chưa nhận được mã? </span>
                            <!-- Currently a button doing nothing, but could map to a re-send OTP method -->
                            <button type="button" class="text-primary font-bold hover:underline text-sm focus:outline-none disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:no-underline" id="resend-btn">
                                Gửi lại mã <span id="timer">(02:00)</span>
                            </button>
                        </div>
                    </div>
                    
                    <!-- Back to Login -->
                    <div class="flex justify-center mt-4">
                        <a class="flex items-center gap-2 text-slate-500 hover:text-slate-900 dark:text-slate-400 dark:hover:text-white text-sm font-bold transition-all" asp-action="Login">
                            <span class="material-symbols-outlined text-[18px]">arrow_back</span>
                            Quay lại đăng nhập
                        </a>
                    </div>
                </form>
            </div>
             <!-- Theme Toggle / Language (Visual only) -->
            <div class="absolute top-8 right-8 flex items-center gap-4">
                <button class="p-2 rounded-full border border-slate-200 dark:border-slate-700 text-slate-400 hover:bg-white dark:hover:bg-surface-dark transition-all">
                    <span class="material-symbols-outlined text-[20px]">translate</span>
                </button>
                <button class="p-2 rounded-full border border-slate-200 dark:border-slate-700 text-slate-400 hover:bg-white dark:hover:bg-surface-dark transition-all" onclick="toggleTheme()">
                    <span class="material-symbols-outlined dark:hidden text-[20px]">dark_mode</span>
                    <span class="material-symbols-outlined hidden dark:block text-[20px]">light_mode</span>
                </button>
            </div>
        </div>
    </div>
    
    <script>
        // Check local storage or system preference on load
        if (localStorage.theme === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark');
        } else {
            document.documentElement.classList.remove('dark');
        }

        // Toggle theme and save preference
        function toggleTheme() {
            if (document.documentElement.classList.contains('dark')) {
                document.documentElement.classList.remove('dark');
                localStorage.theme = 'light';
            } else {
                document.documentElement.classList.add('dark');
                localStorage.theme = 'dark';
            }
        }

        // OTP Input Logic
        document.addEventListener('DOMContentLoaded', () => {
            const inputs = document.querySelectorAll('.otp-input');
            const form = document.getElementById('otp-form');

            // Auto-focus first input
            inputs[0].focus();

            inputs.forEach((input, index) => {
                // Focus next/prev on input
                input.addEventListener('input', (e) => {
                    if (e.target.value.length > 0) {
                        if (index < inputs.length - 1) {
                            inputs[index + 1].focus();
                        } else {
                            // If last input is filled, optionally auto-submit
                            // form.submit();
                        }
                    }
                });

                // Handle backspace
                input.addEventListener('keydown', (e) => {
                    if (e.key === 'Backspace') {
                        if (e.target.value === '' && index > 0) {
                            inputs[index - 1].focus();
                        }
                    }
                });

                // Handle paste
                input.addEventListener('paste', (e) => {
                    e.preventDefault();
                    const pastedData = e.clipboardData.getData('text').slice(0, inputs.length).replace(/[^0-9]/g, '');
                    
                    if (pastedData) {
                        for (let i = 0; i < pastedData.length; i++) {
                            if (index + i < inputs.length) {
                                inputs[index + i].value = pastedData[i];
                            }
                        }
                        
                        // Focus the next empty input or the last one
                        const nextIndex = Math.min(index + pastedData.length, inputs.length - 1);
                        inputs[nextIndex].focus();
                    }
                });
            });

            // Resend Timer Logic
            const resendBtn = document.getElementById('resend-btn');
            const timerSpan = document.getElementById('timer');
            let timeLeft = 120; // 2 minutes

            resendBtn.disabled = true;

            const countdown = setInterval(() => {
                const minutes = Math.floor(timeLeft / 60);
                const seconds = timeLeft % 60;
                
                timerSpan.textContent = `(${minutes.toString().padStart(2, '0')}:${seconds.toString().padStart(2, '0')})`;
                
                timeLeft--;

                if (timeLeft < 0) {
                    clearInterval(countdown);
                    resendBtn.disabled = false;
                    timerSpan.textContent = '';
                }
            }, 1000);
        });
    </script>
</body>
</html>
