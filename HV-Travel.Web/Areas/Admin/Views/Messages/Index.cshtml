@{
    ViewData["Title"] = "Tin nhắn";
    ViewData["AdminSection"] = "messages";
}

<form id="admin-chat-antiforgery-form" class="hidden">
    @Html.AntiForgeryToken()
</form>

<div class="mb-6 flex flex-col gap-4" data-animate="fade-in-up" data-delay="0.05">
    <div class="flex flex-col gap-3 lg:flex-row lg:items-end lg:justify-between">
        <div>
            @await Html.PartialAsync("_AdminBreadcrumb", new HVTravel.Web.Models.BreadcrumbViewModel
            {
                Items = new List<HVTravel.Web.Models.BreadcrumbItemViewModel>
                {
                    new() { Label = "Trang chủ", Url = Url.Action("Index", "Dashboard") },
                    new() { Label = "Tin nhắn", IsCurrent = true }
                }
            })
            <h1 class="mt-2 text-3xl font-bold tracking-tight text-slate-900 dark:text-white">Trung tâm hỗ trợ khách hàng</h1>
            <p class="mt-2 max-w-3xl text-sm text-slate-500 dark:text-slate-400">
                Theo dõi hội thoại theo thời gian thực, xác định cuộc trò chuyện nào cần phản hồi trước và trả lời ngay trong cùng một không gian làm việc.
            </p>
        </div>

        <div class="flex items-center gap-3">
            <div class="rounded-2xl bg-surface-light px-4 py-3 shadow-sm ring-1 ring-border-light dark:bg-surface-elevated-dark dark:ring-border-dark">
                <p class="text-[11px] font-bold uppercase tracking-[0.24em] text-slate-400">Realtime</p>
                <p id="admin-chat-summary" class="mt-1 text-sm font-semibold text-slate-900 dark:text-white">Đang kết nối trung tâm tin nhắn...</p>
            </div>
            <button id="admin-chat-refresh" type="button" class="inline-flex h-11 items-center gap-2 rounded-2xl bg-gradient-to-r from-primary to-accent px-4 text-sm font-bold text-white shadow-lg shadow-primary/30 transition-all hover:-translate-y-0.5 hover:brightness-105">
                <span class="material-symbols-outlined text-[20px]">refresh</span>
                Làm mới
            </button>
        </div>
    </div>

    <div class="grid gap-3 md:grid-cols-3">
        <div class="rounded-2xl bg-surface-light px-4 py-4 shadow-sm ring-1 ring-border-light dark:bg-surface-elevated-dark dark:ring-border-dark">
            <p class="text-[11px] font-bold uppercase tracking-[0.2em] text-slate-400">Tổng hội thoại</p>
            <p id="admin-chat-total-count" class="mt-2 text-2xl font-bold text-slate-900 dark:text-white">0</p>
            <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">Tất cả cuộc trò chuyện đang có trong inbox.</p>
        </div>
        <div class="rounded-2xl bg-surface-light px-4 py-4 shadow-sm ring-1 ring-border-light dark:bg-surface-elevated-dark dark:ring-border-dark">
            <p class="text-[11px] font-bold uppercase tracking-[0.2em] text-slate-400">Chưa đọc</p>
            <p id="admin-chat-unread-count" class="mt-2 text-2xl font-bold text-amber-500">0</p>
            <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">Tin nhắn khách vừa gửi và chưa được nhân viên xem.</p>
        </div>
        <div class="rounded-2xl bg-surface-light px-4 py-4 shadow-sm ring-1 ring-border-light dark:bg-surface-elevated-dark dark:ring-border-dark">
            <p class="text-[11px] font-bold uppercase tracking-[0.2em] text-slate-400">Chờ phản hồi</p>
            <p id="admin-chat-waiting-count" class="mt-2 text-2xl font-bold text-primary">0</p>
            <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">Hội thoại đang ở trạng thái cần admin tiếp nhận hoặc trả lời.</p>
        </div>
    </div>
</div>

<section class="grid grid-cols-1 gap-6 xl:h-[calc(100vh-16rem)] xl:min-h-[calc(100vh-16rem)] xl:grid-cols-[380px_minmax(0,1fr)]" data-animate="fade-in-up" data-delay="0.1">
    <aside class="relative flex min-h-0 flex-col overflow-hidden rounded-[1.75rem] border border-border-light/80 bg-gradient-to-b from-surface-light via-primary-soft/20 to-surface-muted-light shadow-[0_24px_60px_rgba(15,23,42,0.12)] ring-1 ring-border-light/80 dark:border-border-dark dark:bg-gradient-to-b dark:from-surface-dark dark:via-surface-dark dark:to-background-dark dark:ring-border-dark">
        <div class="pointer-events-none absolute inset-x-0 top-0 h-24 bg-gradient-to-r from-primary/15 via-accent-soft/50 to-transparent dark:from-primary/10 dark:via-slate-800/40 dark:to-transparent"></div>
        <div class="relative border-b border-border-light px-5 py-5 dark:border-border-dark">
            <div class="flex items-start justify-between gap-4">
                <div>
                    <p class="text-xs font-bold uppercase tracking-[0.24em] text-primary">Inbox</p>
                    <h2 class="mt-2 text-xl font-bold text-slate-900 dark:text-white">Hội thoại gần đây</h2>
                </div>
                <span id="admin-chat-unread-badge" class="inline-flex min-w-10 items-center justify-center rounded-full bg-primary/10 px-3 py-1 text-xs font-bold text-primary">0</span>
            </div>
            <p class="mt-3 rounded-2xl border border-border-light bg-surface-light/90 px-4 py-3 text-sm text-slate-600 shadow-sm ring-1 ring-border-light dark:border-border-dark dark:bg-surface-elevated-dark/85 dark:text-text-muted-dark dark:ring-border-dark">
                Hội thoại mới sẽ tự cập nhật khi khách gửi thêm tin nhắn hoặc khi nhân viên phản hồi từ thiết bị khác.
            </p>
        </div>

        <div id="admin-chat-conversation-list" class="relative min-h-0 flex-1 space-y-3 overflow-y-auto px-4 py-4">
            <div class="rounded-2xl border border-dashed border-border-light bg-surface-light/80 px-4 py-8 text-center text-sm text-slate-500 shadow-sm dark:border-border-dark dark:bg-surface-elevated-dark/50 dark:text-text-muted-dark">
                Chưa có hội thoại nào.
            </div>
        </div>
    </aside>

    <section class="relative flex min-h-0 flex-col overflow-hidden rounded-[1.75rem] border border-border-light/80 bg-gradient-to-br from-surface-light via-surface-muted-light to-primary-soft/20 shadow-[0_24px_60px_rgba(15,23,42,0.14)] ring-1 ring-border-light/80 xl:h-full dark:border-border-dark dark:bg-gradient-to-br dark:from-surface-dark dark:via-surface-dark dark:to-background-dark dark:ring-border-dark">
        <div class="pointer-events-none absolute inset-x-0 top-0 h-28 bg-gradient-to-r from-primary/10 via-accent-soft/55 to-transparent dark:from-primary/10 dark:via-slate-800/30 dark:to-transparent"></div>
        <header id="admin-chat-thread-header" class="relative border-b border-border-light px-5 py-5 dark:border-border-dark">
            <p class="text-lg font-bold text-slate-900 dark:text-white">Chưa chọn hội thoại</p>
            <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">Chọn một cuộc trò chuyện ở cột bên trái để xem chi tiết và bắt đầu phản hồi.</p>
        </header>

        <div id="admin-chat-thread" class="min-h-[320px] flex-1 overflow-y-auto bg-[radial-gradient(circle_at_top,_rgba(20,184,212,0.10),_transparent_34%),linear-gradient(180deg,rgba(255,255,255,0.82),rgba(236,244,248,0.96))] px-5 py-5 dark:bg-[radial-gradient(circle_at_top,_rgba(20,184,212,0.10),_transparent_28%),linear-gradient(180deg,rgba(13,27,42,0.44),rgba(7,17,27,0.26))] xl:min-h-0">
            <div class="space-y-4">
                <div class="rounded-2xl border border-dashed border-slate-300 bg-white/85 px-4 py-10 text-center text-sm text-slate-500 shadow-sm dark:border-slate-700 dark:bg-slate-900/60 dark:text-slate-400">
                    Tin nhắn sẽ hiển thị ở đây sau khi bạn mở một hội thoại.
                </div>
            </div>
        </div>

        <div class="relative border-t border-border-light bg-surface-light/92 px-5 py-4 backdrop-blur-sm dark:border-border-dark dark:bg-surface-dark/90">
            <div class="flex flex-col gap-3 lg:flex-row lg:items-center lg:justify-between">
                <p id="admin-chat-status" class="text-sm text-slate-500 dark:text-slate-400">Không gian chat đang khởi tạo.</p>
                <button id="admin-chat-mobile-list-toggle" type="button" class="inline-flex items-center gap-2 self-start rounded-xl border border-border-light bg-surface-light px-3.5 py-2 text-sm font-semibold text-slate-700 shadow-sm transition-colors hover:bg-surface-muted-light xl:hidden dark:border-border-dark dark:bg-surface-elevated-dark dark:text-slate-200 dark:hover:bg-surface-dark">
                    <span class="material-symbols-outlined text-[18px]">forum</span>
                    Xem danh sách hội thoại
                </button>
            </div>

            <form id="admin-chat-form" class="mt-4">
                <div class="rounded-[1.35rem] border border-border-light bg-surface-light p-3 shadow-[0_18px_40px_rgba(15,23,42,0.08)] ring-1 ring-accent-soft/60 dark:border-border-dark dark:bg-surface-elevated-dark/80 dark:ring-border-dark">
                    <textarea id="admin-chat-input" rows="3" class="w-full resize-none border-0 bg-transparent p-2 text-sm text-slate-900 outline-none placeholder:text-slate-400 focus:ring-0 dark:text-white dark:placeholder:text-slate-500" placeholder="Chọn hội thoại để bắt đầu phản hồi..." disabled></textarea>
                    <div class="mt-3 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                        <p class="text-xs text-slate-400 dark:text-slate-500">Nhấn Enter để xuống dòng. Dùng nút gửi để phản hồi và giữ lịch sử trao đổi rõ ràng.</p>
                        <p class="text-xs text-primary/80 dark:text-primary-light/80">Nhấn Enter để gửi nhanh, Shift + Enter để xuống dòng.</p>
                        <button id="admin-chat-send" type="submit" class="inline-flex items-center justify-center gap-2 rounded-xl bg-gradient-to-r from-primary to-accent px-4 py-2.5 text-sm font-bold text-white shadow-lg shadow-primary/20 transition-all hover:-translate-y-0.5 hover:brightness-105 disabled:cursor-not-allowed disabled:opacity-50" disabled>
                            <span class="material-symbols-outlined text-[18px]">send</span>
                            Gửi phản hồi
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </section>
</section>

<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>

<script>
    (() => {
        const listEl = document.getElementById('admin-chat-conversation-list');
        const threadEl = document.getElementById('admin-chat-thread');
        const headerEl = document.getElementById('admin-chat-thread-header');
        const inputEl = document.getElementById('admin-chat-input');
        const sendEl = document.getElementById('admin-chat-send');
        const formEl = document.getElementById('admin-chat-form');
        const refreshEl = document.getElementById('admin-chat-refresh');
        const badgeEl = document.getElementById('admin-chat-unread-badge');
        const statusEl = document.getElementById('admin-chat-status');
        const summaryEl = document.getElementById('admin-chat-summary');
        const mobileListToggleEl = document.getElementById('admin-chat-mobile-list-toggle');
        const totalCountEl = document.getElementById('admin-chat-total-count');
        const unreadCountEl = document.getElementById('admin-chat-unread-count');
        const waitingCountEl = document.getElementById('admin-chat-waiting-count');
        const tokenEl = document.querySelector('#admin-chat-antiforgery-form input[name="__RequestVerificationToken"]');

        if (!listEl || !threadEl || !headerEl || !inputEl || !sendEl || !formEl || typeof signalR === 'undefined') {
            return;
        }

        const state = {
            connection: null,
            conversations: [],
            messages: [],
            selectedConversationId: '',
            joinedConversationIds: new Set()
        };

        const escapeHtml = (value) => (value || '')
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#39;');

        const formatTime = (value) => {
            if (!value) {
                return '';
            }

            return new Intl.DateTimeFormat('vi-VN', {
                day: '2-digit',
                month: '2-digit',
                hour: '2-digit',
                minute: '2-digit'
            }).format(new Date(value));
        };

        const formatLongTime = (value) => {
            if (!value) {
                return '';
            }

            return new Intl.DateTimeFormat('vi-VN', {
                weekday: 'short',
                day: '2-digit',
                month: '2-digit',
                year: 'numeric',
                hour: '2-digit',
                minute: '2-digit'
            }).format(new Date(value));
        };

        const normalizeStatus = (value) => (value || '').toLowerCase();
        const normalizeParticipant = (value) => (value || '').toLowerCase();

        const getStatusMeta = (value) => {
            const status = normalizeStatus(value);
            if (status.includes('customer')) {
                return { label: 'Chờ khách hàng', className: 'bg-amber-100 text-amber-700 dark:bg-amber-500/10 dark:text-amber-300' };
            }

            if (status.includes('staff') || status.includes('admin')) {
                return { label: 'Chờ nhân viên', className: 'bg-sky-100 text-sky-700 dark:bg-sky-500/10 dark:text-sky-300' };
            }

            if (status.includes('closed') || status.includes('done')) {
                return { label: 'Đã đóng', className: 'bg-slate-200 text-slate-700 dark:bg-slate-700 dark:text-slate-200' };
            }

            return { label: value || 'Đang mở', className: 'bg-emerald-100 text-emerald-700 dark:bg-emerald-500/10 dark:text-emerald-300' };
        };

        const getParticipantMeta = (value) => {
            const participant = normalizeParticipant(value);
            if (participant.includes('customer')) {
                return { label: 'Khách hàng', className: 'bg-primary/10 text-primary' };
            }

            if (participant.includes('guest') || participant.includes('visitor')) {
                return { label: 'Khách truy cập', className: 'bg-violet-100 text-violet-700 dark:bg-violet-500/10 dark:text-violet-300' };
            }

            return { label: value || 'Người dùng', className: 'bg-slate-100 text-slate-700 dark:bg-slate-700 dark:text-slate-200' };
        };

        const setStatus = (message) => {
            statusEl.textContent = message;
            summaryEl.textContent = message;
        };

        const updateSummary = () => {
            const totalCount = state.conversations.length;
            const unreadCount = state.conversations.reduce((total, item) => total + (item.unreadForAdminCount || 0), 0);
            const waitingCount = state.conversations.filter((item) => {
                const status = normalizeStatus(item.status);
                return status.includes('staff') || status === 'open';
            }).length;

            badgeEl.textContent = unreadCount.toString();
            totalCountEl.textContent = totalCount.toString();
            unreadCountEl.textContent = unreadCount.toString();
            waitingCountEl.textContent = waitingCount.toString();
        };

        const renderConversations = () => {
            updateSummary();

            if (!state.conversations.length) {
                listEl.innerHTML = `
                    <div class="rounded-2xl border border-dashed border-border-light bg-surface-light/80 px-4 py-8 text-center text-sm text-slate-500 shadow-sm dark:border-border-dark dark:bg-surface-elevated-dark/50 dark:text-text-muted-dark">
                        Chưa có hội thoại nào.
                    </div>`;
                return;
            }

            listEl.innerHTML = state.conversations.map((conversation) => {
                const isActive = conversation.id === state.selectedConversationId;
                const statusMeta = getStatusMeta(conversation.status);
                const participantMeta = getParticipantMeta(conversation.participantType);
                const unread = conversation.unreadForAdminCount > 0
                    ? `<span class="inline-flex min-w-7 items-center justify-center rounded-full bg-red-500 px-2 py-1 text-[10px] font-bold text-white">${conversation.unreadForAdminCount}</span>`
                    : `<span class="inline-flex min-w-7 items-center justify-center rounded-full bg-slate-200 px-2 py-1 text-[10px] font-bold text-slate-500 dark:bg-slate-700 dark:text-slate-300">0</span>`;
                const activeClass = isActive
                    ? 'border-primary/50 bg-gradient-to-br from-primary/12 via-surface-light to-accent-soft/40 shadow-[0_20px_40px_rgba(20,184,212,0.16)] ring-1 ring-primary/25 dark:from-primary/10 dark:via-surface-dark dark:to-surface-elevated-dark dark:shadow-primary/10'
                    : 'border-border-light bg-surface-light/92 shadow-sm hover:border-primary/20 hover:bg-surface-light hover:shadow-[0_14px_30px_rgba(15,23,42,0.10)] dark:border-border-dark dark:bg-surface-elevated-dark/90 dark:hover:bg-surface-dark';

                return `
                    <button type="button" data-conversation-id="${conversation.id}" class="admin-chat-conversation group flex w-full items-start gap-3 rounded-[1.4rem] border px-3.5 py-3.5 text-left transition-all ${activeClass}">
                        <div class="flex size-11 shrink-0 items-center justify-center rounded-2xl bg-gradient-to-br from-primary to-accent text-sm font-bold text-white shadow-lg shadow-primary/20">
                            ${escapeHtml((conversation.displayName || 'K').trim().charAt(0).toUpperCase() || 'K')}
                        </div>
                        <div class="min-w-0 flex-1">
                            <div class="flex items-start justify-between gap-3">
                                <div class="min-w-0">
                                    <p class="truncate text-sm font-bold text-slate-900 dark:text-white">${escapeHtml(conversation.displayName || 'Khách truy cập')}</p>
                                    <p class="mt-1 truncate text-[11px] uppercase tracking-[0.18em] text-slate-400">${escapeHtml(conversation.conversationCode || '')}</p>
                                </div>
                                ${unread}
                            </div>
                            <div class="mt-2 flex flex-wrap items-center gap-2 text-[11px] font-semibold">
                                <span class="rounded-full px-2.5 py-1 ${participantMeta.className}">${escapeHtml(participantMeta.label)}</span>
                                <span class="rounded-full px-2.5 py-1 ${statusMeta.className}">${escapeHtml(statusMeta.label)}</span>
                            </div>
                            <p class="mt-3 line-clamp-2 text-sm leading-5 text-slate-500 dark:text-slate-400">${escapeHtml(conversation.lastMessagePreview || 'Chưa có tin nhắn.')}</p>
                            <div class="mt-3 flex items-center justify-between gap-3 text-[11px] text-slate-400">
                                <span class="truncate">${escapeHtml(conversation.sourcePage || '/')}</span>
                                <span>${escapeHtml(formatTime(conversation.lastMessageAt))}</span>
                            </div>
                        </div>
                    </button>`;
            }).join('');

            listEl.querySelectorAll('.admin-chat-conversation').forEach((button) => {
                button.addEventListener('click', () => openConversation(button.dataset.conversationId || ''));
            });
        };

        const renderEmptyThread = (title, description) => {
            headerEl.innerHTML = `
                <p class="text-lg font-bold text-slate-900 dark:text-white">${escapeHtml(title)}</p>
                <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">${escapeHtml(description)}</p>`;

            threadEl.innerHTML = `
                <div class="space-y-4">
                    <div class="rounded-2xl border border-dashed border-slate-300 bg-white/85 px-4 py-10 text-center text-sm text-slate-500 shadow-sm dark:border-slate-700 dark:bg-slate-900/60 dark:text-slate-400">
                        ${escapeHtml(description)}
                    </div>
                </div>`;
        };

        const renderThread = () => {
            const conversation = state.conversations.find((item) => item.id === state.selectedConversationId);

            if (!conversation) {
                renderEmptyThread('Chưa chọn hội thoại', 'Chọn một cuộc trò chuyện ở cột bên trái để xem chi tiết và phản hồi.');
                inputEl.value = '';
                inputEl.disabled = true;
                sendEl.disabled = true;
                return;
            }

            const statusMeta = getStatusMeta(conversation.status);
            const participantMeta = getParticipantMeta(conversation.participantType);
            headerEl.innerHTML = `
                <div class="flex flex-col gap-4 xl:flex-row xl:items-start xl:justify-between">
                    <div class="space-y-3">
                        <div>
                            <p class="text-xl font-bold text-slate-900 dark:text-white">${escapeHtml(conversation.displayName || 'Khách truy cập')}</p>
                            <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">Nguồn truy cập: ${escapeHtml(conversation.sourcePage || '/')}</p>
                        </div>
                        <div class="flex flex-wrap items-center gap-2 text-[11px] font-semibold">
                            <span class="rounded-full px-2.5 py-1 ${participantMeta.className}">${escapeHtml(participantMeta.label)}</span>
                            <span class="rounded-full px-2.5 py-1 ${statusMeta.className}">${escapeHtml(statusMeta.label)}</span>
                            <span class="rounded-full bg-slate-100 px-2.5 py-1 text-slate-600 dark:bg-slate-800 dark:text-slate-300">${escapeHtml(conversation.conversationCode || '')}</span>
                        </div>
                    </div>
                    <div class="rounded-2xl bg-surface-light px-4 py-3 text-sm shadow-sm ring-1 ring-border-light dark:bg-surface-elevated-dark dark:ring-border-dark">
                        <p class="text-xs font-bold uppercase tracking-[0.2em] text-slate-400">Hoạt động gần nhất</p>
                        <p class="mt-2 font-semibold text-slate-900 dark:text-white">${escapeHtml(formatLongTime(conversation.lastMessageAt))}</p>
                    </div>
                </div>`;

            if (!state.messages.length) {
                threadEl.innerHTML = `
                    <div class="space-y-4">
                        <div class="rounded-2xl border border-dashed border-slate-300 bg-white/85 px-4 py-10 text-center text-sm text-slate-500 shadow-sm dark:border-slate-700 dark:bg-slate-900/60 dark:text-slate-400">
                            Chưa có tin nhắn nào trong hội thoại này.
                        </div>
                    </div>`;
            } else {
                threadEl.innerHTML = `<div class="space-y-3">${state.messages.map((message) => {
                    const isStaff = message.senderType === 'staff';
                    const isSystem = message.senderType === 'system';
                    const alignment = isStaff ? 'items-end' : 'items-start';
                    const bubble = isStaff
                        ? 'bg-gradient-to-br from-primary to-accent text-white shadow-[0_16px_34px_rgba(20,184,212,0.24)]'
                        : isSystem
                            ? 'bg-amber-50 text-amber-900 ring-1 ring-amber-200 shadow-sm dark:bg-amber-900/20 dark:text-amber-300 dark:ring-amber-900/50'
                            : 'bg-surface-light text-slate-800 ring-1 ring-border-light shadow-[0_10px_24px_rgba(15,23,42,0.08)] dark:bg-surface-elevated-dark dark:text-slate-100 dark:ring-border-dark';
                    const metaClass = isStaff ? 'text-white/80' : 'text-slate-400 dark:text-slate-500';
                    const senderLabel = isSystem ? 'Hệ thống' : (message.senderDisplayName || (isStaff ? 'HV Travel' : 'Khách hàng'));

                    return `
                        <div class="flex flex-col ${alignment}">
                            <div class="max-w-[85%] rounded-[1.3rem] px-4 py-3 text-sm shadow-sm ${bubble}">
                                <div class="flex items-center gap-2 text-[11px] font-bold uppercase tracking-[0.16em] ${metaClass}">
                                    <span>${escapeHtml(senderLabel)}</span>
                                    <span class="opacity-70">•</span>
                                    <span>${escapeHtml(formatTime(message.sentAt))}</span>
                                </div>
                                <p class="mt-2 whitespace-pre-wrap leading-6">${escapeHtml(message.content || '')}</p>
                            </div>
                        </div>`;
                }).join('')}</div>`;
            }

            inputEl.disabled = false;
            sendEl.disabled = false;
            threadEl.scrollTop = threadEl.scrollHeight;
        };

        const upsertConversation = (conversation) => {
            const index = state.conversations.findIndex((item) => item.id === conversation.id);
            if (index === -1) {
                state.conversations.unshift(conversation);
            } else {
                state.conversations[index] = { ...state.conversations[index], ...conversation };
            }

            state.conversations.sort((a, b) => new Date(b.lastMessageAt || 0) - new Date(a.lastMessageAt || 0));
            renderConversations();
        };

        const markConversationRead = async (conversationId) => {
            if (!tokenEl || !conversationId) {
                return;
            }

            try {
                await fetch(`/Admin/Messages/MarkRead/${conversationId}`, {
                    method: 'POST',
                    headers: {
                        'RequestVerificationToken': tokenEl.value
                    }
                });
            } catch {
                // Keep UI responsive even if mark-read fails.
            }
        };

        const loadConversations = async () => {
            setStatus('Đang tải danh sách hội thoại...');

            const response = await fetch('/Admin/Messages/Conversations', {
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                }
            });

            if (!response.ok) {
                throw new Error('Không tải được danh sách hội thoại.');
            }

            state.conversations = await response.json();
            renderConversations();

            if (!state.selectedConversationId && state.conversations.length) {
                await openConversation(state.conversations[0].id);
            } else {
                renderThread();
            }

            setStatus('Danh sách hội thoại đã được cập nhật.');
        };

        const ensureJoinedConversation = async (conversationId) => {
            if (!state.connection || state.joinedConversationIds.has(conversationId)) {
                return;
            }

            await state.connection.invoke('JoinConversation', conversationId, '');
            state.joinedConversationIds.add(conversationId);
        };

        const openConversation = async (conversationId) => {
            if (!conversationId) {
                return;
            }

            setStatus('Đang mở hội thoại...');

            const response = await fetch(`/Admin/Messages/Conversation/${conversationId}`, {
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                }
            });

            if (!response.ok) {
                throw new Error('Không tải được chi tiết hội thoại.');
            }

            const payload = await response.json();
            state.selectedConversationId = conversationId;
            state.messages = payload.messages || [];
            upsertConversation(payload.conversation);
            renderThread();
            await ensureJoinedConversation(conversationId);
            await markConversationRead(conversationId);
            setStatus('Bạn đang theo dõi hội thoại theo thời gian thực.');

            if (window.innerWidth < 1280) {
                threadEl.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }
        };

        const initializeConnection = async () => {
            state.connection = new signalR.HubConnectionBuilder()
                .withUrl('/supportChatHub')
                .withAutomaticReconnect()
                .build();

            state.connection.onreconnecting(() => {
                setStatus('Kết nối đang gián đoạn, đang thử kết nối lại...');
            });

            state.connection.onreconnected(() => {
                setStatus('Đã kết nối lại trung tâm tin nhắn.');
                loadConversations().catch((error) => setStatus(error.message));
            });

            state.connection.onclose(() => {
                setStatus('Kết nối thời gian thực đã đóng.');
            });

            state.connection.on('ConversationUpdated', (conversation) => {
                upsertConversation(conversation);
                if (conversation.id === state.selectedConversationId) {
                    openConversation(conversation.id).catch((error) => setStatus(error.message));
                }
            });

            state.connection.on('ReceiveMessage', (message) => {
                if (message.conversationId !== state.selectedConversationId) {
                    return;
                }

                state.messages.push(message);
                renderThread();
                markConversationRead(state.selectedConversationId);
            });

            await state.connection.start();
            await state.connection.invoke('JoinAdminInbox');
        };

        refreshEl.addEventListener('click', () => {
            loadConversations().catch((error) => setStatus(error.message));
        });

        mobileListToggleEl?.addEventListener('click', () => {
            listEl.scrollIntoView({ behavior: 'smooth', block: 'start' });
        });

        formEl.addEventListener('submit', async (event) => {
            event.preventDefault();

            const content = inputEl.value.trim();
            if (!content || !state.selectedConversationId || !state.connection) {
                return;
            }

            sendEl.disabled = true;
            setStatus('Đang gửi phản hồi...');

            try {
                await state.connection.invoke('SendAdminMessage', state.selectedConversationId, content);
                inputEl.value = '';
                setStatus('Phản hồi đã được gửi.');
            } catch (error) {
                setStatus(error.message || 'Không gửi được phản hồi.');
            } finally {
                sendEl.disabled = false;
            }
        });

        inputEl.addEventListener('keydown', (event) => {
            if (event.key === 'Enter' && !event.shiftKey && !event.isComposing) {
                event.preventDefault();
                formEl.requestSubmit();
            }
        });

        initializeConnection()
            .then(loadConversations)
            .catch((error) => {
                setStatus(error.message || 'Không khởi tạo được trung tâm tin nhắn.');
            });
    })();
</script>
