@model IEnumerable<HVTravel.Domain.Entities.Booking>
@{
    ViewData["Title"] = "Payments";
}

@functions {
    public string GetStatusText(string status) {
        if (string.IsNullOrEmpty(status)) return "";
        return status.Trim() switch {
            "Completed" => "Hoàn tất",
            "Confirmed" => "Đã xác nhận",
            "Pending" => "Đang chờ",
            "Refunded" => "Đã hoàn tiền",
            "Cancelled" => "Đã hủy",
            "Paid" => "Đã thanh toán",
            _ => status
        };
    }

    public string GetPaymentStatusText(string status) {
        if (string.IsNullOrEmpty(status)) return "";
        return status.Trim() switch {
            "Full" => "Đã thanh toán",
            "Success" => "Thành công",
            "Paid" => "Đã thanh toán",
            "Partial" => "Thanh toán một phần",
            "Pending" => "Chờ thanh toán",
            "Refunded" => "Đã hoàn lại",
            "Unpaid" => "Chưa thanh toán",
            _ => status
        };
    }
}

<!-- Page Header- -->
<div class="flex items-center justify-between mb-8">
    <div class="flex flex-col gap-1">
        <nav class="flex items-center gap-2 text-sm text-slate-500">
            <a class="hover:text-primary transition-colors" href="@Url.Action("Index", "Dashboard")">Trang Chủ</a>
            <span class="material-symbols-outlined text-[16px]">chevron_right</span>
            <span class="text-slate-900 dark:text-white font-medium">Thanh Toán</span>
        </nav>
        <h1 class="text-2xl font-bold text-slate-900 dark:text-white">Thanh Toán &amp; Giao Dịch</h1>
    </div>
    <div class="flex items-center gap-3">
        <button class="flex items-center gap-2 px-4 py-2 border border-slate-200 rounded-lg bg-white dark:bg-[#152326] text-slate-900 dark:text-white hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors">
            <span class="material-symbols-outlined text-[20px]">calendar_today</span>
            <span class="text-sm font-medium">30 Ngày Qua</span>
        </button>
        <button class="flex items-center gap-2 px-4 py-2 bg-primary text-white rounded-lg hover:bg-primary-dark transition-colors shadow-sm shadow-primary/30">
            <span class="material-symbols-outlined text-[20px]">download</span>
            <span class="text-sm font-bold">Xuất Báo Cáo</span>
        </button>
    </div>
</div>

<!-- KPI Section -->
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
    <!-- KPI Card 1 -->
    <div class="bg-white dark:bg-surface-dark p-6 rounded-2xl shadow-sm border border-slate-100 dark:border-slate-800 flex flex-col gap-4 relative overflow-hidden group">
        <div class="absolute -right-6 -top-6 w-24 h-24 bg-green-500/5 rounded-full group-hover:bg-green-500/10 transition-colors"></div>
        <div class="flex items-center justify-between relative z-10">
            <p class="text-slate-500 text-sm font-medium uppercase tracking-wider">Tổng Thu</p>
            <div class="w-10 h-10 flex items-center justify-center rounded-full bg-green-50 dark:bg-green-900/20">
              <span class="material-symbols-outlined text-green-600 dark:text-green-400">account_balance_wallet</span>
            </div>
        </div>
        <div class="relative z-10">
            <p class="text-3xl font-bold text-slate-900 dark:text-white tracking-tight">@(((decimal)(ViewBag.TotalRevenue ?? 0m)).ToString("N0")) ₫</p>
            <div class="flex items-center gap-2 mt-2">
                <span class="flex items-center text-xs font-bold text-green-600 bg-green-50 dark:bg-green-900/30 px-2 py-0.5 rounded-full">
                    <span class="material-symbols-outlined text-[14px] mr-1">trending_up</span>
                    +12%
                </span>
                <p class="text-slate-500 text-sm">so với tuần trước</p>
            </div>
        </div>
    </div>
    <!-- KPI Card 2 -->
    <div class="bg-white dark:bg-surface-dark p-6 rounded-2xl shadow-sm border border-slate-100 dark:border-slate-800 flex flex-col gap-4 relative overflow-hidden group">
        <div class="absolute -right-6 -top-6 w-24 h-24 bg-orange-500/5 rounded-full group-hover:bg-orange-500/10 transition-colors"></div>
        <div class="flex items-center justify-between relative z-10">
            <p class="text-slate-500 text-sm font-medium uppercase tracking-wider">Đã Hoàn Tiền</p>
            <div class="w-10 h-10 flex items-center justify-center rounded-full bg-red-50 dark:bg-green-900/20">
                <span class="material-symbols-outlined text-orange-600 dark:text-orange-400">keyboard_return</span>
            </div>
        </div>
        <div class="relative z-10">
            <p class="text-3xl font-bold text-slate-900 dark:text-white tracking-tight">@(((decimal)(ViewBag.TotalRefunded ?? 0m)).ToString("N0")) ₫</p>
            <div class="flex items-center gap-2 mt-2">
                <span class="flex items-center text-xs font-bold text-orange-600 bg-orange-50 dark:bg-orange-900/30 px-2 py-0.5 rounded-full">
                    <span class="material-symbols-outlined text-[14px] mr-1">trending_down</span>
                    -5%
                </span>
                <p class="text-slate-500 text-sm">so với tuần trước</p>
            </div>
        </div>
    </div>
    <!-- Reconcilation Widget -->
    <div class="bg-primary/5 dark:bg-primary/10 p-6 rounded-xl border border-primary/20 flex flex-col justify-between">
        <div class="flex items-center justify-between mb-2">
            <p class="text-slate-900 dark:text-white text-sm font-bold flex items-center gap-2">
                <span class="material-symbols-outlined text-primary text-[20px]">fact_check</span>
                Tổng Hợp Đối Soát
            </p>
            <span class="size-2 rounded-full bg-orange-500 animate-pulse"></span>
        </div>
        <div class="flex flex-col gap-3">
            <div class="flex justify-between items-center text-sm border-b border-primary/10 pb-2">
                <span class="text-slate-500">Đơn Đặt Đã Ghi Nhận</span>
                <span class="font-bold text-slate-900 dark:text-white">@Model.Count()</span>
            </div>
            <div class="flex justify-between items-center text-sm border-b border-primary/10 pb-2">
                <span class="text-slate-500">Thanh Toán Đã Nhận</span>
                <span class="font-bold text-slate-900 dark:text-white">@Model.Count(x => x.Status == "Success" || x.Status == "Paid")</span>
            </div>
            <div class="flex items-center gap-2 mt-1">
                <span class="material-symbols-outlined text-orange-500 text-[16px]">warning</span>
                <p class="text-orange-600 dark:text-orange-400 text-xs font-bold">Cần kiểm tra đối soát</p>
            </div>
        </div>
    </div>
</div>

<!-- Main Content Area -->
<div class="bg-white dark:bg-surface-dark rounded-2xl shadow-sm border border-slate-100 dark:border-slate-800 flex-1 flex flex-col">
    <!-- Tabs -->
    <div class="px-6 pt-4 border-b border-slate-200 dark:border-slate-700">
        <div class="flex gap-8">
            <button onclick="switchTab('transactions', this)" class="tab-btn active relative pb-4 px-2 text-sm font-bold text-primary border-b-2 border-primary transition-colors">
                Giao Dịch
            </button>
            <button onclick="switchTab('expenses', this)" class="tab-btn relative pb-4 px-2 text-sm font-bold text-slate-500 hover:text-slate-900 dark:hover:text-white border-b-2 border-transparent hover:border-slate-200 transition-colors">
                Khoản Chi (Bản nháp)
            </button>
             <button onclick="switchTab('refunds', this)" class="tab-btn relative pb-4 px-2 text-sm font-bold text-slate-500 hover:text-slate-900 dark:hover:text-white border-b-2 border-transparent hover:border-slate-200 transition-colors">
                Hoàn Tiền
            </button>
        </div>
    </div>
    
    <!-- Content: Giao Dịch -->
    <div id="tab-transactions" class="tab-content mt-4 px-6 pb-6">
        <form method="get" id="filter-form-transactions" class="bg-white dark:bg-surface-dark p-4 rounded-2xl shadow-sm border border-slate-100 dark:border-slate-800 mb-6 flex flex-wrap items-center gap-4">
            <input type="hidden" name="sortOrder" value="@ViewBag.CurrentSort" />
            <div class="flex-1 min-w-[200px]">
                <div class="relative">
                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-[20px]">search</span>
                    <input class="w-full pl-10 pr-4 py-2.5 bg-slate-50 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700 rounded-xl text-sm focus:ring-primary focus:border-primary outline-none transition-all" placeholder="Tìm mã GD hoặc mã đặt chỗ..." name="searchString" value="@ViewData["CurrentSearch"]" type="text" />
                </div>
            </div>
            
            <div class="flex items-center gap-3">
                <!-- Filter Dropdown -->
                <div class="relative group">
                    <button type="button" onclick="toggleFilterMenu()" class="flex items-center justify-center size-10 rounded-xl bg-slate-50 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700 text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors">
                        <span class="material-symbols-outlined !text-[20px]">filter_list</span>
                    </button>

                    <div id="filter-menu" class="absolute right-0 top-full mt-2 w-80 bg-white dark:bg-slate-900 rounded-2xl shadow-xl border border-slate-100 dark:border-slate-800 z-30 hidden menu-hidden animate-scale-in origin-top-right transition-all">
                        <div class="p-4 border-b border-slate-100 dark:border-slate-800">
                            <h3 class="font-bold text-slate-900 dark:text-white">Bộ Lọc</h3>
                        </div>

                        <div class="p-4 flex flex-col gap-5 overflow-y-auto max-h-[60vh]">
                            <!-- Booking Status Filter -->
                            <div>
                                <label class="block text-xs font-bold text-slate-500 uppercase mb-2">Trạng Thái Chuyến Đi</label>
                                <div class="space-y-2">
                                    <label class="flex items-center gap-2 cursor-pointer">
                                        <input type="radio" name="bookingStatusFilter" value="" class="rounded border-slate-300 text-primary focus:ring-primary" @(string.IsNullOrEmpty(ViewBag.CurrentBookingStatusFilter?.ToString()) ? "checked" : "") />
                                        <span class="text-sm text-slate-700 dark:text-slate-300">Tất Cả</span>
                                    </label>
                                    <label class="flex items-center gap-2 cursor-pointer group/opt">
                                        <input type="radio" name="bookingStatusFilter" value="Completed" class="rounded border-slate-300 text-primary focus:ring-primary" @(ViewBag.CurrentBookingStatusFilter?.ToString() == "Completed" ? "checked" : "") />
                                        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-300">
                                            <span class="size-1.5 rounded-full bg-green-600 dark:bg-green-400"></span>Hoàn tất
                                        </span>
                                    </label>
                                    <label class="flex items-center gap-2 cursor-pointer group/opt">
                                        <input type="radio" name="bookingStatusFilter" value="Confirmed" class="rounded border-slate-300 text-primary focus:ring-primary" @(ViewBag.CurrentBookingStatusFilter?.ToString() == "Confirmed" ? "checked" : "") />
                                        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-300">
                                            <span class="size-1.5 rounded-full bg-blue-600 dark:bg-blue-400"></span>Đã xác nhận
                                        </span>
                                    </label>
                                    <label class="flex items-center gap-2 cursor-pointer group/opt">
                                        <input type="radio" name="bookingStatusFilter" value="Pending" class="rounded border-slate-300 text-primary focus:ring-primary" @(ViewBag.CurrentBookingStatusFilter?.ToString() == "Pending" ? "checked" : "") />
                                        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-300">
                                            <span class="size-1.5 rounded-full bg-yellow-600 dark:bg-yellow-400"></span>Đang chờ
                                        </span>
                                    </label>
                                    <label class="flex items-center gap-2 cursor-pointer group/opt">
                                        <input type="radio" name="bookingStatusFilter" value="Refunded" class="rounded border-slate-300 text-primary focus:ring-primary" @(ViewBag.CurrentBookingStatusFilter?.ToString() == "Refunded" ? "checked" : "") />
                                        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-orange-100 text-orange-800 dark:bg-orange-900/30 dark:text-orange-300">
                                            <span class="size-1.5 rounded-full bg-orange-600 dark:bg-orange-400"></span>Đã hoàn tiền
                                        </span>
                                    </label>
                                    <label class="flex items-center gap-2 cursor-pointer group/opt">
                                        <input type="radio" name="bookingStatusFilter" value="Cancelled" class="rounded border-slate-300 text-primary focus:ring-primary" @(ViewBag.CurrentBookingStatusFilter?.ToString() == "Cancelled" ? "checked" : "") />
                                        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-300">
                                            <span class="size-1.5 rounded-full bg-red-600 dark:bg-red-400"></span>Đã hủy
                                        </span>
                                    </label>
                                </div>
                            </div>

                            <!-- Payment Status Filter -->
                            <div>
                                <label class="block text-xs font-bold text-slate-500 uppercase mb-2">Trạng Thái Thanh Toán</label>
                                <div class="space-y-2">
                                    <label class="flex items-center gap-2 cursor-pointer">
                                        <input type="radio" name="paymentStatusFilter" value="" class="rounded border-slate-300 text-primary focus:ring-primary" @(string.IsNullOrEmpty(ViewBag.CurrentPaymentStatusFilter?.ToString()) ? "checked" : "") />
                                        <span class="text-sm text-slate-700 dark:text-slate-300">Tất Cả</span>
                                    </label>
                                    <label class="flex items-center gap-2 cursor-pointer group/opt">
                                        <input type="radio" name="paymentStatusFilter" value="Full" class="rounded border-slate-300 text-primary focus:ring-primary" @(ViewBag.CurrentPaymentStatusFilter?.ToString() == "Full" ? "checked" : "") />
                                        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-300">
                                            <span class="size-1.5 rounded-full bg-green-600 dark:bg-green-400"></span>Đã thanh toán đủ
                                        </span>
                                    </label>
                                    <label class="flex items-center gap-2 cursor-pointer group/opt">
                                        <input type="radio" name="paymentStatusFilter" value="Partial" class="rounded border-slate-300 text-primary focus:ring-primary" @(ViewBag.CurrentPaymentStatusFilter?.ToString() == "Partial" ? "checked" : "") />
                                        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-300">
                                            <span class="size-1.5 rounded-full bg-yellow-600 dark:bg-yellow-400"></span>Thanh toán một phần
                                        </span>
                                    </label>
                                    <label class="flex items-center gap-2 cursor-pointer group/opt">
                                        <input type="radio" name="paymentStatusFilter" value="Unpaid" class="rounded border-slate-300 text-primary focus:ring-primary" @(ViewBag.CurrentPaymentStatusFilter?.ToString() == "Unpaid" ? "checked" : "") />
                                        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-300">
                                            <span class="size-1.5 rounded-full bg-red-600 dark:bg-red-400"></span>Chưa thanh toán
                                        </span>
                                    </label>
                                    <label class="flex items-center gap-2 cursor-pointer group/opt">
                                        <input type="radio" name="paymentStatusFilter" value="Refunded" class="rounded border-slate-300 text-primary focus:ring-primary" @(ViewBag.CurrentPaymentStatusFilter?.ToString() == "Refunded" ? "checked" : "") />
                                        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-orange-100 text-orange-800 dark:bg-orange-900/30 dark:text-orange-300">
                                            <span class="size-1.5 rounded-full bg-orange-600 dark:bg-orange-400"></span>Đã hoàn lại
                                        </span>
                                    </label>
                                </div>
                            </div>
                        </div>

                        <!-- Actions -->
                        <div class="p-4 border-t border-slate-100 dark:border-slate-800 flex gap-2">
                            <button type="button" onclick="resetFilters()" class="flex-1 py-2 text-sm font-bold text-slate-500 hover:bg-slate-50 dark:hover:bg-slate-800 rounded-lg transition-colors">Đặt Lại</button>
                            <button type="button" onclick="applyFilters()" class="flex-1 py-2 text-sm font-bold text-white bg-primary hover:bg-primary-dark rounded-lg shadow-lg shadow-primary/30 transition-all">Áp Dụng</button>
                        </div>
                    </div>
                </div>

                <div class="relative">
                    <button type="button" onclick="toggleColumnMenu()" class="flex items-center justify-center size-10 rounded-xl bg-slate-50 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700 text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors">
                        <span class="material-symbols-outlined !text-[20px]">view_column</span>
                    </button>
                    <div id="column-menu" class="absolute right-0 top-full mt-2 w-48 bg-white dark:bg-slate-900 rounded-xl shadow-xl border border-slate-100 dark:border-slate-800 hidden origin-top-right transition-all menu-hidden animate-scale-in z-50 p-2">
                        <label class="flex items-center gap-2 px-2 py-1.5 hover:bg-slate-50 dark:hover:bg-slate-800 rounded-lg cursor-pointer">
                            <input type="checkbox" checked onchange="toggleColumn('col-trans-id')" class="text-primary focus:ring-primary rounded">
                            <span class="text-sm text-slate-700 dark:text-slate-300">Mã Giao Dịch</span>
                        </label>
                        <label class="flex items-center gap-2 px-2 py-1.5 hover:bg-slate-50 dark:hover:bg-slate-800 rounded-lg cursor-pointer">
                            <input type="checkbox" checked onchange="toggleColumn('col-date')" class="text-primary focus:ring-primary rounded">
                            <span class="text-sm text-slate-700 dark:text-slate-300">Ngày & Giờ</span>
                        </label>
                        <label class="flex items-center gap-2 px-2 py-1.5 hover:bg-slate-50 dark:hover:bg-slate-800 rounded-lg cursor-pointer">
                            <input type="checkbox" checked onchange="toggleColumn('col-booking-id')" class="text-primary focus:ring-primary rounded">
                            <span class="text-sm text-slate-700 dark:text-slate-300">Mã Đặt Chỗ</span>
                        </label>
                        <label class="flex items-center gap-2 px-2 py-1.5 hover:bg-slate-50 dark:hover:bg-slate-800 rounded-lg cursor-pointer">
                            <input type="checkbox" checked onchange="toggleColumn('col-method')" class="text-primary focus:ring-primary rounded">
                            <span class="text-sm text-slate-700 dark:text-slate-300">Phương Thức</span>
                        </label>
                        <label class="flex items-center gap-2 px-2 py-1.5 hover:bg-slate-50 dark:hover:bg-slate-800 rounded-lg cursor-pointer">
                            <input type="checkbox" checked onchange="toggleColumn('col-status')" class="text-primary focus:ring-primary rounded">
                            <span class="text-sm text-slate-700 dark:text-slate-300">Trạng Thái</span>
                        </label>
                        <label class="flex items-center gap-2 px-2 py-1.5 hover:bg-slate-50 dark:hover:bg-slate-800 rounded-lg cursor-pointer">
                            <input type="checkbox" checked onchange="toggleColumn('col-amount')" class="text-primary focus:ring-primary rounded">
                            <span class="text-sm text-slate-700 dark:text-slate-300">Thực Nhận</span>
                        </label>
                    </div>
                </div>
            </div>
        </form>
        <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                       <tr class="bg-slate-50/50 dark:bg-slate-800/50 text-slate-500 dark:text-slate-400 text-xs uppercase tracking-wider font-bold">
                           <th class="p-4 pl-6 text-left cursor-pointer hover:text-primary transition-colors select-none col-trans-id" onclick="applySort('@ViewBag.IdSortParm')">
                               <div class="flex items-center gap-1">
                                   Mã GD
                                   @if(string.IsNullOrEmpty(ViewBag.CurrentSort)) {
                                       <span class="material-symbols-outlined text-[16px]">arrow_downward</span>
                                   } else if (ViewBag.CurrentSort == "id_desc") {
                                        <span class="material-symbols-outlined text-[16px] text-primary">arrow_downward</span>
                                   } else if (ViewBag.CurrentSort == "id") {
                                        <span class="material-symbols-outlined text-[16px] text-primary">arrow_upward</span>
                                   } else {
                                       <span class="material-symbols-outlined text-[16px] opacity-30">unfold_more</span>
                                   }
                               </div>
                           </th>
                           <th class="p-4 text-left cursor-pointer hover:text-primary transition-colors select-none col-date" onclick="applySort('@ViewBag.DateSortParm')">
                               <div class="flex items-center gap-1">
                                   Ngày Đặt
                                   @if (ViewBag.CurrentSort == "date") {
                                       <span class="material-symbols-outlined text-[16px] text-primary">arrow_upward</span>
                                   } else if (ViewBag.CurrentSort == "date_desc") {
                                        <span class="material-symbols-outlined text-[16px] text-primary">arrow_downward</span>
                                   } else {
                                       <span class="material-symbols-outlined text-[16px] opacity-30">unfold_more</span>
                                   }
                               </div>
                           </th>
                           <th class="p-4 text-left cursor-pointer hover:text-primary transition-colors select-none col-booking-id" onclick="applySort('@ViewBag.BookingIdSortParm')">
                               <div class="flex items-center gap-1">
                                   Mã Đặt Chỗ
                                   @if (ViewBag.CurrentSort == "booking") {
                                       <span class="material-symbols-outlined text-[16px] text-primary">arrow_upward</span>
                                   } else if (ViewBag.CurrentSort == "booking_desc") {
                                        <span class="material-symbols-outlined text-[16px] text-primary">arrow_downward</span>
                                   } else {
                                       <span class="material-symbols-outlined text-[16px] opacity-30">unfold_more</span>
                                   }
                               </div>
                           </th>
                           <th class="p-4 text-left cursor-pointer hover:text-primary transition-colors select-none col-status" onclick="applySort('@ViewBag.StatusSortParm')">
                               <div class="flex items-center gap-1">
                                   Thanh Toán
                                   @if (ViewBag.CurrentSort == "status") {
                                       <span class="material-symbols-outlined text-[16px] text-primary">arrow_upward</span>
                                   } else if (ViewBag.CurrentSort == "status_desc") {
                                        <span class="material-symbols-outlined text-[16px] text-primary">arrow_downward</span>
                                   } else {
                                       <span class="material-symbols-outlined text-[16px] opacity-30">unfold_more</span>
                                   }
                               </div>
                           </th>
                           <th class="p-4 text-left cursor-pointer hover:text-primary transition-colors select-none col-booking-status" onclick="applySort('@ViewBag.BookingStatusSortParm')">
                               <div class="flex items-center gap-1">
                                   Trạng Thái
                                   @if (ViewBag.CurrentSort == "booking_status") {
                                       <span class="material-symbols-outlined text-[16px] text-primary">arrow_upward</span>
                                   } else if (ViewBag.CurrentSort == "booking_status_desc") {
                                        <span class="material-symbols-outlined text-[16px] text-primary">arrow_downward</span>
                                   } else {
                                       <span class="material-symbols-outlined text-[16px] opacity-30">unfold_more</span>
                                   }
                               </div>
                           </th>
                           <th class="p-4 text-right cursor-pointer hover:text-primary transition-colors select-none col-amount" onclick="applySort('@ViewBag.AmountSortParm')">
                               <div class="flex items-center justify-end gap-1">
                                   Tổng Tiền
                                   @if (ViewBag.CurrentSort == "amount") {
                                       <span class="material-symbols-outlined text-[16px] text-primary">arrow_upward</span>
                                   } else if (ViewBag.CurrentSort == "amount_desc") {
                                        <span class="material-symbols-outlined text-[16px] text-primary">arrow_downward</span>
                                   } else {
                                       <span class="material-symbols-outlined text-[16px] opacity-30">unfold_more</span>
                                   }
                               </div>
                           </th>
                           <th class="p-4 text-center"></th>
                       </tr>
                   </thead>
                   <tbody class="divide-y divide-slate-100 dark:divide-slate-800 text-sm">
                       @foreach (var item in Model)
                       {
                            <tr class="group hover:bg-slate-50 dark:hover:bg-slate-800/50 transition-colors">
                               <td class="p-4 pl-6 col-trans-id"><span class="text-primary font-bold text-sm">#@item.Id.Substring(0, 8)</span></td>
                               <td class="p-4 col-date">
                                   <div class="flex flex-col"><span class="text-sm font-medium text-slate-900 dark:text-white">@item.BookingDate.ToLocalTime().ToString("dd/MM/yyyy")</span><span class="text-xs text-slate-500">@item.BookingDate.ToLocalTime().ToString("HH:mm")</span></div>
                               </td>
                               <td class="p-4 col-booking-id">
                                    <span class="text-sm font-mono text-slate-500">#@item.BookingCode</span>
                               </td>
                               
                                <td class="p-4 col-status">
                                   @if(item.PaymentStatus == "Full" || item.PaymentStatus == "Success" || item.PaymentStatus == "Paid") {
                                       <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-300"><span class="size-1.5 rounded-full bg-green-600 dark:bg-green-400"></span>@GetPaymentStatusText(item.PaymentStatus)</span>
                                   } else if(item.PaymentStatus == "Pending" || item.PaymentStatus == "Partial") {
                                        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-300"><span class="size-1.5 rounded-full bg-yellow-600 dark:bg-yellow-400"></span>@GetPaymentStatusText(item.PaymentStatus)</span>
                                   } else if(item.PaymentStatus == "Refunded") {
                                        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-orange-100 text-orange-800 dark:bg-orange-900/30 dark:text-orange-300"><span class="size-1.5 rounded-full bg-orange-600 dark:bg-orange-400"></span>@GetPaymentStatusText(item.PaymentStatus)</span>
                                   } else {
                                        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-300"><span class="size-1.5 rounded-full bg-red-600 dark:bg-red-400"></span>@GetPaymentStatusText(item.PaymentStatus)</span>
                                   }
                               </td>
                                <td class="p-4 col-booking-status">
                                   @if(item.Status == "Completed" || item.Status == "Paid") {
                                       <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-300"><span class="size-1.5 rounded-full bg-green-600 dark:bg-green-400"></span>@GetStatusText(item.Status)</span>
                                   } else if(item.Status == "Confirmed") {
                                       <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-300"><span class="size-1.5 rounded-full bg-blue-600 dark:bg-blue-400"></span>@GetStatusText(item.Status)</span>
                                   } else if(item.Status == "Pending") {
                                        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-300"><span class="size-1.5 rounded-full bg-yellow-600 dark:bg-yellow-400"></span>@GetStatusText(item.Status)</span>
                                   } else if(item.Status == "Refunded") {
                                        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-orange-100 text-orange-800 dark:bg-orange-900/30 dark:text-orange-300"><span class="size-1.5 rounded-full bg-orange-600 dark:bg-orange-400"></span>@GetStatusText(item.Status)</span>
                                   } else {
                                        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-300"><span class="size-1.5 rounded-full bg-red-600 dark:bg-red-400"></span>@GetStatusText(item.Status)</span>
                                   }
                               </td>
                               <td class="p-4 text-right col-amount"><span class="text-sm font-bold text-slate-900 dark:text-white">@item.TotalAmount.ToString("N0") ₫</span></td>
                               <td class="p-4 text-center"><button class="text-slate-500 hover:text-primary transition-colors"><span class="material-symbols-outlined text-[20px]">more_vert</span></button></td>
                           </tr>
                       }
                   </tbody>
                </table>
        </div>
    </div>

    <!-- Content: Khoản Chi (Static) -->
    <div id="tab-expenses" class="tab-content hidden">
        <div class="p-10 text-center text-slate-500">
            <span class="material-symbols-outlined text-4xl mb-2">construction</span>
            <p>Tính năng quản lý Khoản chi đang được phát triển.</p>
        </div>
    </div>

    <!-- Content: Hoàn Tiền -->
    <div id="tab-refunds" class="tab-content mt-4 px-6 pb-6 hidden">
        <form method="get" id="filter-form-refunds" class="bg-white dark:bg-surface-dark p-4 rounded-2xl shadow-sm border border-slate-100 dark:border-slate-800 mb-6 flex flex-wrap items-center gap-4">
            <div class="flex-1 min-w-[200px]">
                <div class="relative">
                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-[20px]">search</span>
                    <input class="w-full pl-10 pr-4 py-2.5 bg-slate-50 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700 rounded-xl text-sm focus:ring-primary focus:border-primary outline-none transition-all" placeholder="Tìm yêu cầu hoàn tiền..." type="text" />
                </div>
            </div>
            <div class="flex items-center gap-3">
                <button type="submit" class="h-10 px-4 bg-primary text-white text-sm font-bold rounded-xl hover:bg-primary-dark transition-colors shadow-sm shadow-primary/30">
                    Lọc
                </button>
            </div>
        </form>
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-slate-50/50 dark:bg-slate-800/50 text-slate-500 dark:text-slate-400 text-xs uppercase tracking-wider font-bold">
                        <th class="p-4 pl-6 text-left">Mã Đặt Chỗ</th>
                        <th class="p-4 text-left">Của Khách Hàng</th>
                        <th class="p-4 text-left">Ngày Đặt</th>
                         <th class="p-4 text-left">Trạng Thái</th>
                        <th class="p-4 text-right">Hoàn Lại</th>
                        <th class="p-4 text-center"></th>
                    </tr>
                </thead>
               <tbody class="divide-y divide-slate-100 dark:divide-slate-800">
                    @foreach (var item in Model.Where(x => x.Status == "Refunded" && x.PaymentStatus == "Refunded"))
                    {
                         <tr class="group hover:bg-slate-50 dark:hover:bg-slate-800/50 transition-colors">
                            <td class="p-4 pl-6"><a class="text-primary font-bold text-sm hover:underline" href="#">#@item.BookingCode</a></td>
                            <td class="p-4"><span class="text-sm font-mono text-slate-600">@item.ContactInfo?.Name</span></td>
                            <td class="p-4"><span class="text-slate-500 text-sm">@item.BookingDate.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span></td>
                             <td class="p-4"><span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-orange-100 text-orange-800 dark:bg-orange-900/30 dark:text-orange-300"><span class="size-1.5 rounded-full bg-orange-600 dark:bg-orange-400"></span>@GetStatusText(item.Status)</span></td>
                            <td class="p-4 text-right"><span class="text-sm font-bold text-slate-900 dark:text-white">@item.TotalAmount.ToString("N0") ₫</span></td>
                            <td class="p-4 text-center"><button class="text-slate-500 hover:text-primary transition-colors"><span class="material-symbols-outlined text-[20px]">more_vert</span></button></td>
                        </tr>
                    }
                    @if(!Model.Any(x => x.Status == "Refunded" && x.PaymentStatus == "Refunded"))
                    {
                        <tr>
                            <td colspan="6" class="p-8 text-center text-slate-500">Không có dữ liệu hoàn tiền</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function toggleColumn(colClass) {
            const cols = document.querySelectorAll('.' + colClass);
            cols.forEach(col => col.classList.toggle('col-collapsed'));
        }

        function toggleColumnMenu() {
            const menu = document.getElementById('column-menu');
            if (!menu) return;
            if (menu.classList.contains('menu-visible')) {
                menu.classList.remove('menu-visible');
                menu.classList.add('menu-hidden');
                setTimeout(() => menu.classList.add('hidden'), 200);
            } else {
                menu.classList.remove('hidden');
                requestAnimationFrame(() => {
                    menu.classList.remove('menu-hidden');
                    menu.classList.add('menu-visible');
                });
            }
        }

        function toggleFilterMenu() {
            const menu = document.getElementById('filter-menu');
            if (!menu) return;
            if (menu.classList.contains('menu-visible')) {
                menu.classList.remove('menu-visible');
                menu.classList.add('menu-hidden');
                setTimeout(() => menu.classList.add('hidden'), 200);
            } else {
                menu.classList.remove('hidden');
                requestAnimationFrame(() => {
                    menu.classList.remove('menu-hidden');
                    menu.classList.add('menu-visible');
                });
            }
        }

        function resetFilters() {
            const statusRadios = document.querySelectorAll('input[name="bookingStatusFilter"]');
            if (statusRadios.length > 0) statusRadios[0].checked = true;
            const paymentRadios = document.querySelectorAll('input[name="paymentStatusFilter"]');
            if (paymentRadios.length > 0) paymentRadios[0].checked = true;
        }

        function applyFilters() {
            document.getElementById('filter-form-transactions').submit();
        }

        // Close dropdowns when clicking outside
        document.addEventListener('click', function(event) {
            // Filter Menu
            const filterMenu = document.getElementById('filter-menu');
            const filterBtn = event.target.closest('button[onclick="toggleFilterMenu()"]');
            const insideFilter = event.target.closest('#filter-menu');

            if (!filterBtn && !insideFilter && filterMenu && filterMenu.classList.contains('menu-visible')) {
                filterMenu.classList.remove('menu-visible');
                filterMenu.classList.add('menu-hidden');
                setTimeout(() => filterMenu.classList.add('hidden'), 200);
            }

            // Column Menu
            const colMenu = document.getElementById('column-menu');
            const colBtn = event.target.closest('button[onclick="toggleColumnMenu()"]');
            const insideCol = event.target.closest('#column-menu');
            if (colMenu && !colBtn && !insideCol && colMenu.classList.contains('menu-visible')) {
                colMenu.classList.remove('menu-visible');
                colMenu.classList.add('menu-hidden');
                setTimeout(() => colMenu.classList.add('hidden'), 200);
            }
        });

        function switchTab(tabName, btn) {
            // Hide all tab content
            document.querySelectorAll('.tab-content').forEach(el => el.classList.add('hidden'));
            // Show selected tab
            document.getElementById(`tab-${tabName}`).classList.remove('hidden');

            // Reset tab buttons
            document.querySelectorAll('.tab-btn').forEach(button => {
                 button.classList.remove('text-primary', 'border-primary', 'active');
                 button.classList.add('text-slate-500', 'border-transparent');
            });

            // Activate clicked button
            btn.classList.remove('text-slate-500', 'border-transparent');
            btn.classList.add('text-primary', 'border-primary', 'active');
        }

        function applySort(sortOrder) {
            const params = new URLSearchParams(window.location.search);
            params.set('sortOrder', sortOrder);
            window.location.href = '@Url.Action("Index")' + '?' + params.toString();
        }
    </script>
}


