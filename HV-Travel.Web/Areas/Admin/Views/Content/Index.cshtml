@using HVTravel.Domain.Entities
@using HVTravel.Web.Models
@using HVTravel.Web.Services
@model ContentManagementViewModel
@{
    ViewData["Title"] = "Nội dung website";
    var activeTab = Model.PrimaryTabs.FirstOrDefault(x => x.IsActive);
    var activeSubtab = Model.SecondaryTabs.FirstOrDefault(x => x.IsActive);
    var breadcrumbItems = new List<HVTravel.Web.Models.BreadcrumbItemViewModel>
    {
        new() { Label = "Trang chủ", Url = Url.Action("Index", "Dashboard") },
        new() { Label = "Nội dung website", Url = Url.Action("Index", "Content", new { tab = "site" }), IsCurrent = Model.ActiveTab == "site" }
    };
    var sectionAlignmentOptions = new[]
    {
        new { Value = string.Empty, Label = "Mặc định" },
        new { Value = "left", Label = "Trái" },
        new { Value = "center", Label = "Giữa" },
        new { Value = "right", Label = "Phải" }
    };

    if (Model.ActiveTab != "site" && activeTab != null)
    {
        breadcrumbItems.Add(new HVTravel.Web.Models.BreadcrumbItemViewModel
        {
            Label = activeTab.Label,
            Url = Model.SecondaryTabs.Any() ? Url.Action("Index", "Content", new { tab = Model.ActiveTab, subtab = "consultation" }) : null,
            IsCurrent = !Model.SecondaryTabs.Any()
        });
    }

    if (Model.SecondaryTabs.Any() && activeSubtab != null)
    {
        breadcrumbItems.Add(new HVTravel.Web.Models.BreadcrumbItemViewModel
        {
            Label = activeSubtab.Label,
            IsCurrent = true
        });
    }

    var breadcrumb = new HVTravel.Web.Models.BreadcrumbViewModel { Items = breadcrumbItems };
}

<div class="space-y-8">
    <div class="flex flex-col gap-5 xl:flex-row xl:items-start xl:justify-between">
        <div class="space-y-3">
            @await Html.PartialAsync("_AdminBreadcrumb", breadcrumb)
            <div>
                <p class="text-sm font-bold uppercase tracking-[0.28em] text-primary">CMS v2</p>
                <h1 class="mt-3 text-3xl font-extrabold text-slate-900 dark:text-white">@Model.CurrentEditorTitle</h1>
                <p class="mt-3 max-w-3xl text-sm leading-relaxed text-slate-500 dark:text-slate-400">@Model.CurrentEditorDescription</p>
            </div>
        </div>

        <div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:justify-end">
            <div class="rounded-3xl bg-white px-5 py-4 shadow-sm ring-1 ring-slate-200 dark:bg-slate-800 dark:ring-slate-700">
                <p class="text-xs font-bold uppercase tracking-[0.18em] text-slate-400">Phạm vi</p>
                <p class="mt-2 text-sm font-semibold text-slate-700 dark:text-slate-300">@Model.CurrentScopeSummary</p>
            </div>
        </div>
    </div>

    @if (TempData["ContentSuccess"] is string successMessage)
    {
        <div class="rounded-3xl border border-emerald-200 bg-emerald-50 px-5 py-4 text-sm font-semibold text-emerald-700 dark:border-emerald-900/40 dark:bg-emerald-900/10 dark:text-emerald-300">
            @successMessage
        </div>
    }

    <div class="overflow-hidden rounded-2xl bg-white p-5 shadow-sm ring-1 ring-slate-200 dark:bg-slate-800 dark:ring-slate-700">
        <div class="flex flex-col gap-4">
            <div class="flex flex-col gap-3 xl:flex-row xl:items-center xl:justify-between">
                <div>
                    <p class="text-xs font-bold uppercase tracking-[0.24em] text-slate-400">Điều hướng nội dung</p>
                    <p class="mt-2 text-sm text-slate-500 dark:text-slate-400">Chọn đúng trang hoặc màn hình để chỉnh nội dung và style.</p>
                </div>
                <div class="grid gap-3 sm:grid-cols-2">
                    <div class="rounded-xl border border-slate-200/80 bg-slate-50/60 px-4 py-3 dark:border-slate-700 dark:bg-slate-900/40">
                        <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-slate-400">Section</p>
                        <p class="mt-2 text-2xl font-extrabold text-slate-900 dark:text-white">@Model.VisibleSectionCount</p>
                    </div>
                    <div class="rounded-xl border border-slate-200/80 bg-slate-50/60 px-4 py-3 dark:border-slate-700 dark:bg-slate-900/40">
                        <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-slate-400">Field đang sửa</p>
                        <p class="mt-2 text-2xl font-extrabold text-slate-900 dark:text-white">@Model.VisibleFieldCount</p>
                    </div>
                </div>
            </div>

            <div class="overflow-x-auto pt-2 pb-2">
                <div class="flex min-w-max items-center gap-3">
                    @foreach (var tab in Model.PrimaryTabs)
                    {
                        <a href="@tab.Url" title="@tab.ShortDescription" class="group rounded-xl px-4 py-3 transition-all focus:outline-none focus-visible:ring-2 focus-visible:ring-primary/40 focus-visible:ring-offset-2 focus-visible:ring-offset-white dark:focus-visible:ring-offset-slate-800 @(tab.IsActive ? "bg-primary text-white shadow-lg shadow-primary/20" : "bg-slate-50 text-slate-600 ring-1 ring-slate-200 hover:bg-primary/5 hover:text-primary dark:bg-slate-900/50 dark:text-slate-300 dark:ring-slate-700 dark:hover:bg-slate-700/60")">
                            <p class="text-sm font-bold">@tab.Label</p>
                            <p class="mt-1 text-xs @(tab.IsActive ? "text-white/80" : "text-slate-400 group-hover:text-primary/80")">@tab.ShortDescription</p>
                        </a>
                    }
                </div>
            </div>

            @if (Model.SecondaryTabs.Any())
            {
                <div class="overflow-x-auto pt-2 pb-2">
                    <div class="flex min-w-max items-center gap-2 rounded-xl bg-slate-50 p-2 ring-1 ring-slate-200 dark:bg-slate-900/50 dark:ring-slate-700">
                        @foreach (var subtab in Model.SecondaryTabs)
                        {
                            <a href="@subtab.Url" title="@subtab.ShortDescription" class="rounded-lg px-4 py-3 transition-all focus:outline-none focus-visible:ring-2 focus-visible:ring-primary/40 focus-visible:ring-offset-2 focus-visible:ring-offset-slate-50 dark:focus-visible:ring-offset-slate-900/50 @(subtab.IsActive ? "bg-slate-900 text-white shadow-lg dark:bg-primary" : "text-slate-600 hover:bg-white hover:text-slate-900 dark:text-slate-300 dark:hover:bg-slate-700/60 dark:hover:text-white")">
                                <p class="text-sm font-bold">@subtab.Label</p>
                                <p class="mt-1 text-xs @(subtab.IsActive ? "text-white/80" : "text-slate-400")">@subtab.ShortDescription</p>
                            </a>
                        }
                    </div>
                </div>
            }

            @if (Model.DependencyNotes.Any())
            {
                <div class="grid gap-3 xl:grid-cols-2">
                    @foreach (var note in Model.DependencyNotes)
                    {
                        <div class="rounded-2xl border border-amber-200 bg-amber-50 px-4 py-4 text-sm text-amber-800 dark:border-amber-900/30 dark:bg-amber-900/10 dark:text-amber-300">
                            <p class="font-bold">@note.Title</p>
                            <p class="mt-2 leading-relaxed">@note.Description</p>
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    <section class="space-y-6">
        @if (Model.IsSiteEditor)
        {
            <form id="content-editor-form" asp-action="SaveSiteSettings" method="post" class="space-y-6">
                @Html.AntiForgeryToken()
                <input asp-for="SiteSettings.Id" type="hidden" />
                <input asp-for="SiteSettings.SettingsKey" type="hidden" />

                @for (var i = 0; i < Model.SiteSettings.Groups.Count; i++)
                {
                    var group = Model.SiteSettings.Groups[i];
                    <div class="rounded-[2rem] bg-white p-6 shadow-sm ring-1 ring-slate-200 dark:bg-slate-800 dark:ring-slate-700">
                        <input asp-for="SiteSettings.Groups[i].GroupKey" type="hidden" />
                        <div class="flex flex-col gap-4 border-b border-slate-100 pb-5 dark:border-slate-700">
                            <div class="flex flex-wrap items-center gap-2 text-xs">
                                <span class="rounded-full bg-primary/10 px-3 py-1 font-bold text-primary">Group @(i + 1)</span>
                                <span class="rounded-full bg-slate-100 px-3 py-1 font-mono text-slate-500 dark:bg-slate-700 dark:text-slate-300">@group.GroupKey</span>
                            </div>
                            <div class="grid gap-4 xl:grid-cols-[minmax(0,1fr)_minmax(280px,0.62fr)]">
                                <div class="space-y-4">
                                    <div class="rounded-3xl border border-slate-100 bg-slate-50/50 p-5 dark:border-slate-700 dark:bg-slate-900/40">
                                        <div class="flex items-center justify-between gap-3">
                                            <label class="text-sm font-bold text-slate-900 dark:text-white">Tiêu đề group</label>
                                            <label class="flex items-center gap-2 rounded-2xl border border-slate-200 bg-white px-3 py-2 text-xs font-semibold text-slate-600 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-300">
                                                <input asp-for="SiteSettings.Groups[i].IsTitleEnabled" class="rounded border-slate-300 text-primary focus:ring-primary" />
                                                Hiển thị text này
                                            </label>
                                        </div>
                                        <input asp-for="SiteSettings.Groups[i].Title" class="mt-3 w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-xl font-extrabold text-slate-900 focus:border-primary focus:ring-primary/20 dark:border-slate-700 dark:bg-slate-900 dark:text-white" />
                                    </div>
                                    <div class="rounded-3xl border border-slate-100 bg-slate-50/50 p-5 dark:border-slate-700 dark:bg-slate-900/40">
                                        <div class="flex items-center justify-between gap-3">
                                            <label class="text-sm font-bold text-slate-900 dark:text-white">Mô tả group</label>
                                            <label class="flex items-center gap-2 rounded-2xl border border-slate-200 bg-white px-3 py-2 text-xs font-semibold text-slate-600 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-300">
                                                <input asp-for="SiteSettings.Groups[i].IsDescriptionEnabled" class="rounded border-slate-300 text-primary focus:ring-primary" />
                                                Hiển thị text này
                                            </label>
                                        </div>
                                        <textarea asp-for="SiteSettings.Groups[i].Description" rows="3" class="mt-3 w-full min-h-[120px] resize-none rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm leading-relaxed text-slate-600 focus:border-primary focus:ring-primary/20 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-300" data-rich-editor="true" data-editor-height="180"></textarea>
                                    </div>
                                </div>
                                <div class="grid gap-3 sm:grid-cols-2">
                                    <label class="flex items-center gap-3 rounded-2xl border border-slate-200 bg-slate-50 px-4 py-4 text-sm font-semibold text-slate-700 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-200">
                                        <input asp-for="SiteSettings.Groups[i].IsEnabled" class="rounded border-slate-300 text-primary focus:ring-primary" />
                                        Hiển thị group
                                    </label>
                                    <label class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-4 text-sm font-semibold text-slate-700 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-200">
                                        <span class="block text-[11px] font-bold uppercase tracking-[0.18em] text-slate-400">Thứ tự</span>
                                        <input asp-for="SiteSettings.Groups[i].DisplayOrder" class="mt-3 h-11 w-full rounded-xl border-slate-200 bg-white px-4 text-sm focus:border-primary focus:ring-primary/20 dark:border-slate-700 dark:bg-slate-800" />
                                    </label>
                                </div>
                            </div>
                        </div>

                        <div class="mt-6 grid gap-4 lg:grid-cols-2">
                            @for (var j = 0; j < group.Fields.Count; j++)
                            {
                                var field = group.Fields[j];
                                var isWideField = field.FieldType == "textarea";
                                <div class="rounded-3xl border border-slate-100 bg-slate-50/50 p-5 dark:border-slate-700 dark:bg-slate-900/40 @(isWideField ? "lg:col-span-2" : string.Empty)">
                                    <input asp-for="SiteSettings.Groups[i].Fields[j].Key" type="hidden" />
                                    <input asp-for="SiteSettings.Groups[i].Fields[j].FieldType" type="hidden" />
                                    <input asp-for="SiteSettings.Groups[i].Fields[j].Placeholder" type="hidden" />
                                    <input asp-for="SiteSettings.Groups[i].Fields[j].Label" type="hidden" />
                                    @if (ContentPresentationSchema.SupportsFieldVisibilityToggle(field))
                                    {
                                        <label class="mb-3 inline-flex items-center gap-2 rounded-2xl border border-slate-200 bg-white px-3 py-2 text-xs font-semibold text-slate-600 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-300">
                                            <input asp-for="SiteSettings.Groups[i].Fields[j].IsEnabled" class="rounded border-slate-300 text-primary focus:ring-primary" />
                                            Hiển thị text này
                                        </label>
                                    }
                                    else
                                    {
                                        <input asp-for="SiteSettings.Groups[i].Fields[j].IsEnabled" type="hidden" />
                                    }
                                    <div class="flex items-start justify-between gap-3">
                                        <label class="text-sm font-bold text-slate-900 dark:text-white">@field.Label</label>
                                        <span class="rounded-full bg-white px-3 py-1 text-[11px] font-mono text-slate-400 ring-1 ring-slate-200 dark:bg-slate-800 dark:ring-slate-700">@field.Key</span>
                                    </div>
                                    @if (field.FieldType == "textarea")
                                    {
                                        <textarea asp-for="SiteSettings.Groups[i].Fields[j].Value" rows="5" class="mt-3 w-full rounded-2xl border-slate-200 bg-white px-4 py-3 text-sm focus:border-primary focus:ring-primary/20 dark:border-slate-700 dark:bg-slate-900" data-rich-editor="true" data-editor-height="240"></textarea>
                                    }
                                    else
                                    {
                                        <input asp-for="SiteSettings.Groups[i].Fields[j].Value" type="text" class="mt-3 h-12 w-full rounded-2xl border-slate-200 bg-white px-4 text-sm focus:border-primary focus:ring-primary/20 dark:border-slate-700 dark:bg-slate-900" />
                                    }
                                </div>
                            }
                        </div>
                    </div>
                }

                <div class="flex justify-end">
                    <button type="submit" class="inline-flex items-center gap-2 rounded-2xl bg-primary px-6 py-3 text-sm font-bold text-white shadow-lg shadow-primary/25 transition-all hover:-translate-y-0.5 hover:bg-primary-dark">
                        <span class="material-symbols-outlined text-[18px]">save</span>
                        Lưu cấu hình toàn site
                    </button>
                </div>
            </form>
        }
        else
        {
            <form id="content-editor-form" asp-action="SaveSections" method="post" class="space-y-6">
                @Html.AntiForgeryToken()
                <input asp-for="ActiveTab" type="hidden" />
                <input asp-for="SelectedSubtab" type="hidden" />

                @for (var i = 0; i < Model.Sections.Count; i++)
                {
                    var contentSection = Model.Sections[i];
                    var card = Model.SectionCards[i];
                    var presentation = contentSection.Presentation ?? ContentPresentationDefaults.CreateSectionPresentation();
                    <div class="rounded-[2rem] bg-white p-6 shadow-sm ring-1 ring-slate-200 dark:bg-slate-800 dark:ring-slate-700">
                        <input asp-for="Sections[i].Id" type="hidden" />
                        <input asp-for="Sections[i].PageKey" type="hidden" />
                        <input asp-for="Sections[i].SectionKey" type="hidden" />
                        <div class="flex flex-col gap-4 border-b border-slate-100 pb-5 dark:border-slate-700">
                            <div class="flex flex-wrap items-center gap-2 text-xs">
                                <span class="rounded-full bg-primary/10 px-3 py-1 font-bold text-primary">Section @(i + 1)</span>
                                <span class="rounded-full bg-slate-100 px-3 py-1 font-mono text-slate-500 dark:bg-slate-700 dark:text-slate-300">@contentSection.PageKey</span>
                                <span class="rounded-full bg-slate-100 px-3 py-1 font-mono text-slate-500 dark:bg-slate-700 dark:text-slate-300">@contentSection.SectionKey</span>
                                <span class="rounded-full bg-slate-100 px-3 py-1 font-semibold text-slate-500 dark:bg-slate-700 dark:text-slate-300">@card.ScopeLabel</span>
                            </div>
                            <div class="grid gap-4 xl:grid-cols-[minmax(0,1fr)_minmax(280px,0.68fr)]">
                                <div>
                                    <h2 class="text-xl font-extrabold text-slate-900 dark:text-white">@card.DisplayTitle</h2>
                                    <p class="mt-2 max-w-3xl text-sm leading-relaxed text-slate-500 dark:text-slate-400">@card.Description</p>
                                </div>
                                @if (!card.AllowSectionSettings)
                                {
                                    <div class="rounded-2xl border border-sky-200 bg-sky-50 px-4 py-4 text-sm font-medium text-sky-700 dark:border-sky-900/40 dark:bg-sky-900/10 dark:text-sky-300">
                                        Editor này chỉ mở một phần field của section dùng chung. Cài đặt cấp section đã được ẩn để tránh thay đổi lan sang màn khác.
                                    </div>
                                }
                                else
                                {
                                    <div class="grid gap-3 sm:grid-cols-3">
                                        <label class="flex items-center gap-3 rounded-2xl border border-slate-200 bg-slate-50 px-4 py-4 text-sm font-semibold text-slate-700 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-200">
                                            <input asp-for="Sections[i].IsEnabled" class="rounded border-slate-300 text-primary focus:ring-primary" />
                                            Hiển thị
                                        </label>
                                        <label class="flex items-center gap-3 rounded-2xl border border-slate-200 bg-slate-50 px-4 py-4 text-sm font-semibold text-slate-700 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-200">
                                            <input asp-for="Sections[i].IsPublished" class="rounded border-slate-300 text-primary focus:ring-primary" />
                                            Public dùng
                                        </label>
                                        <label class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-4 text-sm font-semibold text-slate-700 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-200">
                                            <span class="block text-[11px] font-bold uppercase tracking-[0.18em] text-slate-400">Thứ tự</span>
                                            <input asp-for="Sections[i].DisplayOrder" class="mt-3 h-11 w-full rounded-xl border-slate-200 bg-white px-4 text-sm focus:border-primary focus:ring-primary/20 dark:border-slate-700 dark:bg-slate-800" />
                                        </label>
                                    </div>
                                }
                            </div>

                            @if (card.AllowSectionSettings)
                            {
                                <div class="grid gap-4 xl:grid-cols-2">
                                    <div class="rounded-3xl border border-slate-100 bg-slate-50/50 p-5 dark:border-slate-700 dark:bg-slate-900/40">
                                        <div class="flex items-center justify-between gap-3">
                                            <label class="text-sm font-bold text-slate-900 dark:text-white">Tiêu đề section</label>
                                            <label class="flex items-center gap-2 rounded-2xl border border-slate-200 bg-white px-3 py-2 text-xs font-semibold text-slate-600 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-300">
                                                <input asp-for="Sections[i].IsTitleEnabled" class="rounded border-slate-300 text-primary focus:ring-primary" />
                                                Hiển thị text này
                                            </label>
                                        </div>
                                        <input asp-for="Sections[i].Title" class="mt-3 h-12 w-full rounded-2xl border-slate-200 bg-white px-4 text-sm font-semibold focus:border-primary focus:ring-primary/20 dark:border-slate-700 dark:bg-slate-900 dark:text-white" />
                                    </div>
                                    <div class="rounded-3xl border border-slate-100 bg-slate-50/50 p-5 dark:border-slate-700 dark:bg-slate-900/40 xl:col-span-2">
                                        <div class="flex items-center justify-between gap-3">
                                            <label class="text-sm font-bold text-slate-900 dark:text-white">Mô tả section</label>
                                            <label class="flex items-center gap-2 rounded-2xl border border-slate-200 bg-white px-3 py-2 text-xs font-semibold text-slate-600 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-300">
                                                <input asp-for="Sections[i].IsDescriptionEnabled" class="rounded border-slate-300 text-primary focus:ring-primary" />
                                                Hiển thị text này
                                            </label>
                                        </div>
                                        <textarea asp-for="Sections[i].Description" rows="3" class="mt-3 min-h-[120px] w-full resize-none rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-600 focus:border-primary focus:ring-primary/20 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-300" data-rich-editor="true" data-editor-height="180"></textarea>
                                    </div>
                                </div>

                                <details class="rounded-3xl border border-slate-200 bg-slate-50/60 p-5 dark:border-slate-700 dark:bg-slate-900/40" open>
                                    <summary class="cursor-pointer list-none text-sm font-bold text-slate-900 dark:text-white">
                                        Style section
                                    </summary>
                                    <div class="mt-4 space-y-4">
                                        <div class="grid gap-4 xl:grid-cols-[minmax(0,1fr)_minmax(0,1fr)_200px]">
                                            <label class="text-sm font-semibold text-slate-700 dark:text-slate-200">
                                                <span class="mb-2 block text-[11px] font-bold uppercase tracking-[0.18em] text-slate-400">Align section</span>
                                                <select name="Sections[@i].Presentation.Container.Align" class="w-full" data-admin-select="default">
                                                    @foreach (var option in sectionAlignmentOptions)
                                                    {
                                                        <option value="@option.Value" selected="@(string.Equals(presentation.Container.Align, option.Value, StringComparison.OrdinalIgnoreCase))">@option.Label</option>
                                                    }
                                                </select>
                                            </label>
                                            <label class="text-sm font-semibold text-slate-700 dark:text-slate-200">
                                                <span class="mb-2 block text-[11px] font-bold uppercase tracking-[0.18em] text-slate-400">Background preset</span>
                                                <select name="Sections[@i].Presentation.Container.BackgroundPreset" class="w-full" data-admin-select="default">
                                                    @foreach (var preset in ContentPresentationSchema.BackgroundPresets)
                                                    {
                                                        var label = string.IsNullOrWhiteSpace(preset) ? "Mặc định" : preset;
                                                        <option value="@preset" selected="@(string.Equals(presentation.Container.BackgroundPreset, preset, StringComparison.OrdinalIgnoreCase))">@label</option>
                                                    }
                                                </select>
                                            </label>
                                            <label class="text-sm font-semibold text-slate-700 dark:text-slate-200">
                                                <span class="mb-2 block text-[11px] font-bold uppercase tracking-[0.18em] text-slate-400">Custom màu nền</span>
                                                <input type="text" name="Sections[@i].Presentation.Container.CustomBackgroundHex" value="@presentation.Container.CustomBackgroundHex" placeholder="#F8FAFC" class="h-11 w-full rounded-xl border border-slate-200 bg-white px-3 text-sm uppercase focus:border-primary focus:ring-primary/20 dark:border-slate-700 dark:bg-slate-800 dark:text-slate-100" />
                                            </label>
                                        </div>

                                        @await Html.PartialAsync("_ContentTextStyleEditor", new ContentTextStyleEditorViewModel
                                        {
                                            Prefix = $"Sections[{i}].Presentation.EyebrowText",
                                            Title = "Eyebrow / Badge",
                                            Description = "Style mặc định cho badge hoặc eyebrow của section.",
                                            IncludeJustify = false,
                                            Style = presentation.EyebrowText
                                        })

                                        @await Html.PartialAsync("_ContentTextStyleEditor", new ContentTextStyleEditorViewModel
                                        {
                                            Prefix = $"Sections[{i}].Presentation.TitleText",
                                            Title = "Title",
                                            Description = "Style mặc định cho các field tiêu đề trong section.",
                                            IncludeJustify = false,
                                            Style = presentation.TitleText
                                        })

                                        @await Html.PartialAsync("_ContentTextStyleEditor", new ContentTextStyleEditorViewModel
                                        {
                                            Prefix = $"Sections[{i}].Presentation.DescriptionText",
                                            Title = "Description",
                                            Description = "Style mặc định cho field mô tả hoặc body copy của section.",
                                            IncludeJustify = true,
                                            Style = presentation.DescriptionText
                                        })
                                    </div>
                                </details>
                            }
                        </div>

                        @if (contentSection.SectionKey == "carousel")
                        {
                            @await Html.PartialAsync("_HomeCarouselSectionEditor", contentSection, new ViewDataDictionary(ViewData)
                            {
                                ["SectionIndex"] = i
                            })
                        }
                        else
                        {
                            <div class="mt-6 grid gap-4 lg:grid-cols-2">
                                @for (var j = 0; j < contentSection.Fields.Count; j++)
                                {
                                    var field = contentSection.Fields[j];
                                    var isWideField = field.FieldType == "textarea";
                                    var supportsStyle = ContentPresentationSchema.SupportsFieldStyle(field);
                                    var buttonLikeField = ContentPresentationSchema.IsButtonLikeField(field);
                                    <div class="rounded-3xl border border-slate-100 bg-slate-50/50 p-5 dark:border-slate-700 dark:bg-slate-900/40 @(isWideField ? "lg:col-span-2" : string.Empty)">
                                        <input asp-for="Sections[i].Fields[j].Key" type="hidden" />
                                        <input asp-for="Sections[i].Fields[j].Label" type="hidden" />
                                        <input asp-for="Sections[i].Fields[j].FieldType" type="hidden" />
                                        <input asp-for="Sections[i].Fields[j].Placeholder" type="hidden" />
                                        @if (ContentPresentationSchema.SupportsFieldVisibilityToggle(field))
                                        {
                                            <label class="mb-3 inline-flex items-center gap-2 rounded-2xl border border-slate-200 bg-white px-3 py-2 text-xs font-semibold text-slate-600 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-300">
                                                <input asp-for="Sections[i].Fields[j].IsEnabled" class="rounded border-slate-300 text-primary focus:ring-primary" />
                                                Hiển thị text này
                                            </label>
                                        }
                                        else
                                        {
                                            <input asp-for="Sections[i].Fields[j].IsEnabled" type="hidden" />
                                        }
                                        <div class="flex items-start justify-between gap-3">
                                            <label class="text-sm font-bold text-slate-900 dark:text-white">@field.Label</label>
                                            <span class="rounded-full bg-white px-3 py-1 text-[11px] font-mono text-slate-400 ring-1 ring-slate-200 dark:bg-slate-800 dark:ring-slate-700">@field.Key</span>
                                        </div>
                                        @if (field.FieldType == "textarea")
                                        {
                                            <textarea asp-for="Sections[i].Fields[j].Value" rows="5" class="mt-3 w-full rounded-2xl border-slate-200 bg-white px-4 py-3 text-sm focus:border-primary focus:ring-primary/20 dark:border-slate-700 dark:bg-slate-900" data-rich-editor="true" data-editor-height="240"></textarea>
                                        }
                                        else
                                        {
                                            <input asp-for="Sections[i].Fields[j].Value" type="text" class="mt-3 h-12 w-full rounded-2xl border-slate-200 bg-white px-4 text-sm focus:border-primary focus:ring-primary/20 dark:border-slate-700 dark:bg-slate-900" />
                                        }

                                        @if (supportsStyle && !buttonLikeField)
                                        {
                                            <details class="mt-4 rounded-2xl border border-slate-200 bg-white/80 p-4 dark:border-slate-700 dark:bg-slate-900/50">
                                                <summary class="cursor-pointer list-none text-sm font-bold text-slate-900 dark:text-white">Style field</summary>
                                                <div class="mt-4">
                                                    @await Html.PartialAsync("_ContentTextStyleEditor", new ContentTextStyleEditorViewModel
                                                    {
                                                        Prefix = $"Sections[{i}].Fields[{j}].Style",
                                                        Title = field.Label,
                                                        Description = "Override style cho field này. Nếu để mặc định, public site sẽ dùng section role default hoặc theme hiện có.",
                                                        IncludeJustify = true,
                                                        Style = field.Style ?? ContentPresentationDefaults.CreateTextStyle()
                                                    })
                                                </div>
                                            </details>
                                        }
                                        else if (buttonLikeField)
                                        {
                                            <div class="mt-4 rounded-2xl border border-slate-200 bg-white/80 px-4 py-3 text-xs leading-relaxed text-slate-500 dark:border-slate-700 dark:bg-slate-900/50 dark:text-slate-400">
                                                Field này là label cho CTA hoặc nút hành động. Nội dung vẫn chỉnh được, nhưng visual của button sẽ giữ theo design system hiện tại.
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }

                <div class="flex justify-end">
                    <button type="submit" class="inline-flex items-center gap-2 rounded-2xl bg-primary px-6 py-3 text-sm font-bold text-white shadow-lg shadow-primary/25 transition-all hover:-translate-y-0.5 hover:bg-primary-dark">
                        <span class="material-symbols-outlined text-[18px]">save</span>
                        Lưu nội dung trang
                    </button>
                </div>
            </form>
        }
    </section>
</div>
@section Scripts {
    <script>
        (function () {
            const editors = document.querySelectorAll('[data-home-carousel-editor]');
            if (!editors.length) {
                return;
            }

            const updateSlide = (slide) => {
                const sourceSelect = slide.querySelector('[data-source-select]');
                const imageInput = slide.querySelector('[data-image-input]');
                const previewImage = slide.querySelector('[data-preview-image]');
                const previewEmpty = slide.querySelector('[data-preview-empty]');
                const imageUrl = imageInput && imageInput.value ? imageInput.value.trim() : '';

                slide.dataset.sourceType = sourceSelect && sourceSelect.value ? sourceSelect.value : 'external';

                if (previewImage) {
                    previewImage.src = imageUrl;
                    previewImage.classList.toggle('hidden', !imageUrl);
                }

                if (previewEmpty) {
                    previewEmpty.classList.toggle('hidden', !!imageUrl);
                }
            };

            editors.forEach((editor) => {
                editor.querySelectorAll('[data-home-carousel-slide]').forEach((slide) => {
                    const sourceSelect = slide.querySelector('[data-source-select]');
                    const imageInput = slide.querySelector('[data-image-input]');
                    const uploadButton = slide.querySelector('[data-upload-button]');
                    const libraryButton = slide.querySelector('[data-library-button]');
                    const clearButton = slide.querySelector('[data-clear-image-button]');

                    const refresh = () => updateSlide(slide);

                    sourceSelect?.addEventListener('change', refresh);
                    imageInput?.addEventListener('input', refresh);

                    uploadButton?.addEventListener('click', () => {
                        if (!imageInput || typeof window.openCloudinaryWidget !== 'function') {
                            return;
                        }

                        window.openCloudinaryWidget({ multiple: false, folder: 'HV-Travel ASP.NET/home-carousel' }, (url) => {
                            imageInput.value = url;
                            if (sourceSelect) {
                                sourceSelect.value = 'cloudinary';
                            }
                            refresh();
                        });
                    });

                    libraryButton?.addEventListener('click', () => {
                        if (!imageInput || typeof window.openCloudinaryAssetBrowser !== 'function') {
                            return;
                        }

                        window.openCloudinaryAssetBrowser({ multiple: false, folder: 'HV-Travel ASP.NET/home-carousel' }, (url) => {
                            imageInput.value = url;
                            if (sourceSelect) {
                                sourceSelect.value = 'cloudinary';
                            }
                            refresh();
                        });
                    });

                    clearButton?.addEventListener('click', () => {
                        if (!imageInput) {
                            return;
                        }

                        imageInput.value = '';
                        refresh();
                    });

                    refresh();
                });
            });
        })();
    </script>
}




