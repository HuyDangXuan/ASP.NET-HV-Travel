@using HVTravel.Domain.Entities
@model User
@{
    ViewData["Title"] = "Tài Khoản";
}

<style type="text/tailwindcss">
    @@layer components {
        .input-field {
            @@apply w-full bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl h-14 px-4 text-[#111718] dark:text-white font-semibold focus:ring-2 focus:ring-primary/50 transition-all placeholder:text-[#618389]/50 dark:placeholder:text-slate-500 shadow-sm;
        }
        .label-text {
            @@apply text-[#111718] dark:text-white text-sm font-bold uppercase tracking-wider mb-2 block;
        }
    }
</style>

<!-- Page Header -->
<div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6">
    <div class="flex flex-col gap-1">
        <nav class="flex items-center gap-2 text-sm text-slate-500">
            <a class="hover:text-primary transition-colors" href="@Url.Action("Index", "Dashboard")">Trang Chủ</a>
            <span class="material-symbols-outlined text-[16px]">chevron_right</span>
            <a class="hover:text-primary transition-colors" href="@Url.Action("Index", "Users")">Quản Lý Tài Khoản</a>
            <span class="material-symbols-outlined text-[16px]">chevron_right</span>
            <span class="text-slate-900 dark:text-white font-medium">Chỉnh Sửa</span>
        </nav>
        <h1 class="text-2xl font-bold text-slate-900 dark:text-white">Chỉnh Sửa Tài Khoản</h1>
    </div>
</div>
<!-- Form Card -->
<div class="bg-white dark:bg-surface-dark rounded-2xl shadow-sm border border-slate-100 dark:border-slate-800 overflow-hidden max-w-2xl">
    <form asp-action="Edit" method="post" class="p-6 space-y-6">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />

        <!-- Validation Summary -->
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="p-4 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-xl text-red-700 dark:text-red-400 text-sm">
                <div asp-validation-summary="All" class="space-y-1"></div>
            </div>
        }

        <!-- Current Avatar Preview -->
        <div class="flex items-center gap-4">
            <div class="size-16 rounded-full bg-slate-200 overflow-hidden shrink-0">
                <img alt="Avatar" class="size-full object-cover" src="@(string.IsNullOrEmpty(Model.AvatarUrl) ? $"https://ui-avatars.com/api/?name={Uri.EscapeDataString(Model.FullName ?? "U")}&background=random" : Model.AvatarUrl)" />
            </div>
            <div>
                <p class="text-sm font-bold text-slate-900 dark:text-white">@Model.FullName</p>
                <p class="text-xs text-slate-500">@Model.Email</p>
            </div>
        </div>

        <!-- Full Name -->
        <div>
            <label for="FullName" class="label-text">Họ và Tên <span class="text-red-500">*</span></label>
            <input asp-for="FullName" type="text" class="input-field" placeholder="Nhập họ và tên" required />
            <span asp-validation-for="FullName" class="text-xs text-red-500 mt-1"></span>
        </div>

        <!-- Email (Read-only) -->
        <div>
            <label class="label-text">Email</label>
            <input type="email" value="@Model.Email" readonly class="input-field bg-slate-50 dark:bg-slate-900/50 text-slate-500 dark:text-slate-400 cursor-not-allowed" />
            <p class="text-xs text-slate-400 mt-1">Email không thể thay đổi</p>
        </div>

        <!-- Change Password (Optional) -->
        <div class="p-4 bg-slate-50 dark:bg-slate-800/50 rounded-xl space-y-4">
            <p class="text-sm font-bold text-slate-700 dark:text-slate-300">Đổi Mật Khẩu <span class="text-slate-400 font-normal">(để trống nếu không muốn đổi)</span></p>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label for="password" class="label-text text-xs">Mật Khẩu Mới</label>
                    <input type="password" name="password" id="password" class="input-field h-11" placeholder="Nhập mật khẩu mới" />
                </div>
                <div>
                    <label for="confirmPassword" class="label-text text-xs">Xác Nhận</label>
                    <input type="password" name="confirmPassword" id="confirmPassword" class="input-field h-11" placeholder="Nhập lại mật khẩu" />
                </div>
            </div>
        </div>

        <!-- Role -->
        <div>
            <label for="Role" class="label-text">Vai Trò <span class="text-red-500">*</span></label>
            <div class="relative custom-select-container" data-id="Role">
                <div class="custom-select-trigger" onclick="toggleCustomSelect('Role')">
                    <div class="flex items-center gap-3 min-w-0">
                        <span class="custom-select-leading material-symbols-outlined">badge</span>
                        <div class="custom-select-meta">
                            <span class="custom-select-caption">Role</span>
                        <span class="selected-label">@(Model.Role == "Staff" ? "Staff - Nhân viên" : Model.Role == "Manager" ? "Manager - Quản lý" : Model.Role == "Guide" ? "Guide - Hướng dẫn viên" : "Admin - Quản trị viên")</span>
                        </div>
                    </div>
                    <span class="material-symbols-outlined transition-transform duration-300 arrow-icon">expand_more</span>
                </div>
                <div class="options-menu">
                    <div class="custom-option @(Model.Role == "Staff" ? "selected" : "")" data-value="Staff" data-label="Staff - Nhân viên" onclick="selectCustomOption('Role', 'Staff', 'Staff - Nhân viên')">
                        <span class="custom-option-main"><span class="custom-option-dot"></span><span>Staff - Nhân viên</span></span>
                        @if (Model.Role == "Staff") { <span class="material-symbols-outlined text-lg check-icon">check</span> }
                    </div>
                    <div class="custom-option @(Model.Role == "Manager" ? "selected" : "")" data-value="Manager" data-label="Manager - Quản lý" onclick="selectCustomOption('Role', 'Manager', 'Manager - Quản lý')">
                        <span class="custom-option-main"><span class="custom-option-dot"></span><span>Manager - Quản lý</span></span>
                        @if (Model.Role == "Manager") { <span class="material-symbols-outlined text-lg check-icon">check</span> }
                    </div>
                    <div class="custom-option @(Model.Role == "Guide" ? "selected" : "")" data-value="Guide" data-label="Guide - Hướng dẫn viên" onclick="selectCustomOption('Role', 'Guide', 'Guide - Hướng dẫn viên')">
                        <span class="custom-option-main"><span class="custom-option-dot"></span><span>Guide - Hướng dẫn viên</span></span>
                        @if (Model.Role == "Guide") { <span class="material-symbols-outlined text-lg check-icon">check</span> }
                    </div>
                    <div class="custom-option @(Model.Role == "Admin" ? "selected" : "")" data-value="Admin" data-label="Admin - Quản trị viên" onclick="selectCustomOption('Role', 'Admin', 'Admin - Quản trị viên')">
                        <span class="custom-option-main"><span class="custom-option-dot"></span><span>Admin - Quản trị viên</span></span>
                        @if (Model.Role == "Admin") { <span class="material-symbols-outlined text-lg check-icon">check</span> }
                    </div>
                </div>
                <select asp-for="Role" class="hidden">
                    <option value="Staff">Staff - Nhân viên</option>
                    <option value="Manager">Manager - Quản lý</option>
                    <option value="Guide">Guide - Hướng dẫn viên</option>
                    <option value="Admin">Admin - Quản trị viên</option>
                </select>
            </div>
        </div>

        <!-- Status -->
        <div>
            <label for="Status" class="label-text">Trạng Thái</label>
            <div class="relative custom-select-container" data-id="Status">
                <div class="custom-select-trigger" onclick="toggleCustomSelect('Status')">
                    <div class="flex items-center gap-3 min-w-0">
                        <span class="custom-select-leading material-symbols-outlined">toggle_on</span>
                        <div class="custom-select-meta">
                            <span class="custom-select-caption">Status</span>
                        <span class="selected-label">@(Model.Status == "Active" ? "Hoạt động" : "Vô hiệu")</span>
                        </div>
                    </div>
                    <span class="material-symbols-outlined transition-transform duration-300 arrow-icon">expand_more</span>
                </div>
                <div class="options-menu">
                    <div class="custom-option @(Model.Status == "Active" ? "selected" : "")" data-value="Active" data-label="Hoạt động" onclick="selectCustomOption('Status', 'Active', 'Hoạt động')">
                        <span class="custom-option-main"><span class="custom-option-dot"></span><span>Hoạt động</span></span>
                        @if (Model.Status == "Active") { <span class="material-symbols-outlined text-lg check-icon">check</span> }
                    </div>
                    <div class="custom-option @(Model.Status == "Inactive" ? "selected" : "")" data-value="Inactive" data-label="Vô hiệu" onclick="selectCustomOption('Status', 'Inactive', 'Vô hiệu')">
                        <span class="custom-option-main"><span class="custom-option-dot"></span><span>Vô hiệu</span></span>
                        @if (Model.Status == "Inactive") { <span class="material-symbols-outlined text-lg check-icon">check</span> }
                    </div>
                </div>
                <select asp-for="Status" class="hidden">
                    <option value="Active">Hoạt động</option>
                    <option value="Inactive">Vô hiệu</option>
                </select>
            </div>
        </div>

        <!-- Avatar URL (Optional) -->
        <div>
            <label for="AvatarUrl" class="label-text">Ảnh đại diện (URL) <span class="text-gray-400 font-normal normal-case">(Tùy chọn)</span></label>
            <input asp-for="AvatarUrl" type="url" class="input-field" placeholder="https://example.com/avatar.jpg" />
        </div>

        <!-- Actions -->
        <div class="flex items-center gap-4 pt-4 border-t border-slate-100 dark:border-slate-800">
            <button type="submit" class="flex items-center gap-2 px-6 py-3 bg-primary text-white rounded-xl text-sm font-bold shadow-lg shadow-primary/30 hover:bg-primary-dark transition-all">
                <span class="material-symbols-outlined text-[20px]">save</span>
                Lưu Thay Đổi
            </button>
            <a href="@Url.Action("Index")" class="flex items-center gap-2 px-6 py-3 bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400 rounded-xl text-sm font-bold hover:bg-slate-200 dark:hover:bg-slate-700 transition-all">
                <span class="material-symbols-outlined text-[20px]">close</span>
                Hủy
            </a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/admin-custom-select.js" asp-append-version="true"></script>
}
