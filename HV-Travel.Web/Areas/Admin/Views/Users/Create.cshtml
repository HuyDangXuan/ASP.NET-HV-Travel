@using HVTravel.Domain.Entities
@model User
@{
    ViewData["Title"] = "Tài Khoản";
}

<style type="text/tailwindcss">
    @@layer components {
        .input-field {
            @@apply w-full bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl h-14 px-4 text-[#111718] dark:text-white font-semibold focus:ring-2 focus:ring-primary/50 transition-all placeholder:text-[#618389]/50 dark:placeholder:text-slate-500 shadow-sm;
        }
        .label-text {
            @@apply text-[#111718] dark:text-white text-sm font-bold uppercase tracking-wider mb-2 block;
        }
    }
</style>

<!-- Page Header -->
<div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6">
    <div class="flex flex-col gap-1">
        @await Html.PartialAsync("_AdminBreadcrumb", new HVTravel.Web.Models.BreadcrumbViewModel
        {
            Items = new List<HVTravel.Web.Models.BreadcrumbItemViewModel>
            {
                new() { Label = "Trang chủ", Url = Url.Action("Index", "Dashboard") },
                new() { Label = "Quản lý tài khoản", Url = Url.Action("Index", "Users") },
                new() { Label = "Thêm mới", IsCurrent = true }
            }
        })
        <h1 class="text-2xl font-bold text-slate-900 dark:text-white">Thêm Tài Khoản Mới</h1>
    </div>
</div>

<!-- Form Card -->
<div class="bg-white dark:bg-surface-dark rounded-2xl shadow-sm border border-slate-100 dark:border-slate-800 overflow-hidden max-w-2xl">
    <form asp-action="Create" method="post" class="p-6 space-y-6">
        @Html.AntiForgeryToken()

        <!-- Validation Summary -->
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="p-4 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-xl text-red-700 dark:text-red-400 text-sm">
                <div asp-validation-summary="All" class="space-y-1"></div>
            </div>
        }

        <!-- Full Name -->
        <div>
            <label for="FullName" class="label-text">Họ và Tên <span class="text-red-500">*</span></label>
            <input asp-for="FullName" type="text" class="input-field" placeholder="Nhập họ và tên" required />
            <span asp-validation-for="FullName" class="text-xs text-red-500 mt-1"></span>
        </div>

        <!-- Email -->
        <div>
            <label for="Email" class="label-text">Email <span class="text-red-500">*</span></label>
            <input asp-for="Email" type="email" class="input-field" placeholder="email@example.com" required />
            <span asp-validation-for="Email" class="text-xs text-red-500 mt-1"></span>
        </div>

        <!-- Password -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
                <label for="password" class="label-text">Mật Khẩu <span class="text-red-500">*</span></label>
                <input type="password" name="password" id="password" class="input-field" placeholder="Nhập mật khẩu" required />
            </div>
            <div>
                <label for="confirmPassword" class="label-text">Xác Nhận Mật Khẩu <span class="text-red-500">*</span></label>
                <input type="password" name="confirmPassword" id="confirmPassword" class="input-field" placeholder="Nhập lại mật khẩu" required />
            </div>
        </div>

        <!-- Role -->
        <div>
            <label for="Role" class="label-text">Vai Trò <span class="text-red-500">*</span></label>
            <div class="relative">
                <select asp-for="Role" class="input-field appearance-none cursor-pointer">
                    <option value="Staff">Staff - Nhân viên</option>
                    <option value="Manager">Manager - Quản lý</option>
                    <option value="Guide">Guide - Hướng dẫn viên</option>
                    <option value="Admin">Admin - Quản trị viên</option>
                </select>
                <span class="absolute right-3 top-1/2 -translate-y-1/2 pointer-events-none text-slate-400">
                    <span class="material-symbols-outlined text-[18px]">expand_more</span>
                </span>
            </div>
        </div>

        <!-- Avatar URL (Optional) -->
        <div>
            <label for="AvatarUrl" class="label-text">Ảnh đại diện (URL) <span class="text-slate-400 font-normal normal-case">(Tùy chọn)</span></label>
            <input asp-for="AvatarUrl" type="url" class="input-field" placeholder="https://example.com/avatar.jpg" />
            <div class="flex flex-wrap items-center gap-3 mt-3">
                <button type="button" id="user-avatar-upload" class="px-4 py-2 rounded-xl bg-primary text-white text-sm font-bold shadow-sm hover:brightness-110 transition-all">
                    <span class="material-symbols-outlined text-lg align-[-3px] mr-1">cloud_upload</span> Tải ảnh lên
                </button>
                <button type="button" id="user-avatar-remove" class="px-4 py-2 rounded-xl border border-red-200 text-red-500 text-sm font-bold hover:bg-red-50 transition-all">
                    <span class="material-symbols-outlined text-lg align-[-3px] mr-1">delete</span> Xóa ảnh
                </button>
            </div>
            <div class="flex items-center gap-3 mt-3">
                <div class="size-12 rounded-full bg-slate-100 dark:bg-slate-800 overflow-hidden border border-slate-200 dark:border-slate-700">
                    <img id="user-avatar-preview" alt="Avatar preview" class="size-full object-cover" src="https://ui-avatars.com/api/?name=User" />
                </div>
                <span class="text-xs text-slate-500">Xem trước ảnh đại diện</span>
            </div>
        </div>

        <!-- Actions -->
        <div class="flex items-center gap-4 pt-4 border-t border-slate-100 dark:border-slate-800">
            <button type="submit" class="flex items-center gap-2 px-6 py-3 bg-primary text-white rounded-xl text-sm font-bold shadow-lg shadow-primary/30 hover:bg-primary-dark transition-all">
                <span class="material-symbols-outlined text-[20px]">save</span>
                Tạo Tài Khoản
            </button>
            <a href="@Url.Action("Index")" class="flex items-center gap-2 px-6 py-3 bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400 rounded-xl text-sm font-bold hover:bg-slate-200 dark:hover:bg-slate-700 transition-all">
                <span class="material-symbols-outlined text-[20px]">close</span>
                Hủy
            </a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            const avatarInput = document.querySelector('input[name="AvatarUrl"]');
            const preview = document.getElementById('user-avatar-preview');
            const uploadButton = document.getElementById('user-avatar-upload');
            const removeButton = document.getElementById('user-avatar-remove');

            function updatePreview() {
                if (!preview) return;
                const url = avatarInput && avatarInput.value ? avatarInput.value.trim() : '';
                preview.src = url || 'https://ui-avatars.com/api/?name=User';
            }

            if (avatarInput) {
                avatarInput.addEventListener('input', updatePreview);
            }

            if (uploadButton && avatarInput) {
                uploadButton.addEventListener('click', function () {
                    window.openCloudinaryWidget({ multiple: false, folder: 'hv-travel/avatars' }, function (url) {
                        avatarInput.value = url;
                        updatePreview();
                    });
                });
            }

            if (removeButton && avatarInput) {
                removeButton.addEventListener('click', function () {
                    avatarInput.value = '';
                    updatePreview();
                });
            }

            updatePreview();
        })();
    </script>
}
